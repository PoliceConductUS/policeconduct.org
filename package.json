{
  "name": "policeconduct.org",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "astro": "astro",
    "build": "node scripts/validate-build-env.mjs && GIT_COMMIT_SHA=${GIT_COMMIT_SHA:-$(git rev-parse --short=12 HEAD)} GIT_COMMIT_DIRTY=${GIT_COMMIT_DIRTY:-$(if git diff --quiet HEAD -- && [ -z \"$(git ls-files --others --exclude-standard)\" ]; then echo 0; else echo 1; fi)} astro build",
    "dev": "node scripts/dev.mjs",
    "deploy:prod": "bash scripts/deploy-prod.sh",
    "deploy:prod:invalidate": "bash scripts/deploy-prod.sh",
    "deploy:preview": "bash scripts/deploy-preview.sh",
    "seo:audit": "node scripts/seo-audit.mjs",
    "audit:a11y": "node scripts/audit-dist.mjs",
    "litigation:ingest:courtlistener": "node --env-file=.env scripts/litigation/ingest-courtlistener.mjs",
    "litigation:new": "node --env-file=.env scripts/litigation/new.mjs",
    "litigation:normalize:yaml": "node --env-file=.env scripts/litigation/normalize-to-yaml.mjs",
    "litigation:decisions:sync": "node --env-file=.env scripts/litigation/decisions-sync.mjs",
    "litigation:seed": "node --env-file=.env scripts/litigation/seed-from-yaml.mjs",
    "litigation:schema:introspect": "node --env-file=.env scripts/litigation/schema-introspect.mjs",
    "test:e2e": "playwright test",
    "preflight:publish": "npm run seo:audit && npm run audit:a11y",
    "preflight:publish:full": "npm run build && npm run preflight:publish",
    "format": "prettier --write .",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.0",
    "aos": "^2.3.4",
    "astro": "^6.0.0-beta.1",
    "bootstrap": "^5.3.8",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@astrojs/check": "^0.9.6",
    "@playwright/test": "^1.58.2",
    "@types/pg": "^8.18.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1"
  }
}
