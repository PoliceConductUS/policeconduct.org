---
const {
  className,
  type = "button",
  ...rest
} = Astro.props as {
  className?: string;
  type?: "button" | "submit" | "reset";
  [key: string]: unknown;
};
---

<button type={type} class:list={["entity-action", className]} {...rest}>
  <slot />
</button>

<style>
  .entity-action {
    align-items: center;
    background: #fbfcff;
    border: 1px solid #c9d4e6;
    border-radius: 0.4rem;
    color: #071842;
    display: inline-flex;
    font-size: 0.88rem;
    font-weight: 700;
    justify-content: center;
    line-height: 1.1;
    min-height: 3rem;
    padding: 0.72rem 1.05rem;
    text-decoration: none;
  }

  .entity-action-primary {
    background: #071842;
    border-color: #071842;
    color: #f8faff;
  }

  .entity-action :global(svg) {
    height: 1.15rem;
    margin-right: 0.55rem;
    width: 1.15rem;
  }
</style>
