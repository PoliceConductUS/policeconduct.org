---
import type { PersonnelSummary } from "#src/lib/data/types.js";

const { person } = Astro.props as {
  person: PersonnelSummary;
};
---

<article class="card shadow-sm border-0 rounded-0 h-100">
  <div class="card-body d-flex flex-column gap-3">
    <div class="row g-3 align-items-start">
      <div class="col-12 col-md">
        <div class="text-uppercase small text-muted">Name</div>
        <a class="link-dark fw-semibold" href={`/personnel/${person.slug}/`}>
          {person.firstName}
          {person.lastName}{person.nameSuffix ? ` ${person.nameSuffix}` : ""}
        </a>
      </div>
      <div class="col-12 col-md">
        <div class="text-uppercase small text-muted">Role</div>
        <div>{person.roleTitle || "—"}</div>
      </div>
      <div class="col-12 col-md">
        <div class="text-uppercase small text-muted">Agency</div>
        <a
          class="link-dark text-decoration-none"
          href={`/law-enforcement-agency/${person.agencySlug}/`}
        >
          {person.agencyName}
        </a>
      </div>
      <div class="col-12 col-md">
        <div class="text-uppercase small text-muted">Reports</div>
        <div>{person.reportCount}</div>
      </div>
    </div>
  </div>
</article>
