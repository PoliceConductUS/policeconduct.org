---
import { formatShortDate } from "#src/lib/format.js";

type OfficerRef = {
  slug: string;
  first_name?: string;
  last_name?: string;
  firstName?: string;
  lastName?: string;
};

type LitigationCase = {
  title?: string | null;
  caseUrl: string;
  cause_number?: string | null;
  filed_date?: string | null;
  court?: string | null;
  primary_source_url?: string | null;
  officers?: OfficerRef[] | null;
};

type ReportItem = {
  incidentDate?: string | null;
  title?: string | null;
  url: string;
  officers?: OfficerRef[] | null;
};

type CoverageLink = {
  url: string;
  title: string;
  source_name?: string | null;
  published_at?: string | null;
  notes?: string | null;
  officers?: OfficerRef[] | null;
};

type PersonnelEntry = {
  entry: {
    start_date?: string | null;
    end_date?: string | null;
    badge_number?: string | null;
  };
  officer?: OfficerRef | null;
  reportCount?: number;
  rating?: number | null;
};

type PastEmployerEntry = {
  start_date?: string | null;
  end_date?: string | null;
  badge_number?: string | null;
  reportCount?: number;
  rating?: number | null;
  agency?: {
    category?: string | null;
    slug?: string | null;
    name?: string | null;
  } | null;
};

type TabType =
  | "litigation"
  | "reports"
  | "coverage"
  | "personnel"
  | "pastEmployers";
type TabDescriptor = {
  id: string;
  label: string;
  badge?: number;
  tabType?: TabType;
  slotName?: string;
};

type ProfileTabsProps = {
  tabs?: TabDescriptor[];
  activeId?: string;
  extraNavClasses?: string;
  litigation?: {
    cases?: LitigationCase[];
    emptyMessage?: string;
  };
  reports?: {
    items?: ReportItem[];
    emptyMessage?: string;
    layout?: "table" | "list";
  };
  coverage?: {
    links?: CoverageLink[];
    emptyMessage?: string;
    helperText?: string;
  };
  personnel?: {
    entries?: PersonnelEntry[];
  };
  pastEmployers?: {
    entries?: PastEmployerEntry[];
  };
};

const {
  tabs = [],
  activeId,
  extraNavClasses = "",
  litigation = null,
  reports = null,
  coverage = null,
  personnel = null,
  pastEmployers = null,
} = Astro.props as ProfileTabsProps;

const normalizedTabs = tabs.map((tab, index) => ({
  ...tab,
  slotName: tab.slotName || tab.id,
  tabType: tab.tabType || null,
  isActive: tab.id === activeId || (!activeId && index === 0),
}));

const litigationCases = litigation?.cases || [];
const reportsItems = reports?.items || [];
const coverageLinks = coverage?.links || [];
const personnelEntries = personnel?.entries || [];
const pastEmployerEntries = pastEmployers?.entries || [];
const hasLitigation = litigationCases.length > 0;
const hasReports = reportsItems.length > 0;
const hasCoverage = coverageLinks.length > 0;
const hasPersonnel = personnelEntries.length > 0;
const hasPastEmployers = pastEmployerEntries.length > 0;

const formatCaseYear = (date?: string | null) =>
  date ? new Date(date).getFullYear() : "—";
const formatReportDate = (report: ReportItem) => report.incidentDate || "—";
const getOfficerName = (officer: OfficerRef) =>
  [
    officer.first_name || officer.firstName,
    officer.last_name || officer.lastName,
  ]
    .filter(Boolean)
    .join(" ");
---

<div data-profile-tabs>
  <ul class={`nav nav-tabs ${extraNavClasses}`} role="tablist">
    {
      normalizedTabs.map((tab) => (
        <li class="nav-item" role="presentation">
          <button
            class={`nav-link${tab.isActive ? " active" : ""}`}
            id={`${tab.id}-tab`}
            data-bs-toggle="tab"
            data-bs-target={`#${tab.id}`}
            data-profile-tab
            data-tab-id={tab.id}
            data-tab-label={tab.label}
            type="button"
            role="tab"
            aria-controls={tab.id}
            aria-selected={tab.isActive ? "true" : "false"}
          >
            {tab.label}
            {typeof tab.badge === "number" ? (
              <span class="badge bg-dark ms-2 rounded-pill">{tab.badge}</span>
            ) : null}
          </button>
        </li>
      ))
    }
  </ul>
  <div class="tab-content border border-top-0 p-4" id="profileTabsContent">
    {
      normalizedTabs.map((tab) => (
        <div
          class={`tab-pane fade${tab.isActive ? " show active" : ""}`}
          id={tab.id}
          role="tabpanel"
          aria-labelledby={`${tab.id}-tab`}
        >
          {tab.tabType === "litigation" ? (
            <>
              {hasLitigation ? (
                <div class="profile-record-list">
                  {litigationCases.map((caseItem) => (
                    <article class="profile-record">
                      <div class="profile-record-meta">
                        <span>{formatCaseYear(caseItem.filed_date)}</span>
                        {caseItem.cause_number ? (
                          <a
                            href={caseItem.caseUrl}
                            data-profile-link-type="case_reference"
                          >
                            {caseItem.cause_number}
                          </a>
                        ) : null}
                      </div>
                      <div class="profile-record-body">
                        <h3 class="profile-record-title">
                          <a
                            href={caseItem.caseUrl}
                            data-profile-link-type="case_reference"
                          >
                            {caseItem.title || "Civil case"}
                          </a>
                        </h3>
                        <div class="profile-record-detail">
                          <span>{caseItem.court || "Court not listed"}</span>
                          {caseItem.officers?.length ? (
                            <>
                              <span aria-hidden="true">/</span>
                              <span>
                                Officers:{" "}
                                {caseItem.officers.map((officer, index) => (
                                  <>
                                    {index > 0 ? ", " : null}
                                    <a
                                      href={`/personnel/${officer.slug}/`}
                                      data-profile-link-type="personnel_profile"
                                    >
                                      {getOfficerName(officer)}
                                    </a>
                                  </>
                                ))}
                              </span>
                            </>
                          ) : null}
                        </div>
                      </div>
                    </article>
                  ))}
                </div>
              ) : (
                <p class="text-muted">
                  {litigation?.emptyMessage ??
                    "No civil litigation listed yet."}
                </p>
              )}
            </>
          ) : tab.tabType === "reports" ? (
            <>
              {hasReports ? (
                <div class="profile-record-list">
                  {reportsItems.map((report) => (
                    <article class="profile-record">
                      <div class="profile-record-meta">
                        <span>{formatReportDate(report)}</span>
                      </div>
                      <div class="profile-record-body">
                        <h3 class="profile-record-title">
                          <a
                          href={report.url}
                          data-profile-link-type="report"
                        >
                          {report.title}
                        </a>
                        </h3>
                        {report.officers?.length ? (
                          <div class="profile-record-detail">
                            Officers:{" "}
                            {report.officers.map((officer, index) => (
                              <>
                                {index > 0 ? ", " : null}
                                <a
                                  href={`/personnel/${officer.slug}/`}
                                  data-profile-link-type="personnel_profile"
                                >
                                  {getOfficerName(officer)}
                                </a>
                              </>
                            ))}
                          </div>
                        ) : null}
                      </div>
                    </article>
                  ))}
                </div>
              ) : (
                <p class="text-muted">
                  {reports?.emptyMessage ?? "No reports published yet."}
                </p>
              )}
            </>
          ) : tab.tabType === "coverage" ? (
            <>
              {coverage?.helperText ? (
                <p class="text-muted small mb-3">{coverage.helperText}</p>
              ) : null}
              {hasCoverage ? (
                <div class="profile-record-list">
                  {coverageLinks.map((link) => (
                    <article class="profile-record">
                      <div class="profile-record-meta">
                        <span>
                          {[
                            link.source_name,
                            link.published_at
                              ? formatShortDate(link.published_at)
                              : null,
                          ]
                            .filter(Boolean)
                            .join(" / ") || "Related link"}
                        </span>
                      </div>
                      <div class="profile-record-body">
                        <h3 class="profile-record-title">
                          <a
                            href={link.url}
                            data-profile-link-type="coverage"
                            target="_blank"
                            rel="noopener noreferrer"
                          >
                            {link.title}
                          </a>
                        </h3>
                        {link.notes ? (
                          <p class="profile-record-summary">{link.notes}</p>
                        ) : null}
                        {link.officers?.length ? (
                          <div class="profile-record-detail">
                            Officers:{" "}
                            {link.officers.map((officer, index) => (
                              <>
                                {index > 0 ? ", " : null}
                                <a
                                  href={`/personnel/${officer.slug}/`}
                                  data-profile-link-type="personnel_profile"
                                >
                                  {getOfficerName(officer)}
                                </a>
                              </>
                            ))}
                          </div>
                        ) : null}
                      </div>
                    </article>
                  ))}
                </div>
              ) : (
                <p class="text-muted">
                  {coverage?.emptyMessage ?? "No related links listed yet."}
                </p>
              )}
            </>
          ) : tab.tabType === "personnel" ? (
            <>
              {hasPersonnel ? (
                <div class="profile-record-list">
                  {personnelEntries.map((employee) => (
                    <article class="profile-record">
                      <div class="profile-record-meta">
                        <span>
                          {employee.entry.start_date
                            ? formatShortDate(employee.entry.start_date)
                            : "Start date unknown"}
                        </span>
                        <span>
                          {employee.entry.end_date
                            ? formatShortDate(employee.entry.end_date)
                            : "Current"}
                        </span>
                      </div>
                      <div class="profile-record-body">
                        <h3 class="profile-record-title">
                          {employee.officer ? (
                            <a
                              href={`/personnel/${employee.officer.slug}/`}
                              data-profile-link-type="personnel_profile"
                            >
                              {getOfficerName(employee.officer)}
                            </a>
                          ) : (
                            "Unknown person"
                          )}
                        </h3>
                        <div class="profile-record-detail">
                          <span>
                            Badge: {employee.entry.badge_number || "Unknown"}
                          </span>
                          <span aria-hidden="true">/</span>
                          <span>{employee.reportCount || 0} reports</span>
                          <span aria-hidden="true">/</span>
                          <span>
                            {employee.rating && employee.rating > 0
                              ? `Rating ${employee.rating.toFixed(1)}`
                              : "Not rated"}
                          </span>
                        </div>
                      </div>
                    </article>
                  ))}
                </div>
              ) : (
                <p class="text-muted">No personnel listed yet.</p>
              )}
            </>
          ) : tab.tabType === "pastEmployers" ? (
            <>
              {hasPastEmployers ? (
                <div class="profile-record-list">
                  {pastEmployerEntries.map((entry) => (
                    <article class="profile-record">
                      <div class="profile-record-meta">
                        <span>
                          {entry.start_date
                            ? formatShortDate(entry.start_date)
                            : "Start date unknown"}
                        </span>
                        <span>
                          {entry.end_date
                            ? formatShortDate(entry.end_date)
                            : "Current"}
                        </span>
                      </div>
                      <div class="profile-record-body">
                        <h3 class="profile-record-title">
                          {entry.agency ? (
                            <a
                              href={`/law-enforcement-agency/${entry.agency.category}/${entry.agency.slug}/`}
                              data-profile-link-type="agency_profile"
                            >
                              {entry.agency.name}
                            </a>
                          ) : (
                            "Unknown agency"
                          )}
                        </h3>
                        <div class="profile-record-detail">
                          <span>Badge: {entry.badge_number || "Unknown"}</span>
                          <span aria-hidden="true">/</span>
                          <span>{entry.reportCount || 0} reports</span>
                          <span aria-hidden="true">/</span>
                          <span>
                            {entry.rating && entry.rating > 0
                              ? `Rating ${entry.rating.toFixed(1)}`
                              : "Not rated"}
                          </span>
                        </div>
                      </div>
                    </article>
                  ))}
                </div>
              ) : (
                <p class="text-muted mb-0">No past employers listed yet.</p>
              )}
            </>
          ) : null}
        </div>
      ))
    }
  </div>
</div>
<style>
  .profile-record-list {
    border-top: 1px solid var(--bs-border-color);
  }

  .profile-record {
    border-bottom: 1px solid var(--bs-border-color);
    display: grid;
    gap: 0.75rem 1.25rem;
    grid-template-columns: minmax(7rem, 10rem) minmax(0, 1fr);
    padding: 1rem 0;
  }

  .profile-record-media {
    grid-template-columns: minmax(7rem, 10rem) minmax(7rem, 10rem) minmax(
        0,
        1fr
      );
  }

  .profile-record-meta {
    color: var(--bs-secondary-color);
    display: flex;
    flex-direction: column;
    font-size: 0.875rem;
    gap: 0.25rem;
    line-height: 1.35;
  }

  .profile-record-meta a,
  .profile-record-title a,
  .profile-record-detail a {
    color: var(--bs-dark);
  }

  .profile-record-title {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.35;
    margin: 0;
  }

  .profile-record-summary {
    color: var(--bs-secondary-color);
    margin: 0.35rem 0 0;
  }

  .profile-record-detail {
    color: var(--bs-secondary-color);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.875rem;
    gap: 0.25rem 0.5rem;
    margin-top: 0.35rem;
  }

  .profile-record-thumb {
    aspect-ratio: 16 / 9;
    background: var(--bs-dark);
    display: block;
    overflow: hidden;
  }

  .profile-record-thumb img {
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  @media (max-width: 767.98px) {
    .profile-record,
    .profile-record-media {
      grid-template-columns: minmax(0, 1fr);
    }

    .profile-record-meta {
      flex-direction: row;
      flex-wrap: wrap;
    }

    .profile-record-thumb {
      max-width: 18rem;
    }
  }

  .profile-record-list {
    border-top: 0;
    display: grid;
    gap: 0.875rem;
  }

  .profile-record {
    align-items: start;
    background: var(--bs-white);
    border: 1px solid var(--bs-border-color);
    border-radius: 0.375rem;
    box-shadow: 0 1px 2px rgba(17, 24, 39, 0.04);
    grid-template-columns: minmax(0, 1fr) minmax(9rem, 14rem);
    padding: 1rem 1.125rem;
  }

  .profile-record-media {
    grid-template-columns: clamp(9rem, 16vw, 13rem) minmax(0, 1fr) minmax(
        9rem,
        13rem
      );
  }

  .profile-record-body {
    grid-column: 1;
    grid-row: 1;
    min-width: 0;
  }

  .profile-record-meta {
    align-items: flex-end;
    font-size: 0.8125rem;
    grid-column: 2;
    grid-row: 1;
    text-align: right;
  }

  .profile-record-media .profile-record-thumb {
    grid-column: 1;
    grid-row: 1;
  }

  .profile-record-media .profile-record-body {
    grid-column: 2;
  }

  .profile-record-media .profile-record-meta {
    grid-column: 3;
  }

  .profile-record-title {
    font-size: 1.0625rem;
  }

  .profile-record-summary {
    line-height: 1.55;
    max-width: 62rem;
  }

  .profile-record-detail {
    gap: 0.35rem 0.85rem;
    line-height: 1.5;
  }

  .profile-record-detail > span[aria-hidden="true"] {
    display: none;
  }

  @media (max-width: 991.98px) {
    .profile-record,
    .profile-record-media {
      grid-template-columns: minmax(0, 1fr);
    }

    .profile-record-body,
    .profile-record-meta,
    .profile-record-media .profile-record-body,
    .profile-record-media .profile-record-meta,
    .profile-record-media .profile-record-thumb {
      grid-column: 1;
    }

    .profile-record-media .profile-record-thumb {
      grid-row: 1;
    }

    .profile-record-media .profile-record-body {
      grid-row: 2;
    }

    .profile-record-media .profile-record-meta {
      grid-row: 3;
    }

    .profile-record-meta {
      align-items: flex-start;
      flex-direction: row;
      flex-wrap: wrap;
      grid-row: 2;
      text-align: left;
    }

    .profile-record-thumb {
      max-width: 22rem;
    }
  }
</style>
