---
import { formatShortDate } from "#src/lib/format.js";

type OfficerRef = {
  slug: string;
  first_name: string;
  last_name: string;
};

type LitigationCase = {
  title?: string | null;
  caseUrl: string;
  cause_number?: string | null;
  filed_date?: string | null;
  court?: string | null;
  primary_source_url?: string | null;
  officers?: OfficerRef[] | null;
};

type ReportItem = {
  incidentDate?: string | null;
  title?: string | null;
  url: string;
};

type VideoItem = {
  title: string;
  path: string;
  thumbnail?: string | null;
  summary?: string | null;
  description?: string | null;
  sourceLabel?: string | null;
  officers?: {
    relationshipType: string;
    agency?: { name: string } | null;
  }[];
  civilCases?: { title: string; path: string; relationshipType: string }[];
  reports?: { title: string; path: string; relationshipType: string }[];
};

type CoverageLink = {
  url: string;
  title: string;
  source_name?: string | null;
  published_at?: string | null;
  notes?: string | null;
};

type PersonnelEntry = {
  entry: {
    start_date?: string | null;
    end_date?: string | null;
    badge_number?: string | null;
  };
  officer?: OfficerRef | null;
  reportCount?: number;
  rating?: number | null;
};

type PastEmployerEntry = {
  start_date?: string | null;
  end_date?: string | null;
  badge_number?: string | null;
  reportCount?: number;
  rating?: number | null;
  agency?: {
    category?: string | null;
    slug?: string | null;
    name?: string | null;
  } | null;
};

type TabType =
  | "litigation"
  | "reports"
  | "coverage"
  | "personnel"
  | "pastEmployers"
  | "videos";
type TabDescriptor = {
  id: string;
  label: string;
  badge?: number;
  tabType?: TabType;
  slotName?: string;
};

type ProfileTabsProps = {
  tabs?: TabDescriptor[];
  activeId?: string;
  extraNavClasses?: string;
  litigation?: {
    cases?: LitigationCase[];
    emptyMessage?: string;
  };
  reports?: {
    items?: ReportItem[];
    emptyMessage?: string;
    layout?: "table" | "list";
  };
  videos?: {
    items?: VideoItem[];
    emptyMessage?: string;
  };
  coverage?: {
    links?: CoverageLink[];
    emptyMessage?: string;
  };
  personnel?: {
    entries?: PersonnelEntry[];
  };
  pastEmployers?: {
    entries?: PastEmployerEntry[];
  };
};

const {
  tabs = [],
  activeId,
  extraNavClasses = "",
  litigation = null,
  reports = null,
  videos = null,
  coverage = null,
  personnel = null,
  pastEmployers = null,
} = Astro.props as ProfileTabsProps;

const normalizedTabs = tabs.map((tab, index) => ({
  ...tab,
  slotName: tab.slotName || tab.id,
  tabType: tab.tabType || null,
  isActive: tab.id === activeId || (!activeId && index === 0),
}));

const litigationCases = litigation?.cases || [];
const reportsItems = reports?.items || [];
const videoItems = videos?.items || [];
const coverageLinks = coverage?.links || [];
const personnelEntries = personnel?.entries || [];
const pastEmployerEntries = pastEmployers?.entries || [];
const hasLitigation = litigationCases.length > 0;
const hasReports = reportsItems.length > 0;
const hasVideos = videoItems.length > 0;
const hasCoverage = coverageLinks.length > 0;
const hasPersonnel = personnelEntries.length > 0;
const hasPastEmployers = pastEmployerEntries.length > 0;

const formatCaseYear = (date?: string | null) =>
  date ? new Date(date).getFullYear() : "—";
const formatReportDate = (report: ReportItem) => report.incidentDate || "—";
const formatRelationLabel = (value: string) =>
  value
    .split("_")
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");
---

<div data-profile-tabs>
  <ul class={`nav nav-tabs ${extraNavClasses}`} role="tablist">
    {
      normalizedTabs.map((tab) => (
        <li class="nav-item" role="presentation">
          <button
            class={`nav-link${tab.isActive ? " active" : ""}`}
            id={`${tab.id}-tab`}
            data-bs-toggle="tab"
            data-bs-target={`#${tab.id}`}
            data-profile-tab
            data-tab-id={tab.id}
            data-tab-label={tab.label}
            type="button"
            role="tab"
            aria-controls={tab.id}
            aria-selected={tab.isActive ? "true" : "false"}
          >
            {tab.label}
            {typeof tab.badge === "number" ? (
              <span class="badge bg-dark ms-2 rounded-pill">{tab.badge}</span>
            ) : null}
          </button>
        </li>
      ))
    }
  </ul>
  <div class="tab-content border border-top-0 p-4" id="profileTabsContent">
    {
      normalizedTabs.map((tab) => (
        <div
          class={`tab-pane fade${tab.isActive ? " show active" : ""}`}
          id={tab.id}
          role="tabpanel"
          aria-labelledby={`${tab.id}-tab`}
        >
          {tab.tabType === "litigation" ? (
            <>
              <div class="mb-3">
                <span class="text-uppercase small text-muted mb-0">Cases</span>
              </div>
              {hasLitigation ? (
                <div class="table-responsive">
                  <table class="table table-striped align-middle mb-0">
                    <thead>
                      <tr>
                        <th scope="col">Year</th>
                        <th scope="col">Cause #</th>
                        <th scope="col">Case</th>
                        <th scope="col">Court / notes</th>
                      </tr>
                    </thead>
                    <tbody>
                      {litigationCases.map((caseItem) => (
                        <tr>
                          <td>{formatCaseYear(caseItem.filed_date)}</td>
                          <td>
                            <strong>
                              {caseItem.cause_number ? (
                                <a
                                  class="link-dark"
                                  href={caseItem.caseUrl}
                                  data-profile-link-type="case_reference"
                                >
                                  {caseItem.cause_number}
                                </a>
                              ) : (
                                "—"
                              )}
                            </strong>
                          </td>
                          <td>
                            <strong>
                              <a
                                class="link-dark"
                                href={caseItem.caseUrl}
                                data-profile-link-type="case_reference"
                              >
                                {caseItem.title || "Civil case"}
                              </a>
                            </strong>
                            {caseItem.officers?.length ? (
                              <>
                                {" "}
                                —{" "}
                                {caseItem.officers.map((officer, index) => (
                                  <>
                                    {index > 0 ? ", " : null}
                                    <a
                                      href={`/personnel/${officer.slug}/`}
                                      data-profile-link-type="personnel_profile"
                                    >
                                      {officer.first_name} {officer.last_name}
                                    </a>
                                  </>
                                ))}
                              </>
                            ) : null}
                          </td>
                          <td>{caseItem.court || "—"}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              ) : (
                <p class="text-muted">
                  {litigation?.emptyMessage ??
                    "No civil litigation listed yet."}
                </p>
              )}
            </>
          ) : tab.tabType === "reports" ? (
            <>
              {hasReports ? (
                <div class="d-grid gap-3">
                  {reportsItems.map((report) => (
                    <article class="border rounded-2 p-3 mb-3">
                      <div class="d-flex justify-content-between align-items-baseline mb-2">
                        <span class="text-uppercase small text-muted">
                          Date
                        </span>
                        <strong>{formatReportDate(report)}</strong>
                      </div>
                      <div class="mb-3">
                        <a
                          class="fw-bold text-dark"
                          href={report.url}
                          data-profile-link-type="report"
                        >
                          {report.title}
                        </a>
                      </div>
                      <a
                        class="btn btn-sm btn-outline-dark"
                        href={report.url}
                        data-profile-link-type="report"
                      >
                        View report
                      </a>
                    </article>
                  ))}
                </div>
              ) : (
                <p class="text-muted">
                  {reports?.emptyMessage ?? "No reports published yet."}
                </p>
              )}
            </>
          ) : tab.tabType === "videos" ? (
            <>
              {hasVideos ? (
                <div class="d-grid gap-3">
                  {videoItems.map((video) => (
                    <article class="border rounded-2 p-3">
                      <div class="row g-3 align-items-start">
                        {video.thumbnail ? (
                          <div class="col-12 col-md-4">
                            <a class="d-block" href={video.path}>
                              <div class="ratio ratio-16x9 bg-dark">
                                <img
                                  src={video.thumbnail}
                                  alt={`Video thumbnail for ${video.title}`}
                                  class="w-100 h-100 object-fit-cover"
                                  loading="lazy"
                                />
                              </div>
                            </a>
                          </div>
                        ) : null}
                        <div class="col">
                          <div class="text-uppercase small text-muted mb-1">
                            {video.sourceLabel || "Video"}
                          </div>
                          <h3 class="h6 mb-2">
                            <a class="link-dark" href={video.path}>
                              {video.title}
                            </a>
                          </h3>
                          {video.summary || video.description ? (
                            <p class="text-muted mb-2">
                              {video.summary || video.description}
                            </p>
                          ) : null}
                          <div class="small text-muted mb-3">
                            {video.officers?.[0]?.relationshipType
                              ? formatRelationLabel(
                                  video.officers[0].relationshipType,
                                )
                              : "Linked video"}
                            {video.officers?.[0]?.agency
                              ? ` at ${video.officers[0].agency.name}`
                              : ""}
                          </div>
                          <a
                            class="btn btn-sm btn-outline-dark"
                            href={video.path}
                            data-profile-link-type="video"
                          >
                            Watch video
                          </a>
                        </div>
                      </div>
                    </article>
                  ))}
                </div>
              ) : (
                <p class="text-muted">
                  {videos?.emptyMessage ?? "No videos linked yet."}
                </p>
              )}
            </>
          ) : tab.tabType === "coverage" ? (
            <>
              {hasCoverage ? (
                <div class="list-group">
                  {coverageLinks.map((link) => (
                    <article class="list-group-item">
                      <div class="d-flex flex-column flex-md-row gap-2 justify-content-between">
                        <div>
                          <div class="text-uppercase small text-muted mb-1">
                            {[
                              link.source_name,
                              link.published_at
                                ? formatShortDate(link.published_at)
                                : null,
                            ]
                              .filter(Boolean)
                              .join(" • ") || "Coverage"}
                          </div>
                          <h3 class="h6 mb-2">
                            <a
                              class="link-dark"
                              href={link.url}
                              data-profile-link-type="coverage"
                            >
                              {link.title}
                            </a>
                          </h3>
                          {link.notes ? (
                            <p class="text-muted mb-0">{link.notes}</p>
                          ) : null}
                        </div>
                        <div class="flex-shrink-0">
                          <a
                            class="btn btn-sm btn-outline-dark"
                            href={link.url}
                            data-profile-link-type="coverage"
                          >
                            Open source
                          </a>
                        </div>
                      </div>
                    </article>
                  ))}
                </div>
              ) : (
                <p class="text-muted">
                  {coverage?.emptyMessage ?? "No coverage links listed yet."}
                </p>
              )}
            </>
          ) : tab.tabType === "personnel" ? (
            <>
              {hasPersonnel ? (
                <div class="list-group">
                  {personnelEntries.map((employee) => (
                    <div class="list-group-item">
                      <div class="row g-3 align-items-start">
                        <div class="col-auto">
                          <div class="text-uppercase small text-muted">
                            Start
                          </div>
                          <div class="fw-semibold">
                            {employee.entry.start_date
                              ? formatShortDate(employee.entry.start_date)
                              : "Unknown"}
                          </div>
                        </div>
                        <div class="col-auto">
                          <div class="text-uppercase small text-muted">End</div>
                          <div>
                            {employee.entry.end_date
                              ? formatShortDate(employee.entry.end_date)
                              : "Current"}
                          </div>
                        </div>
                        <div class="col-12 col-md">
                          <div class="text-uppercase small text-muted">
                            Name
                          </div>
                          {employee.officer ? (
                            <a
                              href={`/personnel/${employee.officer.slug}/`}
                              data-profile-link-type="personnel_profile"
                            >
                              {employee.officer.first_name}{" "}
                              {employee.officer.last_name}
                            </a>
                          ) : (
                            "Unknown"
                          )}
                        </div>
                        <div class="col-6 col-md-2">
                          <div class="text-uppercase small text-muted">
                            Badge #
                          </div>
                          <div>{employee.entry.badge_number || "Unknown"}</div>
                        </div>
                        <div class="col-6 col-md-2">
                          <div class="text-uppercase small text-muted">
                            Reports
                          </div>
                          <div>{employee.reportCount}</div>
                        </div>
                        <div class="col-12 col-md-2">
                          <div class="text-uppercase small text-muted">
                            Rating
                          </div>
                          <div>
                            {employee.rating && employee.rating > 0
                              ? employee.rating.toFixed(1)
                              : "Not rated"}
                          </div>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              ) : (
                <p class="text-muted">No personnel listed yet.</p>
              )}
            </>
          ) : tab.tabType === "pastEmployers" ? (
            <>
              {hasPastEmployers ? (
                <div class="list-group">
                  {pastEmployerEntries.map((entry) => (
                    <div class="list-group-item">
                      <div class="row g-3 align-items-start">
                        <div class="col-auto">
                          <div class="text-uppercase small text-muted">
                            Start
                          </div>
                          <div class="fw-semibold">
                            {entry.start_date
                              ? formatShortDate(entry.start_date)
                              : "Unknown"}
                          </div>
                        </div>
                        <div class="col-auto">
                          <div class="text-uppercase small text-muted">End</div>
                          <div>
                            {entry.end_date
                              ? formatShortDate(entry.end_date)
                              : "Current"}
                          </div>
                        </div>
                        <div class="col-12 col-md">
                          <div class="text-uppercase small text-muted">
                            Name
                          </div>
                          {entry.agency ? (
                            <a
                              href={`/law-enforcement-agency/${entry.agency.category}/${entry.agency.slug}/`}
                              data-profile-link-type="agency_profile"
                            >
                              {entry.agency.name}
                            </a>
                          ) : (
                            "Unknown"
                          )}
                        </div>
                        <div class="col-6 col-md-2">
                          <div class="text-uppercase small text-muted">
                            Badge #
                          </div>
                          <div>{entry.badge_number || "Unknown"}</div>
                        </div>
                        <div class="col-6 col-md-2">
                          <div class="text-uppercase small text-muted">
                            Reports
                          </div>
                          <div>{entry.reportCount || 0}</div>
                        </div>
                        <div class="col-12 col-md-2">
                          <div class="text-uppercase small text-muted">
                            Rating
                          </div>
                          <div>
                            {entry.rating && entry.rating > 0
                              ? entry.rating.toFixed(1)
                              : "Not rated"}
                          </div>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              ) : (
                <p class="text-muted mb-0">No past employers listed yet.</p>
              )}
            </>
          ) : null}
        </div>
      ))
    }
  </div>
</div>
<style is:global>
  .case-grid {
    display: grid;
    grid-template-columns: max-content minmax(0, 1fr);
    gap: 0.25rem 0.75rem;
    align-items: baseline;
  }
  .case-grid-label {
    text-transform: uppercase;
    font-size: 0.625rem;
    letter-spacing: 0.1em;
    color: #6c757d;
  }
</style>
