---
type AlphaItem = {
  endPage: number | null;
  letter: string;
  page: number | null;
};

const {
  items = [],
  basePath,
  currentPage = 1,
  label = "Alphabetical navigation",
} = Astro.props as {
  items: AlphaItem[];
  basePath: string;
  currentPage?: number;
  label?: string;
};

const getHref = (page: number) =>
  page <= 1 ? basePath : `${basePath}page/${page}/`;

const activeItem = items.find(
  (item) =>
    item.page &&
    currentPage >= item.page &&
    (item.endPage === null || currentPage <= item.endPage),
);
---

{
  items.length ? (
    <nav aria-label={label} class="alpha-navigation mb-4">
      <div class="alpha-navigation-control">
        <label class="alpha-navigation-label" for="alpha-navigation-select">
          Jump to:
        </label>
        <select
          class="form-select rounded-0 alpha-navigation-select"
          id="alpha-navigation-select"
          onchange="if (this.value) window.location.href = this.value"
        >
          {items
            .filter((item) => item.page)
            .map((item) => (
              <option
                selected={item.letter === activeItem?.letter}
                value={getHref(item.page!)}
              >
                {item.letter}
              </option>
            ))}
        </select>
      </div>
    </nav>
  ) : null
}

<style>
  .alpha-navigation-control {
    align-items: center;
    display: flex;
    gap: 0.75rem;
    max-width: 20rem;
  }

  .alpha-navigation-label {
    color: var(--bs-secondary-color);
    flex: 0 0 auto;
    font-weight: 700;
    line-height: 2.375rem;
  }

  .alpha-navigation-select {
    min-width: 0;
  }

  @media (max-width: 575.98px) {
    .alpha-navigation-control {
      align-items: stretch;
      gap: 0.35rem;
      max-width: none;
      width: 100%;
    }

    .alpha-navigation-label {
      line-height: 1.35;
    }
  }
</style>
