---
type AlphaItem = {
  endPage: number | null;
  letter: string;
  page: number | null;
};

const {
  items = [],
  basePath,
  currentPage = 1,
  label = "Alphabetical navigation",
} = Astro.props as {
  items: AlphaItem[];
  basePath: string;
  currentPage?: number;
  label?: string;
};

const getHref = (page: number) =>
  page <= 1 ? basePath : `${basePath}page/${page}/`;
---

{
  items.length ? (
    <nav aria-label={label} class="mb-4">
      <div class="d-flex flex-wrap gap-2">
        {items.map((item) =>
          item.page ? (
            <a
              class:list={[
                "btn rounded-0",
                currentPage >= item.page &&
                (item.endPage === null || currentPage <= item.endPage)
                  ? "btn-dark"
                  : "btn-outline-dark",
              ]}
              href={getHref(item.page)}
            >
              {item.letter}
            </a>
          ) : (
            <span class="btn btn-outline-secondary rounded-0 disabled">
              {item.letter}
            </span>
          ),
        )}
      </div>
    </nav>
  ) : null
}
