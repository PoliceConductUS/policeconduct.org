---
const {
  label = "No measured values",
  detail = "This measurement is reserved for verified data when available.",
} = Astro.props as {
  label?: string;
  detail?: string;
};
---

<div class="empty-measurement-state" role="note">
  <strong>{label}</strong>
  <span>{detail}</span>
</div>

<style>
  .empty-measurement-state {
    align-items: start;
    background: rgba(7, 24, 66, 0.035);
    border: 1px dashed #b8c4d8;
    color: #33456f;
    display: grid;
    gap: 0.25rem;
    margin-top: 1rem;
    min-height: 6.5rem;
    padding: 1rem;
    place-content: center start;
  }

  .empty-measurement-state strong {
    color: #071842;
    font-size: 0.95rem;
    line-height: 1.25;
  }

  .empty-measurement-state span {
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.45;
    max-width: 34rem;
  }
</style>
