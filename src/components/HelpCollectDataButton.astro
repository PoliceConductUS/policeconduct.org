---
import PrefillNavButton from "#src/components/PrefillNavButton.astro";

const { context, sourcePage, topic } = Astro.props as {
  context: string;
  sourcePage: string;
  topic?: string;
};

const message = [
  "I want to help collect data for this page.",
  `Page: ${sourcePage}`,
  `Context: ${context}`,
  topic ? `Topic: ${topic}` : null,
]
  .filter(Boolean)
  .join("\n");
---

<PrefillNavButton
  to="/volunteer/"
  payload={{
    interest: "Data and Product",
    skills: message,
    source_page: sourcePage,
    context,
    topic,
  }}
  class="entity-action entity-action-primary"
>
  Help collect data
</PrefillNavButton>

<style>
  :global(.entity-action) {
    align-items: center;
    background: #fbfcff;
    border: 1px solid #c9d4e6;
    border-radius: 0.4rem;
    color: #071842;
    display: inline-flex;
    font-size: 0.88rem;
    font-weight: 700;
    justify-content: center;
    line-height: 1.1;
    min-height: 3rem;
    padding: 0.72rem 1.05rem;
    text-decoration: none;
  }

  :global(.entity-action-primary) {
    background: #071842;
    border-color: #071842;
    color: #f8faff;
  }
</style>
