---
type ChartRow = {
  label: string;
  value: string;
  width?: number;
  segments?: number[];
};

const {
  ariaLabel,
  rows,
  legend = [],
} = Astro.props as {
  ariaLabel: string;
  rows: ChartRow[];
  legend?: string[];
};

const allowedWidths = new Set([
  0, 12, 14, 18, 24, 26, 28, 30, 32, 34, 36, 38, 42, 44, 46, 48, 52, 54, 56, 58,
  62, 64, 70, 72,
]);
const segmentWidthClass = (width = 0) => {
  if (!allowedWidths.has(width)) {
    throw new Error(`Unsupported sample measurement width: ${width}`);
  }
  return `sample-measurement-width-${width}`;
};
---

<div class="sample-measurement-chart disabled" aria-label={ariaLabel}>
  {
    rows.map((row) => (
      <div class="sample-measurement-row">
        <b>{row.label}</b>
        <span>
          {row.segments?.length ? (
            row.segments.map((segment) => (
              <i class={segmentWidthClass(segment)} />
            ))
          ) : (
            <i class={segmentWidthClass(row.width)} />
          )}
        </span>
        <em>{row.value}</em>
      </div>
    ))
  }
</div>

{
  legend.length ? (
    <div class="sample-measurement-legend" aria-label="Chart legend">
      {legend.map((item) => (
        <span>
          <i />
          {item}
        </span>
      ))}
    </div>
  ) : null
}

<style>
  .sample-measurement-chart {
    background: rgba(7, 24, 66, 0.025);
    border: 1px solid #d9e1ee;
    display: grid;
    gap: 0.68rem;
    margin-top: 1rem;
    min-height: 10.1rem;
    padding: 0.9rem;
  }

  .sample-measurement-chart.disabled {
    opacity: 0.72;
  }

  .sample-measurement-row {
    align-items: center;
    display: grid;
    gap: 0.65rem;
    grid-template-columns: minmax(6.5rem, 0.72fr) minmax(0, 1.5fr) 2.6rem;
  }

  .sample-measurement-row b,
  .sample-measurement-row em,
  .sample-measurement-legend span {
    color: #33456f;
    font-size: 0.75rem;
    font-style: normal;
    font-weight: 750;
    line-height: 1.2;
  }

  .sample-measurement-row span {
    background: #e7edf6;
    display: flex;
    height: 1.05rem;
    overflow: hidden;
  }

  .sample-measurement-row i {
    background: #bac7d8;
    display: block;
    height: 100%;
  }

  .sample-measurement-width-0 {
    width: 0%;
  }

