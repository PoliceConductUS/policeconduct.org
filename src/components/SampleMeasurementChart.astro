  }

  .sample-measurement-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 0.75rem;
    margin-top: 0.72rem;
  }

  .sample-measurement-legend span {
    align-items: center;
    display: inline-flex;
    gap: 0.35rem;
  }

  .sample-measurement-legend i {
