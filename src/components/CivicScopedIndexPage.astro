---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import type { CivicIndexModel } from "#src/lib/data/civic-index.js";

type ScopedPageKind =
  | "personnel"
  | "budget"
  | "civil-cases"
  | "liability-costs";

const { model, kind } = Astro.props as {
  model: CivicIndexModel;
  kind: ScopedPageKind;
};

const pageConfig = {
  personnel: {
    label: "Personnel",
    title: "Personnel",
    description: "Personnel records connected to this geography.",
    value:
      model.coverage
        .find((metric) => metric.key === "personnel")
        ?.value.toLocaleString("en-US") ?? "0",
    columns: ["Name", "Level", "Personnel", "Reports", "Civil Cases"],
  },
  budget: {
    label: "Budget",
    title: "Budget",
    description: "Budget, revenue, spending, forfeiture, and overtime signals.",
    value: "$--",
    columns: ["Name", "Level", "Budget", "Personnel", "Agencies"],
  },
  "civil-cases": {
    label: "Civil Cases",
    title: "Civil Cases",
    description: "Civil cases connected to this geography.",
    value:
      model.coverage
        .find((metric) => metric.key === "civil_cases")
        ?.value.toLocaleString("en-US") ?? "0",
    columns: ["Name", "Level", "Civil Cases", "Personnel", "Reports"],
  },
  "liability-costs": {
    label: "Liability Costs",
    title: "Liability Costs",
    description:
      "Claims, settlements, judgments, defense costs, and related financial exposure.",
    value: "$--",
    columns: ["Name", "Level", "Liability Costs", "Civil Cases", "Personnel"],
  },
}[kind];

const heading =
  model.breadcrumbs[model.breadcrumbs.length - 1]?.label ||
  model.jurisdictionLabel;
const pagePath = `${model.pagePath}${kind}/`;
const pageTitle = `${heading} ${pageConfig.title}`;
const rows = model.rows.slice(0, 50);
const rowLevel =
  model.level === "state"
    ? "County / Area"
    : model.level === "administrative_area"
      ? "Place"
      : "Agency";
const chartTitles =
  kind === "personnel"
    ? ["Personnel Over Time", "Personnel by Child Area", "Record Mix"]
    : kind === "budget"
      ? ["Budget Over Time", "Revenue Sources Over Time", "Budget Allocation"]
      : kind === "civil-cases"
        ? ["Civil Cases Over Time", "Case Types", "Cases by Child Area"]
        : [
            "Liability Costs Over Time",
            "Cost Components Over Time",
            "Payment Source Breakdown",
          ];
---

<SiteLayout
  title={pageTitle}
  description={pageConfig.description}
  pagePath={pagePath}
  canonicalUrl={pagePath}
>
  <main class="civic-scoped-page">
    <section class="civic-scoped-overview">
      <div class="container">
        <Breadcrumbs
          items={[
            ...model.breadcrumbs.map((item) => ({ ...item, current: false })),
            { label: pageConfig.label, href: pagePath, current: true },
          ]}
          className="mb-2"
        />
        <div class="civic-scoped-heading">
          <div>
            <h1>{pageTitle}</h1>
            <p>{pageConfig.description}</p>
          </div>
          <div class="civic-scoped-actions">
            <button type="button">Share</button>
            <button type="button" class="civic-scoped-primary">
              Download Report
            </button>
          </div>
        </div>

        <div class="civic-scoped-metrics">
          <article>
            <p>Total</p>
            <strong>{pageConfig.value}</strong>
            <span>{pageConfig.description}</span>
          </article>
          <article>
            <p>Agencies Tracked</p>
            <strong>
              {
                model.coverage
                  .find((metric) => metric.key === "agencies")
                  ?.value.toLocaleString("en-US") ?? "0"
              }
            </strong>
            <span>Agencies in this geography</span>
          </article>
          <article>
            <p>Personnel</p>
            <strong>
              {
                model.coverage
                  .find((metric) => metric.key === "personnel")
                  ?.value.toLocaleString("en-US") ?? "0"
              }
            </strong>
            <span>Tracked personnel records</span>
          </article>
          <article>
            <p>Civil Cases</p>
            <strong>
              {
                model.coverage
                  .find((metric) => metric.key === "civil_cases")
                  ?.value.toLocaleString("en-US") ?? "0"
              }
            </strong>
            <span>Connected civil case records</span>
          </article>
        </div>

        <div class="civic-scoped-chart-grid">
          {
            chartTitles.map((title) => (
              <article class="civic-scoped-chart-card">
                <h2>{title}</h2>
                <div class="civic-scoped-empty-chart" aria-hidden="true" />
              </article>
            ))
          }
        </div>

        <div class="civic-scoped-table-wrap">
          <h2>{pageConfig.title} by {rowLevel}</h2>
          <table>
            <thead>
              <tr>
                {
                  pageConfig.columns.map((column) => (
                    <th scope="col">{column}</th>
                  ))
                }
                <th scope="col">View</th>
              </tr>
            </thead>
            <tbody>
              {
                rows.map((row) => (
                  <tr>
                    <th scope="row">{row.label}</th>
                    <td>{rowLevel}</td>
                    {kind === "budget" ? (
                      <>
                        <td>$--</td>
                        <td>{row.values.personnel ?? 0}</td>
                        <td>{row.values.agencies ?? ""}</td>
                      </>
                    ) : kind === "liability-costs" ? (
                      <>
                        <td>$--</td>
                        <td>{row.values.civilCases ?? 0}</td>
                        <td>{row.values.personnel ?? 0}</td>
                      </>
                    ) : kind === "civil-cases" ? (
                      <>
                        <td>{row.values.civilCases ?? 0}</td>
                        <td>{row.values.personnel ?? 0}</td>
                        <td>{row.values.reports ?? 0}</td>
                      </>
                    ) : (
                      <>
                        <td>{row.values.personnel ?? 0}</td>
                        <td>{row.values.reports ?? 0}</td>
                        <td>{row.values.civilCases ?? 0}</td>
                      </>
                    )}
                    <td>
                      <a href={row.href}>View</a>
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>

<style>
  .civic-scoped-page {
    background: #fbfcff;
    color: #071842;
  }

  .civic-scoped-overview {
    padding: 1.35rem 0 2rem;
  }

  .civic-scoped-overview > .container {
    max-width: 1240px;
  }

  .civic-scoped-heading {
    align-items: start;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: minmax(0, 1fr);
    margin-bottom: 1rem;
  }

  .civic-scoped-heading h1 {
    font-size: clamp(2.05rem, 3.4vw, 2.8rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1;
    margin: 0 0 0.45rem;
  }

  .civic-scoped-heading p {
    color: #33456f;
    margin: 0;
  }

  .civic-scoped-actions {
    display: flex;
    gap: 1rem;
  }

  .civic-scoped-actions button {
    background: #fbfcff;
    border: 1px solid #c9d4e6;
    border-radius: 0.4rem;
    color: #071842;
    font-weight: 800;
    min-height: 3rem;
    padding: 0.72rem 1.05rem;
  }

  .civic-scoped-actions .civic-scoped-primary {
    background: #071842;
    border-color: #071842;
    color: #f8faff;
  }

  .civic-scoped-metrics,
  .civic-scoped-chart-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(0, 1fr);
    margin-bottom: 1rem;
  }

  .civic-scoped-metrics article,
  .civic-scoped-chart-card,
  .civic-scoped-table-wrap {
    background: #fbfcff;
    border: 1px solid #d5deeb;
    border-radius: 0.45rem;
    box-shadow: 0 1px 2px rgba(7, 24, 66, 0.04);
  }

  .civic-scoped-metrics article {
    min-height: 8rem;
    padding: 1rem 1.1rem;
  }

  .civic-scoped-metrics p {
    font-size: 0.84rem;
    font-weight: 800;
    margin: 0;
  }

  .civic-scoped-metrics strong {
    display: block;
    font-size: 1.65rem;
    line-height: 1.1;
    margin: 0.35rem 0;
  }

  .civic-scoped-metrics span {
    color: #33456f;
    font-size: 0.82rem;
  }

  .civic-scoped-chart-card {
    min-height: 15.8rem;
    padding: 1rem 1.1rem;
  }

  .civic-scoped-chart-card h2,
  .civic-scoped-table-wrap h2 {
    font-size: 1rem;
    font-weight: 800;
    margin: 0 0 1rem;
  }

  .civic-scoped-empty-chart {
    background:
      linear-gradient(#d9e1ee 1px, transparent 1px) 0 0 / 100% 25%,
      linear-gradient(90deg, #b8c4d8 1px, transparent 1px) 0 0 / 10% 100%;
    border-bottom: 1px solid #b8c4d8;
    border-left: 1px solid #b8c4d8;
    height: 10rem;
    margin-top: 1rem;
  }

  .civic-scoped-table-wrap {
    overflow-x: auto;
    padding: 1rem 1.1rem;
  }

  .civic-scoped-table-wrap table {
    border-collapse: collapse;
    min-width: 760px;
    width: 100%;
  }

  .civic-scoped-table-wrap th,
  .civic-scoped-table-wrap td {
    border-top: 1px solid #d9e1ee;
    font-size: 0.82rem;
    padding: 0.55rem 0.45rem;
    text-align: left;
  }

  .civic-scoped-table-wrap a {
    color: #064cfb;
    font-weight: 800;
    text-decoration: none;
  }

  @media (min-width: 768px) {
    .civic-scoped-metrics {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .civic-scoped-chart-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (min-width: 1200px) {
    .civic-scoped-heading {
      grid-template-columns: minmax(0, 1fr) auto;
    }
  }

  @media (max-width: 991.98px) {
  }
</style>
