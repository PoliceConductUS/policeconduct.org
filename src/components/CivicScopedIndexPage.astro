---
import CivicScopedOverviewPage from "#src/components/CivicScopedOverviewPage.astro";
import CivicScopedRowsTable from "#src/components/CivicScopedRowsTable.astro";
import type { CivicIndexModel } from "#src/lib/data/civic-index.js";

type ScopedPageKind = "budget" | "civil-cases" | "liability-costs";

const { model, kind } = Astro.props as {
  model: CivicIndexModel;
  kind: ScopedPageKind;
};
---

<CivicScopedOverviewPage model={model} kind={kind}>
  <CivicScopedRowsTable model={model} kind={kind} />
</CivicScopedOverviewPage>
