---
import type { CivicScopedCivilCaseRow } from "#src/lib/data/civic-index.js";
import { formatShortDate } from "#src/lib/format.js";

const { rows } = Astro.props as {
  rows: CivicScopedCivilCaseRow[];
};

const formatReferenceList = (references: CivicScopedCivilCaseRow["agencies"]) =>
  references.slice(0, 4);

const remainingCount = (references: CivicScopedCivilCaseRow["agencies"]) =>
  Math.max(0, references.length - 4);
---

<div class="civic-scoped-cases-table-wrap">
  <h2>Civil Cases</h2>
  <table>
    <thead>
      <tr>
        <th scope="col">Case</th>
        <th scope="col">Filed</th>
        <th scope="col">Places</th>
        <th scope="col">Agencies</th>
        <th scope="col">Officers</th>
        <th scope="col">View</th>
      </tr>
    </thead>
    <tbody>
      {
        rows.map((row) => (
          <tr>
            <th scope="row">
              <a href={row.href}>{row.title}</a>
              <span>
                {[row.causeNumber, row.court].filter(Boolean).join(" · ")}
              </span>
            </th>
            <td>{formatShortDate(row.filedDate)}</td>
            <td>
              {formatReferenceList(row.places).map((place, index) => (
                <>
                  {index > 0 ? ", " : ""}
                  <a href={place.href}>{place.label}</a>
                </>
              ))}
            </td>
            <td>
              {formatReferenceList(row.agencies).map((agency, index) => (
                <>
                  {index > 0 ? ", " : ""}
                  <a href={agency.href}>{agency.label}</a>
                </>
              ))}
              {remainingCount(row.agencies) ? (
                <span> +{remainingCount(row.agencies)} more</span>
              ) : null}
            </td>
            <td>
              {formatReferenceList(row.officers).map((officer, index) => (
                <>
                  {index > 0 ? ", " : ""}
                  <a href={officer.href}>{officer.label}</a>
                </>
              ))}
              {remainingCount(row.officers) ? (
                <span> +{remainingCount(row.officers)} more</span>
              ) : null}
            </td>
            <td>
              <a href={row.href}>View</a>
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>

<style>
  .civic-scoped-cases-table-wrap {
    background: #fbfcff;
    border: 1px solid #d5deeb;
    border-radius: 0.45rem;
    box-shadow: 0 1px 2px rgba(7, 24, 66, 0.04);
    overflow-x: auto;
    padding: 1rem 1.1rem;
  }

  .civic-scoped-cases-table-wrap h2 {
    font-size: 1rem;
    font-weight: 800;
    margin: 0 0 1rem;
  }

  .civic-scoped-cases-table-wrap table {
    border-collapse: collapse;
    min-width: 980px;
    width: 100%;
  }

  .civic-scoped-cases-table-wrap th,
  .civic-scoped-cases-table-wrap td {
    border-top: 1px solid #d9e1ee;
    color: #071842;
    font-size: 0.82rem;
    line-height: 1.45;
    padding: 0.65rem 0.5rem;
    text-align: left;
    vertical-align: top;
  }

  .civic-scoped-cases-table-wrap th[scope="row"] {
    min-width: 18rem;
  }

  .civic-scoped-cases-table-wrap th[scope="row"] span {
    color: #33456f;
    display: block;
    font-size: 0.76rem;
    font-weight: 500;
    margin-top: 0.2rem;
  }

  .civic-scoped-cases-table-wrap a {
    color: #064cfb;
    font-weight: 800;
    text-decoration: none;
  }

  .civic-scoped-cases-table-wrap td span {
    color: #33456f;
    white-space: nowrap;
  }
</style>
