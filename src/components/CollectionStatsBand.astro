---
type StatItem = {
  actionLabel?: string;
  description?: string;
  href?: string;
  label: string;
  title?: string;
  value: number | string;
};

const { items = [] } = Astro.props as {
  items: StatItem[];
  variant?: "default" | "compact";
};

const { variant = "default" } = Astro.props as {
  items: StatItem[];
  variant?: "default" | "compact";
};
---

{
  items.length > 0 ? (
    <section class:list={["collection-stats-band", variant === "compact" ? "collection-stats-band-compact py-3" : "py-4"]}>
      <div class="container">
        <div class:list={[variant === "compact" ? "collection-stats-compact" : "row g-3"]}>
          {items.map((item) => {
            const content = (
              <div class:list={[variant === "compact" ? "collection-stat-compact" : "card shadow-sm rounded-0 border-dark h-100"]}>
                <div class:list={[variant === "compact" ? "collection-stat-compact-body" : "card-body d-flex flex-column gap-2 h-100"]}>
                  <div class:list={[variant === "compact" ? "collection-stat-label" : "text-uppercase small text-muted"]}>
                    {item.label}
                  </div>
                  <div class:list={[variant === "compact" ? "collection-stat-value" : "display-6 fw-bold"]}>
                    {item.value}
                  </div>
                  {item.title ? <div class="h5 mb-0">{item.title}</div> : null}
                  {item.description ? (
                    <div class:list={[variant === "compact" ? "collection-stat-description" : "text-muted small"]}>
                      {item.description}
                    </div>
                  ) : null}
                  {item.actionLabel && item.href ? (
                    <div class:list={[variant === "compact" ? "collection-stat-action" : "mt-auto pt-2 fw-semibold text-dark"]}>
                      {item.actionLabel}
                    </div>
                  ) : null}
                </div>
              </div>
            );
            const isLinked = Boolean(item.href);

            return (
              <div class:list={[variant === "compact" ? "collection-stat-compact-wrap" : "col-12 col-sm-6 col-xl-3"]}>
                {isLinked ? (
                  <a
                    class="text-decoration-none text-reset d-block h-100"
                    href={item.href!}
                  >
                    {content}
                  </a>
                ) : (
                  content
                )}
              </div>
            );
          })}
        </div>
      </div>
    </section>
  ) : null
}

<style>
  .collection-stats-band-compact {
    border-top: 1px solid var(--bs-border-color);
  }

  .collection-stats-compact {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
  }

  .collection-stat-compact {
    background: var(--bs-white);
    border: 1px solid var(--bs-border-color);
    height: 100%;
  }

  .collection-stat-compact-body {
    display: grid;
    gap: 0.2rem;
    padding: 0.75rem 0.875rem;
  }

  .collection-stat-label {
    color: var(--bs-secondary-color);
    font-size: 0.75rem;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .collection-stat-value {
    color: var(--bs-dark);
    font-family: var(--pc-heading-font, inherit);
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1;
  }

  .collection-stat-description,
  .collection-stat-action {
    font-size: 0.8125rem;
    line-height: 1.35;
  }

  .collection-stat-description {
    color: var(--bs-secondary-color);
  }

  .collection-stat-action {
    color: var(--bs-dark);
    font-weight: 700;
  }

  @media (max-width: 575.98px) {
    .collection-stats-compact {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>
