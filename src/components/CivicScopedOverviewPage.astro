---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import type { CivicIndexModel } from "#src/lib/data/civic-index.js";
import type {
  CivicTopicKind,
  CivicTopicRecords,
} from "#src/lib/data/civic-topic-records.js";
import { metricLabels } from "#src/lib/metric-vocabulary.js";

const { model, kind, records } = Astro.props as {
  model: CivicIndexModel;
  kind: CivicTopicKind;
  records?: CivicTopicRecords;
};

const pageConfig = {
  personnel: {
    label: metricLabels.personnel,
    title: metricLabels.personnel,
    description: "Personnel records connected to this geography.",
    value:
      model.coverage
        .find((metric) => metric.key === "personnel")
        ?.value.toLocaleString("en-US") ?? "0",
  },
  budget: {
    label: metricLabels.budget,
    title: metricLabels.budget,
    description: "Budget, revenue, spending, forfeiture, and overtime signals.",
    value: "$--",
  },
  "civil-cases": {
    label: metricLabels.civilCases,
    title: metricLabels.civilCases,
    description: "Civil cases connected to this geography.",
    value:
      records?.kind === "civil-cases"
        ? records.totalCount.toLocaleString("en-US")
        : "0",
  },
  "liability-costs": {
    label: metricLabels.liabilityCosts,
    title: metricLabels.liabilityCosts,
    description:
      "Claims, settlements, judgments, defense costs, and related financial exposure.",
    value: "$--",
  },
}[kind];

const coverageValue = (key: CivicIndexModel["coverage"][number]["key"]) =>
  model.coverage
    .find((metric) => metric.key === key)
    ?.value.toLocaleString("en-US") ?? "0";

const heading =
  model.breadcrumbs[model.breadcrumbs.length - 1]?.label ||
  model.jurisdictionLabel;
const pagePath = `${model.pagePath}${kind}/`;
const pageTitle = `${heading} ${pageConfig.title}`;
const topicConfig = {
  personnel: {
    metrics: [
      {
        label: metricLabels.personnel,
        value: coverageValue("personnel"),
        detail: "Projected personnel connected to this geography",
      },
      {
        label: metricLabels.personnelRecords,
        value: coverageValue("personnel"),
        detail: "Current personnel records in scope",
      },
      {
        label: metricLabels.agencyAssignments,
        value: "$--",
        detail: "Assignment history coverage is not projected yet",
      },
      {
        label: metricLabels.latestPersonnelUpdate,
        value: "$--",
        detail: "Personnel update recency is not projected yet",
      },
    ],
    charts: ["Personnel Over Time", "Personnel by Child Area", "Record Mix"],
  },
  budget: {
    metrics: [
      {
        label: metricLabels.budget,
        value: "$--",
        detail: "Budget totals are not projected yet",
      },
      {
        label: metricLabels.operatingSpend,
        value: "$--",
        detail: "Operating spend is not projected yet",
      },
      {
        label: metricLabels.overtime,
        value: "$--",
        detail: "Overtime spending is not projected yet",
      },
      {
        label: metricLabels.latestFiscalYear,
        value: "$--",
        detail: "Fiscal-year coverage is not projected yet",
      },
    ],
    charts: [
      "Budget Over Time",
      "Revenue Sources Over Time",
      "Budget Allocation",
    ],
  },
  "civil-cases": {
    metrics: [
      {
        label: metricLabels.civilCases,
        value:
          records?.kind === "civil-cases"
            ? records.totalCount.toLocaleString("en-US")
            : "0",
        detail: "Civil cases connected through agencies and personnel",
      },
      {
        label: metricLabels.caseTypes,
        value: "$--",
        detail: "Case type coverage is not projected yet",
      },
      {
        label: metricLabels.caseOutcomes,
        value: "$--",
        detail: "Outcome coverage is not projected yet",
      },
      {
        label: metricLabels.latestCaseActivity,
        value: "$--",
        detail: "Case activity recency is not projected yet",
      },
    ],
    charts: ["Civil Cases Over Time", "Case Types", "Cases by Child Area"],
  },
  "liability-costs": {
    metrics: [
      {
        label: metricLabels.liabilityCosts,
        value: "$--",
        detail: "Liability cost totals are not projected yet",
      },
      {
        label: metricLabels.settlements,
        value: "$--",
        detail: "Settlement totals are not projected yet",
      },
      {
        label: metricLabels.judgments,
        value: "$--",
        detail: "Judgment totals are not projected yet",
      },
      {
        label: metricLabels.latestRecordedYear,
        value: "$--",
        detail: "Liability-cost recency is not projected yet",
      },
    ],
    charts: [
      "Liability Costs Over Time",
      "Cost Components Over Time",
      "Payment Source Breakdown",
    ],
  },
}[kind];
---

<SiteLayout
  title={pageTitle}
  description={pageConfig.description}
  pagePath={pagePath}
  canonicalUrl={pagePath}
>
  <main class="civic-scoped-page">
    <section class="civic-scoped-overview">
      <div class="container">
        <Breadcrumbs
          items={[
            ...model.breadcrumbs.map((item) => ({ ...item, current: false })),
            { label: pageConfig.label, href: pagePath, current: true },
          ]}
          className="mb-2"
        />
        <div class="civic-scoped-heading">
          <div>
            <h1>{pageTitle}</h1>
            <p>{pageConfig.description}</p>
          </div>
          <div class="civic-scoped-actions">
            <button type="button">Share</button>
            <button type="button" class="civic-scoped-primary">
              Download Report
            </button>
          </div>
        </div>

        <div class="civic-scoped-metrics">
          {
            topicConfig.metrics.map((metric) => (
              <article>
                <p>{metric.label}</p>
                <strong>{metric.value}</strong>
                <span>{metric.detail}</span>
              </article>
            ))
          }
        </div>

        <div class="civic-scoped-chart-grid">
          {
            topicConfig.charts.map((title) => (
              <article class="civic-scoped-chart-card">
                <h2>{title}</h2>
                <div class="civic-scoped-empty-chart" aria-hidden="true" />
              </article>
            ))
          }
        </div>

        <slot />
      </div>
    </section>
  </main>
</SiteLayout>

<style>
  .civic-scoped-page {
    background: #fbfcff;
    color: #071842;
    font-family:
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
  }

  .civic-scoped-overview {
    padding: 1.35rem 0 2rem;
  }

  .civic-scoped-overview > .container {
    max-width: 1240px;
  }

  .civic-scoped-heading {
    align-items: start;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: minmax(0, 1fr);
    margin-bottom: 1rem;
  }

  .civic-scoped-heading h1 {
    color: #071842;
    font-family:
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    font-size: 2.25rem;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1;
    margin: 0 0 0.45rem;
  }

  .civic-scoped-heading p {
    color: #33456f;
    line-height: 1.55;
    margin: 0;
    max-width: 72ch;
  }

  .civic-scoped-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: start;
  }

  .civic-scoped-actions button {
    background: #fbfcff;
    border: 1px solid #c9d4e6;
    border-radius: 0.4rem;
    color: #071842;
    font-size: 0.88rem;
    font-weight: 700;
    min-height: 3rem;
    padding: 0.72rem 1.05rem;
  }

  .civic-scoped-actions .civic-scoped-primary {
    background: #071842;
    border-color: #071842;
    color: #f8faff;
  }

  .civic-scoped-metrics,
  .civic-scoped-chart-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(0, 1fr);
    margin-bottom: 1rem;
  }

  .civic-scoped-metrics article,
  .civic-scoped-chart-card {
    background: #fbfcff;
    border: 1px solid #d5deeb;
    border-radius: 0.45rem;
    box-shadow: 0 1px 2px rgba(7, 24, 66, 0.04);
  }

  .civic-scoped-metrics article {
    min-height: 8rem;
    padding: 1rem 1.1rem;
  }

  .civic-scoped-metrics p {
    font-size: 0.875rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
  }

  .civic-scoped-metrics strong {
    display: block;
    font-size: 1.5rem;
    font-variant-numeric: tabular-nums;
    line-height: 1.12;
    margin: 0.35rem 0;
  }

  .civic-scoped-metrics span {
    color: #33456f;
    font-size: 0.8125rem;
    line-height: 1.45;
  }

  .civic-scoped-chart-card {
    min-height: 15.8rem;
    padding: 1rem 1.1rem;
  }

  .civic-scoped-chart-card h2 {
    font-family:
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    font-size: 1.0625rem;
    font-weight: 750;
    line-height: 1.25;
    margin: 0 0 1rem;
  }

  .civic-scoped-empty-chart {
    background:
      linear-gradient(#d9e1ee 1px, transparent 1px) 0 0 / 100% 25%,
      linear-gradient(90deg, #b8c4d8 1px, transparent 1px) 0 0 / 10% 100%;
    border-bottom: 1px solid #b8c4d8;
    border-left: 1px solid #b8c4d8;
    height: 10rem;
    margin-top: 1rem;
  }

  @media (min-width: 768px) {
    .civic-scoped-metrics {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .civic-scoped-chart-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (min-width: 1200px) {
    .civic-scoped-heading {
      grid-template-columns: minmax(0, 1fr) auto;
    }

    .civic-scoped-actions {
      justify-content: end;
    }
  }
</style>
