---
import PrefillNavButton from "#src/components/PrefillNavButton.astro";
import { USA_STATE_PATHS } from "#src/lib/geo/us-state-paths.js";

type StateStat = {
  code: string;
  count: number;
  href?: string;
  hoverLabel?: string;
};

type FederalPanelItem = {
  badgeText?: string;
  href?: string;
  label: string;
};

type FederalPanel = {
  actionHref?: string;
  actionLabel?: string;
  description?: string;
  eyebrow?: string;
  items?: FederalPanelItem[];
  title: string;
  value?: number | string;
};

type HeaderAction = {
  href: string;
  label: string;
  prefillPayload?: Record<string, unknown> | string;
  target?: string;
};

const {
  stats = [],
  title = "United States",
  subtitle = "",
  emptyLabel = "No data yet",
  interactionLabel = "Click a state to drill down.",
  federalPanel,
  headerAction,
} = Astro.props as {
  stats: StateStat[];
  title?: string;
  subtitle?: string;
  emptyLabel?: string;
  interactionLabel?: string;
  federalPanel?: FederalPanel;
  headerAction?: HeaderAction;
};

const byCode = new Map(stats.map((entry) => [entry.code.toLowerCase(), entry]));

const maxCount = Math.max(0, ...stats.map((entry) => Number(entry.count || 0)));
const EMPTY_STATE_FILL = "#f8f9fa";
const SMALL_STATE_CHIPS = [
  { id: "ma", code: "MA", name: "Massachusetts" },
  { id: "ct", code: "CT", name: "Connecticut" },
  { id: "ri", code: "RI", name: "Rhode Island" },
  { id: "nj", code: "NJ", name: "New Jersey" },
  { id: "de", code: "DE", name: "Delaware" },
  { id: "md", code: "MD", name: "Maryland" },
  { id: "dc", code: "DC", name: "District of Columbia" },
] as const;
const SMALL_STATE_GUTTER_X = 1236;
const SMALL_STATE_GUTTER_Y = 154;
const SMALL_STATE_GUTTER_WIDTH = 74;
const SMALL_STATE_GUTTER_HEIGHT = 30;
const SMALL_STATE_GUTTER_GAP = 10;

const getFill = (count: number) => {
  if (!count) {
    return EMPTY_STATE_FILL;
  }
  if (!maxCount) {
    return "rgba(21, 21, 21, 0.250)";
  }
  // Use log scale for better visibility of small counts
  const logCount = Math.log10(count + 1);
  const logMax = Math.log10(maxCount + 1);
  const intensity = Math.min(1, logCount / logMax);
  // Minimum alpha of 0.25 for any state with data
  const alpha = 0.25 + intensity * 0.35;
  return `rgba(21, 21, 21, ${alpha.toFixed(3)})`;
};

const getStateDisplay = (stateId: string, stateLabel: string) => {
  const stat = byCode.get(stateId.toLowerCase()) || {
    code: stateId,
    count: 0,
  };
  const href = stat.href;
  const count = Number(stat.count || 0);
  const fill = getFill(count);
  const isInteractive = Boolean(href);
  const label =
    stat.hoverLabel || (count ? `${stateLabel}: ${count}` : stateLabel);

  return {
    count,
    fill,
    href,
    isInteractive,
    label,
  };
};
---

<div class="row g-4 align-items-stretch" data-usa-map-card>
  <div class:list={["col-12", federalPanel ? "col-lg-8" : null]}>
    <div class="card shadow-sm border-0 rounded-0 h-100">
      <div class="card-body d-flex flex-column gap-3">
        <div
          class="d-flex flex-column flex-lg-row gap-3 justify-content-between"
        >
          <div>
            <p class="text-uppercase small text-muted mb-1">{title}</p>
            <h2 class="h5 mb-1">Coverage map</h2>
            {subtitle ? <p class="text-muted small mb-0">{subtitle}</p> : null}
          </div>
          {
            headerAction ? (
              <div class="d-flex justify-content-lg-end align-items-start">
                {headerAction.prefillPayload ? (
                  <PrefillNavButton
                    class="btn btn-outline-dark rounded-0"
                    to={headerAction.href}
                    payload={headerAction.prefillPayload}
                    data-map-link-type="header_action"
                    data-map-label={headerAction.label}
                  >
                    {headerAction.label}
                  </PrefillNavButton>
                ) : (
                  <a
                    class="btn btn-outline-dark rounded-0"
                    href={headerAction.href}
                    target={headerAction.target || "_self"}
                    data-map-link-type="header_action"
                    data-map-label={headerAction.label}
                  >
                    {headerAction.label}
                  </a>
                )}
              </div>
            ) : null
          }
        </div>
        <div class="map-wrap" data-usa-map>
          <svg viewBox="192 9 1138 746" class="usa-map">
            <title>{title} coverage map</title>
            <desc>{interactionLabel || "Interactive state map."}</desc>
            {
              USA_STATE_PATHS.map((state) => {
                const { count, fill, href, isInteractive, label } =
                  getStateDisplay(state.id, state.label);
                const pathEl = (
                  <path
                    id={`state-${state.id}`}
                    data-role="map-state"
                    data-state-id={state.id}
                    d={state.d}
                    fill={fill}
                    stroke="#111"
                    stroke-width="1"
                    class:list={{
                      "has-data": Boolean(count),
                      "no-data": !count,
                      "is-interactive": isInteractive,
                    }}
                  >
                    <title>{label}</title>
                  </path>
                );
                return href ? (
                  <a
                    href={href}
                    aria-label={`View ${label}`}
                    data-map-label={state.label}
                    data-map-link-type="state"
                    data-state-count={String(count)}
                    data-state-id={state.id}
                  >
                    {pathEl}
                  </a>
                ) : (
                  pathEl
                );
              })
            }
            <g class="small-state-gutter" aria-hidden="true">
              <text
                x={SMALL_STATE_GUTTER_X}
                y={SMALL_STATE_GUTTER_Y - 18}
                class="small-state-gutter-label"
              >
                Small states
              </text>
            </g>
            {
              SMALL_STATE_CHIPS.map((chip, index) => {
                const { fill, href, label } = getStateDisplay(
                  chip.id,
                  chip.name,
                );
                const y =
                  SMALL_STATE_GUTTER_Y +
                  index * (SMALL_STATE_GUTTER_HEIGHT + SMALL_STATE_GUTTER_GAP);
                const pillEl = (
                  <g
                    class="small-state-pill"
                    data-role="small-state-pill"
                    data-state-id={chip.id}
                  >
                    <rect
                      x={SMALL_STATE_GUTTER_X}
                      y={y}
                      width={SMALL_STATE_GUTTER_WIDTH}
                      height={SMALL_STATE_GUTTER_HEIGHT}
                      rx="15"
                      fill={fill}
                      class="small-state-pill-rect"
                    />
                    <text
                      x={SMALL_STATE_GUTTER_X + SMALL_STATE_GUTTER_WIDTH / 2}
                      y={y + 19}
                      text-anchor="middle"
                      class="small-state-pill-code"
                    >
                      {chip.code}
                    </text>
                    <title>{label}</title>
                  </g>
                );

                return href ? (
                  <a
                    href={href}
                    aria-label={`View ${label}`}
                    data-map-label={chip.name}
                    data-map-link-type="state"
                    data-state-count={String(
                      byCode.get(chip.id.toLowerCase())?.count || 0,
                    )}
                    data-state-id={chip.id}
                  >
                    {pillEl}
                  </a>
                ) : (
                  pillEl
                );
              })
            }
          </svg>
        </div>
        <div class="d-flex align-items-center text-muted small gap-2">
          <span class="legend-swatch"></span>
          <span>{emptyLabel}</span>
          {
            interactionLabel ? (
              <span class="ms-auto">{interactionLabel}</span>
            ) : null
          }
        </div>
      </div>
    </div>
  </div>
  {
    federalPanel ? (
      <div class="col-12 col-lg-4">
        <div class="card shadow-sm rounded-0 border-dark h-100">
          <div class="card-body d-flex flex-column gap-3">
            <div class="d-flex align-items-center justify-content-between gap-3">
              <div>
                {federalPanel.eyebrow ? (
                  <p class="text-uppercase small text-muted mb-1">
                    {federalPanel.eyebrow}
                  </p>
                ) : null}
                <h2 class="h5 mb-0">{federalPanel.title}</h2>
              </div>
              {federalPanel.value !== undefined ? (
                <span class="badge bg-dark rounded-pill">
                  {federalPanel.value}
                </span>
              ) : null}
            </div>
            {federalPanel.description ? (
              <p class="text-muted small mb-0">{federalPanel.description}</p>
            ) : null}
            {federalPanel.items && federalPanel.items.length > 0 ? (
              <ul class="list-unstyled d-flex flex-column gap-2 mb-0">
                {federalPanel.items.map((item) => (
                  <li class="d-flex align-items-start justify-content-between gap-2">
                    {item.href ? (
                      <a
                        class="text-decoration-none fw-semibold"
                        href={item.href}
                        data-map-label={item.label}
                        data-map-link-type="federal_item"
                      >
                        {item.label}
                      </a>
                    ) : (
                      <span class="fw-semibold">{item.label}</span>
                    )}
                    {item.badgeText ? (
                      <span class="badge bg-light text-dark border rounded-pill">
                        {item.badgeText}
                      </span>
                    ) : null}
                  </li>
                ))}
              </ul>
            ) : null}
            {federalPanel.actionHref && federalPanel.actionLabel ? (
              <div class="mt-auto">
                <a
                  class="btn btn-outline-dark rounded-0 w-100"
                  href={federalPanel.actionHref}
                  data-map-label={federalPanel.actionLabel}
                  data-map-link-type="federal_action"
                >
                  {federalPanel.actionLabel}
                </a>
              </div>
            ) : null}
          </div>
        </div>
      </div>
    ) : null
  }
</div>

<style>
  .map-wrap {
    width: 100%;
    background: #f8f9fa;
    border: 1px solid #dee2e6;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: inset 0 1px 0 rgba(0, 0, 0, 0.04);
  }

  .usa-map {
    display: block;
    width: 100%;
    height: auto;
  }

  .usa-map path {
    cursor: default;
    transition:
      transform 120ms ease,
      fill 160ms ease,
      stroke 160ms ease;
  }

  .usa-map path.is-interactive {
    cursor: pointer;
  }

  .usa-map a,
  .usa-map a path {
    cursor: pointer;
  }

  .usa-map path.is-interactive:hover,
  .usa-map path.is-interactive:focus-visible {
    transform: translateY(-1px);
    stroke-width: 2;
  }

  .usa-map path.is-linked-active {
    transform: translateY(-1px);
    stroke: #000;
    stroke-width: 6;
    filter: drop-shadow(0 0 6px rgba(17, 17, 17, 0.35));
  }

  a {
    color: inherit;
  }

  .usa-map .small-state-gutter-label {
    fill: #6c757d;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .usa-map .small-state-pill {
    cursor: default;
    transition: transform 120ms ease;
  }

  .usa-map .small-state-pill-rect {
    stroke: rgba(17, 17, 17, 0.72);
    stroke-width: 1;
  }

  .usa-map .small-state-pill-code {
    fill: #111;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.05em;
    pointer-events: none;
  }

  .usa-map a .small-state-pill,
  .usa-map a .small-state-pill rect {
    cursor: pointer;
  }

  .usa-map a .small-state-pill:hover,
  .usa-map a .small-state-pill:focus-visible {
    transform: translateY(-1px);
  }

  .usa-map a .small-state-pill:hover .small-state-pill-rect,
  .usa-map a .small-state-pill:focus-visible .small-state-pill-rect,
  .usa-map .small-state-pill.is-linked-active .small-state-pill-rect {
    stroke-width: 2;
  }

  .usa-map .small-state-pill.is-linked-active {
    transform: translateY(-1px);
    filter: drop-shadow(0 0 8px rgba(17, 17, 17, 0.28));
  }

  .usa-map .small-state-pill.is-linked-active .small-state-pill-rect {
    stroke: #000;
    stroke-width: 2;
  }

  .usa-map .small-state-pill.is-linked-active .small-state-pill-code {
    fill: #000;
  }

  .state-tiles-wrap {
    overflow-x: auto;
  }

  .state-tiles {
    display: grid;
    grid-template-columns: repeat(11, minmax(2.2rem, 1fr));
    grid-auto-rows: minmax(2.6rem, auto);
    gap: 0.45rem;
    min-width: 420px;
    padding: 0.75rem;
    border: 1px solid var(--bs-border-color);
    border-radius: 8px;
    background: #fff;
  }

  .state-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--bs-border-color);
    text-decoration: none;
    text-align: center;
    color: #111;
    font-size: 0.75rem;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    min-height: 2.6rem;
  }

  .state-tile.is-empty {
    color: var(--bs-gray-600);
  }

  .state-tile .tile-code {
    font-size: 0.6rem;
  }

  .state-tile .tile-count {
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: none;
  }

  .state-tile.is-interactive:hover,
  .state-tile.is-interactive:focus-visible {
    outline: 2px solid rgba(0, 0, 0, 0.2);
    outline-offset: 1px;
  }

  .legend-swatch {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    border: 1px solid #dee2e6;
    background: #f8f9fa;
  }
</style>

<script>
  (() => {
    const cardRoots = document.querySelectorAll("[data-usa-map-card]");

    for (const cardRoot of cardRoots) {
      const mapRoot = cardRoot.querySelector("[data-usa-map]");
      if (!(mapRoot instanceof HTMLElement)) {
        continue;
      }

      let activeStateId = "";

      const applyActiveState = (stateId) => {
        if (activeStateId === stateId) {
          return;
        }

        if (activeStateId) {
          mapRoot
            .querySelectorAll(`[data-state-id="${activeStateId}"]`)
            .forEach((node) => node.classList.remove("is-linked-active"));
        }

        activeStateId = stateId;

        if (!activeStateId) {
          return;
        }

        mapRoot
          .querySelectorAll(`[data-state-id="${activeStateId}"]`)
          .forEach((node) => node.classList.add("is-linked-active"));
      };

      const clearActiveState = () => {
        if (!activeStateId) {
          return;
        }
        mapRoot
          .querySelectorAll(`[data-state-id="${activeStateId}"]`)
          .forEach((node) => node.classList.remove("is-linked-active"));
        activeStateId = "";
      };

      mapRoot.addEventListener("pointerover", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) {
          return;
        }
        const stateNode = target.closest("[data-state-id]");
        if (!(stateNode instanceof Element) || !mapRoot.contains(stateNode)) {
          return;
        }
        const stateId = stateNode.getAttribute("data-state-id");
        if (stateId) {
          applyActiveState(stateId);
        }
      });

      mapRoot.addEventListener("pointerleave", () => {
        clearActiveState();
      });

      mapRoot.addEventListener("focusin", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) {
          return;
        }
        const stateNode = target.closest("[data-state-id]");
        if (!(stateNode instanceof Element) || !mapRoot.contains(stateNode)) {
          return;
        }
        const stateId = stateNode.getAttribute("data-state-id");
        if (stateId) {
          applyActiveState(stateId);
        }
      });

      mapRoot.addEventListener("focusout", () => {
        requestAnimationFrame(() => {
          const activeElement = document.activeElement;
          if (
            activeElement instanceof Element &&
            mapRoot.contains(activeElement)
          ) {
            const stateNode = activeElement.closest("[data-state-id]");
            if (stateNode instanceof Element) {
              const stateId = stateNode.getAttribute("data-state-id");
              if (stateId) {
                applyActiveState(stateId);
                return;
              }
            }
          }
          clearActiveState();
        });
      });
    }
  })();
</script>
