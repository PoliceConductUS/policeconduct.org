---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import EntityActionButton from "#src/components/EntityActionButton.astro";
import EntityPageHeader from "#src/components/EntityPageHeader.astro";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import type { CivicIndexModel } from "#src/lib/data/civic-index.js";
import { buildWebPage, getSiteUrl } from "#src/lib/structured-data.js";

const { model, site } = Astro.props as {
  model: CivicIndexModel;
  site: URL | undefined;
};

const siteUrl = getSiteUrl(site);
const pageUrl = new URL(model.pagePath, siteUrl).toString();
const structuredData = buildWebPage({
  siteUrl,
  pageUrl,
  name: model.title,
  description: model.description,
  type: "CollectionPage",
});

const heading =
  model.breadcrumbs[model.breadcrumbs.length - 1]?.label ||
  model.jurisdictionLabel;
const scopedHref = (slug: string) => `${model.pagePath}${slug}/`;
const formatCount = (value: number) => value.toLocaleString("en-US");
const coverageCount = (key: string) =>
  model.coverage.find((metric) => metric.key === key)?.value ?? 0;
const updatedLabel = "Updated May 2026";

const childMetric =
  model.level === "state"
    ? {
        className: "counties",
        detail: `County and regional pages available under the ${heading} index.`,
        href: scopedHref("counties"),
        icon: "map",
        label: "Counties",
        value: formatCount(model.rows.length),
        action: "Explore counties",
      }
    : model.level === "administrative_area"
      ? {
          className: "places",
          detail: `Place pages available under the ${heading} index.`,
          href: scopedHref("places"),
          icon: "pin",
          label: "Places",
          value: formatCount(model.rows.length),
          action: "Explore places",
        }
      : {
          className: "agencies",
          detail: `Agency pages available under the ${heading} index.`,
          href: scopedHref("agencies"),
          icon: "building",
          label: "Agencies",
          value: formatCount(coverageCount("agencies")),
          action: "Explore agencies",
        };

const linkIfExists = (slug: string) => {
  const available = new Set([
    "budget",
    "civil-cases",
    "fatal-force-incidents",
    "liability-costs",
    "outcomes-by-income",
    "reports",
  ]);
  return available.has(slug) ? scopedHref(slug) : null;
};

type TopMetric = {
  action?: string;
  className: string;
  defaultAction?: boolean;
  detail: string;
  href: string | null;
  icon: string;
  label: string;
  updated?: string;
  value: string;
};

const topMetrics: TopMetric[] = [
  {
    ...childMetric,
    defaultAction: true,
  },
  {
    className: "reports",
    detail: `Published public reports connected to ${heading} records in the past 12 months.`,
    href: linkIfExists("reports"),
    icon: "file",
    label: "Reports",
    updated: updatedLabel,
    value: formatCount(coverageCount("reports")),
  },
  {
    className: "budget",
    detail:
      "Current fiscal-year budget, revenue, overtime, and related finance records.",
    href: linkIfExists("budget"),
    icon: "dollar",
    label: "Budget",
    value: "$--",
  },
  {
    className: "cases",
    detail:
      model.level === "state"
