        : `Total civil case records connected to ${heading}.`,
    href: linkIfExists("civil-cases"),
    icon: "scales",
    label: "Civil cases",
    updated: updatedLabel,
    value: formatCount(coverageCount("civil_cases")),
  },
  {
    className: "liability",
    detail:
      "Claims, settlements, judgments, defense costs, and related payments from the past 5 years.",
    href: linkIfExists("liability-costs"),
    icon: "weight",
    label: "Liability costs",
    value: "$--",
  },
  {
    className: "fatal",
    detail:
      "Fatal force, custody deaths, pursuit deaths, and other police-contact deaths from the past 5 years.",
    href: linkIfExists("fatal-force-incidents"),
    icon: "fatal",
    label: "Fatal Force Incidents",
    updated: updatedLabel,
    value: "0",
  },
];

type BarRow = {
  label: string;
  value: string;
  width: number;
};

type Chart =
  | { kind: "bars"; color?: "blue" | "green" | "purple" | "red" }
  | {
      kind: "stacked";
      legend: string[];
      rows: { label: string; a: number; b: number; c: number }[];
    }
  | { kind: "barRows"; rows: BarRow[] }
  | {
      kind: "grouped";
      legend: string[];
      groups: { label: string; day: number; night: number }[];
    }
  | {
      kind: "countSummary";
      items: { label: string; value: string }[];
    };

type Panel = {
  aria: string;
  chart: Chart;
  description: string;
  href?: string | null;
  meta?: string[];
  title: string;
};

