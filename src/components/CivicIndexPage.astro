---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import DataPanel from "#src/components/DataPanel.astro";
import EntityActionButton from "#src/components/EntityActionButton.astro";
import EntityPageHeader from "#src/components/EntityPageHeader.astro";
import MetricGrid from "#src/components/MetricGrid.astro";
import OutcomesByIncomePanel from "#src/components/OutcomesByIncomePanel.astro";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import type { CivicIndexModel } from "#src/lib/data/civic-index.js";
import { metricVisuals } from "#src/lib/metric-vocabulary.js";
import { buildWebPage, getSiteUrl } from "#src/lib/structured-data.js";

const { model, site } = Astro.props as {
  model: CivicIndexModel;
  site: URL | undefined;
};

const siteUrl = getSiteUrl(site);
const pageUrl = new URL(model.pagePath, siteUrl).toString();
const structuredData = buildWebPage({
  siteUrl,
  pageUrl,
  name: model.title,
  description: model.description,
  type: "CollectionPage",
});
const heading =
  model.breadcrumbs[model.breadcrumbs.length - 1]?.label ||
  model.jurisdictionLabel;
const scopedHref = (slug: string) => `${model.pagePath}${slug}/`;
const coverageCount = (key: string) =>
  model.coverage.find((metric) => metric.key === key)?.value ?? 0;
const formatCount = (value: number) => value.toLocaleString("en-US");
const childMetric =
  model.level === "state"
    ? {
        action: {
          href: scopedHref("counties"),
          kind: "button",
          label: "Explore counties",
        },
        detail: `${model.indexLabel}`,
        icon: metricVisuals.counties.icon,
        label: "Counties",
        value: formatCount(model.rows.length),
      }
    : model.level === "administrative_area"
      ? {
          action: {
            href: scopedHref("places"),
            kind: "button",
            label: "Explore places",
          },
          detail: `${model.indexLabel}`,
          icon: metricVisuals.places.icon,
          label: "Places",
          value: formatCount(model.rows.length),
        }
      : {
          action: {
            href: scopedHref("agencies"),
            kind: "button",
            label: "Explore agencies",
          },
          detail: "Agencies operating in this place",
          icon: metricVisuals.agencies.icon,
          label: metricVisuals.agencies.label,
          value: formatCount(coverageCount("agencies")),
        };
const metricCards = [
  {
    accent:
      model.level === "state"
        ? metricVisuals.counties.accent
        : model.level === "administrative_area"
          ? metricVisuals.places.accent
          : metricVisuals.agencies.accent,
    ...childMetric,
  },
  {
    accent: metricVisuals.reports.accent,
    action: {
      href: scopedHref("reports"),
      kind: "link",
      label: "View details",
    },
    detail: "Published public reports",
    icon: metricVisuals.reports.icon,
    label: metricVisuals.reports.label,
    value: formatCount(coverageCount("reports")),
  },
  {
    accent: metricVisuals.budget.accent,
    action: {
      href: scopedHref("budget"),
      kind: "link",
      label: "View details",
    },
    detail: "Fiscal year agency budget",
    icon: metricVisuals.budget.icon,
    label: metricVisuals.budget.label,
    value: "$--",
  },
  {
    accent: metricVisuals.civilCases.accent,
    action: {
      href: scopedHref("civil-cases"),
      kind: "link",
      label: "View details",
    },
    detail: "Direct and personnel-linked civil cases",
    icon: metricVisuals.civilCases.icon,
    label: metricVisuals.civilCases.label,
    value: formatCount(coverageCount("civil_cases")),
  },
  {
    accent: metricVisuals.liabilityCosts.accent,
    action: {
      href: scopedHref("liability-costs"),
      kind: "link",
      label: "View details",
    },
    detail: "Claims, settlements, judgments, and related costs",
    icon: metricVisuals.liabilityCosts.icon,
    label: metricVisuals.liabilityCosts.label,
    value: "$--",
  },
];
const chartCards = [
  ["Arrests Over Time", "Number of arrests by category"],
  ["Killings Over Time", "People by age group, dogs and other animals"],
  ["Use of Force Over Time", "Number of use of force incidents"],
  [
    "Civil Cases and Liability Costs Over Time",
    "Civil cases and liability costs",
  ],
];

type DecertificationColumn = {
  key: string;
  label: string;
  sourceKeys?: string[];
  status: "missing" | "present" | "unknown";
};

type DecertificationPayload = {
  columns: DecertificationColumn[];
  methodology?: string;
  note?: string;
  tier?: string;
};

const assertString = (value: unknown, field: string, reportId: string) => {
  if (typeof value !== "string" || !value.trim()) {
    throw new Error(`Location report ${reportId} has invalid ${field}.`);
  }
  return value;
};

const assertSourceUrl = (value: string, sourceId: string, reportId: string) => {
  let parsed: URL;
  try {
    parsed = new URL(value);
  } catch {
    throw new Error(
      `Location report ${reportId} source ${sourceId} has invalid url.`,
    );
  }
  if (!["http:", "https:"].includes(parsed.protocol)) {
    throw new Error(
      `Location report ${reportId} source ${sourceId} url must be http or https.`,
    );
  }
};

const assertDecertificationPayload = (
  report: CivicIndexModel["locationReports"][number],
): DecertificationPayload => {
  if (report.reportType !== "decertification_report_card") {
    throw new Error(`Unsupported location report type: ${report.reportType}`);
  }
  if (!report.sources.length) {
    throw new Error(`Location report ${report.id} must include sources.`);
  }
  for (const source of report.sources) {
    assertString(source.id, "source.id", report.id);
    assertString(source.sourceKey, `source ${source.id} sourceKey`, report.id);
    assertString(source.label, `source ${source.id} label`, report.id);
    assertString(source.url, `source ${source.id} url`, report.id);
    assertSourceUrl(source.url, source.id, report.id);
    if (!["law", "methodology", "pdf", "web"].includes(source.sourceType)) {
      throw new Error(
        `Location report ${report.id} source ${source.id} has invalid sourceType ${source.sourceType}.`,
      );
    }
  }

  const payload = report.payload as Record<string, unknown>;
  const methodology = assertString(
    payload.methodology,
    "methodology",
    report.id,
  );
  const tier = assertString(payload.tier, "tier", report.id);
  const note = assertString(payload.note, "note", report.id);
  const columns = payload.columns;
  if (!Array.isArray(columns) || !columns.length) {
    throw new Error(`Location report ${report.id} is missing columns.`);
  }

  const sourceKeys = new Set(report.sources.map((source) => source.sourceKey));
  const validatedColumns = columns.map((rawColumn, index) => {
    if (!rawColumn || typeof rawColumn !== "object") {
      throw new Error(
        `Location report ${report.id} column ${index + 1} must be an object.`,
      );
    }
    const column = rawColumn as Record<string, unknown>;
    const key = assertString(column.key, `columns[${index}].key`, report.id);
    const label = assertString(
      column.label,
      `columns[${index}].label`,
      report.id,
    );
    const status = assertString(
      column.status,
      `columns[${index}].status`,
      report.id,
    );
    if (!["present", "missing", "unknown"].includes(status)) {
      throw new Error(
        `Location report ${report.id} column ${key} has invalid status ${status}.`,
      );
    }
    if (!Array.isArray(column.sourceKeys) || !column.sourceKeys.length) {
      throw new Error(
        `Location report ${report.id} column ${key} must include sourceKeys.`,
      );
    }
    const columnSourceKeys = column.sourceKeys.map((sourceKey, sourceIndex) =>
      assertString(
        sourceKey,
        `columns[${index}].sourceKeys[${sourceIndex}]`,
        report.id,
      ),
    );
    for (const sourceKey of columnSourceKeys) {
      if (!sourceKeys.has(sourceKey)) {
        throw new Error(
          `Location report ${report.id} column ${key} references missing source ${sourceKey}.`,
        );
      }
    }
    return {
      key,
      label,
      sourceKeys: columnSourceKeys,
      status: status as DecertificationColumn["status"],
    };
  });

  return {
    columns: validatedColumns,
    methodology,
    note,
    tier,
  };
};

const statusLabel = (status: DecertificationColumn["status"]) =>
  status === "present" ? "Check" : status === "missing" ? "X" : "?";

const statusSymbol = (status: DecertificationColumn["status"]) =>
  status === "present" ? "✓" : status === "missing" ? "X" : "?";

const sourceForColumn = (
  report: CivicIndexModel["locationReports"][number],
  column: DecertificationColumn,
) => {
  const sourceKey = column.sourceKeys?.[0];
  return sourceKey
    ? report.sources.find((source) => source.sourceKey === sourceKey) || null
    : null;
};
---

<SiteLayout
  title={model.title}
  description={model.description}
  pagePath={model.pagePath}
  structuredData={structuredData}
>
  <main class="civic-dashboard">
    <section class="civic-dashboard-main">
      <div class="container">
        <Breadcrumbs items={model.breadcrumbs} className="mb-2" />
        <EntityPageHeader title={heading} description={model.description}>
          <Fragment slot="actions">
            <EntityActionButton data-civic-share>Share</EntityActionButton>
            <EntityActionButton
              className="entity-action-primary"
              data-civic-download
            >
              Download Report
            </EntityActionButton>
            <span data-civic-coming-soon></span>
          </Fragment>
        </EntityPageHeader>

        <MetricGrid metrics={metricCards} columns="auto" />

        <div class="entity-chart-grid">
          <OutcomesByIncomePanel href={scopedHref("outcomes-by-income")} />
          {
            chartCards.map(([title, description]) => (
              <DataPanel title={title} description={description}>
                <div class="entity-empty-line-chart" aria-hidden="true" />
              </DataPanel>
            ))
          }

          <DataPanel
            title="Racial Breakdown of Stops or Arrests"
            description="Who is most affected in the current dataset"
          >
            <table class="civic-mini-table">
              <thead>
                <tr>
                  <th scope="col">Race / Ethnicity</th>
                  <th scope="col">Stops %</th>
                  <th scope="col">Arrests %</th>
                </tr>
              </thead>
              <tbody>
                {
                  [
                    "White",
                    "Black or African American",
                    "Hispanic or Latino",
                    "Asian",
                    "Other / Unknown",
                  ].map((label) => (
                    <tr>
                      <th scope="row">{label}</th>
                      <td />
                      <td />
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </DataPanel>

          <DataPanel
            title="Daylight vs Nighttime Stops"
            description="Comparison of stops by time of day and race"
          >
            <div class="civic-empty-bars" aria-hidden="true">
              {
                [
                  "White",
                  "Black or African American",
                  "Hispanic or Latino",
                  "Other / Unknown",
                ].map((label) => <span>{label}</span>)
              }
            </div>
          </DataPanel>

          <DataPanel
            title="Top Charge Categories"
            description="Most common reasons for arrest"
          >
            <div class="civic-horizontal-bars">
              {
                [
                  "Traffic Offenses",
                  "Theft",
                  "Assault",
                  "Possession",
                  "DWI",
                ].map((label) => (
                  <div>
                    <span>{label}</span>
                    <i>
                      <b style="width: 0%" />
                    </i>
                    <strong />
                  </div>
                ))
              }
            </div>
          </DataPanel>

          <DataPanel
            title="Budget and Overtime Trend"
            description="Total budget and overtime spending"
          >
            <div class="entity-empty-line-chart" aria-hidden="true"></div>
          </DataPanel>
        </div>
      </div>
    </section>

    {
      model.locationReports.length ? (
        <section class="civic-policy-context">
          <div class="container">
            {model.locationReports.map((report) => {
              const payload = assertDecertificationPayload(report);
              return (
                <article class="civic-location-report">
                  <h2>{report.title}</h2>
                  <p>{report.summary}</p>
                  {payload.tier ? (
                    <p class="civic-policy-context-note">{payload.tier}</p>
                  ) : null}
                  <div class="civic-report-card-table-wrap">
                    <table class="civic-report-card-table">
                      <thead>
                        <tr>
                          {payload.columns.map((column) => (
                            <th scope="col">{column.label}</th>
                          ))}
                        </tr>
                      </thead>
                      <tbody>
                        <tr>
                          {payload.columns.map((column) => {
                            const source = sourceForColumn(report, column);
                            const result = (
                              <span
                                class:list={[
                                  "civic-report-status",
                                  `civic-report-status-${column.status}`,
                                ]}
                                aria-label={statusLabel(column.status)}
                              >
                                {statusSymbol(column.status)}
                              </span>
                            );
                            return (
                              <td>
                                {source ? (
                                  <a href={source.url} title={source.label}>
                                    {result}
                                  </a>
                                ) : (
                                  result
                                )}
                              </td>
                            );
                          })}
                        </tr>
                      </tbody>
                    </table>
                  </div>
                  {payload.note ? (
                    <p class="civic-policy-context-note">{payload.note}</p>
                  ) : null}
                  {report.sources.length ? (
                    <p class="civic-policy-sources">
                      Sources:{" "}
                      {report.sources.map((source, index) => (
                        <>
                          {index > 0 ? ", " : ""}
                          <a href={source.url}>{source.label}</a>
                        </>
                      ))}
                    </p>
                  ) : null}
                </article>
              );
            })}
          </div>
        </section>
      ) : null
    }
  </main>
</SiteLayout>

<script is:inline>
  (() => {
    const setSoon = (button, message) => {
      const output = button
        .closest(".civic-dashboard-actions")
        ?.querySelector("[data-civic-coming-soon]");
      if (output) output.textContent = message;
    };

    document.querySelectorAll("[data-civic-share]").forEach((button) => {
      button.addEventListener("click", () =>
        setSoon(button, "Sharing tools are coming soon."),
      );
    });

    document.querySelectorAll("[data-civic-download]").forEach((button) => {
      button.addEventListener("click", () =>
        setSoon(button, "Downloadable reports are coming soon."),
      );
    });
  })();
</script>

<style>
  .civic-dashboard {
    background: #fbfcff;
    color: #071842;
  }

  .civic-dashboard-main {
    padding: 1.35rem 0 2rem;
  }

  .civic-dashboard-main > .container,
  .civic-policy-context > .container {
    max-width: 1240px;
  }

  .civic-dashboard-heading {
    align-items: start;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: minmax(0, 1fr);
    margin-bottom: 1rem;
  }

  .civic-dashboard-heading h1 {
    color: #071842;
    margin: 0 0 0.45rem;
  }

  .civic-dashboard-heading p {
    color: #33456f;
    line-height: 1.55;
    margin: 0;
    max-width: 72ch;
  }

  .civic-dashboard-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: start;
  }

  .civic-dashboard-actions button {
    background: #fbfcff;
    border: 1px solid #c9d4e6;
    border-radius: 0.4rem;
    color: #071842;
    font-size: 0.88rem;
    font-weight: 700;
    min-height: 3rem;
    padding: 0.72rem 1.05rem;
  }

  .civic-dashboard-actions .civic-dashboard-primary {
    background: #071842;
    border-color: #071842;
    color: #f8faff;
  }

  .civic-dashboard-actions span {
    color: #33456f;
    flex-basis: 100%;
    font-size: 0.82rem;
    font-weight: 700;
    min-height: 1.15rem;
    text-align: right;
  }

  .civic-policy-context h2 {
    color: #071842;
    margin: 0 0 0.25rem;
  }

  .civic-policy-context h3 {
    color: #071842;
    font-size: 0.95rem;
    margin: 0 0 0.65rem;
  }

  .civic-location-report + .civic-location-report {
    border-top: 1px solid #d9e1ee;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
  }

  .civic-report-card-table-wrap {
    margin-top: 1rem;
    overflow-x: auto;
  }

  .civic-report-card-table {
    border-collapse: collapse;
    min-width: 58rem;
    table-layout: fixed;
    width: 100%;
  }

  .civic-report-card-table th,
  .civic-report-card-table td {
    border: 1px solid #d9e1ee;
    color: #071842;
    font-size: 0.75rem;
    line-height: 1.18;
    padding: 0.65rem 0.5rem;
    text-align: center;
    vertical-align: middle;
  }

  .civic-report-card-table th {
    background: #f4f7fb;
    font-weight: 800;
  }

  .civic-report-card-table a {
    color: inherit;
    display: inline-flex;
    text-decoration: none;
  }

  .civic-report-status {
    align-items: center;
    border-radius: 999px;
    display: inline-flex;
    font-size: 1.35rem;
    font-weight: 900;
    height: 2rem;
    justify-content: center;
    line-height: 1;
    width: 2rem;
  }

  .civic-report-status-present {
    color: #087f3b;
  }

  .civic-report-status-missing {
    color: #b0352b;
  }

  .civic-report-status-unknown {
    color: #6d7890;
  }

  .civic-policy-context-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(0, 1fr);
    margin-top: 1rem;
  }

  .civic-policy-context-grid > div {
    border: 1px solid #d9e1ee;
    border-radius: 0.4rem;
    padding: 1rem;
  }

  .civic-policy-context ul {
    color: #33456f;
    display: grid;
    gap: 0.45rem;
    margin: 0;
    padding-left: 1.1rem;
  }

  .civic-mini-table {
    border-collapse: collapse;
    margin-top: 0.85rem;
    width: 100%;
  }

  .civic-mini-table th,
  .civic-mini-table td {
    border-top: 1px solid #d9e1ee;
    color: #071842;
    font-size: 0.8125rem;
    padding: 0.5rem 0.4rem;
    text-align: left;
    vertical-align: top;
  }

  .civic-empty-bars {
    align-items: end;
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    height: 10rem;
    margin-top: 1rem;
  }

  .civic-empty-bars span {
    border-bottom: 1px solid #b8c4d8;
    color: #33456f;
    display: grid;
    font-size: 0.75rem;
    min-height: 100%;
    place-items: end center;
    text-align: center;
  }

  .civic-horizontal-bars {
    display: grid;
    gap: 0.65rem;
    margin-top: 1rem;
  }

  .civic-horizontal-bars div {
    align-items: center;
    display: grid;
    gap: 0.75rem;
    grid-template-columns: minmax(6rem, 0.8fr) minmax(7rem, 2fr) auto;
  }

  .civic-horizontal-bars span,
  .civic-horizontal-bars strong {
    color: #071842;
    font-size: 0.8125rem;
    font-weight: 700;
  }

  .civic-horizontal-bars i {
    background: #e7edf7;
    display: block;
    height: 0.78rem;
  }

  .civic-horizontal-bars b {
    background: #174bff;
    display: block;
    height: 100%;
  }

  .civic-policy-context {
    border-top: 1px solid #d5deeb;
    padding: 2rem 0;
  }

  .civic-policy-context p {
    color: #33456f;
    margin: 0.35rem 0 0;
  }

  .civic-policy-context .civic-policy-context-note {
    font-weight: 700;
    margin-top: 1rem;
  }

  .civic-policy-sources {
    font-size: 0.85rem;
    line-height: 1.55;
  }

  .civic-policy-sources a {
    color: #064cfb;
    font-weight: 700;
    text-decoration: none;
  }

  @media (min-width: 768px) {
    .civic-policy-context-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1200px) {
    .civic-dashboard-heading {
      grid-template-columns: minmax(0, 1fr) auto;
    }

    .civic-dashboard-actions {
      justify-content: end;
    }
  }

  @media (max-width: 991.98px) {
  }
</style>
