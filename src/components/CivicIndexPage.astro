                      <>
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z" />
                        <path d="M14 2v6h6" />
                        <path d="M8 13h8" />
                        <path d="M8 17h5" />
                      </>
                    ) : metric.icon === "dollar" ? (
                      <>
                        <circle cx="12" cy="12" r="10" />
                        <path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8" />
                        <path d="M12 6v12" />
                      </>
                    ) : metric.icon === "scales" ? (
                      <>
                        <path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z" />
                        <path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z" />
                        <path d="M7 21h10" />
                        <path d="M12 3v18" />
                      </>
                    ) : metric.icon === "weight" ? (
                      <>
                        <path d="M8 7a4 4 0 0 1 8 0" />
                        <path d="M6.5 7h11l2 13H4.5Z" />
                        <path d="M10 12h4" />
                      </>
                    ) : (
                      <>
                        <path d="M12 3v18" />
                        <path d="M5 10h14" />
                        <path d="M7 21h10" />
                        <path d="M8 3h8" />
                      </>
                    )}
                  </svg>
                  <div>
                    <p class="metric-label">{metric.label}</p>
                    <strong class="metric-value">{metric.value}</strong>
                  </div>
                </div>
                <p class="metric-detail">{metric.detail}</p>
                <div class="metric-actions">
                  {metric.defaultAction ? (
                    <a class="metric-action primary" href={metric.href}>
                      {metric.action}
                    </a>
                  ) : metric.href ? (
                    <a class="metric-action secondary" href={metric.href}>
                      View details
                    </a>
                  ) : null}
                </div>
                {metric.updated ? (
                  <div class="meta">
                    <span class="chip">{metric.updated}</span>
                  </div>
                ) : null}
              </article>
            ))
          }
        </section>

        <div class="page-layout">
          <div>
            {
              intentBands.map((band) => (
                <section class="intent-band" id={band.id}>
                  <header class="band-heading">
                    <div>
                      <h2>{band.title}</h2>
                      <p>{band.description}</p>
                    </div>
                  </header>

                  {band.policy ? (
                    <article class="policy-card">
                      <h3>{band.policy.title}</h3>
                      <p>{band.policy.description}</p>
                    </article>
                  ) : null}

                  {band.panels ? (
                    <div class="chart-grid">
                      {band.panels.map((panel) => (
                        <article class="panel">
                          <header>
                            <h3>{panel.title}</h3>
                            <p>{panel.description}</p>
                          </header>

                          {panel.chart.kind === "bars" ? (
                            <div class:list={["bars", panel.chart.color]}>
                              <i />
                              <i />
                              <i />
                              <i />
                              <i />
                              <i />
                              <i />
                              <i />
                            </div>
                          ) : panel.chart.kind === "stacked" ? (
                            <div
                              class="sample-chart disabled"
                              aria-label={panel.aria}
                            >
                              <div class="stacked-bars">
                                {panel.chart.rows.map((row) => (
                                  <div class="stacked-row">
                                    <span class="mini-label">{row.label}</span>
                                    <div
                                      style={`--a: ${row.a}%; --b: ${row.b}%; --c: ${row.c}%`}
                                    >
                                      <i />
                                      <i />
                                      <i />
                                    </div>
                                  </div>
                                ))}
                              </div>
                              <div class="mini-legend">
                                {panel.chart.legend.map((item) => (
                                  <span>
                                    <i />
                                    {item}
                                  </span>
                                ))}
                              </div>
                            </div>
                          ) : panel.chart.kind === "grouped" ? (
                            <div
                              class="sample-chart disabled"
                              aria-label={panel.aria}
                            >
                              <div class="grouped-bars">
                                {panel.chart.groups.map((group) => (
                                  <div class="group">
                                    <div class="columns">
                                      <i style={`height: ${group.day}%`} />
                                      <i style={`height: ${group.night}%`} />
                                    </div>
                                    <small>{group.label}</small>
                                  </div>
                                ))}
                              </div>
                              <div class="mini-legend">
                                {panel.chart.legend.map((item) => (
                                  <span>
                                    <i />
                                    {item}
                                  </span>
                                ))}
                              </div>
                            </div>
                          ) : panel.chart.kind === "countSummary" ? (
                            <div class="count-summary">
                              {panel.chart.items.map((item) => (
                                <div class="count-box">
                                  <strong>{item.value}</strong>
                                  <span>{item.label}</span>
                                </div>
                              ))}
                            </div>
                          ) : (
                            <div
                              class="sample-chart disabled"
                              aria-label={panel.aria}
                            >
                              {panel.chart.rows.map((row) => (
                                <div class="bar-row">
                                  <b>{row.label}</b>
                                  <div class="track">
                                    <span style={`--v: ${row.width}`} />
                                  </div>
                                  <em>{row.value}</em>
                                </div>
                              ))}
                              {panel.title === "Complaint outcomes, 5 years" ? (
                                <div class="mini-legend">
                                  <span>
                                    <i />
                                    Actions: discipline, training, coaching,
                                    mediation, rapid resolution
                                  </span>
                                </div>
                              ) : null}
                            </div>
                          )}

                          {panel.meta?.length || panel.href ? (
                            <div class="meta">
                              {panel.meta?.map((item) => (
                                <span class="chip">{item}</span>
                              ))}
                              {panel.href ? (
                                <a href={panel.href}>View details</a>
                              ) : null}
                            </div>
                          ) : null}
                        </article>
                      ))}
                    </div>
                  ) : null}
                </section>
              ))
            }

            {
              decertificationReport && decertificationPayload ? (
                <section class="bottom-context" aria-label="State context">
                  <article class="policy-card">
                    <h3>Decertification law context</h3>
                    <p class="report-source-line">
                      <span class="report-card-summary">
                        {decertificationPresentCount} of {decertificationTotal}{" "}
                        mechanisms present ({decertificationUnknownCount}{" "}
                        unknown). Updated Oct. 16, 2025.
                      </span>
                      {decertificationPayload.tier}
                      <a href={decertificationReport.sources[0]!.url}>
                        Report source
                      </a>
                    </p>
                    <div
                      class="report-matrix-wrap"
                      aria-label={`${heading} decertification report card statuses`}
                    >
                      <table class="report-matrix">
                        <thead>
                          <tr>
                            {decertificationPayload.columns.map((column) => (
                              <th scope="col">{column.label}</th>
                            ))}
                          </tr>
                        </thead>
                        <tbody>
                          <tr>
                            {decertificationPayload.columns.map((column) => {
                              const source = sourceForColumn(
                                decertificationReport,
                                column,
                              );
                              const result = (
                                <span
                                  class:list={["status-mark", column.status]}
                                >
                                  <strong
                                    aria-label={statusLabel(column.status)}
                                  >
                                    {statusSymbol(column.status)}
                                  </strong>
                                  {source ? (
                                    <a href={source.url}>
                                      {sourceFootnote(source.label)}
                                    </a>
                                  ) : null}
                                </span>
                              );
                              return <td>{result}</td>;
                            })}
                          </tr>
                        </tbody>
                      </table>
                    </div>
                  </article>
                </section>
              ) : null
            }
          </div>

          <aside>
            <nav class="intent-nav" aria-label="Page sections">
              <p class="menu-title">On this page</p>
              {
                intentBands.map((band) => (
                  <a href={`#${band.id}`}>{band.nav}</a>
                ))
              }
            </nav>
          </aside>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>

<script is:inline>
  (() => {
    const setStatus = (button, message) => {
      const output = button
        .closest(".entity-page-actions")
        ?.querySelector("[data-civic-action-status]");
      if (output) output.textContent = message;
    };

    document.querySelectorAll("[data-civic-share]").forEach((button) => {
      button.addEventListener("click", () =>
        setStatus(button, "Sharing tools are coming soon."),
      );
    });

    document.querySelectorAll("[data-civic-download]").forEach((button) => {
      button.addEventListener("click", () =>
        setStatus(button, "Downloadable reports are coming soon."),
      );
    });
  })();
</script>

