---
import MetricCardButton from "#src/components/MetricCardButton.astro";
import MetricCardLink from "#src/components/MetricCardLink.astro";
import type { MetricCardItem } from "#src/components/metric-card-types.js";

const { metric } = Astro.props as {
  metric: MetricCardItem;
};
const action = metric.action;
---

<article
  class:list={[
    "entity-metric-card",
    action?.kind === "button" && "entity-metric-card-with-primary-action",
  ]}
>
  <svg
    aria-hidden="true"
    class={`entity-metric-icon entity-metric-${metric.accent || "blue"}`}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    {
      metric.icon === "people" ? (
        <>
          <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
          <circle cx="9" cy="7" r="4" />
          <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
          <path d="M16 3.13a4 4 0 0 1 0 7.75" />
        </>
      ) : metric.icon === "dollar" ? (
        <>
          <circle cx="12" cy="12" r="10" />
          <path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8" />
          <path d="M12 6v12" />
        </>
      ) : metric.icon === "scales" ? (
        <>
          <path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z" />
          <path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z" />
          <path d="M7 21h10" />
          <path d="M12 3v18" />
          <path d="M3 7h2c2 0 5-1 7-4 2 3 5 4 7 4h2" />
        </>
      ) : metric.icon === "shield" ? (
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" />
      ) : metric.icon === "calendar" ? (
        <>
          <path d="M8 2v4" />
          <path d="M16 2v4" />
          <rect x="3" y="4" width="18" height="18" rx="2" />
          <path d="M3 10h18" />
        </>
      ) : metric.icon === "link" ? (
        <>
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
        </>
      ) : metric.icon === "person" ? (
        <>
          <path d="M20 21a8 8 0 0 0-16 0" />
          <circle cx="12" cy="7" r="4" />
        </>
      ) : metric.icon === "map" ? (
        <>
          <path d="M14.5 5.5 9.5 3 3 5.5v15l6.5-2.5 5 2.5 6.5-2.5v-15Z" />
          <path d="M9.5 3v15" />
          <path d="M14.5 5.5v15" />
        </>
      ) : metric.icon === "pin" ? (
        <>
          <path d="M20 10c0 5-8 12-8 12S4 15 4 10a8 8 0 1 1 16 0Z" />
          <circle cx="12" cy="10" r="3" />
        </>
      ) : metric.icon === "file" ? (
        <>
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z" />
          <path d="M14 2v6h6" />
          <path d="M8 13h8" />
          <path d="M8 17h5" />
        </>
      ) : metric.icon === "weight" ? (
        <>
          <path d="M8 7a4 4 0 0 1 8 0" />
          <path d="M6.5 7h11l2 13H4.5Z" />
          <path d="M10 12h4" />
        </>
      ) : metric.icon === "cross" ? (
        <>
          <path d="M12 3v18" />
          <path d="M5 10h14" />
          <path d="M7 21h10" />
          <path d="M8 3h8" />
        </>
      ) : (
        <>
          <path d="M3 21V7l9-4 9 4v14" />
          <path d="M9 21v-8h6v8" />
          <path d="M9 9h.01" />
          <path d="M15 9h.01" />
        </>
      )
    }
  </svg>
  <div class="entity-metric-body">
    <p>{metric.label}</p>
    <strong>{metric.value}</strong>
    {metric.detail ? <span>{metric.detail}</span> : null}
  </div>
  {
    action ? (
      <div class="entity-metric-action">
        {action.kind === "link" ? (
          <MetricCardLink href={action.href}>{action.label}</MetricCardLink>
        ) : (
          <MetricCardButton href={action.href}>{action.label}</MetricCardButton>
        )}
      </div>
    ) : null
  }
</article>

<style>
  .entity-metric-card {
    background: #fbfcff;
    border: 1px solid #d5deeb;
    border-radius: 0.45rem;
    box-shadow: 0 1px 2px rgba(7, 24, 66, 0.04);
    display: grid;
    gap: 0.8rem;
    grid-template-columns: 2.8rem minmax(0, 1fr);
    grid-template-rows: auto auto;
    min-height: 8rem;
    padding: 1rem;
  }

  .entity-metric-card-with-primary-action {
    background: #f4f7fb;
  }

  .entity-metric-icon {
    grid-column: 1;
    grid-row: 1;
    height: 2.7rem;
    margin-top: 0.2rem;
    width: 2.7rem;
  }

  .entity-metric-blue {
    color: #174bff;
  }

  .entity-metric-green {
    color: #087f3b;
  }

  .entity-metric-purple {
    color: #5b2df5;
  }

  .entity-metric-red {
    color: #b42318;
  }

  .entity-metric-body {
    grid-column: 2;
    grid-row: 1;
    min-width: 0;
  }

  .entity-metric-action {
    align-items: center;
    display: flex;
    grid-column: 1 / -1;
    grid-row: 2;
    justify-content: center;
    min-width: 0;
    text-align: center;
  }

  .entity-metric-card p {
    color: #071842;
    font-size: 0.875rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
  }

  .entity-metric-card strong {
    color: #071842;
    display: block;
    font-size: 1.5rem;
    font-variant-numeric: tabular-nums;
    line-height: 1.12;
    margin: 0.25rem 0 0.3rem;
  }

  .entity-metric-card span {
    color: #33456f;
    display: block;
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.45;
  }
</style>
