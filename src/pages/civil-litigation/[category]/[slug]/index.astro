---
import { withDb } from "#src/lib/db.js";

export async function getStaticPaths() {
  const civilCases = await withDb(async (client) => {
    return (
      await client.query(
        `
          select category, slug
          from public.civil_cases
          where slug is not null
          order by category, filed_date desc nulls last, title
        `,
      )
    ).rows;
  });

  return civilCases.map((civilCase: { category: string; slug: string }) => ({
    params: {
      category: civilCase.category,
      slug: civilCase.slug,
    },
    props: {
      canonicalCivilCasePath: `/civil-cases/${civilCase.slug}/`,
    },
  }));
}

// Temporary redirect shim. CloudFront already handles this pattern for deployed
// traffic; this keeps local/static legacy URLs useful until all redirect rules
// are CDN-owned.
return Astro.redirect(Astro.props.canonicalCivilCasePath, 301);
---
