---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import { loadCivilCaseDetail } from "#src/lib/data/civil-litigation-detail.js";
import { withDb } from "#src/lib/db.js";
import { formatLongDate } from "#src/lib/format.js";
import { US_STATE_TILES } from "#src/lib/geo/states.js";
import { getSiteUrl } from "#src/lib/structured-data.js";
import { getVideoEmbedUrl, isDirectVideoContentUrl } from "#src/lib/video.js";

export async function getStaticPaths() {
  const rows = await withDb(async (client) => {
    return (
      await client.query(
        `
          select
            civil_case.category,
            civil_case.slug,
            civil_case_link.id as video_id,
            civil_case_link.url
          from public.civil_case_links civil_case_link
          join public.civil_cases civil_case
            on civil_case.id = civil_case_link.civil_case_id
          order by civil_case.category, civil_case.slug, civil_case_link.id
        `,
      )
    ).rows;
  });

  return rows
    .filter((row: { url: string }) => Boolean(getVideoEmbedUrl(row.url)))
    .map((row: { category: string; slug: string; video_id: string }) => ({
      params: {
        category: row.category,
        slug: row.slug,
        videoId: row.video_id,
      },
    }));
}

const { category, slug, videoId } = Astro.params;
const categoryParam = String(category || "").toLowerCase();
const categoryMeta = US_STATE_TILES.find(
  (entry) => entry.code.toLowerCase() === categoryParam,
);
const categoryLabel =
  categoryParam === "federal"
    ? "Federal"
    : categoryMeta?.name || categoryParam.toUpperCase();

const data = await loadCivilCaseDetail(categoryParam, String(slug || ""));
if (!data) {
  throw new Error(`Civil case ${slug} not found.`);
}

const videos = data.coverageLinks.filter((link) => Boolean(link.embed));
const videoIndex = videos.findIndex((link) => link.id === videoId);
if (videoIndex === -1) {
  throw new Error(`Coverage video ${videoId} not found on civil case ${slug}.`);
}

const video = videos[videoIndex]!;
const previousVideo = videoIndex > 0 ? videos[videoIndex - 1] : null;
const nextVideo =
  videoIndex < videos.length - 1 ? videos[videoIndex + 1] : null;
const caseTitle =
  data.civilCase.title || data.civilCase.cause_number || "Civil case";
const detailPath = `/civil-litigation/${categoryParam}/${data.civilCase.slug}/`;
const watchPath = `/civil-litigation/${categoryParam}/${data.civilCase.slug}/watch/${video.id}/`;
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(watchPath, siteUrl).toString();
const caseUrl = new URL(detailPath, siteUrl).toString();
const videoTitle = video.title || `Coverage video ${videoIndex + 1}`;
const videoDescription =
  data.civilCase.claims_summary || `Coverage video for ${caseTitle}.`;
const normalizeIsoDate = (value?: string | Date | null) => {
  if (!value) {
    return null;
  }
  const parsed = new Date(value);
  return Number.isNaN(parsed.getTime()) ? null : parsed.toISOString();
};
const collapseWhitespace = (value?: string | null) =>
  value ? value.replace(/\s+/g, " ").trim() : "";
const websiteId = new URL("/", siteUrl).toString();
const webpageId = `${pageUrl}#webpage`;
const legalCaseId = `${caseUrl}#legalcase`;
const videoObjectId = `${pageUrl}#video`;
const officerEntities = data.officers.map((officer) => {
  const officerUrl = new URL(`/personnel/${officer.slug}/`, siteUrl).toString();
  return {
    "@type": "Person",
    "@id": `${officerUrl}#person`,
    name: `${officer.first_name} ${officer.last_name}`,
    url: officerUrl,
  };
});
const agencyEntities = data.agencies.map((agency) => {
  const agencyUrl = new URL(
    `/law-enforcement-agency/${agency.category}/${agency.slug}/`,
    siteUrl,
  ).toString();
  return {
    "@type": "GovernmentOrganization",
    "@id": `${agencyUrl}#organization`,
    name: agency.name,
    url: agencyUrl,
  };
});
const legalCaseEntity: Record<string, any> = {
  "@type": "LegalCase",
  "@id": legalCaseId,
  name: caseTitle,
  url: caseUrl,
  ...(data.civilCase.cause_number
    ? { identifier: data.civilCase.cause_number }
    : {}),
  ...(data.civilCase.filed_date
    ? { dateFiled: new Date(data.civilCase.filed_date).toISOString() }
    : {}),
  ...(data.civilCase.court ? { court: data.civilCase.court } : {}),
  ...(data.civilCase.primary_source_url
    ? { sameAs: [data.civilCase.primary_source_url] }
    : {}),
};
if (officerEntities.length || agencyEntities.length) {
  legalCaseEntity.about = [...officerEntities, ...agencyEntities].map(
    (entity) => ({
      "@id": entity["@id"],
    }),
  );
}
const videoUploadDate =
  normalizeIsoDate(video.updated_at) || normalizeIsoDate(video.created_at);
const videoModifiedDate =
  normalizeIsoDate(data.civilCase.updated_at) || videoUploadDate;
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": websiteId,
      url: websiteId,
      name: "PoliceConduct.org",
    },
    {
      "@type": "WebPage",
      "@id": webpageId,
      url: pageUrl,
      name: `${videoTitle} | Watch | PoliceConduct.org`,
      description: collapseWhitespace(videoDescription),
      isPartOf: { "@id": websiteId },
      mainEntity: { "@id": videoObjectId },
    },
    ...agencyEntities,
    ...officerEntities,
    legalCaseEntity,
    {
      "@type": "VideoObject",
      "@id": videoObjectId,
      name: videoTitle,
      description: collapseWhitespace(videoDescription),
      embedUrl: video.embed,
      mainEntityOfPage: { "@id": webpageId },
      url: pageUrl,
      isPartOf: { "@id": legalCaseId },
      ...(video.thumbnail ? { thumbnailUrl: video.thumbnail } : {}),
      ...(isDirectVideoContentUrl(video.url) ? { contentUrl: video.url } : {}),
      ...(videoUploadDate ? { uploadDate: videoUploadDate } : {}),
      ...(videoModifiedDate ? { dateModified: videoModifiedDate } : {}),
    },
  ],
};
---

<SiteLayout
  title={`${videoTitle} | Watch | PoliceConduct.org`}
  description={videoDescription}
  pagePath={watchPath}
  canonicalUrl={watchPath}
  structuredData={structuredData}
>
  <main>
    <section class="py-vh-3 bg-gray-100 border-bottom border-dark">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-12 col-lg-10 col-xl-8">
            <Breadcrumbs
              items={[
                { label: "Civil litigation", href: "/civil-litigation/" },
                {
                  label: categoryLabel,
                  href: `/civil-litigation/${categoryParam}/`,
                },
                { label: caseTitle, href: detailPath },
                { label: "Watch", href: watchPath, current: true },
              ]}
            />
            <p class="text-uppercase small text-muted mb-2">Watch page</p>
            <h1 class="display-6 fw-bold">{videoTitle}</h1>
            <p class="lead mb-2">
              From case: <a class="link-dark" href={detailPath}>{caseTitle}</a>
            </p>
            {
              data.civilCase.filed_date ? (
                <p class="text-muted mb-0">
                  Filed: {formatLongDate(data.civilCase.filed_date)}
                </p>
              ) : null
            }
          </div>
        </div>
      </div>
    </section>

    <section class="py-vh-2">
      <div class="container">
        <div class="row justify-content-center">
          <article class="col-12 col-lg-10 col-xl-8">
            <div class="ratio ratio-16x9 border mb-3">
              <iframe
                src={video.embed!}
                title={videoTitle}
                loading="lazy"
                allow="
                  accelerometer;
                  autoplay;
                  clipboard-write;
                  encrypted-media;
                  gyroscope;
                  picture-in-picture;
                  web-share;
                "
                referrerpolicy="strict-origin-when-cross-origin"
                allowfullscreen></iframe>
            </div>

            <div class="d-flex flex-wrap gap-2 mb-4">
              <a class="btn btn-dark rounded-0" href={detailPath}>
                Back to case
              </a>
              <a
                class="btn btn-outline-dark rounded-0"
                href={video.url}
                target="_blank"
                rel="noopener"
              >
                Open original source
              </a>
            </div>

            <section class="border p-3 bg-white mb-4">
              <h2 class="h6 text-uppercase text-muted mb-3">Case details</h2>
              <div class="row g-3">
                <div class="col-sm-6">
                  <div class="small text-uppercase text-muted">
                    Cause number
                  </div>
                  <div>{data.civilCase.cause_number || "—"}</div>
                </div>
                <div class="col-sm-6">
                  <div class="small text-uppercase text-muted">Court</div>
                  <div>{data.civilCase.court || "—"}</div>
                </div>
                <div class="col-sm-6">
                  <div class="small text-uppercase text-muted">Filed</div>
                  <div>
                    {
                      data.civilCase.filed_date
                        ? formatLongDate(data.civilCase.filed_date)
                        : "—"
                    }
                  </div>
                </div>
                <div class="col-sm-6">
                  <div class="small text-uppercase text-muted">
                    Primary source
                  </div>
                  {
                    data.civilCase.primary_source_url ? (
                      <a
                        href={data.civilCase.primary_source_url}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        Open source
                      </a>
                    ) : (
                      <span>—</span>
                    )
                  }
                </div>
                <div class="col-12">
                  <div class="small text-uppercase text-muted">Claims</div>
                  <p class="mb-0">
                    {
                      collapseWhitespace(data.civilCase.claims_summary) ||
                        "No claims summary listed."
                    }
                  </p>
                </div>
                <div class="col-12">
                  <div class="small text-uppercase text-muted">Officers</div>
                  {
                    data.officers.length ? (
                      <p class="mb-0">
                        {data.officers.map((officer, index) => (
                          <>
                            {index > 0 ? ", " : null}
                            <a href={`/personnel/${officer.slug}/`}>
                              {officer.first_name} {officer.last_name}
                            </a>
                          </>
                        ))}
                      </p>
                    ) : (
                      <p class="mb-0">No officers linked.</p>
                    )
                  }
                </div>
                <div class="col-12">
                  <div class="small text-uppercase text-muted">Agencies</div>
                  {
                    data.agencies.length ? (
                      <p class="mb-0">
                        {data.agencies.map((agency, index) => (
                          <>
                            {index > 0 ? ", " : null}
                            <a
                              href={`/law-enforcement-agency/${agency.category}/${agency.slug}/`}
                            >
                              {agency.name}
                            </a>
                          </>
                        ))}
                      </p>
                    ) : (
                      <p class="mb-0">No agencies linked.</p>
                    )
                  }
                </div>
              </div>
            </section>

            <div
              class="d-flex flex-wrap justify-content-between gap-2 border-top border-bottom py-3 mb-4"
            >
              {
                previousVideo ? (
                  <a
                    class="link-dark fw-semibold"
                    href={`/civil-litigation/${categoryParam}/${data.civilCase.slug}/watch/${previousVideo.id}/`}
                  >
                    Previous video
                  </a>
                ) : (
                  <span class="text-muted">Previous video</span>
                )
              }
              {
                nextVideo ? (
                  <a
                    class="link-dark fw-semibold"
                    href={`/civil-litigation/${categoryParam}/${data.civilCase.slug}/watch/${nextVideo.id}/`}
                  >
                    Next video
                  </a>
                ) : (
                  <span class="text-muted">Next video</span>
                )
              }
            </div>
          </article>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
