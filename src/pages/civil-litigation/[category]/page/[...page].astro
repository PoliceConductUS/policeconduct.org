---
import { loadCivilCasesByCategory } from "#src/lib/data/civil-litigation-category.js";
import { US_STATE_TILES } from "#src/lib/geo/states.js";
import { PAGE_SIZE } from "#src/lib/pagination.js";

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const pages: any[] = [];

  for (const category of [
    ...US_STATE_TILES.map((state) => state.code.toLowerCase()),
    "federal",
  ]) {
    const cases = await loadCivilCasesByCategory(category.toUpperCase());
    paginate(cases, {
      pageSize: PAGE_SIZE,
      params: { category },
    })
      .filter((page: any) => {
        const pageParam = page.params?.page;
        if (Array.isArray(pageParam)) {
          return pageParam.length > 0 && pageParam[0] !== "1";
        }
        return (
          typeof pageParam === "string" &&
          pageParam.length > 0 &&
          pageParam !== "1"
        );
      })
      .forEach((page: any) => pages.push(page));
  }

  return pages;
}

return Astro.redirect(
  `/${String(Astro.params.category || "").toLowerCase()}/`,
  301,
);
---
