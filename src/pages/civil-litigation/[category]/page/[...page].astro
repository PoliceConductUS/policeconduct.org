---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import CollectionStatsBand from "#src/components/CollectionStatsBand.astro";
import Pagination from "#src/components/Pagination.astro";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import {
  loadCivilCasesByCategory,
  type AgencyRef,
  type OfficerRef,
} from "#src/lib/data/civil-litigation-category.js";
import {
  buildCategoryCollectionStats,
  loadCategoryCollectionCounts,
  type CategoryCollectionCounts,
} from "#src/lib/category-collection-stats.js";
import { US_STATE_TILES } from "#src/lib/geo/states.js";
import { PAGE_SIZE } from "#src/lib/pagination.js";
import {
  buildItemList,
  buildWebPage,
  getSiteUrl,
} from "#src/lib/structured-data.js";

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const pages: any[] = [];
  const countsByCategory = await loadCategoryCollectionCounts();

  for (const category of [
    ...US_STATE_TILES.map((state) => state.code.toLowerCase()),
    "federal",
  ]) {
    const cases = await loadCivilCasesByCategory(category.toUpperCase());
    paginate(cases, {
      pageSize: PAGE_SIZE,
      params: { category },
      props: {
        categoryCounts: countsByCategory.get(category) || {
          agencyCount: 0,
          personnelCount: 0,
          reportCount: 0,
          civilCaseCount: 0,
        },
      },
    })
      .filter((page: any) => {
        const pageParam = page.params?.page;
        if (Array.isArray(pageParam)) {
          return pageParam.length > 0 && pageParam[0] !== "1";
        }
        return (
          typeof pageParam === "string" &&
          pageParam.length > 0 &&
          pageParam !== "1"
        );
      })
      .forEach((page: any) => pages.push(page));
  }

  return pages;
}

const { page } = Astro.props;
const { category } = Astro.params;
const categoryParam = String(category || "").toLowerCase();
const categoryCode = categoryParam.toUpperCase();
const categoryMeta = US_STATE_TILES.find(
  (entry) => entry.code.toLowerCase() === categoryParam,
);
const categoryLabel =
  categoryParam === "federal" ? "Federal" : categoryMeta?.name || categoryCode;
const pagePath = `/civil-litigation/${categoryParam}/page/${page.currentPage}/`;
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(pagePath, siteUrl).toString();
const title =
  page.currentPage > 1
    ? `Civil litigation in ${categoryLabel} – Page ${page.currentPage} | PoliceConduct.org`
    : `Civil litigation in ${categoryLabel} | PoliceConduct.org`;
const {
  categoryCounts = {
    agencyCount: 0,
    personnelCount: 0,
    reportCount: 0,
    civilCaseCount: 0,
  },
} = Astro.props as {
  categoryCounts: CategoryCollectionCounts;
};

const formatIsoDate = (value?: string | null) => {
  if (!value) {
    return null;
  }
  const parsed = new Date(value);
  return Number.isNaN(parsed.getTime()) ? null : parsed.toISOString();
};

const caseItems = page.data.map((caseItem: any, index: number) => {
  const filedDateIso = caseItem.filed_date
    ? formatIsoDate(caseItem.filed_date)
    : null;
  const caseUrl = new URL(
    `/civil-litigation/${categoryParam}/${caseItem.slug}/`,
    siteUrl,
  ).toString();
  const legalCase = {
    "@type": "LegalCase",
    "@id": `${caseUrl}#legalcase`,
    name: caseItem.title || caseItem.cause_number || "Civil case",
    url: caseUrl,
    ...(caseItem.cause_number ? { identifier: caseItem.cause_number } : {}),
    ...(filedDateIso ? { dateFiled: filedDateIso } : {}),
    ...(caseItem.court ? { court: caseItem.court } : {}),
    ...(caseItem.primary_source_url
      ? { sameAs: [caseItem.primary_source_url] }
      : {}),
  };
  return {
    "@type": "ListItem",
    position: index + 1,
    item: legalCase,
  };
});

const structuredData = buildWebPage({
  siteUrl,
  pageUrl,
  name: title,
  description: `Civil litigation cases tied to ${categoryLabel} agencies and personnel.`,
  type: "CollectionPage",
});
const caseItemList = buildItemList(caseItems);
if (caseItemList) {
  structuredData.mainEntity = caseItemList;
}
const stats = buildCategoryCollectionStats(
  categoryParam,
  categoryLabel,
  categoryCounts,
);
---

<SiteLayout
  title={title}
  description={`Civil litigation cases tied to ${categoryLabel} agencies and personnel.`}
  pagePath={pagePath}
  canonicalUrl={pagePath}
  structuredData={structuredData}
>
  <main>
    <section class="py-vh-3 bg-gray-100 border-bottom border-dark">
      <div class="container">
        <div class="row align-items-end">
          <div class="col-12">
            <Breadcrumbs
              items={[
                { label: "Home", href: "/" },
                { label: "Civil litigation", href: "/civil-litigation/" },
                {
                  label: categoryLabel,
                  href: `/civil-litigation/${categoryParam}/`,
                },
                {
                  label: `Page ${page.currentPage}`,
                  href: pagePath,
                  current: true,
                },
              ]}
              className="mb-2"
            />
            <h1 class="display-4 fw-bold mb-3">
              {categoryLabel} civil litigation
            </h1>
            <p class="text-muted">
              We track {page.total} public civil cases referencing agencies categorized
              for {categoryLabel}.
            </p>
            <p class="small text-muted mb-0">
              Page {page.currentPage} of {page.lastPage}
            </p>
          </div>
        </div>
      </div>
    </section>
    <section class="py-vh-2">
      <div class="container">
        <div class="row">
          <div class="col-12">
            {
              page.data.length ? (
                <div class="profile-record-list">
                  {page.data.map((caseItem: any) => {
                    const casePath = `/civil-litigation/${categoryParam}/${caseItem.slug}/`;
                    const defendants = [
                      ...caseItem.officers.map((officer: OfficerRef) => ({
                        href: `/personnel/${officer.slug}/`,
                        label: `${officer.first_name} ${officer.last_name}`,
                      })),
                      ...caseItem.agencies.map((agency: AgencyRef) => ({
                        href: `/law-enforcement-agency/${agency.category}/${agency.slug}/`,
                        label: agency.name,
                      })),
                    ];
                    return (
                      <article class="profile-record">
                        <div class="profile-record-meta">
                          <span>
                            {caseItem.filed_date
                              ? new Date(caseItem.filed_date).getFullYear()
                              : "Year not listed"}
                          </span>
                          {caseItem.cause_number ? (
                            <span>{caseItem.cause_number}</span>
                          ) : null}
                        </div>
                        <div class="profile-record-body">
                          <h2 class="profile-record-title">
                            <a href={casePath}>
                              {caseItem.title || "Unnamed case"}
                            </a>
                          </h2>
                          <div class="profile-record-detail">
                            {defendants.length ? (
                              <span>
                                Defendants:{" "}
                                {defendants.map((entry, index) => (
                                  <>
                                    {index > 0 ? ", " : null}
                                    <a href={entry.href}>{entry.label}</a>
                                  </>
                                ))}
                              </span>
                            ) : (
                              <span>Defendants not listed</span>
                            )}
                          </div>
                        </div>
                      </article>
                    );
                  })}
                </div>
              ) : (
                <div
                  class="alert alert-secondary rounded-0 border-dark"
                  role="status"
                >
                  No civil litigation listed yet for {categoryLabel}.
                </div>
              )
            }
          </div>
        </div>
        <Pagination
          basePath={`/civil-litigation/${categoryParam}/`}
          currentPage={page.currentPage}
          lastPage={page.lastPage}
        />
      </div>
    </section>
    <CollectionStatsBand items={stats} variant="compact" />
  </main>
</SiteLayout>
<style>
  .display-4 {
    max-width: 100%;
    overflow-wrap: anywhere;
  }

  .profile-record-list {
    border-top: 0;
    display: grid;
    gap: 0;
  }

  .profile-record {
    align-items: start;
    border-top: 1px solid var(--bs-border-color);
    display: grid;
    gap: 0.75rem 1.25rem;
    grid-template-columns: minmax(0, 1fr) minmax(8rem, 13rem);
    padding: 0.95rem 0;
    transition:
      background-color 140ms ease,
      border-color 140ms ease;
  }

  .profile-record:hover {
    background: color-mix(in srgb, var(--bs-gray-100) 42%, var(--bs-white));
  }

  .profile-record-body {
    grid-column: 1;
    grid-row: 1;
    min-width: 0;
  }

  .profile-record-meta {
    align-items: flex-end;
    color: var(--bs-secondary-color);
    display: flex;
    flex-direction: column;
    font-size: 0.8125rem;
    gap: 0.25rem;
    grid-column: 2;
    grid-row: 1;
    line-height: 1.35;
    min-width: 0;
    text-align: right;
  }

  .profile-record-title {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.35;
    margin: 0;
  }

  .profile-record-title a,
  .profile-record-detail a {
    color: var(--bs-dark);
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .profile-record-detail {
    color: var(--bs-secondary-color);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.875rem;
    gap: 0.35rem 0.85rem;
    line-height: 1.5;
    margin-top: 0.35rem;
    min-width: 0;
  }

  .profile-record-detail > span[aria-hidden="true"] {
    display: none;
  }

  .profile-record-meta span,
  .profile-record-meta a {
    color: var(--bs-secondary-color);
    max-width: 100%;
  }

  .profile-record-title a {
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  .profile-record-detail a {
    font-weight: 600;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.16em;
  }

  .profile-record-title,
  .profile-record-detail,
  .profile-record-meta {
    overflow-wrap: anywhere;
  }

  @media (max-width: 991.98px) {
    .display-4 {
      font-size: clamp(2.25rem, 12vw, 3.5rem);
      line-height: 1.05;
    }

    .profile-record {
      grid-template-columns: minmax(0, 1fr);
    }

    .profile-record-body,
    .profile-record-meta {
      grid-column: 1;
    }

    .profile-record-meta {
      align-items: flex-start;
      flex-direction: row;
      flex-wrap: wrap;
      grid-row: 2;
      text-align: left;
    }
  }

  @media (max-width: 575.98px) {
    .profile-record-list,
    .profile-record {
      max-width: calc(100vw - 1rem);
    }

    .profile-record-detail {
      align-items: flex-start;
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }

    .profile-record-detail > * {
      margin-right: 0;
    }
  }
</style>
