---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import CollectionStatsBand from "#src/components/CollectionStatsBand.astro";
import Pagination from "#src/components/Pagination.astro";
import PrefillBootstrap from "#src/components/PrefillBootstrap.astro";
import PrefillNavButton from "#src/components/PrefillNavButton.astro";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import {
  loadCivilCasesByCategory,
  type AgencyRef,
  type OfficerRef,
} from "#src/lib/data/civil-litigation-category.js";
import {
  buildCategoryCollectionStats,
  loadCategoryCollectionCounts,
  type CategoryCollectionCounts,
} from "#src/lib/category-collection-stats.js";
import { US_STATE_TILES } from "#src/lib/geo/states.js";
import { PAGE_SIZE } from "#src/lib/pagination.js";
import {
  buildItemList,
  buildWebPage,
  getSiteUrl,
} from "#src/lib/structured-data.js";

export async function getStaticPaths() {
  const countsByCategory = await loadCategoryCollectionCounts();
  const categoryEntries = [
    ...US_STATE_TILES.map((state) => state.code.toLowerCase()),
    "federal",
  ];

  const categoryCases = await Promise.all(
    categoryEntries.map(async (category) => ({
      category,
      cases: await loadCivilCasesByCategory(category.toUpperCase()),
    })),
  );

  return categoryCases.map(({ category, cases }) => ({
    params: { category },
    props: {
      allCases: cases,
      categoryCounts: countsByCategory.get(category) || {
        agencyCount: 0,
        personnelCount: 0,
        reportCount: 0,
        civilCaseCount: 0,
      },
    },
  }));
}

const { category } = Astro.params;
const categoryParam = (category || "").toLowerCase();
const categoryCode = categoryParam.toUpperCase();
const categoryMeta = US_STATE_TILES.find(
  (entry) => entry.code.toLowerCase() === categoryParam,
);
const categoryLabel =
  categoryParam === "federal" ? "Federal" : categoryMeta?.name || categoryCode;

const {
  allCases: casesWithDetails = [],
  categoryCounts = {
    agencyCount: 0,
    personnelCount: 0,
    reportCount: 0,
    civilCaseCount: 0,
  },
} = Astro.props as {
  allCases: any[];
  categoryCounts: CategoryCollectionCounts;
};
const caseCount = casesWithDetails.length;
const pageCases = casesWithDetails.slice(0, PAGE_SIZE);
const totalPages = Math.max(1, Math.ceil(caseCount / PAGE_SIZE));
const pagePath = categoryParam
  ? `/civil-litigation/${categoryParam}/`
  : "/civil-litigation/";
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(pagePath, siteUrl).toString();
const formatIsoDate = (value?: string | null) => {
  if (!value) {
    return null;
  }
  const parsed = new Date(value);
  return Number.isNaN(parsed.getTime()) ? null : parsed.toISOString();
};
const caseItems = pageCases.map((caseItem, index) => {
  const filedDateIso = caseItem.filed_date
    ? formatIsoDate(caseItem.filed_date)
    : null;
  const caseUrl = new URL(
    `/civil-litigation/${categoryParam}/${caseItem.slug}/`,
    siteUrl,
  ).toString();
  const legalCase = {
    "@type": "LegalCase",
    "@id": `${caseUrl}#legalcase`,
    name: caseItem.title || caseItem.cause_number || "Civil case",
    url: caseUrl,
    ...(caseItem.cause_number ? { identifier: caseItem.cause_number } : {}),
    ...(filedDateIso ? { dateFiled: filedDateIso } : {}),
    ...(caseItem.court ? { court: caseItem.court } : {}),
    ...(caseItem.primary_source_url
      ? { sameAs: [caseItem.primary_source_url] }
      : {}),
  };
  return {
    "@type": "ListItem",
    position: index + 1,
    item: legalCase,
  };
});
const structuredData = buildWebPage({
  siteUrl,
  pageUrl,
  name: `Civil litigation in ${categoryLabel} | PoliceConduct.org`,
  description: `Civil litigation cases tied to ${categoryLabel} agencies and personnel.`,
  type: "CollectionPage",
});
const caseItemList = buildItemList(caseItems);
if (caseItemList) {
  structuredData.mainEntity = caseItemList;
}
const stateName = categoryLabel;
const stats = buildCategoryCollectionStats(
  categoryParam,
  categoryLabel,
  categoryCounts,
);
---

<SiteLayout
  title={`Civil litigation in ${categoryLabel} | PoliceConduct.org`}
  description={`Civil litigation cases tied to ${categoryLabel} agencies and personnel.`}
  pagePath={pagePath}
  structuredData={structuredData}
>
  <PrefillBootstrap />
  <main class="">
    <section class="py-vh-3 bg-gray-100 border-bottom border-dark">
      <div class="container">
        <div class="row align-items-end">
          <div class="col-12">
            <Breadcrumbs
              items={[
                { label: "Home", href: "/" },
                { label: "Civil litigation", href: "/civil-litigation/" },
                { label: stateName, href: pagePath, current: true },
              ]}
              className="mb-2"
            />
            <p class="text-uppercase small text-muted mb-2">
              Civil litigation • {categoryLabel}
            </p>
            <h1 class="display-4 fw-bold mb-3">
              {categoryLabel} civil litigation
            </h1>
            <p class="text-muted">
              {
                caseCount
                  ? `We track ${caseCount} public civil cases referencing agencies categorized for ${categoryLabel}.`
                  : `No civil litigation has been published for ${categoryLabel} agencies yet.`
              }
            </p>
            <p class="small text-muted mb-0">Page 1 of {totalPages}</p>
          </div>
        </div>
      </div>
    </section>
    <div class="bg-white border-bottom border-dark">
      <CollectionStatsBand items={stats} />
    </div>

    <section class="py-vh-2">
      <div class="container">
        <div class="row">
          <div class="col-12">
            {
              caseCount ? (
                <div class="row row-cols-1 g-3">
                  {pageCases.map((caseItem) => {
                    const casePath = `/civil-litigation/${categoryParam}/${caseItem.slug}/`;
                    return (
                      <div class="col">
                        <article class="card shadow-sm border-0 rounded-0 h-100">
                          <div class="card-body d-flex flex-column gap-3">
                            <div class="row g-3 align-items-start">
                              <div class="col-12 col-md-2 col-xl-1">
                                <div class="text-uppercase small text-muted">
                                  Year
                                </div>
                                <div class="fw-bold">
                                  {caseItem.filed_date
                                    ? new Date(
                                        caseItem.filed_date,
                                      ).getFullYear()
                                    : "—"}
                                </div>
                              </div>
                              <div class="col-12 col-md-5 col-xl-4">
                                <div class="text-uppercase small text-muted">
                                  Case
                                </div>
                                <a
                                  class="link-dark fw-semibold"
                                  href={casePath}
                                >
                                  {caseItem.title || "Unnamed case"}
                                </a>
                                <div class="text-muted small">
                                  {caseItem.cause_number ||
                                    "No cause number listed"}
                                </div>
                              </div>
                              <div class="col-12 col-md-5 col-xl-4">
                                <div class="text-uppercase small text-muted">
                                  Defendants
                                </div>
                                <div class="d-flex flex-wrap align-items-center gap-1">
                                  {[
                                    ...caseItem.officers.map(
                                      (officer: OfficerRef) => ({
                                        href: `/personnel/${officer.slug}/`,
                                        label: `${officer.first_name} ${officer.last_name}`,
                                      }),
                                    ),
                                    ...caseItem.agencies.map(
                                      (agency: AgencyRef) => ({
                                        href: `/law-enforcement-agency/${agency.category}/${agency.slug}/`,
                                        label: agency.name,
                                      }),
                                    ),
                                  ].map((entry, index) => (
                                    <>
                                      {index > 0 ? (
                                        <span class="mx-1 text-muted">•</span>
                                      ) : null}
                                      <a
                                        class="link-dark text-decoration-none"
                                        href={entry.href}
                                      >
                                        {entry.label}
                                      </a>
                                    </>
                                  ))}
                                  {caseItem.officers.length === 0 &&
                                  caseItem.agencies.length === 0 ? (
                                    <span class="text-muted">—</span>
                                  ) : null}
                                </div>
                              </div>
                            </div>
                          </div>
                        </article>
                      </div>
                    );
                  })}
                </div>
              ) : (
                <div
                  class="alert alert-secondary rounded-0 border-dark d-flex flex-column gap-2"
                  role="status"
                >
                  <span>
                    No civil litigation listed yet for {categoryLabel}.
                  </span>
                  <PrefillNavButton
                    class="btn btn-dark rounded-0 w-auto"
                    to="/civil-litigation/new/"
                    payload={{
                      jurisdiction: categoryParam,
                    }}
                  >
                    Add one now
                  </PrefillNavButton>
                </div>
              )
            }
          </div>
        </div>
        <Pagination basePath={pagePath} currentPage={1} lastPage={totalPages} />
      </div>
    </section>
  </main>
</SiteLayout>
