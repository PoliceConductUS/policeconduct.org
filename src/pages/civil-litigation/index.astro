---
import SiteLayout from "#src/layouts/SiteLayout.astro";
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import PrefillBootstrap from "#src/components/PrefillBootstrap.astro";
import UsaChoroplethMap from "#src/components/UsaChoroplethMap.astro";
import { withDb } from "#src/lib/db.js";
import { loadFederalAgencySummaries } from "#src/lib/data/federal-agencies.js";
import { US_STATE_TILES } from "#src/lib/geo/states.js";
import {
  buildItemList,
  buildWebPage,
  getSiteUrl,
} from "#src/lib/structured-data.js";

type StateCount = {
  state: string;
  count: number;
};

type FederalAgency = {
  id: string;
  name: string;
  path: string;
  branchCount: number;
};

const [caseData, federalAgencies] = await Promise.all([
  withDb(async (client) => {
    const totalResult = await client.query(
      "select count(*) as count from public.civil_cases",
    );
    const stateResult = await client.query(
      `
        select upper(lp.state_or_territory_slug) as state, count(distinct c.id) as case_count
        from public.civil_cases c
        join public.location_path lp
          on lp.location_path_id = c.location_path_id
        group by upper(lp.state_or_territory_slug)
      `,
    );
    return {
      totalCases: Number(totalResult.rows[0]?.count ?? 0),
      stateCounts: stateResult.rows.map(
        (row: { state: string; case_count: string | number }) => ({
          state: row.state,
          count: Number(row.case_count),
        }),
      ),
    };
  }),
  loadFederalAgencySummaries(),
]);
const { totalCases, stateCounts } = caseData;

const countsByCategory = new Map(
  (stateCounts as StateCount[]).map((entry) => [
    entry.state,
    entry.count,
  ]),
);
const stateStats = US_STATE_TILES.map((state) => ({
  code: state.code,
  count: countsByCategory.get(state.code) ?? 0,
  href: `/${state.code.toLowerCase()}/`,
}));
const totalCaseCount = totalCases;
const statesWithCases = stateStats.filter((state) => state.count > 0).length;
const civilLandingPath = "/civil-litigation/";
const newCivilLandingHref = "/civil-litigation/new/";
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(civilLandingPath, siteUrl).toString();
const federalAgencyItems = (federalAgencies as FederalAgency[]).map(
  (agency, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "GovernmentOrganization",
      name: agency.name,
      url: new URL(agency.path, siteUrl).toString(),
    },
  }),
);
const structuredData = buildWebPage({
  siteUrl,
  pageUrl,
  name: "Civil Litigation | PoliceConduct.org",
  description:
    "Browse civil litigation cases linked to law enforcement agencies and personnel.",
  type: "CollectionPage",
});
const federalItemList = buildItemList(federalAgencyItems);
if (federalItemList) {
  structuredData.mainEntity = federalItemList;
}
---

<SiteLayout
  title="Civil Litigation | PoliceConduct.org"
  description="Browse civil litigation cases linked to law enforcement agencies and personnel."
  pagePath={civilLandingPath}
  structuredData={structuredData}
>
  <PrefillBootstrap />
  <main>
    <section class="py-vh-3 bg-gray-100 border-bottom border-dark">
      <div class="container">
        <div class="row g-5 align-items-end">
          <div class="col-12 col-lg-8">
            <Breadcrumbs
              items={[
                { label: "Home", href: "/" },
                {
                  label: "Civil Litigation",
                  href: civilLandingPath,
                  current: true,
                },
              ]}
              className="mb-2"
            />
            <h1 class="display-4 fw-bold">Civil Litigation</h1>
            <p class="lead text-muted mb-0">
              Civil cases that reference a law enforcement agency or personnel
              by state.
            </p>
            <div class="ipc-hero-summary ipc-hero-summary-mobile mt-3">
              <span class="badge bg-light text-dark border rounded-0">
                {totalCaseCount} cases
              </span>
              <span class="badge bg-light text-dark border rounded-0">
                {statesWithCases} states covered
              </span>
            </div>
          </div>
          <div class="col-12 col-lg-4 d-none d-lg-flex justify-content-lg-end">
            <div class="ipc-hero-summary" aria-label="Civil litigation summary">
              <span class="badge bg-light text-dark border rounded-0">
                {totalCaseCount} cases
              </span>
              <span class="badge bg-light text-dark border rounded-0">
                {statesWithCases} states covered
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>
    <section class="py-vh-2">
      <div class="container">
        <UsaChoroplethMap
          stats={stateStats}
          title="States"
          subtitle="Select a state to browse available records by place."
          emptyLabel="No cases yet"
          interactionLabel="Click a state to browse available records."
          headerAction={{
            href: newCivilLandingHref,
            label: "Suggest a new civil case",
            target: "_self",
            prefillPayload: { jurisdiction: "" },
          }}
          federalPanel={{
            title: "Federal agencies",
            value: federalAgencies.length,
            description: "Federal agencies linked to listed cases.",
            items: (federalAgencies as FederalAgency[]).map((agency) => ({
              label: agency.name,
              href: agency.path,
              badgeText: `${agency.branchCount} locations`,
            })),
          }}
        />
      </div>
    </section>
  </main>
</SiteLayout>
