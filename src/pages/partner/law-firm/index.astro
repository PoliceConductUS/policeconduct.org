---
import SiteLayout from "#src/layouts/SiteLayout.astro";
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import PrefillBootstrap from "#src/components/PrefillBootstrap.astro";
import { buildWebPage, getSiteUrl } from "#src/lib/structured-data.js";

const pagePath = "/partner/law-firm/";
const pageDescription =
  "Partnership information for law firms using PoliceConduct.org for public-record review, client reporting workflows, and case-oriented research support.";
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(pagePath, siteUrl).toString();
const structuredData = buildWebPage({
  siteUrl,
  pageUrl,
  name: "Partnerships for Law Firms | PoliceConduct.org",
  description: pageDescription,
});
---

<SiteLayout
  title="Partnerships for Law Firms | PoliceConduct.org"
  description={pageDescription}
  pagePath={pagePath}
  structuredData={structuredData}
>
  <PrefillBootstrap />
  <main class="flex-grow-1">
    <section class="py-vh-3 bg-gray-100 border-bottom border-dark">
      <div class="container">
        <Breadcrumbs
          items={[
            { label: "Partner", href: "/partner/" },
            { label: "Law Firm", href: pagePath, current: true },
          ]}
        />
        <div class="row g-4 align-items-end">
          <div class="col-12 col-lg-8">
            <p class="text-uppercase small text-muted mb-2">Partnership</p>
            <h1 class="display-4 fw-bold">For Law Firms</h1>
            <p class="lead text-muted mb-0">
              Use PoliceConduct.org for public-record review, client reporting
              workflows, and case-oriented research support tied to active
              matters.
            </p>
          </div>
          <div class="col-12 col-lg-4">
            <div class="card shadow-sm rounded-0 border-dark">
              <div class="card-body d-flex flex-column gap-2">
                <div class="text-uppercase small text-muted">
                  What we can do now
                </div>
                <div class="fw-semibold">Support public-record case review</div>
                <div class="text-muted small">
                  We can help firms organize public-facing records, site
                  entries, and client reporting workflows around active matters.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-vh-2">
      <div class="container">
        <div class="row g-4">
          <div class="col-12 col-lg-7">
            <h2 class="h4 fw-semibold">How We Can Help</h2>
            <p class="text-muted mb-0">
              We can help a firm organize the public-facing record around a
              department, officer, or incident so counsel can see what is
              already documented and what still needs independent development.
            </p>
          </div>
          <div class="col-12 col-lg-5">
            <div class="card shadow-sm rounded-0 border-dark h-100">
              <div class="card-body d-flex flex-column gap-3">
                <div class="text-uppercase small text-muted">Good fit</div>
                <ul class="list-unstyled mb-0 d-flex flex-column gap-2">
                  <li>
                    Civil rights or defense firms working from a defined case
                    list.
                  </li>
                  <li>
                    Teams that want better record organization, not inflated
                    guarantees.
                  </li>
                  <li>
                    Matters where a public brief or intake workflow would help.
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-vh-2 bg-light border-top border-bottom border-dark">
      <div class="container">
        <h2 class="h4 fw-semibold mb-3">What we can help with now</h2>
        <div class="row g-4">
          <div class="col-12 col-lg-6">
            <div class="card shadow-sm rounded-0 border-dark h-100">
              <div class="card-body d-flex flex-column gap-2">
                <p class="text-uppercase small text-muted mb-1">
                  Intake workflow
                </p>
                <h3 class="h6 fw-semibold">Client reporting support</h3>
                <p class="mb-0">
                  Use reporting forms and public pages to help clients document
                  interactions while details are still available.
                </p>
              </div>
            </div>
          </div>
          <div class="col-12 col-lg-6">
            <div class="card shadow-sm rounded-0 border-dark h-100">
              <div class="card-body d-flex flex-column gap-2">
                <p class="text-uppercase small text-muted mb-1">
                  Public-record review
                </p>
                <h3 class="h6 fw-semibold">Working brief</h3>
                <p class="mb-0">
                  Prepare a scoped summary of related reports, agencies,
                  personnel, and civil cases tied to the matter.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-vh-2">
      <div class="container">
        <h2 class="h4 fw-semibold mb-3">What partnership looks like</h2>
        <p class="text-muted mb-0">
          We start with the matter, jurisdiction, and document set. Then we
          clarify what public-facing material we can help organize. We do not
          promise litigation outcomes or substitute for legal investigation.
        </p>
      </div>
    </section>

    <section class="py-vh-2">
      <div class="container">
        <div
          class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3"
        >
          <div>
            <h2 class="h4 fw-semibold mb-1">Ready to discuss a matter?</h2>
            <p class="text-muted mb-0">
              If you want to discuss intake support or a scoped public-record
              brief for active matters, send the practice area and jurisdiction.
            </p>
          </div>
          <a
            class="btn btn-dark rounded-0"
            href="/about/contact/"
            target="_self"
            data-prefill-key="prefill:contact"
            data-prefill-payload={JSON.stringify({
              whoami: "Partner",
              message:
                "I am interested in a scoped law firm partnership for public-record case review.",
            })}
          >
            Contact partnerships
          </a>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
