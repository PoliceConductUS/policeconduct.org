---
import SiteLayout from "#src/layouts/SiteLayout.astro";
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import PrefillBootstrap from "#src/components/PrefillBootstrap.astro";
import PrefillNavButton from "#src/components/PrefillNavButton.astro";
import { buildWebPage, getSiteUrl } from "#src/lib/structured-data.js";

const pagePath = "/partner/media/";
const pageDescription =
  "Partnership information for newsrooms and investigative reporters using PoliceConduct.org as a working public-record resource.";
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(pagePath, siteUrl).toString();
const structuredData = buildWebPage({
  siteUrl,
  pageUrl,
  name: "Partnerships for Newsrooms and Investigative Reporters | PoliceConduct.org",
  description: pageDescription,
});
---

<SiteLayout
  title="Partnerships for Newsrooms and Investigative Reporters | PoliceConduct.org"
  description={pageDescription}
  pagePath={pagePath}
  structuredData={structuredData}
>
  <PrefillBootstrap />
  <main class="flex-grow-1">
    <section class="py-vh-3 bg-gray-100 border-bottom border-dark">
      <div class="container">
        <Breadcrumbs
          items={[
            { label: "Partner", href: "/partner/" },
            { label: "Media", href: pagePath, current: true },
          ]}
        />
        <div class="row g-4 align-items-end">
          <div class="col-12 col-lg-8">
            <p class="text-uppercase small text-muted mb-2">Partnership</p>
            <h1 class="display-4 fw-bold">
              For Newsrooms and Investigative Reporters
            </h1>
            <p class="lead text-muted mb-0">
              Use PoliceConduct.org as a working public-record resource when a
              story needs faster source organization, better context, and a
              clearer view of what the current record actually shows.
            </p>
          </div>
          <div class="col-12 col-lg-4">
            <div class="card shadow-sm rounded-0 border-dark">
              <div class="card-body d-flex flex-column gap-2">
                <div class="text-uppercase small text-muted">
                  What we can do now
                </div>
                <div class="fw-semibold">
                  Support record review and reporting context
                </div>
                <div class="text-muted small">
                  We can help journalists review site entries, linked public
                  materials, and related records around a defined reporting
                  question.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-vh-2">
      <div class="container">
        <div class="row g-4">
          <div class="col-12 col-lg-7">
            <h2 class="h4 fw-semibold">How We Can Help</h2>
            <p class="text-muted mb-0">
              We can help a newsroom assemble a scoped records brief around a
              department, officer, incident, or local accountability issue by
              organizing relevant site entries and linked public sources into a
              single working summary.
            </p>
          </div>
          <div class="col-12 col-lg-5">
            <div class="card shadow-sm rounded-0 border-dark h-100">
              <div class="card-body d-flex flex-column gap-3">
                <div class="text-uppercase small text-muted">Good fit</div>
                <ul class="list-unstyled mb-0 d-flex flex-column gap-2">
                  <li>Investigative or public-interest reporting teams.</li>
                  <li>
                    Editors who need a scoped records brief, not a product
                    pitch.
                  </li>
                  <li>
                    Stories where context across multiple records matters.
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-vh-2 bg-light border-top border-bottom border-dark">
      <div class="container">
        <h2 class="h4 fw-semibold mb-3">What we can help with now</h2>
        <p class="text-muted">
          The value is practical: gather what is already public, clarify how it
          connects, and reduce the time it takes to understand the record.
        </p>
        <div class="row g-4 mt-2">
          <div class="col-12 col-lg-4">
            <div class="card shadow-sm rounded-0 border-dark h-100">
              <div class="card-body d-flex flex-column gap-2">
                <p class="text-uppercase small text-muted mb-1">
                  Record review
                </p>
                <h3 class="h6 fw-semibold">Source gathering</h3>
                <ul class="list-unstyled mb-0 d-flex flex-column gap-2">
                  <li>
                    Pull together relevant site entries and linked public
                    materials.
                  </li>
                  <li>
                    Flag obvious gaps that still require independent reporting.
                  </li>
                </ul>
              </div>
            </div>
          </div>
          <div class="col-12 col-lg-4">
            <div class="card shadow-sm rounded-0 border-dark h-100">
              <div class="card-body d-flex flex-column gap-2">
                <p class="text-uppercase small text-muted mb-1">Context</p>
                <h3 class="h6 fw-semibold">Pattern review</h3>
                <ul class="list-unstyled mb-0 d-flex flex-column gap-2">
                  <li>
                    Show related reports, personnel, agencies, and civil cases
                    in one place.
                  </li>
                  <li>
                    Help distinguish one incident from a broader pattern when
                    the record supports it.
                  </li>
                </ul>
              </div>
            </div>
          </div>
          <div class="col-12 col-lg-4">
            <div class="card shadow-sm rounded-0 border-dark h-100">
              <div class="card-body d-flex flex-column gap-2">
                <p class="text-uppercase small text-muted mb-1">
                  Working output
                </p>
                <h3 class="h6 fw-semibold">Scoped brief</h3>
                <ul class="list-unstyled mb-0 d-flex flex-column gap-2">
                  <li>
                    Prepare a short summary of what the current record appears
                    to show.
                  </li>
                  <li>
                    Keep the brief narrow enough to be useful in an active
                    reporting cycle.
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-vh-2">
      <div class="container">
        <div class="row g-4 align-items-center">
          <div class="col-12 col-lg-7">
            <h2 class="h4 fw-semibold">What partnership looks like</h2>
            <ul class="list-unstyled mb-0 d-flex flex-column gap-2">
              <li>Tell us the reporting question, geography, and deadline.</li>
              <li>
                We respond with a scoped plan for what records or site data we
                can help organize.
              </li>
              <li>
                We do not replace reporting, legal review, or editorial
                judgment.
              </li>
            </ul>
          </div>
          <div class="col-12 col-lg-5">
            <div class="card shadow-sm rounded-0 border-dark">
              <div class="card-body d-flex flex-column gap-3">
                <div class="text-uppercase small text-muted">
                  Suggested next step
                </div>
                <p class="mb-0">
                  If you are working a story and want to know whether we can
                  help assemble a records brief, send the newsroom, topic, and
                  deadline.
                </p>
                <PrefillNavButton
                  class="btn btn-dark rounded-0"
                  to="/about/contact/"
                  payload={{
                    whoami: "Partner",
                    message:
                      "I am interested in a scoped records brief for a newsroom reporting project.",
                  }}
                >
                  Contact partnerships
                </PrefillNavButton>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
