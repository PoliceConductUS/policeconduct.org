---
import SiteLayout from "#src/layouts/SiteLayout.astro";
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import { buildWebPage, getSiteUrl } from "#src/lib/structured-data.js";

const pagePath = "/partner/academic/";
const pageDescription =
  "Work with PoliceConduct.org on scoped accountability research grounded in public records and documented site material.";
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(pagePath, siteUrl).toString();
const structuredData = buildWebPage({
  siteUrl,
  pageUrl,
  name: "Partnerships for Academic Researchers | PoliceConduct.org",
  description: pageDescription,
});
---

<SiteLayout
  title="Partnerships for Academic Researchers | PoliceConduct.org"
  description={pageDescription}
  pagePath={pagePath}
  structuredData={structuredData}
>
  <main class="flex-grow-1">
    <section class="py-vh-3 bg-gray-100 border-bottom border-dark">
      <div class="container">
        <Breadcrumbs
          items={[
            { label: "Partner", href: "/partner/" },
            { label: "Academic", href: pagePath, current: true },
          ]}
        />
        <div class="row g-4 align-items-end">
          <div class="col-12 col-lg-8">
            <p class="text-uppercase small text-muted mb-2">Partnership</p>
            <h1 class="display-4 fw-bold">For Academic Researchers</h1>
            <p class="lead text-muted mb-0">
              Work with PoliceConduct.org on scoped accountability research
              grounded in public records, documented site material, and a clear
              research question.
            </p>
          </div>
          <div class="col-12 col-lg-4">
            <div class="card shadow-sm rounded-0 border-dark">
              <div class="card-body d-flex flex-column gap-2">
                <div class="text-uppercase small text-muted">
                  What we can do now
                </div>
                <div class="fw-semibold">
                  Support scoped accountability research
                </div>
                <div class="text-muted small">
                  We can help researchers work with existing site records,
                  linked public materials, and defined research questions.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-vh-2">
      <div class="container">
        <div class="row g-4">
          <div class="col-12 col-lg-7">
            <h2 class="h4 fw-semibold">How We Can Help</h2>
            <p class="text-muted mb-0">
              We can support a defined research project by organizing relevant
              site records, linked public materials, and documentation methods
              around a narrow question.
            </p>
          </div>
          <div class="col-12 col-lg-5">
            <div class="card shadow-sm rounded-0 border-dark h-100">
              <div class="card-body d-flex flex-column gap-3">
                <div class="text-uppercase small text-muted">Good fit</div>
                <ul class="list-unstyled mb-0 d-flex flex-column gap-2">
                  <li>
                    Researchers with a clear topic, geography, and method.
                  </li>
                  <li>
                    Projects that need record organization more than speculative
                    features.
                  </li>
                  <li>
                    Academic work that can operate within public-record limits.
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-vh-2 bg-light border-top border-bottom border-dark">
      <div class="container">
        <h2 class="h4 fw-semibold mb-3">What we can help with now</h2>
        <p class="text-muted">
          The practical value is in structure and method: clarifying what
          records exist, how they are linked, and what the current public record
          can responsibly support.
        </p>
        <div class="row g-4">
          <div class="col-12 col-lg-6">
            <div class="card shadow-sm rounded-0 border-dark h-100">
              <div class="card-body d-flex flex-column gap-2">
                <p class="text-uppercase small text-muted mb-1">
                  Record mapping
                </p>
                <h3 class="h6 fw-semibold">Source inventory</h3>
                <p class="mb-0">
                  Identify which site entries, public documents, and related
                  records fit the research question.
                </p>
              </div>
            </div>
          </div>
          <div class="col-12 col-lg-6">
            <div class="card shadow-sm rounded-0 border-dark h-100">
              <div class="card-body d-flex flex-column gap-2">
                <p class="text-uppercase small text-muted mb-1">
                  Research support
                </p>
                <h3 class="h6 fw-semibold">Scoped collaboration</h3>
                <p class="mb-0">
                  Collaborate on a limited project, memo, or letter of support
                  where the deliverable is clear.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-vh-2">
      <div class="container">
        <h2 class="h4 fw-semibold mb-3">What partnership looks like</h2>
        <p class="text-muted mb-0">
          We start with a defined question and discuss whether the available
          public record is enough to support it. If it is, we scope the work. If
          it is not, we say so directly.
        </p>
      </div>
    </section>

    <section class="py-vh-2">
      <div class="container">
        <div
          class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3"
        >
          <div>
            <h2 class="h4 fw-semibold mb-1">Ready to partner on a project?</h2>
            <p class="text-muted mb-0">
              If you have a defined topic or grant proposal, we can discuss a
              scoped collaboration or a letter of support where appropriate.
            </p>
          </div>
          <a
            class="btn btn-dark rounded-0"
            href="/about/contact/"
            target="_self"
            data-prefill-key="prefill:contact"
            data-prefill-payload={JSON.stringify({
              whoami: "Partner",
              message:
                "I am interested in a scoped academic partnership or letter of support.",
            })}
          >
            Contact partnerships
          </a>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
