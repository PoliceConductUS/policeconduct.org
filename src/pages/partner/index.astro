---
import SiteLayout from "#src/layouts/SiteLayout.astro";
import Breadcrumbs from "#src/components/Breadcrumbs.astro";

const partnerTracks = [
  {
    slug: "media",
    title: "Media",
    summary:
      "Work with us on record review, source organization, and context for public-interest reporting.",
    badge: "Press",
  },
  {
    slug: "nonprofit",
    title: "Nonprofits",
    summary:
      "Use the public record in community education, advocacy, and issue-focused accountability work.",
    badge: "Community",
  },
  {
    slug: "academic",
    title: "Academic Researchers",
    summary:
      "Collaborate on scoped research questions that rely on public records and documented site material.",
    badge: "Research",
  },
  {
    slug: "law-firm",
    title: "Law Firms",
    summary:
      "Use PoliceConduct.org for public-record review, client reporting workflows, and case-oriented research support.",
    badge: "Legal",
  },
];
---

<SiteLayout
  title="Partnerships | PoliceConduct.org"
  description="Explore current partnership paths for newsrooms, nonprofits, academic researchers, and law firms."
  pagePath="/partner/"
>
  <main>
    <section class="py-vh-3 bg-gray-100 border-bottom border-dark">
      <div class="container">
        <div class="row g-4 align-items-end">
          <div class="col-12 col-lg-8">
            <Breadcrumbs
              items={[
                { label: "Home", href: "/" },
                { label: "Partner", href: "/partner/", current: true },
              ]}
              className="mb-2"
            />
            <p class="text-uppercase small text-muted mb-2">Partnerships</p>
            <h1 class="display-4 fw-bold">Partner with PoliceConduct.org</h1>
            <p class="lead text-muted mb-0">
              We currently focus on a small number of partnership paths where we
              can offer concrete help now: newsrooms, nonprofits, academic
              researchers, and law firms.
            </p>
          </div>
          <div class="col-12 col-lg-4">
            <div class="card shadow-sm rounded-0 border-dark h-100">
              <div class="card-body d-flex flex-column gap-3">
                <div class="text-uppercase small text-muted">
                  Start a conversation
                </div>
                <p class="mb-0">
                  If your organization is not listed below, you can still reach
                  out. We would rather keep this section narrow and credible
                  than publish a long list of speculative offers.
                </p>
                <div class="d-grid gap-2">
                  <a
                    class="btn btn-dark rounded-0"
                    href="/about/contact/"
                    target="_self"
                    data-prefill-key="prefill:contact"
                    data-prefill-payload={JSON.stringify({
                      whoami: "Partner",
                      message:
                        "I want to discuss a partnership with PoliceConduct.org.",
                    })}
                  >
                    Contact partnerships
                  </a>
                </div>
                <p class="text-muted small mb-0">
                  Prefer email? Reach us at hello@policeconduct.org and include
                  your organization, role, and the work you want to discuss.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-vh-2">
      <div class="container">
        <div class="row row-cols-1 row-cols-md-2 g-3">
          {
            partnerTracks.map((track) => (
              <div class="col">
                <article class="card h-100 shadow-sm border-0 rounded-0">
                  <div class="card-body d-flex flex-column gap-3">
                    <div>
                      <span class="badge bg-dark rounded-0">{track.badge}</span>
                    </div>
                    <div>
                      <h2 class="h5 mb-2">
                        <a
                          class="link-dark text-decoration-none stretched-link"
                          href={`/partner/${track.slug}/`}
                        >
                          {track.title}
                        </a>
                      </h2>
                      <p class="text-muted mb-0">{track.summary}</p>
                    </div>
                  </div>
                </article>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
