---
import CivicAgencyHierarchyPage from "#src/components/CivicAgencyHierarchyPage.astro";
import {
  buildFederalAgencyTopicIndexModel,
  loadFederalAgencySummaries,
} from "#src/lib/data/federal-agencies.js";

const federalAgencies = await loadFederalAgencySummaries();
const model = buildFederalAgencyTopicIndexModel(
  federalAgencies,
  "outcomes-by-income",
);
---

<CivicAgencyHierarchyPage model={model} site={Astro.site} />
