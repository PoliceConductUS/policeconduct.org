---
import ReportArchivePage from "#src/components/ReportArchivePage.astro";
import { buildReportArchiveStaticPaths } from "#src/lib/data/report-archives.js";
import { loadReportSummaries } from "#src/lib/data/summaries.js";

export async function getStaticPaths() {
  return buildReportArchiveStaticPaths(await loadReportSummaries(), "county");
}

const { breadcrumbs, pagePath, reports, title } = Astro.props;
---

<ReportArchivePage
  breadcrumbs={breadcrumbs}
  pagePath={pagePath}
  reports={reports}
  title={title}
/>
