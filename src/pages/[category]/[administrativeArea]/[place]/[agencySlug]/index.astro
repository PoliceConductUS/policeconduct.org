---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import DataPanel from "#src/components/DataPanel.astro";
import EntityActionButton from "#src/components/EntityActionButton.astro";
import EntityPageHeader from "#src/components/EntityPageHeader.astro";
import MetricGrid from "#src/components/MetricGrid.astro";
import OutcomesByIncomePanel from "#src/components/OutcomesByIncomePanel.astro";
import PrefillBootstrap from "#src/components/PrefillBootstrap.astro";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import {
  loadAgencyDetailByRouteParams,
  loadAgencyLocationStaticPaths,
} from "#src/lib/data/agency-detail.js";
import { getSiteUrl } from "#src/lib/structured-data.js";
import { metricVisuals } from "#src/lib/metric-vocabulary.js";

export async function getStaticPaths() {
  return loadAgencyLocationStaticPaths();
}

const data = await loadAgencyDetailByRouteParams(Astro.params);

const {
  agencyName,
  agencyState,
  categorySlug,
  categoryLabel,
  agencyPath,
  administrativeArea,
  placeLabel,
  placePath,
  civilCases,
  counts,
} = data;
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(agencyPath, siteUrl).toString();
const profilePageId = `${pageUrl}#profilepage`;
const pageDescription = `${agencyName} agency profile with contact information, personnel, public reports, and recent civil litigation references.`;
const personnelIndexPath = `${agencyPath}personnel/`;
const reportsIndexPath = `${agencyPath}reports/`;
const budgetIndexPath = `${agencyPath}budget/`;
const civilCasesIndexPath = `${agencyPath}civil-cases/`;
const liabilityCostsIndexPath = `${agencyPath}liability-costs/`;
const outcomesByIncomePath = `${agencyPath}outcomes-by-income/`;
const civilCaseTotal = counts.civilCases + counts.personnelLinkedCivilCases;
const addressAvailable =
  data.agency.address ||
  data.agency.city ||
  agencyState ||
  data.agency.zip_code;
const address = addressAvailable
  ? {
      "@type": "PostalAddress",
      addressCountry: "US",
      ...(data.agency.address ? { streetAddress: data.agency.address } : {}),
      ...(data.agency.city ? { addressLocality: data.agency.city } : {}),
      addressRegion: agencyState,
      ...(data.agency.zip_code ? { postalCode: data.agency.zip_code } : {}),
    }
  : null;
const contactPoints = data.agencyPhones.map(
  (phone: { phone_number: string; label?: string | null }) => ({
    "@type": "ContactPoint",
    telephone: phone.phone_number,
    ...(phone.label ? { contactType: phone.label } : {}),
  }),
);
const sameAs = data.agencyLinks
  .map((link: { url?: string | null }) => link.url)
  .filter(Boolean);
const federalAgency = data.federalAgency
  ? {
      name: data.federalAgency.name,
      path: `/federal/${data.federalAgency.slug}/`,
    }
  : null;
const formatNumber = (value: number) => value.toLocaleString("en-US");
const toDisplayName = (value: string) =>
  value === value.toUpperCase()
    ? value
        .toLocaleLowerCase("en-US")
        .replace(/\b[a-z]/g, (letter) => letter.toLocaleUpperCase("en-US"))
    : value;
const agencyDisplayName = toDisplayName(agencyName);
const getYear = (value: string | null | undefined) => {
  if (!value) return null;
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return null;
  return String(date.getUTCFullYear());
};
const buildYearSeries = (
  records: Record<string, string | null | undefined>[],
  dateKey: string,
) => {
  const countsByYear = new Map<string, number>();
  records.forEach((record) => {
    const year = getYear(record[dateKey]);
    if (year) countsByYear.set(year, (countsByYear.get(year) || 0) + 1);
  });
  return [...countsByYear.entries()]
    .sort(([left], [right]) => left.localeCompare(right))
    .slice(-7)
    .map(([year, value]) => ({ label: year, value }));
};
const civilCasesByYear = buildYearSeries(
  civilCases as Record<string, string | null | undefined>[],
  "filed_date",
);
const maxYearValue = Math.max(
  1,
  ...civilCasesByYear.map((point) => point.value),
);
const getPlotLeft = (index: number, total: number) =>
  total <= 1 ? 50 : 8 + (index / (total - 1)) * 84;
const getPlotTop = (value: number, max: number) => 90 - (value / max) * 76;
const getLinePoints = (series: { label: string; value: number }[]) =>
  series
    .map(
      (point, index) =>
        `${getPlotLeft(index, series.length)},${getPlotTop(
          point.value,
          maxYearValue,
        )}`,
    )
    .join(" ");
const organization = {
  "@type": "GovernmentOrganization",
  "@id": `${pageUrl}#organization`,
  name: agencyName,
  url: pageUrl,
  mainEntityOfPage: { "@id": profilePageId },
  ...(address ? { address } : {}),
  ...(data.agency.contact_email ? { email: data.agency.contact_email } : {}),
  ...(contactPoints.length ? { contactPoint: contactPoints } : {}),
  ...(sameAs.length ? { sameAs } : {}),
  areaServed: { "@type": "AdministrativeArea", name: agencyState },
};
const websiteId = new URL("/", siteUrl).toString();
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": websiteId,
      url: websiteId,
      name: "PoliceConduct.org",
    },
    {
      "@type": "ProfilePage",
      "@id": profilePageId,
      url: pageUrl,
      name: `${agencyName} | PoliceConduct.org`,
      description: pageDescription,
      isPartOf: { "@id": websiteId },
      mainEntity: { "@id": organization["@id"] },
      ...(data.agency.updated_at
        ? { dateModified: String(data.agency.updated_at) }
        : {}),
    },
    organization,
  ],
};
const agencyMetrics = [
  {
    accent: metricVisuals.personnel.accent,
    action: {
      href: personnelIndexPath,
      kind: "link",
      label: "View details",
    },
    detail: "Active / total",
    icon: metricVisuals.personnel.icon,
    label: metricVisuals.personnel.label,
    value: `${formatNumber(counts.currentPersonnel)} active / ${formatNumber(
      counts.personnel,
    )} total`,
  },
  {
    accent: metricVisuals.budget.accent,
    action: {
      href: budgetIndexPath,
      kind: "link",
      label: "View details",
    },
    detail: "Fiscal year agency budget",
    icon: metricVisuals.budget.icon,
    label: metricVisuals.budget.label,
    value: "$--",
  },
  {
    accent: metricVisuals.reports.accent,
    action: {
      href: reportsIndexPath,
      kind: "link",
      label: "View details",
    },
    detail: "Published public reports",
    icon: metricVisuals.reports.icon,
    label: metricVisuals.reports.label,
    value: formatNumber(counts.reports),
  },
  {
    accent: metricVisuals.civilCases.accent,
    action: {
      href: civilCasesIndexPath,
      kind: "link",
      label: "View details",
    },
    detail: "Direct and personnel-linked civil cases",
    icon: metricVisuals.civilCases.icon,
    label: metricVisuals.civilCases.label,
    value: formatNumber(civilCaseTotal),
  },
  {
    accent: metricVisuals.liabilityCosts.accent,
    action: {
      href: liabilityCostsIndexPath,
      kind: "link",
      label: "View details",
    },
    detail: "Claims, settlements, judgments, and related costs",
    icon: metricVisuals.liabilityCosts.icon,
    label: metricVisuals.liabilityCosts.label,
    value: "$--",
  },
] as const;
---

<SiteLayout
  title={`${agencyName} | PoliceConduct.org`}
  description={pageDescription}
  pagePath={agencyPath}
  structuredData={structuredData}
>
  <PrefillBootstrap />
  <main class="agency-overview-page flex-grow-1">
    <section class="agency-overview">
      <div class="container">
        <Breadcrumbs
          items={[
            { label: "Home", href: "/" },
            { label: categoryLabel, href: `/${categorySlug}/` },
            {
              label: administrativeArea,
              href: `/${categorySlug}/${data.administrativeAreaSlug}/`,
            },
            {
              label: placeLabel,
              href: placePath,
            },
            { label: agencyDisplayName, href: agencyPath, current: true },
          ]}
        />
        <EntityPageHeader
          title={agencyDisplayName}
          description={`${placeLabel}, ${administrativeArea}, ${agencyState}`}
        >
            {
              federalAgency ? (
                <p class="agency-overview-federal">
                  <span>Federal agency</span>
                  <a href={federalAgency.path}>{federalAgency.name}</a>
                </p>
              ) : null
            }
          <Fragment slot="actions">
            <EntityActionButton data-agency-share>
              <svg
                aria-hidden="true"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="18" cy="5" r="3"></circle>
                <circle cx="6" cy="12" r="3"></circle>
                <circle cx="18" cy="19" r="3"></circle>
                <path d="m8.59 13.51 6.83 3.98"></path>
                <path d="m15.41 6.51-6.82 3.98"></path>
              </svg>
              Share
            </EntityActionButton>
            <EntityActionButton
              className="entity-action-primary"
              data-agency-download-report
            >
              <svg
                aria-hidden="true"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <path d="M7 10l5 5 5-5"></path>
                <path d="M12 15V3"></path>
              </svg>
              Download Report
            </EntityActionButton>
            <span class="agency-coming-soon" data-agency-coming-soon></span>
          </Fragment>
        </EntityPageHeader>

        <MetricGrid metrics={agencyMetrics} columns="auto" />

        <div class="entity-chart-grid">
          <OutcomesByIncomePanel href={outcomesByIncomePath} />
          <DataPanel
            title="Arrests Over Time"
            description="Number of arrests by category"
          >
            <div class="agency-line-chart">
              <svg viewBox="0 0 100 100" preserveAspectRatio="none">
                <path class="agency-grid-line" d="M8 14H96"></path>
                <path class="agency-grid-line" d="M8 38H96"></path>
                <path class="agency-grid-line" d="M8 62H96"></path>
                <path class="agency-grid-line" d="M8 86H96"></path>
                <path class="agency-axis-line" d="M8 8V90H96"></path>
              </svg>
            </div>
          </DataPanel>
          <DataPanel
            title="Killings Over Time"
            description="People by age group, dogs and other animals"
          >
            <div class="agency-line-chart">
              <div class="agency-chart-legend">
                <span><i class="agency-dot-blue"></i>Under 18</span>
                <span><i class="agency-dot-green"></i>18+</span>
                <span><i class="agency-dot-purple"></i>Unknown age</span>
                <span><i class="agency-dot-orange"></i>Dogs</span>
                <span><i class="agency-dot-gold"></i>Other animals</span>
              </div>
              <svg viewBox="0 0 100 100" preserveAspectRatio="none">
                <path class="agency-grid-line" d="M8 14H96"></path>
                <path class="agency-grid-line" d="M8 38H96"></path>
                <path class="agency-grid-line" d="M8 62H96"></path>
                <path class="agency-grid-line" d="M8 86H96"></path>
                <path class="agency-axis-line" d="M8 8V90H96"></path>
              </svg>
            </div>
          </DataPanel>
          <DataPanel
            title="Use of Force Over Time"
            description="Number of use of force incidents"
          >
            <div class="agency-line-chart">
              <svg viewBox="0 0 100 100" preserveAspectRatio="none">
                <path class="agency-grid-line" d="M8 14H96"></path>
                <path class="agency-grid-line" d="M8 38H96"></path>
                <path class="agency-grid-line" d="M8 62H96"></path>
                <path class="agency-grid-line" d="M8 86H96"></path>
                <path class="agency-axis-line" d="M8 8V90H96"></path>
              </svg>
            </div>
          </DataPanel>
          <DataPanel
            id="agency-liability-costs"
            title="Civil Cases and Liability Costs Over Time"
            description="Civil cases and liability costs"
          >
            <div class="agency-line-chart">
              <svg viewBox="0 0 100 100" preserveAspectRatio="none">
                <path class="agency-grid-line" d="M8 14H96"></path>
                <path class="agency-grid-line" d="M8 38H96"></path>
                <path class="agency-grid-line" d="M8 62H96"></path>
                <path class="agency-grid-line" d="M8 86H96"></path>
                <path class="agency-axis-line" d="M8 8V90H96"></path>
                {
                  civilCasesByYear.length ? (
                    <polyline
                      class="agency-line agency-line-green"
                      points={getLinePoints(civilCasesByYear)}
                    />
                  ) : null
                }
              </svg>
              <div class="agency-chart-labels">
                {civilCasesByYear.map((point) => <span>{point.label}</span>)}
              </div>
            </div>
          </DataPanel>
          <DataPanel
            title="Racial Breakdown of Stops or Arrests"
            description="Who is most affected in the current dataset"
          >
            <table>
              <thead>
                <tr>
                  <th scope="col">Race / Ethnicity</th>
                  <th scope="col">Stops %</th>
                  <th scope="col">Arrests %</th>
                </tr>
              </thead>
              <tbody>
                <tr><th scope="row">White</th><td></td><td></td></tr>
                <tr
                  ><th scope="row">Black or African American</th><td></td><td
                  ></td></tr
                >
                <tr
                  ><th scope="row">Hispanic or Latino</th><td></td><td></td></tr
                >
                <tr><th scope="row">Asian</th><td></td><td></td></tr>
                <tr><th scope="row">Other / Unknown</th><td></td><td></td></tr>
              </tbody>
            </table>
          </DataPanel>
          <DataPanel
            title="Daylight vs Nighttime Stops"
            description="Comparison of stops by time of day and race"
          >
            <div class="agency-stacked-bars" aria-hidden="true">
              {
                [
                  "White",
                  "Black or African American",
                  "Hispanic or Latino",
                  "Other / Unknown",
                ].map((label) => (
                  <div>
                    <i>
                      <>
                        <b />
                        <b />
                      </>
                    </i>
                    <span>{label}</span>
                  </div>
                ))
              }
            </div>
          </DataPanel>
          <DataPanel
            title="Top Charge Categories"
            description="Most common reasons for arrest"
          >
            <div class="agency-source-bars">
              {
                [
                  "Traffic Offenses",
                  "Theft",
                  "Assault",
                  "Possession",
                  "DWI",
                ].map((label) => (
                  <div class="agency-source-bar">
                    <span>{label}</span>
                    <i>
                      <b style="width: 0%" />
                    </i>
                    <strong />
                  </div>
                ))
              }
            </div>
          </DataPanel>
          <DataPanel
            id="agency-budget-trend"
            title="Budget and Overtime Trend"
            description="Total budget and overtime spending"
          >
            <div class="agency-line-chart">
              <svg viewBox="0 0 100 100" preserveAspectRatio="none">
                <path class="agency-grid-line" d="M8 14H96"></path>
                <path class="agency-grid-line" d="M8 38H96"></path>
                <path class="agency-grid-line" d="M8 62H96"></path>
                <path class="agency-grid-line" d="M8 86H96"></path>
                <path class="agency-axis-line" d="M8 8V90H96"></path>
              </svg>
            </div>
          </DataPanel>
        </div>
      </div>
    </section>
  </main>
  <style>
    .agency-overview-page {
      background: #f7f9fd;
      color: #071842;
    }

    .agency-overview {
      background: #fbfcff;
      border-bottom: 1px solid #d9e1ee;
      min-height: calc(100vh - 3.25rem);
      padding: 1.35rem 0 clamp(2.5rem, 5vw, 4rem);
    }

    .agency-overview > .container {
      max-width: 1240px;
    }

    .agency-overview :global(.breadcrumb) {
      margin-bottom: 1.15rem;
    }

    .agency-overview-heading {
      align-items: start;
      display: grid;
      gap: 1.5rem;
      grid-template-columns: minmax(0, 1fr);
      margin-bottom: 1.25rem;
    }

    .agency-overview-heading h1 {
      color: #071842;
      margin: 0 0 0.45rem;
    }

    .agency-overview-heading p {
      color: #33456f;
      margin: 0;
    }

    .agency-overview-federal {
      align-items: baseline;
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin-top: 0.75rem;
    }

    .agency-overview-federal span {
      color: #5a6684;
      font-size: 0.76rem;
      font-weight: 800;
      text-transform: uppercase;
    }

    .agency-overview-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      justify-content: start;
    }

    .agency-overview-action {
      align-items: center;
      background: #fbfcff;
      border: 1px solid #c9d4e6;
      border-radius: 0.4rem;
      color: #071842;
      display: inline-flex;
      font-size: 0.95rem;
      font-weight: 700;
      gap: 0.6rem;
      min-height: 3rem;
      padding: 0.72rem 1.05rem;
      text-decoration: none;
    }

    .agency-overview-action svg {
      height: 1.15rem;
      width: 1.15rem;
    }

    .agency-overview-primary {
      background: #071842;
      border-color: #071842;
      color: #f8faff;
      padding-inline: 1.35rem;
    }

    .agency-coming-soon {
      color: #33456f;
      display: block;
      flex-basis: 100%;
      font-size: 0.82rem;
      font-weight: 700;
      min-height: 1.15rem;
      text-align: right;
    }

    .agency-metric-grid {
      display: grid;
      gap: 1rem;
      grid-template-columns: minmax(0, 1fr);
    }

    .agency-metric-grid {
      margin-bottom: 1rem;
    }

    .agency-metric-card {
      background: #fbfcff;
      border: 1px solid #d5deeb;
      border-radius: 0.45rem;
      box-shadow: 0 1px 2px rgba(7, 24, 66, 0.04);
    }

    .agency-metric-card {
      display: grid;
      gap: 0.95rem;
      grid-template-columns: 3rem minmax(0, 1fr);
      min-height: 8.8rem;
      padding: 1rem 1.15rem;
    }

    .agency-metric-icon {
      height: 2.7rem;
      margin-top: 0.35rem;
      width: 2.7rem;
    }

    .agency-metric-icon-blue {
      color: #174bff;
    }

    .agency-metric-icon-green {
      color: #087f3b;
    }

    .agency-metric-icon-purple {
      color: #5b2df5;
    }

    .agency-metric-card p {
      color: #071842;
      font-size: 0.95rem;
      font-weight: 700;
      line-height: 1.25;
      margin: 0;
    }

    .agency-metric-card strong {
      color: #071842;
      display: block;
      font-size: 1.5rem;
      font-variant-numeric: tabular-nums;
      line-height: 1.1;
      margin: 0.25rem 0 0.35rem;
    }

    .agency-metric-card span {
      color: #33456f;
      display: block;
      font-size: 0.88rem;
      font-weight: 500;
    }

    .agency-metric-card a,
    .agency-inline-action,
    .agency-action-link {
      color: #064cfb;
      font-weight: 700;
      text-decoration: none;
    }

    .agency-metric-card a::after,
    .agency-action-link::after {
      content: " ->";
    }

    .agency-line-chart {
      display: grid;
      gap: 0.5rem;
      margin-top: 1rem;
      min-height: 11rem;
    }

    .agency-line-chart svg {
      height: 9.3rem;
      overflow: visible;
      width: 100%;
    }

    .agency-grid-line,
    .agency-axis-line {
      fill: none;
      vector-effect: non-scaling-stroke;
    }

    .agency-grid-line {
      stroke: #d9e1ee;
      stroke-width: 1;
    }

    .agency-axis-line {
      stroke: #b8c4d8;
      stroke-width: 1.15;
    }

    .agency-line {
      fill: none;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-width: 2.5;
      vector-effect: non-scaling-stroke;
    }

    .agency-line-blue {
      stroke: #174bff;
    }

    .agency-line-green {
      stroke: #087f3b;
    }

    .agency-chart-labels {
      color: #33456f;
      display: flex;
      font-size: 0.75rem;
      justify-content: space-between;
      min-height: 1rem;
    }

    .agency-chart-legend {
      display: flex;
      flex-wrap: wrap;
      gap: 0.8rem;
      margin-bottom: 0.35rem;
    }

    .agency-chart-legend span {
      align-items: center;
      color: #33456f;
      display: inline-flex;
      font-size: 0.75rem;
      font-weight: 700;
      gap: 0.3rem;
    }

    .agency-chart-legend i {
      border-radius: 999px;
      display: inline-block;
      height: 0.42rem;
      width: 0.42rem;
    }

    .agency-dot-blue {
      background: #174bff;
    }

    .agency-dot-green {
      background: #087f3b;
    }

    .agency-dot-purple {
      background: #5b2df5;
    }

    .agency-dot-orange {
      background: #ffad1f;
    }

    .agency-dot-gold {
      background: #a66f00;
    }

    .agency-horizontal-bars,
    .agency-source-bars {
      display: grid;
      gap: 0.75rem;
      margin-top: 1.15rem;
    }

    .agency-horizontal-bar,
    .agency-source-bar {
      align-items: center;
      display: grid;
      gap: 0.75rem;
      grid-template-columns: minmax(5.5rem, 0.8fr) minmax(7rem, 2fr) auto;
    }

    .agency-horizontal-bar span,
    .agency-source-bar span,
    .agency-horizontal-bar strong,
    .agency-source-bar strong {
      color: #071842;
      font-size: 0.82rem;
      font-weight: 700;
    }

    .agency-horizontal-bar i,
    .agency-source-bar i {
      background: #e7edf7;
      display: block;
      height: 0.78rem;
    }

    .agency-horizontal-bar b,
    .agency-source-bar b {
      background: #174bff;
      display: block;
      height: 100%;
    }

    .agency-source-bar b {
      background: #087f3b;
    }

    .agency-action-list {
      display: grid;
      gap: 0.55rem;
      margin-top: 0.9rem;
    }

    .agency-action-link {
      border-top: 1px solid #d9e1ee;
      display: block;
      font-size: 0.84rem;
      padding-top: 0.55rem;
    }

    @media (min-width: 768px) {
      .agency-metric-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

    }

    @media (min-width: 1200px) {
      .agency-overview-heading {
        align-items: start;
        grid-template-columns: minmax(0, 1fr) auto;
      }

      .agency-overview-actions {
        justify-content: end;
      }

      .agency-metric-grid {
        grid-template-columns: repeat(4, minmax(0, 1fr));
      }

    }

    .agency-stacked-bars {
      display: grid;
      gap: 0.75rem;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      margin-top: 1.25rem;
    }

    .agency-stacked-bars div {
      display: grid;
      gap: 0.5rem;
      min-width: 0;
      text-align: center;
    }

    .agency-stacked-bars i {
      align-items: end;
      border-bottom: 1px solid #b8c4d8;
      display: flex;
      height: 6.5rem;
      justify-content: center;
    }

    .agency-stacked-bars b {
      display: block;
      width: 2.2rem;
    }

    .agency-stacked-bars b:first-child {
      background: #ffad1f;
      height: 0;
    }

    .agency-stacked-bars b:last-child {
      background: #071842;
      height: 0;
    }

    .agency-stacked-bars span {
      color: #33456f;
      font-size: 0.75rem;
      line-height: 1.15;
    }

    @media (max-width: 991.98px) {
    }

    @media (max-width: 575.98px) {
      .agency-overview-action {
        justify-content: center;
        width: 100%;
      }

      .agency-metric-card {
        grid-template-columns: minmax(0, 1fr);
      }

      .agency-horizontal-bar,
      .agency-source-bar {
        grid-template-columns: minmax(0, 1fr);
      }

      .agency-coming-soon {
        text-align: left;
      }
    }
  </style>
  <script>
    import AOS from "aos";
    import "aos/dist/aos.css";

    if (!document.documentElement.dataset.aosInit) {
      AOS.init({
        duration: 800,
        once: true,
      });
      document.documentElement.dataset.aosInit = "1";
    }

    const setComingSoon = (button: Element, message: string) => {
      const actions = button.closest(".agency-overview-actions");
      const output = actions?.querySelector("[data-agency-coming-soon]");
      if (output) output.textContent = message;
    };

    const trackAgencyInterest = (eventName: string) => {
      window.__IPC_ANALYTICS__?.track?.(eventName, {
        agency_path: window.location.pathname,
        page_path: window.location.pathname,
      });
    };

    document.querySelectorAll("[data-agency-share]").forEach((button) => {
      button.addEventListener("click", () => {
        trackAgencyInterest("agency_share_interest");
        setComingSoon(button, "Sharing tools are coming soon.");
      });
    });

    document
      .querySelectorAll("[data-agency-download-report]")
      .forEach((button) => {
        button.addEventListener("click", () => {
          trackAgencyInterest("agency_report_download_interest");
          setComingSoon(button, "Downloadable agency reports are coming soon.");
        });
      });
  </script>
</SiteLayout>
