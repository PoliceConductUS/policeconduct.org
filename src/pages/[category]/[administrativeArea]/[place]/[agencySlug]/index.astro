---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import PrefillBootstrap from "#src/components/PrefillBootstrap.astro";
import PrefillNavButton from "#src/components/PrefillNavButton.astro";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import DisqusComments from "#src/components/DisqusComments.astro";
import {
  loadAgencyDetail,
  loadAgencyLocationStaticPaths,
} from "#src/lib/data/agency-detail.js";
import type { ReportNewPrefill } from "#src/lib/forms/prefill";
import { getSiteUrl } from "#src/lib/structured-data.js";

export async function getStaticPaths() {
  return loadAgencyLocationStaticPaths();
}

const { agencyId } = Astro.props;
const data = await loadAgencyDetail(agencyId);

const {
  agencyName,
  agencyState,
  agencySlug,
  categorySlug,
  categoryLabel,
  agencyPath,
  administrativeArea,
  placeLabel,
  placePath,
  civilCases,
  reportedReports,
  counts,
} = data;
const agencyLinksSummary = data.agencyLinks
  .map((link: { url?: string | null; label?: string | null }) =>
    [link.label || null, link.url || null].filter(Boolean).join(" — "),
  )
  .filter(Boolean)
  .join("\n");
const primaryWebsite =
  data.agencyLinks.find((link: { url?: string | null }) =>
    /^https?:\/\//i.test(link.url || ""),
  )?.url || "";
const civilLitigationSummary = civilCases
  .map((record) => {
    const segments = [
      record.title || "Civil case",
      record.cause_number || null,
      record.court || null,
      record.caseUrl,
    ];
    return segments.filter(Boolean).join(" — ");
  })
  .join("\n");
const reportLinksSummary = reportedReports
  .map((report) => report.url)
  .join("\n");
const reportNewPrefillPayload = JSON.stringify({
  officer: {
    department: agencyName,
  },
} satisfies ReportNewPrefill);
const addCivilCaseHref = "/civil-litigation/new/";
const addCivilCasePrefillPayload = JSON.stringify({
  jurisdiction: categorySlug,
  defendants: agencyName,
  summary: `${agencyName} agency profile: ${agencyPath}`,
  links: [
    agencyPath,
    ...reportedReports.slice(0, 3).map((report) => report.url),
  ]
    .filter(Boolean)
    .join("\n"),
});
const suggestEditHref = "/law-enforcement-agency/suggest-edit/";
const suggestEditPrefillPayload = JSON.stringify({
  agencyPath,
  agencyName,
  jurisdiction: categorySlug,
  departmentWebsite: primaryWebsite,
  departmentHead: data.agency.contact_name || "",
  socialLinks: agencyLinksSummary,
  civilLitigation: civilLitigationSummary,
});
const suggestPersonnelHref = "/personnel/new/";
const suggestPersonnelPrefillPayload = JSON.stringify({
  currentAgency: agencyName,
  currentAgencyCity: data.agency.city || "",
  currentAgencyState: agencyState,
  civilLitigation: civilLitigationSummary,
  reportLinks: reportLinksSummary,
});
const claimProfileHref = "/about/contact/";
const claimProfilePrefillPayload = JSON.stringify({
  whoami: "Profile Owner",
  message: `I would like to claim ownership of this profile.\nProfile path: ${agencyPath}`,
});
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(agencyPath, siteUrl).toString();
const profilePageId = `${pageUrl}#profilepage`;
const disqusIdentifier = `agency:${agencySlug}`;
const pageDescription = `${agencyName} agency profile with contact information, personnel, public reports, and recent civil litigation references.`;
const personnelIndexPath = `${agencyPath}personnel/`;
const budgetIndexPath = `${agencyPath}budget/`;
const civilCasesIndexPath = `${agencyPath}civil-cases/`;
const liabilityCostsIndexPath = `${agencyPath}liability-costs/`;
const addressAvailable =
  data.agency.address ||
  data.agency.city ||
  agencyState ||
  data.agency.zip_code;
const address = addressAvailable
  ? {
      "@type": "PostalAddress",
      addressCountry: "US",
      ...(data.agency.address ? { streetAddress: data.agency.address } : {}),
      ...(data.agency.city ? { addressLocality: data.agency.city } : {}),
      addressRegion: agencyState,
      ...(data.agency.zip_code ? { postalCode: data.agency.zip_code } : {}),
    }
  : null;
const contactPoints = data.agencyPhones.map(
  (phone: { phone_number: string; label?: string | null }) => ({
    "@type": "ContactPoint",
    telephone: phone.phone_number,
    ...(phone.label ? { contactType: phone.label } : {}),
  }),
);
const sameAs = data.agencyLinks
  .map((link: { url?: string | null }) => link.url)
  .filter(Boolean);
const federalAgency = data.federalAgency
  ? {
      name: data.federalAgency.name,
      path: `/federal/${data.federalAgency.slug}/`,
    }
  : null;
const formatNumber = (value: number) => value.toLocaleString("en-US");
const toDisplayName = (value: string) =>
  value === value.toUpperCase()
    ? value
        .toLocaleLowerCase("en-US")
        .replace(/\b[a-z]/g, (letter) => letter.toLocaleUpperCase("en-US"))
    : value;
const agencyDisplayName = toDisplayName(agencyName);
const getYear = (value: string | null | undefined) => {
  if (!value) return null;
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return null;
  return String(date.getUTCFullYear());
};
const buildYearSeries = (
  records: Record<string, string | null | undefined>[],
  dateKey: string,
) => {
  const countsByYear = new Map<string, number>();
  records.forEach((record) => {
    const year = getYear(record[dateKey]);
    if (year) countsByYear.set(year, (countsByYear.get(year) || 0) + 1);
  });
  return [...countsByYear.entries()]
    .sort(([left], [right]) => left.localeCompare(right))
    .slice(-7)
    .map(([year, value]) => ({ label: year, value }));
};
const civilCasesByYear = buildYearSeries(
  civilCases as Record<string, string | null | undefined>[],
  "filed_date",
);
const maxYearValue = Math.max(
  1,
  ...civilCasesByYear.map((point) => point.value),
);
const getPlotLeft = (index: number, total: number) =>
  total <= 1 ? 50 : 8 + (index / (total - 1)) * 84;
const getPlotTop = (value: number, max: number) => 90 - (value / max) * 76;
const getLinePoints = (series: { label: string; value: number }[]) =>
  series
    .map(
      (point, index) =>
        `${getPlotLeft(index, series.length)},${getPlotTop(
          point.value,
          maxYearValue,
        )}`,
    )
    .join(" ");
const organization = {
  "@type": "GovernmentOrganization",
  "@id": `${pageUrl}#organization`,
  name: agencyName,
  url: pageUrl,
  mainEntityOfPage: { "@id": profilePageId },
  ...(address ? { address } : {}),
  ...(data.agency.contact_email ? { email: data.agency.contact_email } : {}),
  ...(contactPoints.length ? { contactPoint: contactPoints } : {}),
  ...(sameAs.length ? { sameAs } : {}),
  areaServed: { "@type": "AdministrativeArea", name: agencyState },
};
const websiteId = new URL("/", siteUrl).toString();
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": websiteId,
      url: websiteId,
      name: "PoliceConduct.org",
    },
    {
      "@type": "ProfilePage",
      "@id": profilePageId,
      url: pageUrl,
      name: `${agencyName} | PoliceConduct.org`,
      description: pageDescription,
      isPartOf: { "@id": websiteId },
      mainEntity: { "@id": organization["@id"] },
      ...(data.agency.updated_at
        ? { dateModified: String(data.agency.updated_at) }
        : {}),
    },
    organization,
  ],
};
---

<SiteLayout
  title={`${agencyName} | PoliceConduct.org`}
  description={pageDescription}
  pagePath={agencyPath}
  structuredData={structuredData}
>
  <PrefillBootstrap />
  <main class="agency-overview-page flex-grow-1">
    <section class="agency-overview">
      <div class="container">
        <Breadcrumbs
          items={[
            { label: "Home", href: "/" },
            { label: categoryLabel, href: `/${categorySlug}/` },
            {
              label: administrativeArea,
              href: `/${categorySlug}/${data.administrativeAreaSlug}/`,
            },
            {
              label: placeLabel,
              href: placePath,
            },
            { label: agencyDisplayName, href: agencyPath, current: true },
          ]}
        />
        <div class="agency-overview-heading">
          <div>
            <h1>{agencyDisplayName}</h1>
            <p>
              {placeLabel}, {administrativeArea}, {agencyState}
            </p>
            {
              federalAgency ? (
                <p class="agency-overview-federal">
                  <span>Federal agency</span>
                  <a href={federalAgency.path}>{federalAgency.name}</a>
                </p>
              ) : null
            }
          </div>
          <div class="agency-overview-actions">
            <button
              type="button"
              class="agency-overview-action"
              data-agency-share
            >
              <svg
                aria-hidden="true"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="18" cy="5" r="3"></circle>
                <circle cx="6" cy="12" r="3"></circle>
                <circle cx="18" cy="19" r="3"></circle>
                <path d="m8.59 13.51 6.83 3.98"></path>
                <path d="m15.41 6.51-6.82 3.98"></path>
              </svg>
              Share
            </button>
            <button
              type="button"
              class="agency-overview-action agency-overview-primary"
              data-agency-download-report
            >
              <svg
                aria-hidden="true"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <path d="M7 10l5 5 5-5"></path>
                <path d="M12 15V3"></path>
              </svg>
              Download Report
            </button>
            <span class="agency-coming-soon" data-agency-coming-soon></span>
          </div>
        </div>

        <div class="agency-metric-grid">
          <article class="agency-metric-card">
            <svg
              aria-hidden="true"
              class="agency-metric-icon agency-metric-icon-blue"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
            <div>
              <p>Personnel</p>
              <strong>
                {formatNumber(counts.currentPersonnel)} active /{" "}
                {formatNumber(counts.personnel)} total
              </strong>
              <span>Active officers and total tracked personnel history</span>
              <a href={personnelIndexPath}>View details</a>
            </div>
          </article>
          <article class="agency-metric-card">
            <svg
              aria-hidden="true"
              class="agency-metric-icon agency-metric-icon-green"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"></path>
              <path d="M12 6v12"></path>
            </svg>
            <div>
              <p>Annual Budget</p>
              <strong>$0</strong>
              <span>Fiscal year agency budget</span>
              <a href={budgetIndexPath}>View details</a>
            </div>
          </article>
          <article class="agency-metric-card">
            <svg
              aria-hidden="true"
              class="agency-metric-icon agency-metric-icon-purple"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"></path>
              <path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"></path>
              <path d="M7 21h10"></path>
              <path d="M12 3v18"></path>
              <path d="M3 7h2c2 0 5-1 7-4 2 3 5 4 7 4h2"></path>
            </svg>
            <div>
              <p>Civil Cases</p>
              <strong>19 active / 22 total</strong>
              <span>Active and total direct civil cases</span>
              <a href={civilCasesIndexPath}>View details</a>
            </div>
          </article>
          <article class="agency-metric-card">
            <svg
              aria-hidden="true"
              class="agency-metric-icon agency-metric-icon-green"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"></path>
              <path d="M12 6v12"></path>
            </svg>
            <div>
              <p>Liability Costs</p>
              <strong>$0</strong>
              <span>Claims, settlements, judgments, and related costs</span>
              <a href={liabilityCostsIndexPath}>View details</a>
            </div>
          </article>
        </div>

        <div class="agency-chart-grid">
          <article class="agency-chart-card">
            <h2>Arrests Over Time</h2>
            <p>Number of arrests by category</p>
            <div class="agency-line-chart">
              <svg viewBox="0 0 100 100" preserveAspectRatio="none">
                <path class="agency-grid-line" d="M8 14H96"></path>
                <path class="agency-grid-line" d="M8 38H96"></path>
                <path class="agency-grid-line" d="M8 62H96"></path>
                <path class="agency-grid-line" d="M8 86H96"></path>
                <path class="agency-axis-line" d="M8 8V90H96"></path>
              </svg>
            </div>
          </article>
          <article class="agency-chart-card">
            <h2>Killings Over Time</h2>
            <p>People, dogs, and other pets</p>
            <div class="agency-line-chart">
              <div class="agency-chart-legend">
                <span><i class="agency-dot-blue"></i>People</span>
                <span><i class="agency-dot-green"></i>Dogs</span>
                <span><i class="agency-dot-orange"></i>Other pets</span>
              </div>
              <svg viewBox="0 0 100 100" preserveAspectRatio="none">
                <path class="agency-grid-line" d="M8 14H96"></path>
                <path class="agency-grid-line" d="M8 38H96"></path>
                <path class="agency-grid-line" d="M8 62H96"></path>
                <path class="agency-grid-line" d="M8 86H96"></path>
                <path class="agency-axis-line" d="M8 8V90H96"></path>
              </svg>
            </div>
          </article>
          <article class="agency-chart-card">
            <h2>Use of Force Over Time</h2>
            <p>Number of use of force incidents</p>
            <div class="agency-line-chart">
              <svg viewBox="0 0 100 100" preserveAspectRatio="none">
                <path class="agency-grid-line" d="M8 14H96"></path>
                <path class="agency-grid-line" d="M8 38H96"></path>
                <path class="agency-grid-line" d="M8 62H96"></path>
                <path class="agency-grid-line" d="M8 86H96"></path>
                <path class="agency-axis-line" d="M8 8V90H96"></path>
              </svg>
            </div>
          </article>
          <article id="agency-liability-costs" class="agency-chart-card">
            <h2>Civil Cases and Liability Costs Over Time</h2>
            <p>Active civil cases and documented liability costs</p>
            <div class="agency-line-chart">
              <svg viewBox="0 0 100 100" preserveAspectRatio="none">
                <path class="agency-grid-line" d="M8 14H96"></path>
                <path class="agency-grid-line" d="M8 38H96"></path>
                <path class="agency-grid-line" d="M8 62H96"></path>
                <path class="agency-grid-line" d="M8 86H96"></path>
                <path class="agency-axis-line" d="M8 8V90H96"></path>
                {
                  civilCasesByYear.length ? (
                    <polyline
                      class="agency-line agency-line-green"
                      points={getLinePoints(civilCasesByYear)}
                    />
                  ) : null
                }
              </svg>
              <div class="agency-chart-labels">
                {civilCasesByYear.map((point) => <span>{point.label}</span>)}
              </div>
            </div>
          </article>
          <article class="agency-chart-card agency-half-card">
            <h2>Racial Breakdown of Stops or Arrests</h2>
            <p>Who is most affected in the current dataset</p>
            <table>
              <thead>
                <tr>
                  <th scope="col">Race / Ethnicity</th>
                  <th scope="col">Stops %</th>
                  <th scope="col">Arrests %</th>
                </tr>
              </thead>
              <tbody>
                <tr><th scope="row">White</th><td></td><td></td></tr>
                <tr
                  ><th scope="row">Black or African American</th><td></td><td
                  ></td></tr
                >
                <tr
                  ><th scope="row">Hispanic or Latino</th><td></td><td></td></tr
                >
                <tr><th scope="row">Asian</th><td></td><td></td></tr>
                <tr><th scope="row">Other / Unknown</th><td></td><td></td></tr>
              </tbody>
            </table>
          </article>
          <article class="agency-chart-card">
            <h2>Daylight vs Nighttime Stops</h2>
            <p>Comparison of stops by time of day and race</p>
            <div class="agency-stacked-bars" aria-hidden="true">
              {
                [
                  "White",
                  "Black or African American",
                  "Hispanic or Latino",
                  "Other / Unknown",
                ].map((label) => (
                  <div>
                    <i>
                      <>
                        <b />
                        <b />
                      </>
                    </i>
                    <span>{label}</span>
                  </div>
                ))
              }
            </div>
          </article>
          <article class="agency-chart-card agency-half-card">
            <h2>Top Charge Categories</h2>
            <p>Most common reasons for arrest</p>
            <div class="agency-source-bars">
              {
                [
                  "Traffic Offenses",
                  "Theft",
                  "Assault",
                  "Possession",
                  "DWI",
                ].map((label) => (
                  <div class="agency-source-bar">
                    <span>{label}</span>
                    <i>
                      <b style="width: 0%" />
                    </i>
                    <strong />
                  </div>
                ))
              }
            </div>
          </article>
          <article
            id="agency-budget-trend"
            class="agency-chart-card agency-wide-card"
          >
            <h2>Budget and Overtime Trend</h2>
            <p>Total budget and overtime spending</p>
            <div class="agency-line-chart agency-wide-line-chart">
              <svg viewBox="0 0 100 100" preserveAspectRatio="none">
                <path class="agency-grid-line" d="M8 14H96"></path>
                <path class="agency-grid-line" d="M8 38H96"></path>
                <path class="agency-grid-line" d="M8 62H96"></path>
                <path class="agency-grid-line" d="M8 86H96"></path>
                <path class="agency-axis-line" d="M8 8V90H96"></path>
              </svg>
            </div>
          </article>
          <aside class="agency-chart-card agency-about-card">
            <h2>About the Data</h2>
            <p>
              PoliceConduct.org compiles public records and agency source links
              to help residents understand policing in {placeLabel}.
            </p>
            <a href="/about/">Learn more about our data and methods</a>
          </aside>
        </div>
      </div>
    </section>

    <div class="container">
      <div class="mt-5">
        <h2 class="h5 text-uppercase text-muted">Comments</h2>
        <DisqusComments pageUrl={pageUrl} disqusIdentifier={disqusIdentifier} />
      </div>
    </div>
  </main>
  <style>
    .agency-overview-page {
      background: #f7f9fd;
      color: #071842;
    }

    .agency-overview {
      background: #fbfcff;
      border-bottom: 1px solid #d9e1ee;
      min-height: calc(100vh - 3.25rem);
      padding: 1.35rem 0 clamp(2.5rem, 5vw, 4rem);
    }

    .agency-overview > .container {
      max-width: 1194px;
    }

    .agency-overview :global(.breadcrumb) {
      margin-bottom: 1.15rem;
    }

    .agency-overview-heading {
      align-items: start;
      display: grid;
      gap: 1.5rem;
      grid-template-columns: minmax(0, 1fr);
      margin-bottom: 1.25rem;
    }

    .agency-overview-heading h1 {
      color: #071842;
      font-family:
        ui-sans-serif,
        system-ui,
        -apple-system,
        BlinkMacSystemFont,
        "Segoe UI",
        sans-serif;
      font-size: clamp(2.05rem, 3.4vw, 2.8rem);
      font-weight: 800;
      letter-spacing: 0;
      line-height: 1;
      margin: 0 0 0.45rem;
    }

    .agency-overview-heading p {
      color: #33456f;
      margin: 0;
    }

    .agency-overview-federal {
      align-items: baseline;
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin-top: 0.75rem;
    }

    .agency-overview-federal span {
      color: #5a6684;
      font-size: 0.76rem;
      font-weight: 800;
      text-transform: uppercase;
    }

    .agency-overview-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      justify-content: start;
    }

    .agency-overview-action {
      align-items: center;
      background: #fbfcff;
      border: 1px solid #c9d4e6;
      border-radius: 0.4rem;
      color: #071842;
      display: inline-flex;
      font-size: 0.95rem;
      font-weight: 700;
      gap: 0.6rem;
      min-height: 3rem;
      padding: 0.72rem 1.05rem;
      text-decoration: none;
    }

    .agency-overview-action svg {
      height: 1.15rem;
      width: 1.15rem;
    }

    .agency-overview-primary {
      background: #071842;
      border-color: #071842;
      color: #f8faff;
      padding-inline: 1.35rem;
    }

    .agency-coming-soon {
      color: #33456f;
      display: block;
      flex-basis: 100%;
      font-size: 0.82rem;
      font-weight: 700;
      min-height: 1.15rem;
      text-align: right;
    }

    .agency-metric-grid,
    .agency-chart-grid {
      display: grid;
      gap: 1rem;
      grid-template-columns: minmax(0, 1fr);
    }

    .agency-metric-grid {
      margin-bottom: 1rem;
    }

    .agency-metric-card,
    .agency-chart-card {
      background: #fbfcff;
      border: 1px solid #d5deeb;
      border-radius: 0.45rem;
      box-shadow: 0 1px 2px rgba(7, 24, 66, 0.04);
    }

    .agency-metric-card {
      display: grid;
      gap: 0.95rem;
      grid-template-columns: 3rem minmax(0, 1fr);
      min-height: 8.8rem;
      padding: 1rem 1.15rem;
    }

    .agency-metric-icon {
      height: 2.7rem;
      margin-top: 0.35rem;
      width: 2.7rem;
    }

    .agency-metric-icon-blue {
      color: #174bff;
    }

    .agency-metric-icon-green {
      color: #087f3b;
    }

    .agency-metric-icon-purple {
      color: #5b2df5;
    }

    .agency-metric-card p,
    .agency-chart-card p {
      color: #071842;
      font-size: 0.95rem;
      font-weight: 700;
      line-height: 1.25;
      margin: 0;
    }

    .agency-metric-card strong {
      color: #071842;
