---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import CivilCaseScopeNote from "#src/components/CivilCaseScopeNote.astro";
import Pagination from "#src/components/Pagination.astro";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import {
  buildAgencyCivilCaseRows,
  type CivilCaseRow,
} from "#src/lib/data/agency-civil-case-rows.js";
import { timeBuildStep } from "#src/lib/build-timing.js";
import {
  loadAgencyDetailByRouteParams,
  loadAgencyLocationStaticPathsForTopic,
} from "#src/lib/data/agency-detail.js";
import { PAGE_SIZE } from "#src/lib/pagination.js";

export async function getStaticPaths({ paginate }: { paginate: any }) {
  return timeBuildStep(
    "agency civil case pagination static paths",
    async () => {
      const agencyPaths =
        await loadAgencyLocationStaticPathsForTopic("civil-cases");
      const pages: any[] = [];

      for (const agencyPath of agencyPaths) {
        const data = await loadAgencyDetailByRouteParams(agencyPath.params);
        paginate(buildAgencyCivilCaseRows(data), {
          pageSize: PAGE_SIZE,
          params: agencyPath.params,
        })
          .filter((page: any) => {
            const pageParam = page.params?.page;
            if (Array.isArray(pageParam)) {
              return pageParam.length > 0 && pageParam[0] !== "1";
            }
            return (
              typeof pageParam === "string" &&
              pageParam.length > 0 &&
              pageParam !== "1"
            );
          })
          .forEach((page: any) => pages.push(page));
      }

      return pages;
    },
  );
}

const { page } = Astro.props;
const data = await loadAgencyDetailByRouteParams(Astro.params);
const {
  agencyName,
  agencyPath,
  categoryLabel,
  categorySlug,
  administrativeArea,
  placeLabel,
  placePath,
} = data;

const caseRows = buildAgencyCivilCaseRows(data);
const pagePath = `${agencyPath}civil-cases/page/${page.currentPage}/`;
const civilCasesIndexPath = `${agencyPath}civil-cases/`;
const pageTitle = `${agencyName} Civil Cases - Page ${page.currentPage}`;
const pageDescription = `Civil cases connected to ${agencyName}, including direct agency cases and personnel-linked cases.`;

const formatDate = (value?: string | null) =>
  value
    ? new Intl.DateTimeFormat("en", {
        month: "short",
        day: "numeric",
        year: "numeric",
      }).format(new Date(value))
    : "";
---

<SiteLayout
  title={pageTitle}
  description={pageDescription}
  pagePath={pagePath}
  canonicalUrl={pagePath}
>
  <main>
    <section class="agency-cases-hero">
      <div class="container">
        <Breadcrumbs
          items={[
            { label: "Home", href: "/" },
            { label: categoryLabel, href: `/${categorySlug}/` },
            {
              label: administrativeArea,
              href: `/${categorySlug}/${data.administrativeAreaSlug}/`,
            },
            { label: placeLabel, href: placePath },
            { label: agencyName, href: agencyPath },
            { label: "Civil cases", href: civilCasesIndexPath },
            {
              label: `Page ${page.currentPage}`,
              href: pagePath,
              current: true,
            },
          ]}
          className="mb-2"
        />
        <div class="agency-cases-heading">
          <div>
            <p class="agency-cases-kicker">{placeLabel}</p>
            <h1 class="ipc-page-title">{agencyName} Civil Cases</h1>
            <p>{pageDescription}</p>
          </div>
          <div class="agency-cases-count">
            <strong>{caseRows.length.toLocaleString("en")}</strong>
            <span>case links</span>
          </div>
        </div>
      </div>
    </section>

    <section class="agency-cases-section">
      <div class="container">
        <div class="agency-cases-table-wrap">
          <table class="agency-cases-table">
            <thead>
              <tr>
                <th scope="col">Case</th>
                <th scope="col">Type</th>
                <th scope="col">Filed</th>
                <th scope="col">Court</th>
                <th scope="col">Cause</th>
                <th scope="col">Personnel</th>
              </tr>
            </thead>
            <tbody>
              {
                page.data.map((caseItem: CivilCaseRow) => (
                  <tr>
                    <td>
                      <a href={caseItem.caseUrl}>
                        {caseItem.title || "Civil case"}
                      </a>
                    </td>
                    <td>{caseItem.type}</td>
                    <td>{formatDate(caseItem.filed_date)}</td>
                    <td>{caseItem.court || ""}</td>
                    <td>{caseItem.cause_number || ""}</td>
                    <td>
                      {caseItem.personnel.map((person, index) => (
                        <>
                          {index > 0 ? ", " : null}
                          <a href={person.href}>{person.name}</a>
                        </>
                      ))}
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>

        <Pagination
          basePath={civilCasesIndexPath}
          currentPage={page.currentPage}
          lastPage={page.lastPage}
        />
        <CivilCaseScopeNote />
      </div>
    </section>
  </main>
</SiteLayout>

<style>
  .agency-cases-hero {
    background: #f7f9fc;
    border-bottom: 1px solid #d7dde8;
    padding: 2rem 0 1.75rem;
  }

  .agency-cases-heading {
    align-items: end;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
  }

  .agency-cases-kicker {
    color: #315f63;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    margin: 0 0 0.25rem;
    text-transform: uppercase;
  }

  .agency-cases-heading h1 {
    color: #071942;
    margin: 0;
  }

  .agency-cases-heading p {
    color: #33446b;
    margin: 0.5rem 0 0;
  }

  .agency-cases-count {
    border: 1px solid #d7dde8;
    border-radius: 8px;
    min-width: 11rem;
    padding: 0.9rem 1rem;
    text-align: right;
  }

  .agency-cases-count strong {
    color: #071942;
    display: block;
    font-size: 1.5rem;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .agency-cases-count span {
    color: #53627f;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .agency-cases-section {
    padding: 1.5rem 0 2.5rem;
  }

  .agency-cases-table-wrap {
    border: 1px solid #d7dde8;
    border-radius: 8px;
    overflow-x: auto;
  }

  .agency-cases-table {
    border-collapse: collapse;
    color: #071942;
    font-size: 0.9rem;
    min-width: 980px;
    width: 100%;
  }

  .agency-cases-table th,
  .agency-cases-table td {
    border-bottom: 1px solid #e4e8f0;
    padding: 0.75rem 0.8rem;
    text-align: left;
    vertical-align: top;
  }

  .agency-cases-table th {
    background: #f7f9fc;
    color: #53627f;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .agency-cases-table tbody tr:last-child td {
    border-bottom: 0;
  }

  .agency-cases-table a {
    color: #003bff;
    font-weight: 800;
    text-decoration: none;
  }

  @media (max-width: 720px) {
    .agency-cases-heading {
      align-items: stretch;
      flex-direction: column;
    }

    .agency-cases-count {
      text-align: left;
    }
  }
</style>
