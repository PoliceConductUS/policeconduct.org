---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import Pagination from "#src/components/Pagination.astro";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import {
  loadAgencyDetail,
  loadAgencyLocationStaticPaths,
} from "#src/lib/data/agency-detail.js";
import { PAGE_SIZE } from "#src/lib/pagination.js";

export async function getStaticPaths() {
  return loadAgencyLocationStaticPaths();
}

const { agencyId } = Astro.props;
const data = await loadAgencyDetail(agencyId);
const {
  agencyName,
  agencyPath,
  categoryLabel,
  categorySlug,
  administrativeArea,
  placeLabel,
  placePath,
  civilCases,
  personnelLinkedCivilCases,
} = data;

type CivilCaseRow = {
  id: string;
  slug: string;
  title?: string | null;
  cause_number?: string | null;
  filed_date?: string | null;
  court?: string | null;
  caseUrl: string;
  type: "Direct" | "Personnel-linked" | "Direct + personnel-linked";
  personnelNames: string[];
};

const getOfficerName = (officer: {
  first_name?: string | null;
  last_name?: string | null;
}) => [officer.first_name, officer.last_name].filter(Boolean).join(" ");

const casesById = new Map<string, CivilCaseRow>();

for (const caseItem of civilCases) {
  casesById.set(caseItem.id, {
    id: caseItem.id,
    slug: caseItem.slug,
    title: caseItem.title,
    cause_number: caseItem.cause_number,
    filed_date: caseItem.filed_date,
    court: caseItem.court,
    caseUrl: caseItem.caseUrl,
    type: "Direct",
    personnelNames: (caseItem.officers || [])
      .map((officer) => getOfficerName(officer))
      .filter(Boolean),
  });
}

for (const caseItem of personnelLinkedCivilCases) {
  const existing = casesById.get(caseItem.id);
  const personnelNames = (caseItem.links || [])
    .map((link) => getOfficerName(link.officer))
    .filter(Boolean);

  if (existing) {
    existing.type = "Direct + personnel-linked";
    existing.personnelNames = [
      ...new Set([...existing.personnelNames, ...personnelNames]),
    ];
    continue;
  }

  casesById.set(caseItem.id, {
    id: caseItem.id,
    slug: caseItem.slug,
    title: caseItem.title,
    cause_number: caseItem.cause_number,
    filed_date: caseItem.filed_date,
    court: caseItem.court,
    caseUrl: caseItem.caseUrl,
    type: "Personnel-linked",
    personnelNames,
  });
}

const compareText = new Intl.Collator("en", {
  numeric: true,
  sensitivity: "base",
}).compare;
const getTime = (value?: string | null) =>
  value ? new Date(value).getTime() : 0;
const caseRows = [...casesById.values()].sort((left, right) => {
  const dateCompare = getTime(right.filed_date) - getTime(left.filed_date);
  if (dateCompare !== 0) return dateCompare;
  return compareText(left.title || "", right.title || "");
});

const pageCases = caseRows.slice(0, PAGE_SIZE);
const totalPages = Math.max(1, Math.ceil(caseRows.length / PAGE_SIZE));
const pagePath = `${agencyPath}civil-cases/`;
const pageTitle = `${agencyName} Civil Cases`;
const pageDescription = `Civil cases connected to ${agencyName}, including direct agency cases and personnel-linked cases.`;

const formatDate = (value?: string | null) =>
  value
    ? new Intl.DateTimeFormat("en", {
        month: "short",
        day: "numeric",
        year: "numeric",
      }).format(new Date(value))
    : "";
---

<SiteLayout
  title={pageTitle}
  description={pageDescription}
  pagePath={pagePath}
  canonicalUrl={pagePath}
>
  <main>
    <section class="agency-cases-hero">
      <div class="container">
        <Breadcrumbs
          items={[
            { label: "Home", href: "/" },
            { label: categoryLabel, href: `/${categorySlug}/` },
            {
              label: administrativeArea,
              href: `/${categorySlug}/${data.administrativeAreaSlug}/`,
            },
            { label: placeLabel, href: placePath },
            { label: agencyName, href: agencyPath },
            { label: "Civil cases", href: pagePath, current: true },
          ]}
          className="mb-2"
        />
        <div class="agency-cases-heading">
          <div>
            <p class="agency-cases-kicker">{placeLabel}</p>
            <h1>{pageTitle}</h1>
            <p>{pageDescription}</p>
          </div>
          <div class="agency-cases-count">
            <strong>{caseRows.length.toLocaleString("en")}</strong>
            <span>case links</span>
          </div>
        </div>
      </div>
    </section>

    <section class="agency-cases-section">
      <div class="container">
        <div class="agency-cases-toolbar">
          <label for="agency-cases-search">Search civil cases</label>
          <input
            id="agency-cases-search"
            type="search"
            placeholder="Search by title, type, court, cause, or personnel"
            autocomplete="off"
            data-agency-cases-search
          />
        </div>

        {
          pageCases.length === 0 ? (
            <p class="agency-cases-empty">No civil cases listed.</p>
          ) : (
            <div class="agency-cases-table-wrap">
              <table class="agency-cases-table">
                <thead>
                  <tr>
                    <th scope="col">Case</th>
                    <th scope="col">Type</th>
                    <th scope="col">Filed</th>
                    <th scope="col">Court</th>
                    <th scope="col">Cause</th>
                    <th scope="col">Personnel</th>
                  </tr>
                </thead>
                <tbody>
                  {pageCases.map((caseItem) => {
                    const personnelText = caseItem.personnelNames.join(", ");
                    const searchText = [
                      caseItem.title,
                      caseItem.type,
                      caseItem.filed_date,
                      caseItem.court,
                      caseItem.cause_number,
                      personnelText,
                    ]
                      .filter(Boolean)
                      .join(" ")
                      .toLowerCase();

                    return (
                      <tr data-agency-cases-row data-search-text={searchText}>
                        <td>
                          <a href={caseItem.caseUrl}>
                            {caseItem.title || "Civil case"}
                          </a>
                        </td>
                        <td>{caseItem.type}</td>
                        <td>{formatDate(caseItem.filed_date)}</td>
                        <td>{caseItem.court || ""}</td>
                        <td>{caseItem.cause_number || ""}</td>
                        <td>{personnelText}</td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          )
        }

        <p class="agency-cases-empty" data-agency-cases-no-results hidden>
          No civil cases match that search.
        </p>

        <Pagination basePath={pagePath} currentPage={1} lastPage={totalPages} />
      </div>
    </section>
  </main>
</SiteLayout>

<script>
  const searchInput = document.querySelector<HTMLInputElement>(
    "[data-agency-cases-search]",
  );
  const rows = Array.from(
    document.querySelectorAll<HTMLTableRowElement>("[data-agency-cases-row]"),
  );
  const noResults = document.querySelector<HTMLElement>(
    "[data-agency-cases-no-results]",
  );

  searchInput?.addEventListener("input", () => {
    const query = searchInput.value.trim().toLowerCase();
    let visibleCount = 0;

    for (const row of rows) {
      const isVisible = !query || row.dataset.searchText?.includes(query);
      row.hidden = !isVisible;
      if (isVisible) visibleCount += 1;
    }

    if (noResults) {
      noResults.hidden = visibleCount > 0;
    }
  });
</script>

<style>
  .agency-cases-hero {
    background: #f7f9fc;
    border-bottom: 1px solid #d7dde8;
    padding: 2rem 0 1.75rem;
  }

  .agency-cases-heading {
    align-items: end;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
  }

  .agency-cases-kicker {
    color: #315f63;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    margin: 0 0 0.25rem;
    text-transform: uppercase;
  }

  .agency-cases-heading h1 {
    color: #071942;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.05;
    margin: 0;
  }

  .agency-cases-heading p {
    color: #33446b;
    margin: 0.5rem 0 0;
  }

  .agency-cases-count {
    border: 1px solid #d7dde8;
    border-radius: 8px;
    min-width: 11rem;
    padding: 0.9rem 1rem;
    text-align: right;
  }

  .agency-cases-count strong {
    color: #071942;
    display: block;
    font-size: 2rem;
    line-height: 1;
  }

  .agency-cases-count span {
    color: #53627f;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .agency-cases-section {
    padding: 1.5rem 0 2.5rem;
  }

  .agency-cases-toolbar {
    align-items: center;
    display: flex;
    gap: 0.75rem;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .agency-cases-toolbar label {
    color: #071942;
    font-size: 0.85rem;
    font-weight: 800;
  }

  .agency-cases-toolbar input {
    border: 1px solid #cdd5e3;
    border-radius: 6px;
    color: #071942;
    max-width: 28rem;
    padding: 0.65rem 0.75rem;
    width: 100%;
  }

  .agency-cases-table-wrap {
    border: 1px solid #d7dde8;
    border-radius: 8px;
    overflow-x: auto;
  }

  .agency-cases-table {
    border-collapse: collapse;
    color: #071942;
    font-size: 0.9rem;
    min-width: 980px;
    width: 100%;
  }

  .agency-cases-table th,
  .agency-cases-table td {
    border-bottom: 1px solid #e4e8f0;
    padding: 0.75rem 0.8rem;
    text-align: left;
    vertical-align: top;
  }

  .agency-cases-table th {
    background: #f7f9fc;
    color: #53627f;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .agency-cases-table tbody tr:last-child td {
    border-bottom: 0;
  }

  .agency-cases-table a {
    color: #003bff;
    font-weight: 800;
    text-decoration: none;
  }

  .agency-cases-empty {
    color: #53627f;
    margin: 1rem 0 0;
  }

  @media (max-width: 720px) {
    .agency-cases-heading,
    .agency-cases-toolbar {
      align-items: stretch;
      flex-direction: column;
    }

    .agency-cases-count {
      text-align: left;
    }
  }
</style>
