---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import LocationMap from "#src/components/LocationMap.astro";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import {
  loadLocationBuildPayloads,
  type LocationPagePayload,
} from "#src/lib/data/build-payloads.js";
import { buildWebPage, getSiteUrl } from "#src/lib/structured-data.js";

export async function getStaticPaths() {
  const locations = await loadLocationBuildPayloads();

  return locations
    .filter((location) => location.level === "place")
    .map((place) => {
      const parts = place.path.split("/").filter(Boolean);
      return {
        params: {
          category: parts[0],
          administrativeArea: parts[1],
          place: parts[2],
        },
        props: { place },
      };
    });
}

const { place } = Astro.props as { place: LocationPagePayload };
const pagePath = place.path;
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(pagePath, siteUrl).toString();
const title = `${place.displayName}, ${place.administrativeArea} Agencies | PoliceConduct.org`;
const description = `Agencies in ${place.displayName}, ${place.administrativeArea}, ${place.stateLabel}.`;
const mapPoints = (place.agencies || [])
  .filter((agency) => agency.mapPoint)
  .map((agency) => ({
    href: agency.path,
    label: agency.name,
    meta: agency.address || "Agency",
    lat: agency.mapPoint!.lat,
    lng: agency.mapPoint!.lng,
  }));
const structuredData = buildWebPage({
  siteUrl,
  pageUrl,
  name: title,
  description,
  type: "CollectionPage",
});
---

<SiteLayout
  title={title}
  description={description}
  pagePath={pagePath}
  structuredData={structuredData}
>
  <main>
    <section class="py-vh-3 bg-gray-100 border-bottom border-dark">
      <div class="container">
        <div class="row g-4 align-items-end">
          <div class="col-12 col-lg-8">
            <Breadcrumbs
              items={[
                { label: "Home", href: "/" },
                { label: "Find Records", href: "/find-records/" },
                { label: place.stateLabel, href: `/${place.state}/` },
                {
                  label: place.administrativeArea!,
                  href: place.parentPath!,
                },
                { label: place.displayName, href: pagePath, current: true },
              ]}
              className="mb-2"
            />
            <p class="text-uppercase small text-muted mb-2">Place</p>
            <h1 class="display-4 fw-bold mb-3">{place.displayName}</h1>
          </div>
        </div>
      </div>
    </section>
    <section class="py-vh-2">
      <div class="container">
        <LocationMap
          title={`${place.displayName} agencies`}
          description="Agencies with available records."
          bounds={place.mapBounds}
          points={mapPoints}
          emptyLabel="No mapped agencies."
        />
      </div>
    </section>
    <section class="py-vh-2 pt-0">
      <div class="container">
        <div class="row g-4">
          <div class="col-12">
            <h2 class="h4 mb-3">Agencies located here</h2>
            <label class="form-label fw-semibold" for="agencySearch">
              Search agencies
            </label>
            <input
              class="form-control rounded-0 mb-3"
              id="agencySearch"
              type="search"
              placeholder="Search agencies"
              data-location-filter-input
            />
            <div class="profile-record-list">
              {
                (place.agencies || []).map((agency) => (
                  <article
                    class="profile-record"
                    data-location-filter-item
                    data-location-filter-text={`${agency.name} ${agency.address || ""}`}
                  >
                    <div class="profile-record-body">
                      <h3 class="profile-record-title">
                        <a href={agency.path}>{agency.name}</a>
                      </h3>
                      <div class="profile-record-detail">
                        {agency.address ? <span>{agency.address}</span> : null}
                      </div>
                    </div>
                  </article>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <script is:inline>
    document
      .querySelectorAll("[data-location-filter-input]")
      .forEach((input) => {
        input.addEventListener("input", () => {
          const query = input.value.trim().toLowerCase();
          document
            .querySelectorAll("[data-location-filter-item]")
            .forEach((item) => {
              const text =
                item.getAttribute("data-location-filter-text")?.toLowerCase() ||
                "";
              item.hidden = Boolean(query) && !text.includes(query);
            });
        });
      });
  </script>
</SiteLayout>

<style>
  .profile-record-list {
    display: grid;
  }

  .profile-record {
    border-top: 1px solid var(--bs-border-color);
    padding: 1rem 0;
  }

  .profile-record:last-child {
    border-bottom: 1px solid var(--bs-border-color);
  }

  .profile-record-title {
    font-size: 1.1rem;
    margin: 0;
  }

  .profile-record-title a {
    color: var(--bs-dark);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  .profile-record-detail {
    color: var(--bs-secondary-color);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.875rem;
    gap: 0.4rem 0.9rem;
    margin-top: 0.35rem;
  }
</style>
