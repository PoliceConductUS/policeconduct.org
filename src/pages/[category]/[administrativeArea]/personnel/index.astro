---
import CivicScopedOverviewPage from "#src/components/CivicScopedOverviewPage.astro";
import { buildAdministrativeAreaCivicIndex } from "#src/lib/data/civic-index.js";
import {
  loadAdministrativeAreaScopedPaths,
  loadRequiredLocationByPath,
} from "#src/lib/data/civic-scoped-routes.js";

export async function getStaticPaths() {
  return loadAdministrativeAreaScopedPaths();
}

const location = await loadRequiredLocationByPath(
  `/${Astro.params.category}/${Astro.params.administrativeArea}/`,
  "administrative_area",
);
const model = await buildAdministrativeAreaCivicIndex(location);
---

<CivicScopedOverviewPage model={model} kind="personnel" />
