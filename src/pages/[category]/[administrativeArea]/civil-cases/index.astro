---
import CivicScopedCivilCaseTable from "#src/components/CivicScopedCivilCaseTable.astro";
import CivicScopedOverviewPage from "#src/components/CivicScopedOverviewPage.astro";
import {
  buildAdministrativeAreaCivicIndex,
  loadScopedCivilCaseRows,
} from "#src/lib/data/civic-index.js";
import {
  loadAdministrativeAreaScopedPaths,
  loadRequiredLocationByPath,
} from "#src/lib/data/civic-scoped-routes.js";

export async function getStaticPaths() {
  return loadAdministrativeAreaScopedPaths();
}

const location = await loadRequiredLocationByPath(
  `/${Astro.params.category}/${Astro.params.administrativeArea}/`,
  "administrative_area",
);
const model = await buildAdministrativeAreaCivicIndex(location);
const civilCaseRows = await loadScopedCivilCaseRows(location);
---

<CivicScopedOverviewPage model={model} kind="civil-cases">
  <CivicScopedCivilCaseTable rows={civilCaseRows} />
</CivicScopedOverviewPage>
