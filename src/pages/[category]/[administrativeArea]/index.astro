---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import LocationMap from "#src/components/LocationMap.astro";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import {
  loadLocationBuildPayloads,
  type LocationPagePayload,
} from "#src/lib/data/build-payloads.js";
import { buildWebPage, getSiteUrl } from "#src/lib/structured-data.js";

export async function getStaticPaths() {
  const locations = await loadLocationBuildPayloads();

  return locations
    .filter((location) => location.level === "administrative_area")
    .map((area) => ({
      params: {
        category: area.state,
        administrativeArea: area.path.split("/").filter(Boolean)[1],
      },
      props: { area },
    }));
}

const { area } = Astro.props as { area: LocationPagePayload };
const pagePath = area.path;
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(pagePath, siteUrl).toString();
const title = `${area.administrativeArea}, ${area.stateLabel} Places | PoliceConduct.org`;
const description = `Browse places in ${area.administrativeArea}, ${area.stateLabel}.`;
const mapPoints = (area.children || [])
  .filter((place) => place.mapPoint)
  .map((place) => ({
    count: place.childCount,
    href: place.nextPath || place.path,
    label: place.nextLabel || place.label,
    meta: place.nextDetail || `${place.childCount} agencies located here`,
    lat: place.mapPoint!.lat,
    lng: place.mapPoint!.lng,
  }));
const structuredData = buildWebPage({
  siteUrl,
  pageUrl,
  name: title,
  description,
  type: "CollectionPage",
});
---

<SiteLayout
  title={title}
  description={description}
  pagePath={pagePath}
  structuredData={structuredData}
>
  <main>
    <section class="py-vh-3 bg-gray-100 border-bottom border-dark">
      <div class="container">
        <div class="row g-4 align-items-end">
          <div class="col-12 col-lg-8">
            <Breadcrumbs
              items={[
                { label: "Home", href: "/" },
                { label: "Find Records", href: "/find-records/" },
                { label: area.stateLabel, href: `/${area.state}/` },
                {
                  label: area.administrativeArea!,
                  href: pagePath,
                  current: true,
                },
              ]}
              className="mb-2"
            />
            <p class="text-uppercase small text-muted mb-2">
              {area.administrativeAreaKind}
            </p>
            <h1 class="display-4 fw-bold mb-3">{area.administrativeArea}</h1>
            <p class="lead text-muted mb-0">Select a place to see agencies.</p>
          </div>
        </div>
      </div>
    </section>
    <section class="py-vh-2">
      <div class="container">
        <div class="row g-3 align-items-end mb-4">
          <div class="col-12 col-md-6">
            <label class="form-label fw-semibold" for="placeJump">
              Jump to a place
            </label>
            <select
              class="form-select rounded-0"
              id="placeJump"
              data-jump-select
            >
              <option value="">Select a place</option>
              {
                (area.children || []).map((place) => (
                  <option value={place.nextPath || place.path}>
                    {place.nextLabel || place.label}
                    {place.nextDetail ? ` (${place.nextDetail})` : ""}
                  </option>
                ))
              }
            </select>
          </div>
          <div class="col-12 col-md-6">
            <label class="form-label fw-semibold" for="placeSearch">
              Search places
            </label>
            <input
              class="form-control rounded-0"
              id="placeSearch"
              type="search"
              placeholder="Search places"
              data-location-filter-input
            />
          </div>
        </div>
        <LocationMap
          title={`${area.administrativeArea} places`}
          description="Places with available agency records."
          bounds={area.mapBounds}
          points={mapPoints}
          emptyLabel="No mapped places."
        />
      </div>
    </section>
    <section class="py-vh-2 pt-0">
      <div class="container">
        <div class="row g-4">
          <div class="col-12">
            <h2 class="h4 mb-3">Places</h2>
            <div class="profile-record-list">
              {
                (area.children || []).map((place) => (
                  <article
                    class="profile-record"
                    data-location-filter-item
                    data-location-filter-text={`${place.label} ${place.nextLabel || ""} ${place.nextDetail || ""}`}
                  >
                    <div class="profile-record-body">
                      <h3 class="profile-record-title">
                        <a href={place.nextPath || place.path}>
                          {place.nextLabel || place.label}
                        </a>
                      </h3>
                      <div class="profile-record-detail">
                        <span>
                          {place.nextDetail ||
                            `${place.childCount} agencies located here`}
                        </span>
                      </div>
                    </div>
                  </article>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <script is:inline>
    document.querySelectorAll("[data-jump-select]").forEach((select) => {
      select.addEventListener("change", () => {
        if (select.value) {
          window.location.href = select.value;
        }
      });
    });

    document
      .querySelectorAll("[data-location-filter-input]")
      .forEach((input) => {
        input.addEventListener("input", () => {
          const query = input.value.trim().toLowerCase();
          document
            .querySelectorAll("[data-location-filter-item]")
            .forEach((item) => {
              const text =
                item.getAttribute("data-location-filter-text")?.toLowerCase() ||
                "";
              item.hidden = Boolean(query) && !text.includes(query);
            });
        });
      });
  </script>
</SiteLayout>

<style>
  .profile-record-list {
    display: grid;
  }

  .profile-record {
    border-top: 1px solid var(--bs-border-color);
    padding: 1rem 0;
  }

  .profile-record:last-child {
    border-bottom: 1px solid var(--bs-border-color);
  }

  .profile-record-title {
    font-size: 1.1rem;
    margin: 0;
  }

  .profile-record-title a {
    color: var(--bs-dark);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  .profile-record-detail {
    color: var(--bs-secondary-color);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.875rem;
    gap: 0.4rem 0.9rem;
    margin-top: 0.35rem;
  }
</style>
