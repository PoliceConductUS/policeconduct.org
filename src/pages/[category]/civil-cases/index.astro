---
import CivicScopedIndexPage from "#src/components/CivicScopedIndexPage.astro";
import { buildStateCivicIndex } from "#src/lib/data/civic-index.js";
import {
  loadRequiredLocationByPath,
  loadStateScopedPaths,
} from "#src/lib/data/civic-scoped-routes.js";

export async function getStaticPaths() {
  return loadStateScopedPaths();
}

const location = await loadRequiredLocationByPath(
  `/${Astro.params.category}/`,
  "state",
);
const model = await buildStateCivicIndex(location);
---

<CivicScopedIndexPage model={model} kind="civil-cases" />
