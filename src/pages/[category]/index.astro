---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import LocationMap from "#src/components/LocationMap.astro";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import {
  loadLocationBuildPayloads,
  type LocationPagePayload,
} from "#src/lib/data/build-payloads.js";
import { buildWebPage, getSiteUrl } from "#src/lib/structured-data.js";

export async function getStaticPaths() {
  const locations = await loadLocationBuildPayloads();

  return locations
    .filter(
      (location) =>
        location.level === "state" && (location.children?.length ?? 0) > 0,
    )
    .map((state) => ({
      params: { category: state.state },
      props: { state },
    }));
}

const { state } = Astro.props as { state: LocationPagePayload };
const pagePath = state.path;
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(pagePath, siteUrl).toString();
const title = `${state.stateLabel} Places | PoliceConduct.org`;
const administrativeAreaPlural = state.administrativeAreaPlural!;
const description = `Browse ${state.stateLabel} by ${administrativeAreaPlural.toLowerCase()} and place.`;
const mapPoints = (state.children || [])
  .filter((area) => area.mapPoint)
  .map((area) => ({
    count: area.childCount,
    href: area.nextPath || area.path,
    label: area.nextLabel || area.label,
    meta: area.nextDetail || `${area.childCount} places`,
    lat: area.mapPoint!.lat,
    lng: area.mapPoint!.lng,
  }));
const structuredData = buildWebPage({
  siteUrl,
  pageUrl,
  name: title,
  description,
  type: "CollectionPage",
});
---

<SiteLayout
  title={title}
  description={description}
  pagePath={pagePath}
  structuredData={structuredData}
>
  <main>
    <section class="py-vh-3 bg-gray-100 border-bottom border-dark">
      <div class="container">
        <div class="row g-4 align-items-end">
          <div class="col-12 col-lg-8">
            <Breadcrumbs
              items={[
                { label: "Home", href: "/" },
                { label: "Find Records", href: "/find-records/" },
                { label: state.stateLabel, href: pagePath, current: true },
              ]}
              className="mb-2"
            />
            <p class="text-uppercase small text-muted mb-2">State overview</p>
            <h1 class="display-4 fw-bold mb-3">{state.stateLabel}</h1>
            <p class="lead text-muted mb-0">
              Browse by {administrativeAreaPlural.toLowerCase()}, then by place.
            </p>
          </div>
        </div>
      </div>
    </section>
    <section class="py-vh-2">
      <div class="container">
        <div class="row g-3 align-items-end mb-4">
          <div class="col-12 col-md-6">
            <label class="form-label fw-semibold" for="areaJump">
              Jump to {administrativeAreaPlural.toLowerCase()}
            </label>
            <select
              class="form-select rounded-0"
              id="areaJump"
              data-jump-select
            >
              <option value=""
                >Select {administrativeAreaPlural.toLowerCase()}</option
              >
              {
                (state.children || []).map((area) => (
                  <option value={area.nextPath || area.path}>
                    {area.nextLabel || area.label}
                    {area.nextDetail ? ` (${area.nextDetail})` : ""}
                  </option>
                ))
              }
            </select>
          </div>
          <div class="col-12 col-md-6">
            <label class="form-label fw-semibold" for="areaSearch">
              Search {administrativeAreaPlural.toLowerCase()}
            </label>
            <input
              class="form-control rounded-0"
              id="areaSearch"
              type="search"
              placeholder={`Search ${administrativeAreaPlural.toLowerCase()}`}
              data-location-filter-input
            />
          </div>
        </div>
        <LocationMap
          title={`${state.stateLabel} ${administrativeAreaPlural}`}
          description={`${administrativeAreaPlural} with available agency records.`}
          bounds={state.mapBounds}
          points={mapPoints}
          emptyLabel={`No mapped ${administrativeAreaPlural.toLowerCase()} records.`}
        />
      </div>
    </section>
    <section class="py-vh-2 pt-0">
      <div class="container">
        <div class="row g-4">
          <div class="col-12">
            <h2 class="h4 mb-3">{administrativeAreaPlural}</h2>
            <div class="profile-record-list">
              {
                (state.children || []).map((area) => (
                  <article
                    class="profile-record"
                    data-location-filter-item
                    data-location-filter-text={`${area.label} ${area.nextLabel || ""} ${area.nextDetail || ""}`}
                  >
                    <div class="profile-record-body">
                      <h3 class="profile-record-title">
                        <a href={area.nextPath || area.path}>
                          {area.nextLabel || area.label}
                        </a>
                      </h3>
                      <div class="profile-record-detail">
                        <span>
                          {area.nextDetail || `${area.childCount} places`}
                        </span>
                      </div>
                    </div>
                  </article>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <script is:inline>
    document.querySelectorAll("[data-jump-select]").forEach((select) => {
      select.addEventListener("change", () => {
        if (select.value) {
          window.location.href = select.value;
        }
      });
    });

    document
      .querySelectorAll("[data-location-filter-input]")
      .forEach((input) => {
        input.addEventListener("input", () => {
          const query = input.value.trim().toLowerCase();
          document
            .querySelectorAll("[data-location-filter-item]")
            .forEach((item) => {
              const text =
                item.getAttribute("data-location-filter-text")?.toLowerCase() ||
                "";
              item.hidden = Boolean(query) && !text.includes(query);
            });
        });
      });
  </script>
</SiteLayout>

<style>
  .profile-record-list {
    display: grid;
  }

  .profile-record {
    border-top: 1px solid var(--bs-border-color);
    padding: 1rem 0;
  }

  .profile-record:last-child {
    border-bottom: 1px solid var(--bs-border-color);
  }

  .profile-record-title {
    font-size: 1.1rem;
    margin: 0;
  }

  .profile-record-title a {
    color: var(--bs-dark);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  .profile-record-detail {
    color: var(--bs-secondary-color);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.875rem;
    gap: 0.4rem 0.9rem;
    margin-top: 0.35rem;
  }
</style>
