---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import DisqusComments from "#src/components/DisqusComments.astro";
import PrefillBootstrap from "#src/components/PrefillBootstrap.astro";
import PrefillNavButton from "#src/components/PrefillNavButton.astro";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import {
  getVideoContentUrlFields,
  loadVideoByCategorySlug,
  loadVideoSummaries,
} from "#src/lib/data/videos.js";
import { formatLongDate } from "#src/lib/format.js";
import { getSiteUrl } from "#src/lib/structured-data.js";

export async function getStaticPaths() {
  const videos = await loadVideoSummaries();
  return videos.map((video) => ({
    params: { category: video.category, slug: video.slug },
  }));
}

const video = await loadVideoByCategorySlug(
  String(Astro.params.category || ""),
  String(Astro.params.slug || ""),
);
if (!video) {
  throw new Error(
    `Video ${Astro.params.category}/${Astro.params.slug} not found.`,
  );
}

const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(video.path, siteUrl).toString();
const disqusIdentifier = `video:${video.category}:${video.slug}`;
const pageDescription =
  video.description ||
  video.summary ||
  `Video linked to police conduct pages: ${video.title}.`;
const websiteId = new URL("/", siteUrl).toString();
const webpageId = `${pageUrl}#webpage`;
const videoObjectId = `${pageUrl}#video`;
const personEntities = video.officers.map((entry) => {
  const officerUrl = new URL(
    `/personnel/${entry.officer.slug}/`,
    siteUrl,
  ).toString();
  return {
    "@type": "Person",
    "@id": `${officerUrl}#person`,
    name: `${entry.officer.firstName} ${entry.officer.lastName}${entry.officer.suffix ? ` ${entry.officer.suffix}` : ""}`.trim(),
    url: officerUrl,
  };
});
const agencyEntities = Array.from(
  new Map(
    video.officers.map((entry) => {
      const agencyUrl = new URL(
        `/law-enforcement-agency/${entry.agency.category}/${entry.agency.slug}/`,
        siteUrl,
      ).toString();
      return [
        `${agencyUrl}#organization`,
        {
          "@type": "GovernmentOrganization",
          "@id": `${agencyUrl}#organization`,
          name: entry.agency.name,
          url: agencyUrl,
        },
      ] as const;
    }),
  ).values(),
);
const linkedAgencies = video.officers.reduce(
  (agencies, entry) => {
    if (!agencies.some((agency) => agency.id === entry.agency.id)) {
      agencies.push(entry.agency);
    }
    return agencies;
  },
  [] as (typeof video.officers)[number]["agency"][],
);
const relatedEntities = [
  ...personEntities,
  ...agencyEntities,
  ...video.civilCases.map((caseItem) => ({
    "@type": "LegalCase",
    "@id": `${new URL(caseItem.path, siteUrl).toString()}#legalcase`,
    name: caseItem.title,
    url: new URL(caseItem.path, siteUrl).toString(),
    identifier: caseItem.causeNumber,
  })),
  ...video.reports.map((report) => ({
    "@type": "Report",
    "@id": `${new URL(report.path, siteUrl).toString()}#report`,
    name: report.title,
    url: new URL(report.path, siteUrl).toString(),
  })),
];
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": websiteId,
      url: websiteId,
      name: "PoliceConduct.org",
    },
    {
      "@type": "WebPage",
      "@id": webpageId,
      url: pageUrl,
      name: `${video.title} | PoliceConduct.org`,
      description: pageDescription,
      isPartOf: { "@id": websiteId },
      mainEntity: { "@id": videoObjectId },
    },
    ...relatedEntities,
    {
      "@type": "VideoObject",
      "@id": videoObjectId,
      name: video.title,
      description: pageDescription,
      url: pageUrl,
      mainEntityOfPage: { "@id": webpageId },
      ...(video.embed ? { embedUrl: video.embed } : {}),
      ...(video.thumbnail ? { thumbnailUrl: video.thumbnail } : {}),
      ...(video.publishedAt
        ? { uploadDate: new Date(video.publishedAt).toISOString() }
        : {}),
      ...(video.updatedAt
        ? { dateModified: new Date(video.updatedAt).toISOString() }
        : {}),
      ...(video.tags.length
        ? { keywords: video.tags.map((tag) => tag.label).join(", ") }
        : {}),
      ...getVideoContentUrlFields(video),
      ...(relatedEntities.length
        ? { about: relatedEntities.map((entity) => ({ "@id": entity["@id"] })) }
        : {}),
    },
  ],
};

const relationLabel = (value: string) =>
  value
    .split("_")
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");
const linkedPersonnelSummary = video.officers
  .map(
    (entry) =>
      `${entry.officer.firstName} ${entry.officer.lastName} - ${entry.agency.name}`,
  )
  .join("\n");
const linkedAgencySummary = linkedAgencies.map((agency) => agency.name).join("\n");
const linkedCaseReportSummary = [
  ...video.civilCases.map((caseItem) => `${caseItem.title} - ${caseItem.path}`),
  ...video.reports.map((report) => `${report.title} - ${report.path}`),
].join("\n");
const videoNewPrefillPayload = JSON.stringify({
  category: video.category,
  linkedPersonnel: linkedPersonnelSummary,
  linkedAgencies: linkedAgencySummary,
  linkedCasesReports: linkedCaseReportSummary || video.path,
  sourceLinks: video.path,
});
const videoEditPrefillPayload = JSON.stringify({
  videoPath: video.path,
  videoUrl: video.url,
  videoTitle: video.title,
  relationshipCorrections: [
    linkedPersonnelSummary,
    linkedAgencySummary,
    linkedCaseReportSummary,
  ]
    .filter(Boolean)
    .join("\n\n"),
});
---

<SiteLayout
  title={`${video.title} | PoliceConduct.org`}
  description={pageDescription}
  pagePath={video.path}
  canonicalUrl={video.path}
  structuredData={structuredData}
>
  <PrefillBootstrap />
  <main>
    <section class="py-vh-3 bg-gray-100 border-bottom border-dark">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-12 col-lg-10 col-xl-8">
            <Breadcrumbs
              items={[
                { label: "Videos", href: "/video/" },
                {
                  label: video.category.toUpperCase(),
                  href: `/video/${video.category}/`,
                },
                { label: video.title, href: video.path, current: true },
              ]}
            />
            <p class="text-uppercase small text-muted mb-2">Video</p>
            <h1 class="display-6 fw-bold">{video.title}</h1>
            {
              video.recordedAt || video.publishedAt ? (
                <p class="text-muted mb-0">
                  {video.recordedAt
                    ? `Recorded ${formatLongDate(video.recordedAt)}`
                    : `Published ${formatLongDate(video.publishedAt!)}`}
                </p>
              ) : null
            }
          </div>
        </div>
      </div>
    </section>

    <section class="py-vh-2">
      <div class="container">
        <div class="row justify-content-center">
          <article class="col-12 col-lg-10 col-xl-8">
            {
              video.embed ? (
                <div class="ratio ratio-16x9 border mb-3">
                  <iframe
                    src={video.embed}
                    title={video.title}
                    loading="lazy"
                    allow="
                      accelerometer;
                      autoplay;
                      clipboard-write;
                      encrypted-media;
                      gyroscope;
                      picture-in-picture;
                      web-share;
                    "
                    referrerpolicy="strict-origin-when-cross-origin"
                    allowfullscreen
                  />
                </div>
              ) : video.thumbnail ? (
                <img
                  src={video.thumbnail}
                  alt={`Video thumbnail for ${video.title}`}
                  class="img-fluid border mb-3"
                  loading="lazy"
                />
              ) : null
            }

            <div class="d-flex flex-wrap gap-2 mb-4">
              <a
                class="btn btn-dark rounded-0"
                href={video.url}
                target="_blank"
                rel="noopener noreferrer"
              >
                Open original source
              </a>
              <PrefillNavButton
                class="btn btn-outline-dark rounded-0"
                to="/video/suggest-edit/"
                payload={videoEditPrefillPayload}
              >
                Suggest correction
              </PrefillNavButton>
              <PrefillNavButton
                class="btn btn-outline-dark rounded-0"
                to="/video/new/"
                payload={videoNewPrefillPayload}
              >
                Suggest related video
              </PrefillNavButton>
            </div>

            {
              video.summary || video.description ? (
                <section class="mb-5">
                  <h2 class="h5 text-uppercase text-muted">Summary</h2>
                  <p class="fs-5">{video.summary || video.description}</p>
                </section>
              ) : null
            }

            <section class="border p-3 bg-white mb-4">
              <h2 class="h6 text-uppercase text-muted mb-3">Related pages</h2>
              <div class="row g-4">
                <div class="col-12">
                  <div class="small text-uppercase text-muted">Agencies</div>
                  {
                    linkedAgencies.length ? (
                      <ul class="mb-0">
                        {linkedAgencies.map((agency) => (
                          <li>
                            <a
                              href={`/law-enforcement-agency/${agency.category}/${agency.slug}/`}
                            >
                              {agency.name}
                            </a>
                          </li>
                        ))}
                      </ul>
                    ) : (
                      <p class="mb-0">No agencies linked.</p>
                    )
                  }
                </div>
                <div class="col-12">
                  <div class="small text-uppercase text-muted">Personnel</div>
                  {
                    video.officers.length ? (
                      <ul class="mb-0">
                        {video.officers.map((entry) => (
                          <li>
                            <a href={`/personnel/${entry.officer.slug}/`}>
                              {entry.officer.firstName} {entry.officer.lastName}
                            </a>{" "}
                            <span class="text-muted">
                              {relationLabel(entry.relationshipType)} at{" "}
                              <a
                                class="link-secondary"
                                href={`/law-enforcement-agency/${entry.agency.category}/${entry.agency.slug}/`}
                              >
                                {entry.agency.name}
                              </a>
                            </span>
                          </li>
                        ))}
                      </ul>
                    ) : (
                      <p class="mb-0">No personnel linked.</p>
                    )
                  }
                </div>
                <div class="col-12">
                  <div class="small text-uppercase text-muted">Civil cases</div>
                  {
                    video.civilCases.length ? (
                      <ul class="mb-0">
                        {video.civilCases.map((caseItem) => (
                          <li>
                            <a href={caseItem.path}>{caseItem.title}</a>{" "}
                            <span class="text-muted">
                              {relationLabel(caseItem.relationshipType)}
                            </span>
                          </li>
                        ))}
                      </ul>
                    ) : (
                      <p class="mb-0">No civil cases linked.</p>
                    )
                  }
                </div>
                <div class="col-12">
                  <div class="small text-uppercase text-muted">Reports</div>
                  {
                    video.reports.length ? (
                      <ul class="mb-0">
                        {video.reports.map((report) => (
                          <li>
                            <a href={report.path}>{report.title}</a>{" "}
                            <span class="text-muted">
                              {relationLabel(report.relationshipType)}
                            </span>
                          </li>
                        ))}
                      </ul>
                    ) : (
                      <p class="mb-0">No reports linked.</p>
                    )
                  }
                </div>
              </div>
            </section>

            <div class="small text-muted border-top pt-3">
              <p class="mb-1">
                Video links are published for transparency. A link to this page
                means the video is associated with the listed pages; it does not
                by itself establish misconduct.
              </p>
              <p class="mb-0">
                See our{" "}
                <a class="link-secondary" href="/legal-notice/terms-of-service">
                  Terms of Service
                </a>{" "}
                for full disclaimers.
              </p>
            </div>
          </article>
        </div>
      </div>
    </section>
    <section class="py-vh-2 border-top">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-12 col-lg-10 col-xl-8">
            <h2 class="h5 text-uppercase text-muted">Comments</h2>
            <DisqusComments
              pageUrl={pageUrl}
              disqusIdentifier={disqusIdentifier}
            />
          </div>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
