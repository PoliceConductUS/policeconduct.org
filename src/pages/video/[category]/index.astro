---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import PrefillBootstrap from "#src/components/PrefillBootstrap.astro";
import PrefillNavButton from "#src/components/PrefillNavButton.astro";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import {
  loadVideoCategoryCounts,
  loadVideosByCategory,
} from "#src/lib/data/videos.js";
import { US_STATE_TILES } from "#src/lib/geo/states.js";
import { getSiteUrl } from "#src/lib/structured-data.js";

export async function getStaticPaths() {
  const categoryCounts = await loadVideoCategoryCounts();
  return categoryCounts.map((entry) => ({
    params: { category: entry.category },
  }));
}

const categoryParam = String(Astro.params.category || "").toLowerCase();
const videos = await loadVideosByCategory(categoryParam);
const state = US_STATE_TILES.find(
  (entry) => entry.code.toLowerCase() === categoryParam,
);
const categoryLabel =
  categoryParam === "federal"
    ? "Federal"
    : state?.name || categoryParam.toUpperCase();
const pagePath = `/video/${categoryParam}/`;
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(pagePath, siteUrl).toString();
const pageDescription = `Videos with ${categoryLabel} as the primary recording location.`;
const videoNewPrefillPayload = JSON.stringify({
  category: categoryParam,
  linkedCasesReports: pagePath,
});
const videoEditPrefillPayload = JSON.stringify({
  videoPath: pagePath,
  correctionDetails: `${categoryLabel} video index correction or missing video link.`,
});
const uniqueAgenciesForVideo = (video: (typeof videos)[number]) =>
  Array.from(
    new Map(
      video.officers.map((entry) => [
        entry.agency.id,
        {
          id: entry.agency.id,
          name: entry.agency.name,
          href: `/law-enforcement-agency/${entry.agency.category}/${entry.agency.slug}/`,
        },
      ]),
    ).values(),
  );
const totalLinkedPages = videos.reduce(
  (total, video) =>
    total +
    uniqueAgenciesForVideo(video).length +
    video.officers.length +
    video.civilCases.length +
    video.reports.length,
  0,
);
const formatDateLabel = (value: string | null) =>
  value
    ? new Intl.DateTimeFormat("en", {
        month: "short",
        day: "numeric",
        year: "numeric",
      }).format(new Date(value))
    : null;
const formatSourceLabel = (video: (typeof videos)[number]) =>
  video.sourceLabel || video.sourcePlatform || "Video source";
const primaryLink = (video: (typeof videos)[number]) => {
  const report = video.reports[0];
  if (report) {
    return {
      label: report.title,
      href: report.path,
      type: "Report",
    };
  }
  const civilCase = video.civilCases[0];
  if (civilCase) {
    return {
      label: civilCase.title,
      href: civilCase.path,
      type: "Civil case",
    };
  }
  const officer = video.officers[0];
  if (officer) {
    return {
      label: `${officer.officer.firstName} ${officer.officer.lastName}`,
      href: `/personnel/${officer.officer.slug}/`,
      type: "Personnel",
    };
  }
  const agency = uniqueAgenciesForVideo(video)[0];
  if (agency) {
    return {
      label: agency.name,
      href: agency.href,
      type: "Agency",
    };
  }
  return null;
};
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${pageUrl}#collection`,
      url: pageUrl,
      name: `${categoryLabel} Videos | PoliceConduct.org`,
      description: pageDescription,
    },
    {
      "@type": "ItemList",
      "@id": `${pageUrl}#itemlist`,
      itemListElement: videos.map((video, index) => ({
        "@type": "ListItem",
        position: index + 1,
        url: new URL(video.path, siteUrl).toString(),
        name: video.title,
      })),
    },
  ],
};
---

<SiteLayout
  title={`${categoryLabel} Videos | PoliceConduct.org`}
  description={pageDescription}
  pagePath={pagePath}
  canonicalUrl={pagePath}
  structuredData={structuredData}
>
  <PrefillBootstrap />
  <main>
    <section class="py-vh-3 bg-gray-100 border-bottom border-dark">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-12 col-lg-10 col-xl-8">
            <Breadcrumbs
              items={[
                { label: "Home", href: "/" },
                { label: "Videos", href: "/video/" },
                { label: categoryLabel, href: pagePath, current: true },
              ]}
            />
            <p class="text-uppercase small text-muted mb-2">Videos</p>
            <h1 class="display-5 fw-bold">{categoryLabel} Videos</h1>
            <p class="lead mb-0">{pageDescription}</p>
            <div class="d-flex flex-wrap gap-2 mt-4">
              <PrefillNavButton
                class="btn btn-dark rounded-0"
                to="/video/new/"
                payload={videoNewPrefillPayload}
              >
                Suggest a video
              </PrefillNavButton>
              <PrefillNavButton
                class="btn btn-outline-dark rounded-0"
                to="/video/suggest-edit/"
                payload={videoEditPrefillPayload}
              >
                Suggest a correction
              </PrefillNavButton>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-vh-2">
      <div class="container">
        <div class="video-index-shell">
          <div
            class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 border-bottom pb-3 mb-4"
          >
            <div>
              <h2 class="h5 text-uppercase text-muted mb-1">Video index</h2>
              <p class="mb-0 text-muted">
                Compact cards for scanning source footage, linked reports, civil
                cases, agencies, and personnel.
              </p>
            </div>
            <div class="video-index-stats" aria-label="Video index summary">
              <span>{videos.length} videos</span>
              <span>{totalLinkedPages} linked pages</span>
            </div>
          </div>

          <div>
            {
              videos.length ? (
                <div class="video-grid">
                  {videos.map((video) => {
                    const link = primaryLink(video);
                    const agencies = uniqueAgenciesForVideo(video);
                    const dateLabel = formatDateLabel(
                      video.recordedAt || video.publishedAt,
                    );

                    return (
                      <article class="video-card">
                        <a class="video-thumb" href={video.path}>
                          {video.thumbnail ? (
                            <>
                              <img
                                src={video.thumbnail}
                                alt={`Video thumbnail for ${video.title}`}
                                loading="lazy"
                              />
                              <span class="video-thumb-label">Watch video</span>
                            </>
                          ) : (
                            <span class="video-thumb-empty">Video</span>
                          )}
                        </a>
                        <div class="video-card-body">
                          <div class="video-card-kicker">
                            <span>{formatSourceLabel(video)}</span>
                            {dateLabel ? (
                              <>
                                <span aria-hidden="true">/</span>
                                <span>{dateLabel}</span>
                              </>
                            ) : null}
                          </div>
                          <h2 class="video-card-title">
                            <a class="link-dark" href={video.path}>
                              {video.title}
                            </a>
                          </h2>
                          {video.summary || video.description ? (
                            <p class="video-card-summary">
                              {video.summary || video.description}
                            </p>
                          ) : null}
                          <dl class="video-card-links">
                            <div>
                              <dt>Agencies</dt>
                              <dd>{agencies.length}</dd>
                            </div>
                            <div>
                              <dt>Personnel</dt>
                              <dd>{video.officers.length}</dd>
                            </div>
                            <div>
                              <dt>Cases</dt>
                              <dd>{video.civilCases.length}</dd>
                            </div>
                            <div>
                              <dt>Reports</dt>
                              <dd>{video.reports.length}</dd>
                            </div>
                          </dl>
                          {link ? (
                            <p class="video-card-link">
                              <span>{link.type}</span>
                              <a href={link.href}>{link.label}</a>
                            </p>
                          ) : null}
                          <div class="video-card-footer">
                            <a
                              class="btn btn-outline-dark rounded-0 btn-sm"
                              href={video.path}
                            >
                              Watch video
                            </a>
                          </div>
                        </div>
                      </article>
                    );
                  })}
                </div>
              ) : (
                <div class="video-empty">
                  <h2 class="h5">No videos for {categoryLabel} yet</h2>
                  <p class="mb-0">
                    Videos appear here after they are linked to a report, civil
                    case, agency, or law enforcement personnel.
                  </p>
                </div>
              )
            }
          </div>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>

<style>
  .video-index-shell {
    max-width: 1180px;
    margin: 0 auto;
  }

  .video-index-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .video-index-stats span {
    border: 1px solid var(--bs-border-color);
    color: var(--bs-secondary-color);
    font-size: 0.8125rem;
    padding: 0.35rem 0.6rem;
    text-transform: uppercase;
  }

  .video-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }

  .video-card {
    background: var(--bs-white);
    border: 1px solid var(--bs-border-color);
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .video-thumb {
    aspect-ratio: 16 / 9;
    background: var(--bs-dark);
    color: var(--bs-white);
    display: block;
    overflow: hidden;
    position: relative;
    text-decoration: none;
  }

  .video-thumb img {
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .video-thumb-label {
    background: rgba(0, 0, 0, 0.72);
    bottom: 0.5rem;
    font-size: 0.75rem;
    letter-spacing: 0.02em;
    padding: 0.25rem 0.45rem;
    position: absolute;
    right: 0.5rem;
    text-transform: uppercase;
  }

  .video-thumb-empty {
    align-items: center;
    display: flex;
    font-size: 0.8125rem;
    height: 100%;
    justify-content: center;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .video-card-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 0.75rem;
    padding: 0.95rem;
  }

  .video-card-kicker {
    color: var(--bs-secondary-color);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.75rem;
    gap: 0.35rem;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .video-card-title {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.25;
    margin: 0;
  }

  .video-card-summary {
    color: var(--bs-secondary-color);
    display: -webkit-box;
    font-size: 0.875rem;
    line-height: 1.45;
    margin: 0;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .video-card-links {
    border-top: 1px solid var(--bs-border-color);
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin: 0;
    padding-top: 0.75rem;
  }

  .video-card-links div {
    min-width: 0;
  }

  .video-card-links dt {
    color: var(--bs-secondary-color);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .video-card-links dd {
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
  }

  .video-card-link {
    border-left: 3px solid var(--bs-dark);
    font-size: 0.8125rem;
    margin: 0;
    padding-left: 0.65rem;
  }

  .video-card-link span {
    color: var(--bs-secondary-color);
    display: block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .video-card-link a {
    color: var(--bs-dark);
    font-weight: 700;
    text-decoration-thickness: 1px;
  }

  .video-card-footer {
    align-items: center;
    display: flex;
    gap: 0.75rem;
    justify-content: space-between;
    margin-top: auto;
  }

  .video-empty {
    border: 1px solid var(--bs-border-color);
    color: var(--bs-secondary-color);
    padding: 1.5rem;
  }

  @media (min-width: 768px) {
    .video-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1200px) {
    .video-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
