---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import PrefillBootstrap from "#src/components/PrefillBootstrap.astro";
import PrefillNavButton from "#src/components/PrefillNavButton.astro";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import UsaChoroplethMap from "#src/components/UsaChoroplethMap.astro";
import {
  loadFederalAgencyVideoCounts,
  loadVideoCategoryCounts,
} from "#src/lib/data/videos.js";
import { US_STATE_TILES } from "#src/lib/geo/states.js";
import { getSiteUrl } from "#src/lib/structured-data.js";

const categoryCounts = await loadVideoCategoryCounts();
const federalAgencies = await loadFederalAgencyVideoCounts();
const countsByCategory = new Map(
  categoryCounts.map((entry) => [entry.category.toLowerCase(), entry.count]),
);
const stateStats = US_STATE_TILES.map((state) => ({
  code: state.code,
  count: countsByCategory.get(state.code.toLowerCase()) || 0,
  href: `/video/${state.code.toLowerCase()}/`,
}));
const federalVideoCount = countsByCategory.get("federal") || 0;
const statesWithVideos = stateStats.filter((state) => state.count > 0).length;
const totalVideos = categoryCounts.reduce(
  (total, entry) => total + entry.count,
  0,
);
const pagePath = "/video/";
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(pagePath, siteUrl).toString();
const pageDescription =
  "Browse videos linked to police conduct reports, civil litigation, agencies, and law enforcement personnel.";
const videoNewPrefillPayload = JSON.stringify({
  category: "",
  linkedCasesReports: "/video/",
});
const videoEditPrefillPayload = JSON.stringify({
  videoPath: "/video/",
  correctionDetails: "Collection-level video correction or missing video link.",
});
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": new URL("/", siteUrl).toString(),
      url: new URL("/", siteUrl).toString(),
      name: "PoliceConduct.org",
    },
    {
      "@type": "CollectionPage",
      "@id": `${pageUrl}#collection`,
      url: pageUrl,
      name: "Videos | PoliceConduct.org",
      description: pageDescription,
    },
  ],
};
---

<SiteLayout
  title="Videos | PoliceConduct.org"
  description={pageDescription}
  pagePath={pagePath}
  canonicalUrl={pagePath}
  structuredData={structuredData}
>
  <PrefillBootstrap />
  <main>
    <section class="py-vh-3 bg-gray-100 border-bottom border-dark">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-12 col-lg-10 col-xl-8">
            <Breadcrumbs
              items={[
                { label: "Home", href: "/" },
                { label: "Videos", href: pagePath, current: true },
              ]}
            />
            <p class="text-uppercase small text-muted mb-2">Videos</p>
            <h1 class="display-4 fw-bold">Videos</h1>
            <p class="lead mb-0">
              Video evidence and source footage linked to reports, civil cases,
              agencies, and law enforcement personnel.
            </p>
            <div class="ipc-hero-summary ipc-hero-summary-mobile mt-3">
              <span class="badge bg-light text-dark border rounded-0">
                {totalVideos} videos
              </span>
              <span class="badge bg-light text-dark border rounded-0">
                {statesWithVideos} states covered
              </span>
              <span class="badge bg-light text-dark border rounded-0">
                {federalVideoCount} federal videos
              </span>
            </div>
            <div class="d-flex flex-wrap gap-2 mt-4">
              <PrefillNavButton
                class="btn btn-dark rounded-0"
                to="/video/new/"
                payload={videoNewPrefillPayload}
              >
                Suggest a video
              </PrefillNavButton>
              <PrefillNavButton
                class="btn btn-outline-dark rounded-0"
                to="/video/suggest-edit/"
                payload={videoEditPrefillPayload}
              >
                Suggest a correction
              </PrefillNavButton>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-vh-2 border-bottom">
      <div class="container">
        <UsaChoroplethMap
          stats={stateStats}
          title="States"
          subtitle="Counts of videos by primary recording location."
          emptyLabel="No videos yet"
          interactionLabel="Hover over a state to see the count."
          federalPanel={{
            eyebrow: "Federal",
            title: "Federal agencies",
            value: federalAgencies.length,
            description: "Federal agencies with related videos.",
            items: federalAgencies.map((agency) => ({
              label: agency.name,
              href: `/law-enforcement-agency/${agency.category}/${agency.slug}/`,
              badgeText: `Videos: ${agency.videoCount}`,
            })),
          }}
        />
      </div>
    </section>
  </main>
</SiteLayout>
