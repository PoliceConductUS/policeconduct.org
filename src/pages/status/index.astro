---
import SiteLayout from "#src/layouts/SiteLayout.astro";
import PrefillBootstrap from "#src/components/PrefillBootstrap.astro";
---

<SiteLayout
  title="Submission Status | PoliceConduct.org"
  pagePath="/status/"
  robots="noindex,follow"
>
  <PrefillBootstrap />
  <main class="flex-grow-1 py-vh-3">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
          <h1 class="display-6 fw-bold mb-3">Check Submission Status</h1>
          <p class="text-muted mb-4">
            Enter your submission ID to check the latest status.
          </p>

          <form id="statusLookupForm" class="border p-4 bg-white shadow-sm">
            <div class="form-floating mb-3">
              <input
                id="submissionId"
                name="submissionId"
                type="text"
                class="form-control"
                placeholder="Submission ID"
                required
              />
              <label for="submissionId">Submission ID</label>
            </div>
            <button
              id="statusLookupSubmit"
              type="submit"
              class="btn btn-dark rounded-0"
            >
              Check status
            </button>
          </form>

          <div
            id="statusLookupResult"
            class="mt-4 border p-4 bg-light d-none"
            aria-live="polite"
          >
          </div>
        </div>
      </div>
    </div>
  </main>

  <script is:inline>
    (function () {
      const form = document.getElementById("statusLookupForm");
      const input = document.getElementById("submissionId");
      const submitButton = document.getElementById("statusLookupSubmit");
      const result = document.getElementById("statusLookupResult");
      if (!form || !input || !submitButton || !result) {
        return;
      }

      const setSubmitEnabled = (enabled) => {
        submitButton.disabled = !enabled;
      };

      const renderMessage = (headingText, bodyText) => {
        result.classList.remove("d-none");
        result.innerHTML = "";

        const heading = document.createElement("h2");
        heading.className = "h5 mb-3";
        heading.textContent = headingText;

        const body = document.createElement("p");
        body.className = "mb-0";
        body.textContent = bodyText;

        result.appendChild(heading);
        result.appendChild(body);
      };

      const renderStatus = (submissionId, statusText, messageText) => {
        const message =
          typeof messageText === "string" && messageText.trim()
            ? messageText.trim()
            : `Submission ${submissionId} status: ${statusText}`;
        renderMessage("Status", message);
      };

      setSubmitEnabled(false);

      input.addEventListener("input", function () {
        setSubmitEnabled(Boolean(input.value.trim()));
      });

      form.addEventListener("submit", async function (event) {
        event.preventDefault();
        const submissionId = input.value.trim();
        if (!submissionId) {
          return;
        }

        setSubmitEnabled(false);

        try {
          const response = await fetch(
            `/api/status/${encodeURIComponent(submissionId)}`,
            {
              headers: { accept: "application/json" },
            },
          );
          let payload;
          try {
            payload = await response.json();
          } catch (_error) {
            payload = { status: "pending" };
          }
          if (
            !payload ||
            typeof payload !== "object" ||
            Array.isArray(payload)
          ) {
            payload = { status: "pending" };
          }
          const status =
            typeof payload.status === "string" && payload.status.trim()
              ? payload.status.trim()
              : "pending";
          const message =
            typeof payload.message === "string" && payload.message.trim()
              ? payload.message.trim()
              : "";
          renderStatus(submissionId, status, message);
        } catch (_error) {
          renderStatus(submissionId, "pending", "");
        } finally {
          setSubmitEnabled(Boolean(input.value.trim()));
        }
      });

      const flashedPrefill = window.__IPC_PREFILL__?.readAndConsume?.(
        window.location.pathname,
      );
      const flashedSubmissionId =
        flashedPrefill &&
        typeof flashedPrefill.submissionId === "string" &&
        flashedPrefill.submissionId.trim()
          ? flashedPrefill.submissionId.trim()
          : "";
      if (flashedSubmissionId) {
        input.value = flashedSubmissionId;
        setSubmitEnabled(true);
      }
    })();
  </script>
</SiteLayout>
