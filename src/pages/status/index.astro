---
import SiteLayout from "#src/layouts/SiteLayout.astro";
---

<SiteLayout
  title="Submission Status | PoliceConduct.org"
  pagePath="/status/"
  robots="noindex,follow"
>
  <main class="flex-grow-1 py-vh-3">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
          <h1 class="display-6 fw-bold mb-3">Check Submission Status</h1>
          <p class="text-muted mb-4">
            Enter your submission ID to check the latest status.
          </p>

          <form id="statusLookupForm" class="border p-4 bg-white shadow-sm">
            <div class="form-floating mb-3">
              <input
                id="submissionId"
                name="submissionId"
                type="text"
                class="form-control"
                placeholder="Submission ID"
                required
              />
              <label for="submissionId">Submission ID</label>
            </div>
            <button
              id="statusLookupSubmit"
              type="submit"
              class="btn btn-dark rounded-0"
            >
              Check status
            </button>
          </form>

          <div
            id="statusLookupResult"
            class="mt-4 border p-4 bg-light d-none"
            aria-live="polite"
          >
          </div>
        </div>
      </div>
    </div>
  </main>

  <script is:inline>
    (function () {
      const form = document.getElementById("statusLookupForm");
      const input = document.getElementById("submissionId");
      const submitButton = document.getElementById("statusLookupSubmit");
      const result = document.getElementById("statusLookupResult");
      if (!form || !input || !submitButton || !result) {
        return;
      }

      let lockedId = "";

      const setSubmitEnabled = (enabled) => {
        submitButton.disabled = !enabled;
      };

      const renderMessage = (headingText, bodyText) => {
        result.classList.remove("d-none");
        result.innerHTML = "";

        const heading = document.createElement("h2");
        heading.className = "h5 mb-3";
        heading.textContent = headingText;

        const body = document.createElement("p");
        body.className = "mb-0";
        body.textContent = bodyText;

        result.appendChild(heading);
        result.appendChild(body);
      };

      const renderStatus = (submissionId, statusText) => {
        renderMessage(
          "Status",
          `Submission ${submissionId} status: ${statusText}`,
        );
      };

      const verifyFromLink = async (token) => {
        renderMessage("Verification", "Verifying your submission...");
        setSubmitEnabled(false);

        try {
          const response = await fetch("/api/forms/verify-link", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({ token }),
          });
          let payload;
          try {
            payload = await response.json();
          } catch (_error) {
            payload = null;
          }

          if (!response.ok) {
            const message =
              payload &&
              typeof payload.error === "string" &&
              payload.error.trim()
                ? payload.error.trim()
                : "We could not verify that link.";
            renderMessage("Verification failed", message);
            return;
          }

          const submissionId =
            payload &&
            typeof payload.submissionId === "string" &&
            payload.submissionId.trim()
              ? payload.submissionId.trim()
              : "";

          if (!submissionId) {
            renderMessage(
              "Submission Verification Failed",
              "The verification response did not include a submission ID.",
            );
            return;
          }

          lockedId = submissionId;
          input.value = submissionId;
          renderStatus(submissionId, "in_review");
        } catch (_error) {
          renderMessage(
            "Submission Verification Failed",
            "We could not verify that link right now.",
          );
        } finally {
          const nextUrl = new URL(window.location.href);
          nextUrl.searchParams.delete("verify");
          window.history.replaceState(
            {},
            "",
            nextUrl.pathname + nextUrl.search,
          );
          setSubmitEnabled(Boolean(input.value.trim()));
        }
      };

      setSubmitEnabled(false);

      input.addEventListener("input", function () {
        const nextId = input.value.trim();
        if (!nextId) {
          setSubmitEnabled(false);
          return;
        }
        if (!lockedId || nextId !== lockedId) {
          setSubmitEnabled(true);
        }
      });

      form.addEventListener("submit", async function (event) {
        event.preventDefault();
        const submissionId = input.value.trim();
        if (!submissionId) {
          return;
        }

        lockedId = submissionId;
        setSubmitEnabled(false);

        try {
          const response = await fetch(
            `/api/status/${encodeURIComponent(submissionId)}`,
            {
              headers: { accept: "application/json" },
            },
          );
          let payload;
          try {
            payload = await response.json();
          } catch (_error) {
            payload = { status: "pending" };
          }
          if (
            !payload ||
            typeof payload !== "object" ||
            Array.isArray(payload)
          ) {
            payload = { status: "pending" };
          }
          const status =
            typeof payload.status === "string" && payload.status.trim()
              ? payload.status.trim()
              : "pending";
          renderStatus(submissionId, status);
        } catch (_error) {
          renderStatus(submissionId, "pending");
        }
      });

      const verifyToken = new URLSearchParams(window.location.search).get(
        "verify",
      );
      if (verifyToken) {
        void verifyFromLink(verifyToken);
      }
    })();
  </script>
</SiteLayout>
