---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import Pagination from "#src/components/Pagination.astro";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import {
  CIVIL_CASES_PAGE_SIZE,
  loadCivilCaseList,
} from "#src/lib/data/civil-cases.js";
import { formatLongDate } from "#src/lib/format.js";
import { buildItemList, getSiteUrl } from "#src/lib/structured-data.js";

const civilCases = await loadCivilCaseList();
const pageCases = civilCases.slice(0, CIVIL_CASES_PAGE_SIZE);
const totalPages = Math.max(
  1,
  Math.ceil(civilCases.length / CIVIL_CASES_PAGE_SIZE),
);
const pagePath = "/civil-cases/";
const pageTitle = "Civil cases";
const pageDescription =
  "Civil litigation records involving law enforcement, sorted by filing date.";
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(pagePath, siteUrl).toString();
const caseItems = pageCases.map((caseItem, index) => ({
  "@type": "ListItem",
  position: index + 1,
  item: {
    "@type": "LegalCase",
    name: caseItem.title,
    url: new URL(`/civil-cases/${caseItem.slug}/`, siteUrl).toString(),
    dateFiled: new Date(caseItem.filed_date).toISOString(),
    ...(caseItem.cause_number ? { identifier: caseItem.cause_number } : {}),
    ...(caseItem.court ? { court: caseItem.court } : {}),
  },
}));
const caseItemList = buildItemList(caseItems);
const websiteId = new URL("/", siteUrl).toString();
const itemListId = caseItemList ? `${pageUrl}#itemlist` : null;
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": websiteId,
      url: websiteId,
      name: "PoliceConduct.org",
    },
    {
      "@type": "CollectionPage",
      "@id": pageUrl,
      url: pageUrl,
      name: `${pageTitle} | PoliceConduct.org`,
      description: pageDescription,
      isPartOf: { "@id": websiteId },
      ...(itemListId ? { mainEntity: { "@id": itemListId } } : {}),
    },
    ...(caseItemList ? [{ ...caseItemList, "@id": itemListId }] : []),
  ],
};
---

<SiteLayout
  title={`${pageTitle} | PoliceConduct.org`}
  description={pageDescription}
  pagePath={pagePath}
  canonicalUrl={pagePath}
  structuredData={structuredData}
>
  <main>
    <section class="py-vh-3 bg-gray-100 border-bottom border-dark">
      <div class="container">
        <div class="row">
          <div class="col-12 col-lg-10">
            <Breadcrumbs
              items={[
                { label: "Home", href: "/" },
                { label: "Civil cases", href: pagePath, current: true },
              ]}
              className="mb-2"
            />
            <h1 class="display-4 fw-bold">Civil cases</h1>
            <p class="lead text-muted mb-0">{pageDescription}</p>
            <p class="small text-muted mb-0 mt-3">Page 1 of {totalPages}</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-vh-2">
      <div class="container">
        <div class="profile-record-list">
          {
            pageCases.map((caseItem) => (
              <article class="profile-record">
                <div class="profile-record-meta">
                  <span>{formatLongDate(caseItem.filed_date)}</span>
                  {caseItem.court ? <span>{caseItem.court}</span> : null}
                </div>
                <div class="profile-record-body">
                  <h2 class="profile-record-title">
                    <a href={`/civil-cases/${caseItem.slug}/`}>
                      {caseItem.title}
                    </a>
                  </h2>
                  <div class="profile-record-detail">
                    {caseItem.cause_number ? (
                      <span>{caseItem.cause_number}</span>
                    ) : null}
                    {caseItem.claims_summary ? (
                      <span>{caseItem.claims_summary}</span>
                    ) : null}
                  </div>
                </div>
              </article>
            ))
          }
        </div>
        <Pagination basePath={pagePath} currentPage={1} lastPage={totalPages} />
      </div>
    </section>
  </main>
</SiteLayout>
<style>
  .display-4 {
    max-width: 100%;
    overflow-wrap: anywhere;
  }

  .profile-record-list {
    border-top: 0;
    display: grid;
    gap: 0;
  }

  .profile-record {
    align-items: start;
    border-top: 1px solid var(--bs-border-color);
    display: grid;
    gap: 0.75rem 1.25rem;
    grid-template-columns: minmax(0, 1fr) minmax(10rem, 18rem);
    padding: 0.95rem 0;
    transition:
      background-color 140ms ease,
      border-color 140ms ease;
  }

  .profile-record:hover {
    background: color-mix(in srgb, var(--bs-gray-100) 42%, var(--bs-white));
  }

  .profile-record-body {
    grid-column: 1;
    grid-row: 1;
    min-width: 0;
  }

  .profile-record-meta {
    align-items: flex-end;
    color: var(--bs-secondary-color);
    display: flex;
    flex-direction: column;
    font-size: 0.8125rem;
    gap: 0.25rem;
    grid-column: 2;
    grid-row: 1;
    line-height: 1.35;
    min-width: 0;
    text-align: right;
  }

  .profile-record-title {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.35;
    margin: 0;
  }

  .profile-record-title a,
  .profile-record-detail a {
    color: var(--bs-dark);
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .profile-record-detail {
    color: var(--bs-secondary-color);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.875rem;
    gap: 0.35rem 0.85rem;
    line-height: 1.5;
    margin-top: 0.35rem;
    min-width: 0;
  }

  .profile-record-title,
  .profile-record-detail,
  .profile-record-meta {
    overflow-wrap: anywhere;
  }

  @media (max-width: 991.98px) {
    .display-4 {
      font-size: clamp(2.25rem, 12vw, 3.5rem);
      line-height: 1.05;
    }

    .profile-record {
      grid-template-columns: minmax(0, 1fr);
    }

    .profile-record-body,
    .profile-record-meta {
      grid-column: 1;
    }

    .profile-record-meta {
      align-items: flex-start;
      flex-direction: row;
      flex-wrap: wrap;
      grid-row: 2;
      text-align: left;
    }
  }

  @media (max-width: 575.98px) {
    .profile-record-list,
    .profile-record {
      max-width: calc(100vw - 1rem);
    }

    .profile-record-detail {
      align-items: flex-start;
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }
  }
</style>
