---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import Pagination from "#src/components/Pagination.astro";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import {
  CIVIL_CASES_PAGE_SIZE,
  loadCivilCaseList,
  type CivilCaseListItem,
} from "#src/lib/data/civil-cases.js";
import { formatLongDate } from "#src/lib/format.js";

type PaginatedCivilCasesPage = {
  data: CivilCaseListItem[];
  currentPage: number;
  lastPage: number;
};

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const civilCases = await loadCivilCaseList();
  return paginate(civilCases, {
    pageSize: CIVIL_CASES_PAGE_SIZE,
  }).filter((page: any) => {
    const pageParam = page.params?.page;
    if (Array.isArray(pageParam)) {
      return pageParam.length > 0 && pageParam[0] !== "1";
    }
    return (
      typeof pageParam === "string" && pageParam.length > 0 && pageParam !== "1"
    );
  });
}

const { page } = Astro.props as { page: PaginatedCivilCasesPage };
const pagePath = `/civil-cases/page/${page.currentPage}/`;
const title = `Civil cases - Page ${page.currentPage}`;
const pageDescription =
  "Civil litigation records involving law enforcement, sorted by filing date.";
---

<SiteLayout
  title={`${title} | PoliceConduct.org`}
  description={pageDescription}
  pagePath={pagePath}
  canonicalUrl={pagePath}
>
  <main class="civic-cases-page">
    <section class="civic-cases-hero">
      <div class="container">
        <div class="civic-cases-heading">
          <div>
            <Breadcrumbs
              items={[
                { label: "Home", href: "/" },
                { label: "Civil cases", href: "/civil-cases/" },
                {
                  label: `Page ${page.currentPage}`,
                  href: pagePath,
                  current: true,
                },
              ]}
              className="mb-2"
            />
            <h1>{title}</h1>
            <p>{pageDescription}</p>
          </div>
          <div class="civic-cases-actions">
            <a href="/civil-litigation/new/">Submit civil case</a>
            <span>Page {page.currentPage} of {page.lastPage}</span>
          </div>
        </div>
      </div>
    </section>

    <section class="civic-cases-list-section">
      <div class="container">
        <div class="profile-record-list">
          {
            page.data.map((caseItem) => (
              <article class="profile-record">
                <div class="profile-record-meta">
                  <span>{formatLongDate(caseItem.filed_date)}</span>
                  {caseItem.court ? <span>{caseItem.court}</span> : null}
                </div>
                <div class="profile-record-body">
                  <h2 class="profile-record-title">
                    <a href={`/civil-cases/${caseItem.slug}/`}>
                      {caseItem.title}
                    </a>
                  </h2>
                  <div class="profile-record-detail">
                    {caseItem.cause_number ? (
                      <span>{caseItem.cause_number}</span>
                    ) : null}
                    {caseItem.claims_summary ? (
                      <span>{caseItem.claims_summary}</span>
                    ) : null}
                  </div>
                </div>
              </article>
            ))
          }
        </div>
        <Pagination
          basePath="/civil-cases/"
          currentPage={page.currentPage}
          lastPage={page.lastPage}
        />
      </div>
    </section>
  </main>
</SiteLayout>
<style>
  .civic-cases-page {
    background: #fbfcff;
    color: #071842;
    font-family:
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
  }

  .civic-cases-hero,
  .civic-cases-list-section {
    padding: 1.35rem 0 2rem;
  }

  .civic-cases-hero > .container,
  .civic-cases-list-section > .container {
    max-width: 1240px;
  }

  .civic-cases-heading {
    align-items: start;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: minmax(0, 1fr);
    margin-bottom: 1rem;
  }

  .civic-cases-heading h1 {
    color: #071842;
    font-size: clamp(2.05rem, 3.4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1;
    margin: 0 0 0.45rem;
    max-width: 100%;
    overflow-wrap: anywhere;
  }

  .civic-cases-heading p {
    color: #33456f;
    margin: 0;
  }

  .civic-cases-actions {
    align-items: flex-start;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: start;
  }

  .civic-cases-actions a {
    background: #071842;
    border: 1px solid #071842;
    border-radius: 0.4rem;
    color: #f8faff;
    font-weight: 800;
    min-height: 3rem;
    padding: 0.72rem 1.05rem;
    text-decoration: none;
  }

  .civic-cases-actions span {
    color: #33456f;
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 3rem;
  }

  .profile-record-list {
    background: #fbfcff;
    border: 1px solid #d5deeb;
    border-radius: 0.45rem;
    box-shadow: 0 1px 2px rgba(7, 24, 66, 0.04);
    display: grid;
    gap: 0;
    overflow: hidden;
  }

  .profile-record {
    align-items: start;
    border-top: 1px solid #d9e1ee;
    display: grid;
    gap: 0.75rem 1.25rem;
    grid-template-columns: minmax(0, 1fr) minmax(10rem, 18rem);
    padding: 0.95rem 1.1rem;
    transition:
      background-color 140ms ease,
      border-color 140ms ease;
  }

  .profile-record:hover {
    background: #f7f9fc;
  }

  .profile-record-body {
    grid-column: 1;
    grid-row: 1;
    min-width: 0;
  }

  .profile-record-meta {
    align-items: flex-end;
    color: #33456f;
    display: flex;
    flex-direction: column;
    font-size: 0.8125rem;
    gap: 0.25rem;
    grid-column: 2;
    grid-row: 1;
    line-height: 1.35;
    min-width: 0;
    text-align: right;
  }

  .profile-record-title {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.35;
    margin: 0;
  }

  .profile-record-title a,
  .profile-record-detail a {
    color: #071842;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .profile-record-detail {
    color: #33456f;
    display: flex;
    flex-wrap: wrap;
    font-size: 0.875rem;
    gap: 0.35rem 0.85rem;
    line-height: 1.5;
    margin-top: 0.35rem;
    min-width: 0;
  }

  .profile-record-title,
  .profile-record-detail,
  .profile-record-meta {
    overflow-wrap: anywhere;
  }

  @media (max-width: 991.98px) {
    .profile-record {
      grid-template-columns: minmax(0, 1fr);
    }

    .profile-record-body,
    .profile-record-meta {
      grid-column: 1;
    }

    .profile-record-meta {
      align-items: flex-start;
      flex-direction: row;
      flex-wrap: wrap;
      grid-row: 2;
      text-align: left;
    }
  }

  @media (max-width: 575.98px) {
    .profile-record-list,
    .profile-record {
      max-width: calc(100vw - 1rem);
    }

    .profile-record-detail {
      align-items: flex-start;
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }
  }

  @media (min-width: 1200px) {
    .civic-cases-heading {
      grid-template-columns: minmax(0, 1fr) auto;
    }

    .civic-cases-actions {
      justify-content: end;
    }
  }
</style>
