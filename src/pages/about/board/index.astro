---
import SiteLayout from "#src/layouts/SiteLayout.astro";
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import { buildWebPage, getSiteUrl } from "#src/lib/structured-data.js";

const pagePath = "/about/board/";
const pageDescription =
  "Board information for the Institute for Police Conduct, Inc. and PoliceConduct.org.";
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(pagePath, siteUrl).toString();
const structuredData = buildWebPage({
  siteUrl,
  pageUrl,
  name: "Board | PoliceConduct.org",
  description: pageDescription,
});
---

<SiteLayout
  title="Board | PoliceConduct.org"
  description={pageDescription}
  pagePath={pagePath}
  structuredData={structuredData}
>
  <main class="flex-grow-1 py-vh-3">
    <div class="container">
      <Breadcrumbs
        items={[
          { label: "About", href: "/about/" },
          { label: "Board", href: pagePath, current: true },
        ]}
      />
      <h1 class="display-5 fw-bold">Board</h1>
      <p class="lead text-muted">Content coming soon.</p>
    </div>
  </main>
</SiteLayout>
