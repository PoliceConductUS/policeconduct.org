---
import SiteLayout from "../../../layouts/SiteLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import { buildWebPage, getSiteUrl } from "../../../lib/structured-data.js";

const pagePath = "/about/financial-reports/";
const pageDescription =
  "Financial reports and transparency documents for the Institute for Police Conduct, Inc.";
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(pagePath, siteUrl).toString();
const structuredData = buildWebPage({
  siteUrl,
  pageUrl,
  name: "Financial Reports | PoliceConduct.org",
  description: pageDescription,
});
---

<SiteLayout
  title="Financial Reports | PoliceConduct.org"
  description={pageDescription}
  pagePath={pagePath}
  structuredData={structuredData}
>
  <main class="flex-grow-1 py-vh-3">
    <div class="container">
      <Breadcrumbs
        items={[
          { label: "About", href: "/about/" },
          { label: "Financial Reports", href: pagePath, current: true },
        ]}
      />
      <h1 class="display-5 fw-bold">Financial Reports</h1>
      <p class="lead text-muted">Content coming soon.</p>
    </div>
  </main>
</SiteLayout>
