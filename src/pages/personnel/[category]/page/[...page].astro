---
import { loadPersonnelSummaries } from "#src/lib/data/summaries.js";
import type { PersonnelSummary } from "#src/lib/data/types.js";
import { PAGE_SIZE } from "#src/lib/pagination.js";

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const personnel = await loadPersonnelSummaries();
  const personnelByCategory = new Map<string, PersonnelSummary[]>();

  for (const person of personnel) {
    const category = person.agencyState?.toLowerCase();
    if (!category) {
      continue;
    }
    const list = personnelByCategory.get(category) || [];
    list.push(person);
    personnelByCategory.set(category, list);
  }

  const pages: any[] = [];
  personnelByCategory.forEach((categoryPersonnel, category) => {
    paginate(categoryPersonnel, {
      pageSize: PAGE_SIZE,
      params: { category },
    })
      .filter((page: any) => {
        const pageParam = page.params?.page;
        if (Array.isArray(pageParam)) {
          return pageParam.length > 0 && pageParam[0] !== "1";
        }
        return (
          typeof pageParam === "string" &&
          pageParam.length > 0 &&
          pageParam !== "1"
        );
      })
      .forEach((page: any) => pages.push(page));
  });

  return pages;
}

return Astro.redirect(
  `/${String(Astro.params.category || "").toLowerCase()}/`,
  301,
);
---
