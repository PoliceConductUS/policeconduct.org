---
import SiteLayout from "#src/layouts/SiteLayout.astro";
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import CollectionStatsBand from "#src/components/CollectionStatsBand.astro";
import { loadPersonnelSummaries } from "#src/lib/data/summaries.js";
import UsaChoroplethMap from "#src/components/UsaChoroplethMap.astro";
import { US_STATE_TILES } from "#src/lib/geo/states.js";
import { withDb } from "#src/lib/db.js";
import {
  buildItemList,
  buildWebPage,
  getSiteUrl,
} from "#src/lib/structured-data.js";

const personnelRows = await loadPersonnelSummaries();
const federalAgencies = await withDb(async (client) => {
  const agencies = (
    await client.query(
      `
        select
          a.id,
          a.name,
          a.slug,
          a.category,
          count(distinct ao.officer_id) as active_personnel_count
        from public.agency a
        left join public.agency_officers ao
          on ao.agency_id = a.id
         and ao.end_date is null
        where lower(a.category) = 'federal'
        group by a.id, a.name, a.slug, a.category
        order by a.name
      `,
    )
  ).rows;
  return agencies.map((agency: any) => ({
    id: agency.id,
    name: agency.name,
    slug: agency.slug,
    category: agency.category,
    activePersonnelCount: Number(agency.active_personnel_count || 0),
  }));
});
const stateStats = US_STATE_TILES.map((state) => {
  const count = personnelRows.filter(
    (person) => person.agencyCategory?.toUpperCase() === state.code,
  ).length;
  return {
    code: state.code,
    count,
    href: `/personnel/${state.code.toLowerCase()}/`,
  };
});
const totalPersonnel = personnelRows.length;
const statesWithPersonnel = stateStats.filter(
  (state) => state.count > 0,
).length;
const federalPersonnelCount = personnelRows.filter(
  (person) => person.agencyCategory?.toLowerCase() === "federal",
).length;
const personnelStats = [
  {
    label: "Personnel",
    value: totalPersonnel,
    description: "Listed personnel profiles.",
  },
  {
    label: "States Covered",
    value: statesWithPersonnel,
    description: "States with active listed personnel.",
  },
  {
    label: "Federal Personnel",
    value: federalPersonnelCount,
    description: "Listed personnel tied to federal agencies.",
  },
];
const pagePath = "/personnel/";
const suggestPersonnelHref = "/personnel/new/";
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(pagePath, siteUrl).toString();
const personnelItems = personnelRows.slice(0, 25).map((person, index) => ({
  "@type": "ListItem",
  position: index + 1,
  item: {
    "@type": "Person",
    name: person.name,
    url: new URL(`/personnel/${person.slug}/`, siteUrl).toString(),
    ...(person.agencyName
      ? {
          worksFor: {
            "@type": "GovernmentOrganization",
            name: person.agencyName,
          },
        }
      : {}),
  },
}));
const structuredData = buildWebPage({
  siteUrl,
  pageUrl,
  name: "Personnel",
  description: "Personnel profiles currently listed on PoliceConduct.org.",
  type: "CollectionPage",
});
const personnelItemList = buildItemList(personnelItems);
if (personnelItemList) {
  structuredData.mainEntity = personnelItemList;
}
---

<SiteLayout
  title="Personnel"
  description="Personnel profiles currently listed on PoliceConduct.org."
  pagePath={pagePath}
  structuredData={structuredData}
>
  <main>
    <section class="py-vh-3 bg-gray-100 border-bottom border-dark">
      <div class="container">
        <div class="row g-4 align-items-end">
          <div class="col-12 col-lg-8">
            <Breadcrumbs
              items={[
                { label: "Home", href: "/" },
                { label: "Personnel", href: pagePath, current: true },
              ]}
              className="mb-2"
            />
            <p class="text-uppercase small text-muted mb-2">Personnel</p>
            <h1 class="display-4 fw-bold">Personnel</h1>
            <p class="lead text-muted mb-0">
              Profiles of law enforcement personnel with listed agencies.
            </p>
          </div>
        </div>
      </div>
    </section>
    <section class="py-vh-2">
      <div class="container">
        <UsaChoroplethMap
          stats={stateStats}
          title="States"
          subtitle="Counts of active personnel by agency state."
          emptyLabel="No personnel yet"
          interactionLabel="Hover over a state to see the count."
          headerAction={{
            href: suggestPersonnelHref,
            label: "Suggest new person",
            target: "_self",
          }}
          federalPanel={{
            eyebrow: "Federal",
            title: "Federal agencies",
            value: federalAgencies.length,
            description: "Federal agencies with listed personnel.",
            items: federalAgencies.map((agency) => ({
              label: agency.name,
              href: `/law-enforcement-agency/${agency.category}/${agency.slug}/`,
              badgeText: `Personnel: ${agency.activePersonnelCount}`,
            })),
          }}
        />
      </div>
    </section>
    <div class="bg-white border-bottom border-dark">
      <CollectionStatsBand items={personnelStats} />
    </div>
  </main>
</SiteLayout>
