---
import SiteLayout from "#src/layouts/SiteLayout.astro";
import PrefillBootstrap from "#src/components/PrefillBootstrap.astro";
---

<SiteLayout
  title="Suggest Officer Edit | PoliceConduct.org"
  pagePath="/personnel/suggest-edit/"
  robots="noindex,follow"
>
  <PrefillBootstrap />
  <main class="">
    <section class="py-vh-3 bg-gray-100 border-bottom border-dark">
      <div class="container">
        <div class="row">
          <div class="col-lg-8">
            <p class="text-uppercase small text-muted mb-2">
              Officer profile updates
            </p>
            <h1 class="display-5 fw-bold mb-3">Suggest an edit</h1>
            <p class="text-muted mb-0">
              Share verified corrections or missing information for an officer
              profile. We review every submission before updating a public
              profile.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-vh-2" data-form-shell="officerEdit">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-12 col-lg-8">
            <div class="border p-4 bg-white shadow-sm">
              <h2 class="h5 fw-semibold">Officer edit form</h2>
              <p class="text-muted mb-3">
                Use this form to suggest updates to an officer profile. You can
                fill in only the fields you are correcting.
              </p>
              <p class="text-muted mb-3">
                Submitter contact details are required so we can follow up about
                your correction if needed.
              </p>
              <div class="alert alert-warning rounded-0 small">
                Please do not include personal addresses, phone numbers, family
                details, or other private information. Submissions should focus
                on public, verifiable facts.
              </div>
              <form
                name="officerEdit"
                method="POST"
                data-netlify-honeypot="organization"
                class="needs-validation"
                novalidate
              >
                <input type="hidden" name="form-name" value="officerEdit" />
                <div class="honeypot visually-hidden">
                  <label>
                    Organization
                    <input type="text" name="organization" />
                  </label>
                </div>
                <div class="form-floating mb-3">
                  <input
                    type="text"
                    class="form-control"
                    id="officerPath"
                    name="officerPath"
                    placeholder="/personnel/"
                    required
                  />
                  <label for="officerPath">Officer profile path*</label>
                  <div class="invalid-feedback">
                    Please include the officer profile path.
                  </div>
                  <div class="form-text">
                    Example: /personnel/james-marhkam-1379/
                  </div>
                </div>
                <div class="form-floating mb-3">
                  <input
                    type="text"
                    class="form-control"
                    id="officerName"
                    name="officerName"
                    placeholder="Officer name"
                  />
                  <label for="officerName">Officer name</label>
                </div>
                <div class="form-floating mb-3">
                  <input
                    type="text"
                    class="form-control"
                    id="badgeNumber"
                    name="badgeNumber"
                    placeholder="Badge number"
                  />
                  <label for="badgeNumber">Badge number</label>
                </div>
                <div class="form-floating mb-3">
                  <input
                    type="text"
                    class="form-control"
                    id="currentEmployer"
                    name="currentEmployer"
                    placeholder="Current employer"
                  />
                  <label for="currentEmployer">Current employer</label>
                </div>
                <div class="form-floating mb-3">
                  <input
                    type="text"
                    class="form-control"
                    id="currentSupervisor"
                    name="currentSupervisor"
                    placeholder="Current supervisor"
                  />
                  <label for="currentSupervisor">Current supervisor</label>
                </div>
                <div class="form-floating mb-3">
                  <textarea
                    class="form-control"
                    id="pastEmployers"
                    name="pastEmployers"
                    placeholder="Past employers"
                    style="height: 110px"></textarea>
                  <label for="pastEmployers">Past employers</label>
                </div>
                <div class="form-floating mb-3">
                  <input
                    type="url"
                    class="form-control"
                    id="postOrgLink"
                    name="postOrgLink"
                    placeholder="P.O.S.T. organization link"
                  />
                  <label for="postOrgLink">
                    Peace Officer's Standards and Training (P.O.S.T.) org link
                  </label>
                </div>
                <div class="form-floating mb-3">
                  <input
                    type="url"
                    class="form-control"
                    id="profilePhotoLink"
                    name="profilePhotoLink"
                    placeholder="Profile picture link"
                  />
                  <label for="profilePhotoLink">Profile picture link</label>
                </div>
                <div class="form-floating mb-3">
                  <textarea
                    class="form-control"
                    id="socialLinks"
                    name="socialLinks"
                    placeholder="Social media links"
                    style="height: 110px"></textarea>
                  <label for="socialLinks">Social media links</label>
                  <div class="form-text">
                    List any official or public social profiles, one per line.
                  </div>
                </div>
                <div class="form-floating mb-3">
                  <textarea
                    class="form-control"
                    id="civilLitigation"
                    name="civilLitigation"
                    placeholder="Civil litigation"
                    style="height: 130px"></textarea>
                  <label for="civilLitigation">Civil litigation</label>
                  <div class="form-text">
                    Include case numbers, court, and links if available.
                  </div>
                </div>
                <div class="row g-3 mb-3">
                  <div class="col-md-6">
                    <div class="form-floating">
                      <input
                        type="text"
                        class="form-control"
                        id="submitterName"
                        name="submitterName"
                        placeholder="Full name"
                        required
                      />
                      <label for="submitterName">Submitter full name*</label>
                      <div class="invalid-feedback">
                        Please provide your full name.
                      </div>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="form-floating">
                      <input
                        type="email"
                        class="form-control"
                        id="submitterEmail"
                        name="submitterEmail"
                        placeholder="Email"
                        required
                      />
                      <label for="submitterEmail">Submitter email*</label>
                      <div class="invalid-feedback">
                        Please provide a valid email address.
                      </div>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="form-floating">
                      <input
                        type="tel"
                        class="form-control"
                        id="submitterPhone"
                        name="submitterPhone"
                        placeholder="Phone"
                      />
                      <label for="submitterPhone"
                        >Submitter phone (optional)</label
                      >
                    </div>
                  </div>
                </div>
                <div class="small text-muted mb-3">
                  Protected by reCAPTCHA Enterprise.
                </div>
                <button type="submit" class="btn btn-dark rounded-0 w-100">
                  Submit edit suggestion
                </button>
              </form>
              <p class="small text-muted mt-3 mb-0">
                If you have documents or public records, include them in the
                civil litigation field or submit a separate message via
                <a href="/about/contact">Contact Us</a>.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <script>
    import {
      initRecaptcha,
      showFormLoadError,
      submitJsonForm,
    } from "#src/lib/client/forms.ts";

    const form = document.querySelector(
      'form[name="officerEdit"]',
    ) as HTMLFormElement | null;
    const shell = document.querySelector(
      '[data-form-shell="officerEdit"]',
    ) as HTMLElement | null;

    if (!form) {
      showFormLoadError({ formName: "officerEdit", shell });
    } else {
      initRecaptcha();
      form.addEventListener("submit", async function (event) {
        await submitJsonForm({
          event,
          form,
          formName: "officerEdit",
          onReset: function () {
            form.classList.remove("was-validated");
          },
          recaptchaAction: "officerEditSubmit",
          successKind: "verification_pending",
        });
      });
    }
  </script>

  <script is:inline>
    window.__IPC_PREFILL__?.prefillFields?.({
      key: "prefill:personnelSuggestEdit",
    });
  </script>
</SiteLayout>
