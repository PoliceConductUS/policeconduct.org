---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import HelpCollectDataButton from "#src/components/HelpCollectDataButton.astro";
import MetricGrid from "#src/components/MetricGrid.astro";
import OutcomesByIncomePanel from "#src/components/OutcomesByIncomePanel.astro";
import PrefillBootstrap from "#src/components/PrefillBootstrap.astro";
import PrefillNavButton from "#src/components/PrefillNavButton.astro";
import SampleMeasurementChart from "#src/components/SampleMeasurementChart.astro";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import { withDb } from "#src/lib/db.js";
import { mapBy, normalizeAgencyHistory } from "#src/lib/data.js";
import { formatShortDate } from "#src/lib/format.js";
import type { ReportNewPrefill } from "#src/lib/forms/prefill";
import { metricLabels, metricVisuals } from "#src/lib/metric-vocabulary.js";
import { getPersonnelImageById } from "#src/lib/personnel-images.js";
import { requireAgencyCanonicalPath } from "#src/lib/data/location-paths.js";
import { buildReportCanonicalPath } from "#src/lib/data/report-paths.js";
import { getSiteUrl } from "#src/lib/structured-data.js";
import type { MetricCardItem } from "#src/components/metric-card-types.js";

export async function getStaticPaths() {
  if ((process.env.NO_PERSONNEL || "").trim() !== "") {
    return [];
  }

  const officers = await withDb(async (client) => {
    return (
      await client.query(
        `select distinct o.slug
         from public.officers o
         join public.agency_officers ao on ao.officer_id = o.id`,
      )
    ).rows;
  });

  return officers.map((officer: { slug: string }) => ({
    params: { slug: officer.slug },
  }));
}

const { slug } = Astro.params;
if (!slug) {
  throw new Error("Personnel route requires a slug.");
}
const data = await withDb(async (client) => {
  const officer = (
    await client.query("select * from public.officers where slug = $1", [slug])
  ).rows[0];
  if (!officer || officer.slug !== slug) {
    throw new Error(`Personnel ${slug} not found.`);
  }
  const officerId = officer.id;
  const officerStats = (
    await client.query("select * from public.officers_stats where id = $1", [
      officerId,
    ])
  ).rows[0];
  const agencyOfficers = (
    await client.query(
      "select * from public.agency_officers where officer_id = $1",
      [officerId],
    )
  ).rows;
  const agencyIds = agencyOfficers.map(
    (entry: { agency_id: string }) => entry.agency_id,
  );
  const agencies = agencyIds.length
    ? (
        await client.query(
          `
            select a.*, lp.path as location_path, bpp.path as canonical_path
            from public.agency a
            join public.location_path lp
              on lp.location_path_id = a.location_path_id
            join public.build_page_payload bpp
              on bpp.page_type = 'agency'
             and bpp.entity_id = a.id
            where a.id = any($1)
          `,
          [agencyIds],
        )
      ).rows
    : [];
  const agencyOfficerIds = agencyOfficers.map(
    (entry: { id: string }) => entry.id,
  );
  const reportOfficers = agencyOfficerIds.length
    ? (
        await client.query(
          "select * from public.review_officers where agency_officer_id = any($1)",
          [agencyOfficerIds],
        )
      ).rows
    : [];
  const reportIds = reportOfficers.map(
    (entry: { review_id: string }) => entry.review_id,
  );
  const reports = reportIds.length
    ? (
        await client.query(
          `
            select r.*, lp.path as location_path
            from public.reviews r
            join public.location_path lp on lp.location_path_id = r.location_path_id
            where r.id = any($1)
          `,
          [reportIds],
        )
      ).rows
    : [];

  const civilCaseIds = (
    await client.query(
      `select distinct cco.civil_case_id
       from public.civil_case_officers cco
       join public.agency_officers ao on ao.id = cco.agency_officer_id
       where ao.officer_id = $1`,
      [officerId],
    )
  ).rows.map((row: { civil_case_id: string }) => row.civil_case_id);
  const civilCases = civilCaseIds.length
    ? (
        await client.query(
          `select *
           from public.civil_cases
           where id = any($1)
           order by filed_date desc, title asc, cause_number asc`,
          [civilCaseIds],
        )
      ).rows
    : [];
  return {
    officer,
    officerStats,
    agencyOfficers,
    agencies,
    reports,
    civilCases,
  };
});
const agenciesById = mapBy(data.agencies, "id");
const history = normalizeAgencyHistory(data.agencyOfficers);
const missingAgencyAssignment = history.find(
  (entry) => !agenciesById[entry.agency_id],
);
if (missingAgencyAssignment) {
  throw new Error(
    `Personnel ${data.officer.slug} assignment ${missingAgencyAssignment.id} references agency ${missingAgencyAssignment.agency_id} without a required canonical path.`,
  );
}
const assignmentHistory = history
  .map((entry) => ({
    ...entry,
    agency: agenciesById[entry.agency_id],
  }))
  .filter((entry) => entry.agency);
const activeAssignment =
  [...history].reverse().find((entry) => !entry.end_date) || null;
const currentAssignment = activeAssignment || history[history.length - 1];
if (!currentAssignment) {
  throw new Error(
    `Personnel ${data.officer.slug} is missing required agency assignment history.`,
  );
}
const hasCurrentAssignment = Boolean(activeAssignment);
const currentBadge = currentAssignment?.badge_number || null;
const currentLicenseType =
  typeof currentAssignment?.license_type === "string"
    ? currentAssignment.license_type.trim()
    : "";
const currentAgency = currentAssignment
  ? agenciesById[currentAssignment.agency_id]
  : null;
if (!currentAgency) {
  throw new Error(
    `Personnel ${data.officer.slug} assignment ${currentAssignment.id} is missing required agency ${currentAssignment.agency_id}.`,
  );
}
const currentAgencyPrefillName = currentAgency.name.toLocaleUpperCase("en-US");
const isPlaceholderPersonnel =
  data.officer.slug === "unknown-personnel-935d1d" ||
  (data.officer.first_name === "Unknown" &&
    data.officer.last_name === "Personnel");
if (!isPlaceholderPersonnel && !currentLicenseType) {
  throw new Error(
    `Personnel ${data.officer.slug} is missing required license_type on agency_officers ${currentAssignment?.id || "unknown"}`,
  );
}

const civilCasesWithPaths = data.civilCases.map(
  (caseItem: {
    id: string;
    slug: string;
    category: string;
    title?: string | null;
    cause_number?: string | null;
    filed_date: string;
    date_terminated?: string | null;
    court?: string | null;
    primary_source_url?: string | null;
  }) => {
    return {
      ...caseItem,
      caseUrl: `/civil-cases/${caseItem.slug}/`,
    };
  },
);

const reportItems = data.reports.map(
  (report: {
    id: string;
    incident_date: string;
    location_path: string;
    slug: string;
    title?: string | null;
  }) => {
    return {
      ...report,
      incidentDate: formatShortDate(report.incident_date),
      url: buildReportCanonicalPath({
        id: report.id,
        incidentDate: report.incident_date,
        locationPath: report.location_path,
        slug: report.slug,
      }),
    };
  },
);

const officerPath = `/personnel/${data.officer.slug}/`;
const officerName =
  `${data.officer.first_name} ${data.officer.last_name}`.trim();
const deceasedOnValue = data.officer.deceased_on;
const isDeceased = Boolean(deceasedOnValue);
const deceasedOnDisplay = deceasedOnValue
  ? formatShortDate(String(deceasedOnValue))
  : null;
const deceasedPublicMessage =
  (typeof data.officer.deceased_message === "string"
    ? data.officer.deceased_message.trim()
    : "") ||
  (deceasedOnDisplay
    ? `Reported deceased on ${deceasedOnDisplay}.`
    : "This individual is reported deceased.");
const assignmentStatusLabel = hasCurrentAssignment
  ? "Current agency"
  : "Last known agency";
const pageTitle = `${isDeceased ? "Deceased: " : ""}Personnel ${data.officer.first_name} ${data.officer.last_name} | ${hasCurrentAssignment ? currentAgency!.name : `Last known: ${currentAgency!.name}`}`;
const pageDescription = isDeceased
  ? `${officerName} personnel profile with agency assignments, public reports, and civil litigation records${deceasedOnDisplay ? `; reported deceased on ${deceasedOnDisplay}` : ""}.`
  : `${officerName} personnel profile with ${assignmentStatusLabel.toLowerCase()} ${currentAgency!.name}, agency assignments, public reports, coverage, and civil litigation records.`;
const pastEmployerSummary = assignmentHistory
  .filter((entry) => entry.id !== activeAssignment?.id)
  .map((entry) => ({
    ...entry,
  }))
  .map((entry) => {
    const segments = [entry.agency?.name];
    const dateRange = [
      entry.start_date ? formatShortDate(entry.start_date) : null,
      entry.end_date ? formatShortDate(entry.end_date) : "Current",
    ]
      .filter(Boolean)
      .join(" to ");
    if (dateRange) {
      segments.push(dateRange);
    }
    if (entry.badge_number) {
      segments.push(`Badge ${entry.badge_number}`);
    }
    return segments.filter(Boolean).join(" — ");
  })
  .join("\n");
const civilLitigationSummary = civilCasesWithPaths
  .map((caseItem) => {
    const segments = [
      caseItem.title || "Civil case",
      caseItem.cause_number || null,
      caseItem.court || null,
      caseItem.caseUrl,
    ];
    return segments.filter(Boolean).join(" — ");
  })
  .join("\n");
const reportLinksSummary = reportItems.map((report) => report.url).join("\n");
const reportNewPrefillPayload = JSON.stringify({
  officer: {
    department: currentAgencyPrefillName,
    name: `${data.officer.first_name} ${data.officer.last_name}`,
  },
} satisfies ReportNewPrefill);
const addCivilCaseHref = "/civil-cases/new/";
const addCivilCasePrefillPayload = JSON.stringify({
  jurisdiction: String(currentAgency?.state || "").toLowerCase(),
  defendants: [officerName, currentAgencyPrefillName]
    .filter(Boolean)
    .join("\n"),
  summary: `${officerName} profile: ${officerPath}\nCurrent agency: ${currentAgencyPrefillName}`,
  links: [officerPath, ...reportItems.slice(0, 3).map((report) => report.url)]
    .filter(Boolean)
    .join("\n"),
});
const pastEmployerHref = "/personnel/new/";
const pastEmployerPrefillPayload = JSON.stringify({
  firstName: data.officer.first_name || "",
  lastName: data.officer.last_name || "",
  suffix: data.officer.suffix || "",
  badgeNumber: currentBadge || "",
  currentAgency: currentAgencyPrefillName,
  currentAgencyCity: currentAgency?.city || "",
  currentAgencyState: currentAgency?.state || "",
  pastEmployers: pastEmployerSummary,
  civilLitigation: civilLitigationSummary,
  reportLinks: reportLinksSummary,
});
const suggestEditHref = "/personnel/suggest-edit/";
const suggestEditPrefillPayload = JSON.stringify({
  officerPath,
  officerName,
  badgeNumber: currentBadge || "",
  currentEmployer: currentAgencyPrefillName,
  pastEmployers: pastEmployerSummary,
  civilLitigation: civilLitigationSummary,
});
const claimProfileHref = "/about/contact/";
const claimProfilePrefillPayload = JSON.stringify({
  whoami: "Profile Owner",
  message: `I would like to claim ownership of this profile.\nProfile path: ${officerPath}`,
});

const personnelImageSrc =
  getPersonnelImageById(data.officer.id) || "/img/personnel/default.webp";
const hasMappedPersonnelImage = Boolean(getPersonnelImageById(data.officer.id));
const civilCaseCount = data.civilCases.length;
const activeCivilCaseCount = civilCasesWithPaths.filter(
  (caseItem) => !caseItem.date_terminated,
).length;
const associatedAgencyCount = new Set(
  assignmentHistory.map((entry) => entry.agency_id),
).size;
const currentAgencyPath = requireAgencyCanonicalPath(currentAgency!);
const currentAgencyLocation = [currentAgency!.city, currentAgency!.state]
  .filter(Boolean)
  .join(", ");
const statusLabel = isDeceased
  ? "Deceased"
  : hasCurrentAssignment
    ? "Active"
    : "Former";
const formatCount = (value: number) =>
  new Intl.NumberFormat("en-US").format(value);
const unavailableValue = "--";
const formatMonthsDuration = (months: number) => {
  const years = Math.floor(months / 12);
  const remainingMonths = months % 12;
  return years
    ? `${years} yrs${remainingMonths ? `, ${remainingMonths} mos` : ""}`
    : `${remainingMonths} mos`;
};
const countAssignmentMonths = (start?: string | null, end?: string | null) => {
  if (!start) {
    return 0;
  }
  const startDate = new Date(start);
  const endDate = end ? new Date(end) : new Date();
  if (Number.isNaN(startDate.getTime()) || Number.isNaN(endDate.getTime())) {
    return 0;
  }
  return Math.max(
    0,
    (endDate.getFullYear() - startDate.getFullYear()) * 12 +
      endDate.getMonth() -
      startDate.getMonth(),
  );
};
const totalAssignmentMonths = assignmentHistory.reduce(
  (total, entry) =>
    total + countAssignmentMonths(entry.start_date, entry.end_date),
  0,
);
const totalTimeAsOfficer = totalAssignmentMonths
  ? formatMonthsDuration(totalAssignmentMonths)
  : unavailableValue;
const civilCaseYears = Object.entries(
  civilCasesWithPaths.reduce<Record<string, number>>((counts, caseItem) => {
    if (!caseItem.filed_date) {
      return counts;
    }
    const year = String(new Date(caseItem.filed_date).getFullYear());
    if (year === "NaN") {
      return counts;
    }
    counts[year] = (counts[year] || 0) + 1;
    return counts;
  }, {}),
)
  .map(([year, count]) => ({ count, year }))
  .sort((left, right) => left.year.localeCompare(right.year));
const civilCaseYearBarValue = (count: number) =>
  Math.min(100, Math.max(12, count * 18));
const personnelMetricCards: MetricCardItem[] = [
  {
    ...(associatedAgencyCount > 1
      ? {
          action: {
            href: `${officerPath}agencies/`,
            kind: "link" as const,
            label: "View details",
          },
        }
      : {}),
    accent: metricVisuals.agencies.accent,
    icon: metricVisuals.agencies.icon,
    label: metricVisuals.agencies.label,
    value: formatCount(associatedAgencyCount),
  },
  {
    accent: metricVisuals.currentSalary.accent,
    icon: metricVisuals.currentSalary.icon,
    label: metricVisuals.currentSalary.label,
    value: unavailableValue,
  },
  {
    ...(civilCaseCount > 0
      ? {
          action: {
            href: `${officerPath}civil-cases/`,
            kind: "link" as const,
            label: "View details",
          },
        }
      : {}),
    accent: metricVisuals.civilCases.accent,
    detail: metricLabels.activeTotal,
    icon: metricVisuals.civilCases.icon,
    label: metricVisuals.civilCases.label,
    value: `${formatCount(activeCivilCaseCount)} / ${formatCount(civilCaseCount)}`,
  },
  {
    accent: metricVisuals.liabilityCosts.accent,
    icon: metricVisuals.liabilityCosts.icon,
    label: metricVisuals.liabilityCosts.label,
    value: unavailableValue,
  },
  {
    accent: metricVisuals.arrests.accent,
    icon: metricVisuals.arrests.icon,
    label: metricVisuals.arrests.label,
    value: unavailableValue,
  },
  {
    ...(reportItems.length > 0
      ? {
          action: {
            href: `${officerPath}reports/`,
            kind: "link" as const,
            label: "View details",
          },
        }
      : {}),
    accent: metricVisuals.reports.accent,
    icon: metricVisuals.reports.icon,
    label: metricVisuals.reports.label,
    value: formatCount(reportItems.length),
  },
];
const sampleRows = {
  salary: [
    { label: "2021", value: "$--", width: 0 },
    { label: "2022", value: "$--", width: 0 },
    { label: "2023", value: "$--", width: 0 },
    { label: "2024", value: "$--", width: 0 },
    { label: "2025", value: "$--", width: 0 },
  ],
  arrests: [
    { label: "Jan", value: "--", width: 0 },
    { label: "Apr", value: "--", width: 0 },
    { label: "Jul", value: "--", width: 0 },
    { label: "Oct", value: "--", width: 0 },
  ],
  liability: [
    { label: "2021", value: "$--", width: 0 },
    { label: "2022", value: "$--", width: 0 },
    { label: "2023", value: "$--", width: 0 },
    { label: "2024", value: "$--", width: 0 },
    { label: "2025", value: "$--", width: 0 },
  ],
  civilCases: [
    { label: "2021", value: "--", width: 0 },
    { label: "2022", value: "--", width: 0 },
    { label: "2023", value: "--", width: 0 },
    { label: "2024", value: "--", width: 0 },
    { label: "2025", value: "--", width: 0 },
  ],
  stopsEthnicity: [
    { label: "Jan", value: "--", width: 0 },
    { label: "Apr", value: "--", width: 0 },
    { label: "Jul", value: "--", width: 0 },
    { label: "Oct", value: "--", width: 0 },
  ],
  dayNight: [
    { label: "Jan", value: "--", width: 0 },
    { label: "Apr", value: "--", width: 0 },
    { label: "Jul", value: "--", width: 0 },
    { label: "Oct", value: "--", width: 0 },
  ],
  charges: [
    { label: "Jan", value: "--", width: 0 },
    { label: "Apr", value: "--", width: 0 },
    { label: "Jul", value: "--", width: 0 },
    { label: "Oct", value: "--", width: 0 },
  ],
  fatalForce: [
    { label: "2021", value: "--", width: 0 },
    { label: "2022", value: "--", width: 0 },
    { label: "2023", value: "--", width: 0 },
    { label: "2024", value: "--", width: 0 },
    { label: "2025", value: "--", width: 0 },
  ],
};
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(officerPath, siteUrl).toString();
const profilePageId = `${pageUrl}#profilepage`;
const agencyUrl = currentAgency
  ? new URL(requireAgencyCanonicalPath(currentAgency), siteUrl).toString()
  : null;
const organization =
  currentAgency && agencyUrl
    ? {
        "@type": "GovernmentOrganization",
        "@id": `${agencyUrl}#organization`,
        name: currentAgency.name,
        url: agencyUrl,
      }
    : null;
const person = {
  "@type": "Person",
  "@id": `${pageUrl}#person`,
  name: officerName,
  url: pageUrl,
  ...(hasMappedPersonnelImage
    ? { image: new URL(personnelImageSrc, siteUrl).toString() }
    : {}),
  mainEntityOfPage: { "@id": profilePageId },
  ...(isDeceased ? { deathDate: String(deceasedOnValue) } : {}),
  ...(organization ? { worksFor: { "@id": organization["@id"] } } : {}),
};
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": new URL("/", siteUrl).toString(),
      url: new URL("/", siteUrl).toString(),
      name: "PoliceConduct.org",
    },
    {
      "@type": "ProfilePage",
      "@id": profilePageId,
      url: pageUrl,
      name: pageTitle,
      description: pageDescription,
      isPartOf: { "@id": new URL("/", siteUrl).toString() },
      mainEntity: { "@id": person["@id"] },
      dateModified: String(data.officer.updated_at),
    },
    ...(organization ? [organization] : []),
    person,
  ],
};
---

<SiteLayout
  title={pageTitle}
  description={pageDescription}
  pagePath={`/personnel/${data.officer.slug}/`}
  structuredData={structuredData}
>
  <PrefillBootstrap />
  <main class="personnel-dashboard">
    <section class="personnel-profile-surface">
      <div class="container personnel-profile-container">
        <div class="personnel-topbar">
          <Breadcrumbs
            items={[
              { label: "Personnel", href: "/personnel/" },
              { label: officerName, href: officerPath, current: true },
            ]}
            className="personnel-breadcrumbs"
          />
          <div class="personnel-actions">
            <HelpCollectDataButton
              context={officerName}
              sourcePage={officerPath}
              topic="Personnel"
            />
            <PrefillNavButton
              to={suggestEditHref}
              payload={suggestEditPrefillPayload}
              class="personnel-action"
            >
              Suggest edit
            </PrefillNavButton>
            <PrefillNavButton
              to="/report/new/"
              payload={reportNewPrefillPayload}
              class="personnel-action personnel-action-primary"
            >
              Share your experience
            </PrefillNavButton>
          </div>
        </div>

        <div class="personnel-profile-hero">
          <div class="personnel-profile-title">
            <h1 class="ipc-page-title">{officerName}</h1>
            <p class="personnel-current-line">
              Current agency: <a href={currentAgencyPath}
                >{currentAgency!.name}</a
              >
              <span aria-hidden="true"> · </span>
              {currentAgencyLocation}
            </p>
            <p class="personnel-profile-note">
              Combined career data aggregated across all known agencies.
            </p>
            {
              isDeceased ? (
                <div class="personnel-status-note" role="status">
                  <strong>Status: Deceased.</strong>
                  <span>{deceasedPublicMessage}</span>
                </div>
              ) : null
            }
          </div>

          <figure class="personnel-portrait">
            <img
              src={personnelImageSrc}
              alt={`Portrait of ${data.officer.first_name} ${data.officer.last_name}`}
            />
          </figure>

          <aside class="personnel-profile-aside" aria-label="Personnel summary">
            <dl>
              <div>
                <dt>License Type</dt>
                <dd>{currentLicenseType}</dd>
              </div>
              <div>
                <dt>Status</dt>
                <dd>
                  <span class="personnel-status-pill">{statusLabel}</span>
                </dd>
              </div>
              <div>
                <dt>{metricLabels.totalTimeAsOfficer}</dt>
                <dd>{totalTimeAsOfficer}</dd>
              </div>
              {
                currentBadge ? (
                  <div>
                    <dt>Badge Number</dt>
                    <dd>{currentBadge}</dd>
                  </div>
                ) : null
              }
              <div>
                <dt>{assignmentStatusLabel}</dt>
                <dd><a href={currentAgencyPath}>{currentAgency!.name}</a></dd>
              </div>
              <div>
                <dt>Updated</dt>
                <dd>{formatShortDate(data.officer.updated_at)}</dd>
              </div>
            </dl>
          </aside>
        </div>

        <MetricGrid metrics={personnelMetricCards} />

        <div class="personnel-section-grid">
          <OutcomesByIncomePanel />
          <section class="personnel-panel">
            <div class="personnel-panel-heading">
              <h2>1. Salary History</h2>
              <p>Annual base salary, Previous 5 years</p>
            </div>
            <SampleMeasurementChart
              ariaLabel="Sample salary history chart"
              rows={sampleRows.salary}
            />
          </section>

          <section class="personnel-panel">
            <div class="personnel-panel-heading">
              <h2>2. Arrests Over Time</h2>
              <p>Low-level arrests and other arrests, Previous 12 months</p>
            </div>
            <SampleMeasurementChart
              ariaLabel="Sample arrests over time chart, Previous 12 months"
              rows={sampleRows.arrests}
            />
          </section>

          <section class="personnel-panel">
            <div class="personnel-panel-heading">
              <h2>3. Liability Costs Over Time</h2>
              <p>Total liability costs, Previous 5 years</p>
            </div>
            <SampleMeasurementChart
              ariaLabel="Sample liability costs over time chart, Previous 5 years"
              rows={sampleRows.liability}
            />
          </section>

          <section class="personnel-panel">
            <div class="personnel-panel-heading">
              <h2>4. Civil Cases and Claims Over Time</h2>
              <p>Active and historical cases, Previous 5 years</p>
            </div>
            {
              civilCaseYears.length ? (
                <div class="personnel-year-bars">
                  {civilCaseYears.map((row) => (
                    <div>
                      <span>{row.year}</span>
                      <meter
                        min="0"
                        max="100"
                        value={civilCaseYearBarValue(row.count)}
                        aria-label={`${row.year} civil case count`}
                      >
                        {row.count}
                      </meter>
                      <strong>{row.count}</strong>
                    </div>
                  ))}
                </div>
