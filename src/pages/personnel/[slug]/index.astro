---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import PrefillBootstrap from "#src/components/PrefillBootstrap.astro";
import PrefillNavButton from "#src/components/PrefillNavButton.astro";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import DisqusComments from "#src/components/DisqusComments.astro";
import { withDb } from "#src/lib/db.js";
import { mapBy, normalizeAgencyHistory } from "#src/lib/data.js";
import { formatShortDate } from "#src/lib/format.js";
import type { ReportNewPrefill } from "#src/lib/forms/prefill";
import { getPersonnelImageById } from "#src/lib/personnel-images.js";
import ProfileTabs from "#src/components/ProfileTabs.astro";
import { loadVideosForOfficer } from "#src/lib/data/videos.js";
import { getSiteUrl } from "#src/lib/structured-data.js";

export async function getStaticPaths() {
  if ((process.env.NO_PERSONNEL || "").trim() !== "") {
    return [];
  }

  const officers = await withDb(async (client) => {
    return (
      await client.query(
        `select distinct o.id, o.first_name, o.last_name, o.suffix, o.slug
         from public.officers o
         join public.agency_officers ao on ao.officer_id = o.id`,
      )
    ).rows;
  });

  return officers.map((officer: { id: string; slug: string }) => ({
    params: { slug: officer.slug },
    props: { officerId: officer.id },
  }));
}

const { officerId } = Astro.props;
const data = await withDb(async (client) => {
  const officer = (
    await client.query("select * from public.officers where id = $1", [
      officerId,
    ])
  ).rows[0];
  const officerStats = (
    await client.query("select * from public.officers_stats where id = $1", [
      officerId,
    ])
  ).rows[0];
  const agencyOfficers = (
    await client.query(
      "select * from public.agency_officers where officer_id = $1",
      [officerId],
    )
  ).rows;
  const agencyIds = agencyOfficers.map(
    (entry: { agency_id: string }) => entry.agency_id,
  );
  const agencies = agencyIds.length
    ? (
        await client.query("select * from public.agency where id = any($1)", [
          agencyIds,
        ])
      ).rows
    : [];
  const agencyOfficerIds = agencyOfficers.map(
    (entry: { id: string }) => entry.id,
  );
  const reportOfficers = agencyOfficerIds.length
    ? (
        await client.query(
          "select * from public.review_officers where agency_officer_id = any($1)",
          [agencyOfficerIds],
        )
      ).rows
    : [];
  const reportIds = reportOfficers.map(
    (entry: { review_id: string }) => entry.review_id,
  );
  const reports = reportIds.length
    ? (
        await client.query("select * from public.reviews where id = any($1)", [
          reportIds,
        ])
      ).rows
    : [];

  const civilCaseIds = (
    await client.query(
      `select distinct cco.civil_case_id
       from public.civil_case_officers cco
       join public.agency_officers ao on ao.id = cco.agency_officer_id
       where ao.officer_id = $1`,
      [officerId],
    )
  ).rows.map((row: { civil_case_id: string }) => row.civil_case_id);
  const civilCases = civilCaseIds.length
    ? (
        await client.query(
          `select *
           from public.civil_cases
           where id = any($1)
           order by filed_date desc nulls last, title asc, cause_number asc`,
          [civilCaseIds],
        )
      ).rows
    : [];
  const coverageLinks = (
    await client.query(
      `select *
       from public.personnel_coverage_links
       where officer_id = $1
       order by
         case
           when source_name like 'City of %' then 0
           when source_name ilike '%mortuary%' then 0
           else 1
         end,
         published_at desc nulls last,
         title asc`,
      [officerId],
    )
  ).rows;
  const sameNameOfficers = (
    await client.query(
      `select
         o.id,
         o.slug,
         concat_ws(' ', o.first_name, o.middle_name, o.last_name, o.suffix) as name,
         array_remove(array_agg(distinct a.name order by a.name), null) as agency_names
       from public.officers o
       join public.agency_officers ao on ao.officer_id = o.id
       join public.agency a on a.id = ao.agency_id
       where lower(o.first_name) = lower($1)
         and lower(o.last_name) = lower($2)
         and o.id <> $3
       group by o.id, o.slug, o.first_name, o.middle_name, o.last_name, o.suffix
       order by o.last_name asc, o.first_name asc, o.middle_name asc nulls last`,
      [officer.first_name, officer.last_name, officerId],
    )
  ).rows;

  return {
    officer,
    officerStats,
    agencyOfficers,
    agencies,
    reports,
    civilCases,
    coverageLinks,
    sameNameOfficers,
  };
});
const videoItems = await loadVideosForOfficer(officerId);

const agenciesById = mapBy(data.agencies, "id");
const history = normalizeAgencyHistory(data.agencyOfficers);
const assignmentHistory = history
  .map((entry) => ({
    ...entry,
    agency: agenciesById[entry.agency_id],
  }))
  .filter((entry) => entry.agency);
const activeAssignment =
  [...history].reverse().find((entry) => !entry.end_date) || null;
const currentAssignment = activeAssignment || history[history.length - 1];
const hasCurrentAssignment = Boolean(activeAssignment);
const currentBadge = currentAssignment?.badge_number || null;
const currentAgency = currentAssignment
  ? agenciesById[currentAssignment.agency_id]
  : null;
const currentTitle = currentAssignment?.title || null;
const assignmentDateRange = currentAssignment
  ? [
      currentAssignment.start_date
        ? formatShortDate(currentAssignment.start_date)
        : null,
      currentAssignment.end_date
        ? formatShortDate(currentAssignment.end_date)
        : hasCurrentAssignment
          ? "Current"
          : null,
    ]
      .filter(Boolean)
      .join(" to ")
  : "";

const civilCasesWithPaths = data.civilCases.map(
  (caseItem: {
    id: string;
    slug: string;
    category: string;
    title?: string | null;
    cause_number?: string | null;
    filed_date?: string | null;
    court?: string | null;
    primary_source_url?: string | null;
  }) => {
    return {
      ...caseItem,
      caseUrl: `/civil-litigation/${caseItem.category}/${caseItem.slug}/`,
    };
  },
);

const reportItems = data.reports.map(
  (report: { incident_date: string; slug: string; category: string }) => {
    return {
      ...report,
      incidentDate: formatShortDate(report.incident_date),
      url: `/report/${report.category}/${report.slug}/`,
    };
  },
);

const officerPath = `/personnel/${data.officer.slug}/`;
const officerName =
  `${data.officer.first_name} ${data.officer.last_name}`.trim();
const deceasedOnValue = data.officer.deceased_on;
const isDeceased = Boolean(deceasedOnValue);
const deceasedOnDisplay = deceasedOnValue
  ? formatShortDate(String(deceasedOnValue))
  : null;
const deceasedPublicMessage =
  (typeof data.officer.deceased_message === "string"
    ? data.officer.deceased_message.trim()
    : "") ||
  (deceasedOnDisplay
    ? `Reported deceased on ${deceasedOnDisplay}.`
    : "This individual is reported deceased.");
const assignmentStatusLabel = hasCurrentAssignment
  ? "Current agency"
  : "Last known agency";
const pageTitle = `${isDeceased ? "Deceased: " : ""}Personnel ${data.officer.first_name} ${data.officer.last_name} | ${hasCurrentAssignment ? currentAgency!.name : `Last known: ${currentAgency!.name}`}`;
const pageDescription = isDeceased
  ? `${officerName} personnel profile with agency history, public reports, and civil litigation records${deceasedOnDisplay ? `; reported deceased on ${deceasedOnDisplay}` : ""}.`
  : `${officerName} personnel profile with ${assignmentStatusLabel.toLowerCase()} ${currentAgency!.name}, agency history, public reports, videos, coverage, and civil litigation records.`;
const pastEmployerSummary = assignmentHistory
  .filter((entry) => entry.id !== activeAssignment?.id)
  .map((entry) => ({
    ...entry,
  }))
  .map((entry) => {
    const segments = [entry.agency?.name];
    const dateRange = [
      entry.start_date ? formatShortDate(entry.start_date) : null,
      entry.end_date ? formatShortDate(entry.end_date) : "Current",
    ]
      .filter(Boolean)
      .join(" to ");
    if (dateRange) {
      segments.push(dateRange);
    }
    if (entry.badge_number) {
      segments.push(`Badge ${entry.badge_number}`);
    }
    return segments.filter(Boolean).join(" — ");
  })
  .join("\n");
const civilLitigationSummary = civilCasesWithPaths
  .map((caseItem) => {
    const segments = [
      caseItem.title || "Civil case",
      caseItem.cause_number || null,
      caseItem.court || null,
      caseItem.caseUrl,
    ];
    return segments.filter(Boolean).join(" — ");
  })
  .join("\n");
const reportLinksSummary = reportItems.map((report) => report.url).join("\n");
const reportNewPrefillPayload = JSON.stringify({
  officer: {
    department: currentAgency!.name,
    name: `${data.officer.first_name} ${data.officer.last_name}`,
  },
} satisfies ReportNewPrefill);
const addCivilCaseHref = "/civil-litigation/new/";
const addCivilCasePrefillPayload = JSON.stringify({
  jurisdiction: currentAgency?.category?.toLowerCase() || "",
  defendants: [officerName, currentAgency?.name || ""]
    .filter(Boolean)
    .join("\n"),
  summary: `${officerName} profile: ${officerPath}${currentAgency?.name ? `\nCurrent agency: ${currentAgency.name}` : ""}`,
  links: [officerPath, ...reportItems.slice(0, 3).map((report) => report.url)]
    .filter(Boolean)
    .join("\n"),
});
const pastEmployerHref = "/personnel/new/";
const pastEmployerPrefillPayload = JSON.stringify({
  firstName: data.officer.first_name || "",
  lastName: data.officer.last_name || "",
  suffix: data.officer.suffix || "",
  badgeNumber: currentBadge || "",
  currentAgency: currentAgency?.name || "",
  currentAgencyCity: currentAgency?.city || "",
  currentAgencyState: currentAgency?.state || "",
  pastEmployers: pastEmployerSummary,
  civilLitigation: civilLitigationSummary,
  reportLinks: reportLinksSummary,
});
const suggestEditHref = "/personnel/suggest-edit/";
const suggestEditPrefillPayload = JSON.stringify({
  officerPath,
  officerName,
  badgeNumber: currentBadge || "",
  currentEmployer: currentAgency?.name || "",
  pastEmployers: pastEmployerSummary,
  civilLitigation: civilLitigationSummary,
});
const claimProfileHref = "/about/contact/";
const claimProfilePrefillPayload = JSON.stringify({
  whoami: "Profile Owner",
  message: `I would like to claim ownership of this profile.\nProfile path: ${officerPath}`,
});

const defaultPersonnelImagePath = "/img/personnel/default.webp";
const personnelImageSrc =
  getPersonnelImageById(data.officer.id) || defaultPersonnelImagePath;
const civilCaseCount = data.civilCases.length;
const reportCount = data.reports.length;
const videoCount = videoItems.length;
const coverageCount = data.coverageLinks.length;
const assignmentHistoryCount = assignmentHistory.length;
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(officerPath, siteUrl).toString();
const profilePageId = `${pageUrl}#profilepage`;
const disqusIdentifier = `personnel:${data.officer.slug}`;
const agencyUrl = currentAgency
  ? new URL(
      `/law-enforcement-agency/${currentAgency.category}/${currentAgency.slug}/`,
      siteUrl,
    ).toString()
  : null;
const organization =
  currentAgency && agencyUrl
    ? {
        "@type": "GovernmentOrganization",
        "@id": `${agencyUrl}#organization`,
        name: currentAgency.name,
        url: agencyUrl,
      }
    : null;
const person = {
  "@type": "Person",
  "@id": `${pageUrl}#person`,
  name: officerName,
  url: pageUrl,
  image: new URL(personnelImageSrc, siteUrl).toString(),
  mainEntityOfPage: { "@id": profilePageId },
  ...(isDeceased ? { deathDate: String(deceasedOnValue) } : {}),
  ...(organization ? { worksFor: { "@id": organization["@id"] } } : {}),
};
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": new URL("/", siteUrl).toString(),
      url: new URL("/", siteUrl).toString(),
      name: "PoliceConduct.org",
    },
    {
      "@type": "ProfilePage",
      "@id": profilePageId,
      url: pageUrl,
      name: pageTitle,
      description: pageDescription,
      isPartOf: { "@id": new URL("/", siteUrl).toString() },
      mainEntity: { "@id": person["@id"] },
      dateModified: String(data.officer.updated_at),
    },
    ...(organization ? [organization] : []),
    person,
  ],
};
---

<SiteLayout
  title={pageTitle}
  description={pageDescription}
  pagePath={`/personnel/${data.officer.slug}/`}
  structuredData={structuredData}
>
  <PrefillBootstrap />
  <main class="">
    <section class="py-vh-3 bg-gray-100 border-bottom border-dark">
      <div class="container">
        <Breadcrumbs
          items={[
            { label: "Personnel", href: "/personnel/" },
            { label: officerName, href: officerPath, current: true },
          ]}
        />
        <div class="row align-items-center">
          <div class="col-lg-12">
            <p class="text-uppercase small text-muted mb-2">
              {assignmentStatusLabel}: {currentAgency!.name} •{" "}
              {currentAgency!.city || "Unknown"}, {currentAgency!.state}
            </p>
            <h1 class="display-4 fw-bold mb-3">
              {data.officer.first_name}
              {data.officer.last_name}
            </h1>
            {
              isDeceased ? (
                <div
                  class="alert alert-secondary border-dark rounded-0 mb-3"
                  role="status"
                >
                  <p class="mb-1 fw-semibold">Status: Deceased.</p>
                  <p class="mb-0">{deceasedPublicMessage}</p>
                </div>
              ) : null
            }
            <p class="text-muted small mb-0">
              Last updated {formatShortDate(data.officer.updated_at)}. Compiled
              from public records and community submitted reports.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-vh-2">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-12 col-lg-10">
            {
              data.sameNameOfficers.length ? (
                <div class="alert alert-light border rounded-2 mb-4">
                  <div class="fw-semibold mb-2">
                    Similar names in the database
                  </div>
                  <ul class="mb-0">
                    {data.sameNameOfficers.map(
                      (person: {
                        slug: string;
                        name: string;
                        agency_names?: string[] | null;
                      }) => (
                        <li>
                          <a href={`/personnel/${person.slug}/`}>
                            {person.name}
                          </a>
                          {person.agency_names?.length
                            ? ` — ${person.agency_names.join(", ")}`
                            : ""}
                        </li>
                      ),
                    )}
                  </ul>
                </div>
              ) : null
            }
            <div class="row align-items-start">
              <div class="col-12 col-lg-7">
                <dl class="row mb-4 mb-lg-0">
                  <dt class="col-sm-4">Badge number</dt>
                  <dd class="col-sm-8">
                    {currentBadge || "Not publicly listed"}
                  </dd>
                  <dt class="col-sm-4">{assignmentStatusLabel}</dt>
                  <dd class="col-sm-8">
                    <a
                      href={`/law-enforcement-agency/${currentAgency!.category}/${currentAgency!.slug}/`}
                    >
                      {currentAgency!.name}
                    </a>
                    {
                      currentAssignment?.start_date
                        ? `${hasCurrentAssignment ? " since" : " from"}: ${formatShortDate(currentAssignment.start_date)}`
                        : ""
                    }
                    {
                      currentAssignment?.end_date
                        ? `; ended: ${formatShortDate(currentAssignment.end_date)}`
                        : ""
                    }
                  </dd>
                  <dt class="col-sm-4">Civil litigation</dt>
                  <dd class="col-sm-8">{data.civilCases.length}</dd>
                  <dt class="col-sm-4">Reports</dt>
                  <dd class="col-sm-8">{reportCount}</dd>
                  <dt class="col-sm-4">Videos</dt>
                  <dd class="col-sm-8">{videoCount}</dd>
                  <dt class="col-sm-4">Agency history</dt>
                  <dd class="col-sm-8">{assignmentHistoryCount}</dd>
                </dl>
                <div class="d-flex flex-wrap gap-2 mt-3">
                  <PrefillNavButton
                    class="btn btn-dark rounded-0"
                    to="/report/new/"
                    payload={reportNewPrefillPayload}
                  >
                    Submit Report
                  </PrefillNavButton>
                  <PrefillNavButton
                    class="btn btn-outline-dark rounded-0"
                    to={addCivilCaseHref}
                    payload={addCivilCasePrefillPayload}
                  >
                    Add a civil case
                  </PrefillNavButton>
                  <PrefillNavButton
                    class="btn btn-outline-dark rounded-0"
                    to={pastEmployerHref}
                    payload={pastEmployerPrefillPayload}
                  >
                    Submit past employer
                  </PrefillNavButton>
                  <PrefillNavButton
                    class="btn btn-outline-dark rounded-0"
                    to={suggestEditHref}
                    payload={suggestEditPrefillPayload}
                  >
                    Suggest edit
                  </PrefillNavButton>
                  <PrefillNavButton
                    class="btn btn-outline-dark rounded-0 d-flex align-items-center gap-2"
                    to="/about/contact/"
                    payload={{
                      whoami: "Subscriber",
                      message: `Please notify me when this profile changes: /personnel/${data.officer.slug}/`,
                    }}
                    data-testid="personnel-subscribe-link"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="lucide lucide-bell"
                    >
                      <path d="M10.268 21a2 2 0 0 0 3.464 0"></path>
                      <path
                        d="M3.262 15a4 4 0 0 0 3.938 3h9.6a4 4 0 0 0 3.938-3"
                      ></path>
                      <path d="M7 18v-7a5 5 0 0 1 10 0v7"></path>
                    </svg>
                    <span>Notify me when this profile changes</span>
                  </PrefillNavButton>
                </div>
              </div>
              <div class="col-12 col-lg-5 text-center">
                <img
                  src={personnelImageSrc}
                  class="img-fluid rounded shadow"
                  alt={`Portrait of ${data.officer.first_name} ${data.officer.last_name}`}
                />
                {
                  personnelImageSrc === defaultPersonnelImagePath ? (
                    <p class="small text-muted mt-2">
                      Official portrait not yet available — placeholder image
                      shown.
                    </p>
                  ) : null
                }
              </div>
            </div>

            <hr class="my-5" />

            <ProfileTabs
              tabs={[
                {
                  id: "officer-litigation",
                  label: "Civil litigation",
                  badge: civilCaseCount,
                  tabType: "litigation",
                },
                {
                  id: "officer-reports",
                  label: "Reports",
                  badge: reportCount,
                  tabType: "reports",
                },
                {
                  id: "officer-videos",
                  label: "Videos",
                  badge: videoCount,
                  tabType: "videos",
                },
                {
                  id: "officer-coverage",
                  label: "Coverage",
                  badge: coverageCount,
                  tabType: "coverage",
                },
                {
                  id: "officer-past",
                  label: "Agency history",
                  badge: assignmentHistoryCount,
                  tabType: "pastEmployers",
                },
              ]}
              litigation={{
                cases: civilCasesWithPaths,
              }}
              reports={{
                items: reportItems,
                layout: "table",
              }}
              videos={{
                items: videoItems,
              }}
              coverage={{
                links: data.coverageLinks,
              }}
              pastEmployers={{
                entries: assignmentHistory,
              }}
            />

            <div class="mt-3">
              <PrefillNavButton
                class="link-dark small"
                to={claimProfileHref}
                payload={claimProfilePrefillPayload}
                data-testid="personnel-claim-profile-link"
                variant="link"
              >
                Claim this profile
              </PrefillNavButton>
            </div>

            <div class="my-5">
              <h2 class="h5 text-uppercase text-muted">Comments</h2>
              <DisqusComments
                pageUrl={pageUrl}
                disqusIdentifier={disqusIdentifier}
              />
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
