---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import AlphaNavigation from "#src/components/AlphaNavigation.astro";
import CollectionStatsBand from "#src/components/CollectionStatsBand.astro";
import Pagination from "#src/components/Pagination.astro";
import PrefillBootstrap from "#src/components/PrefillBootstrap.astro";
import { buildAlphaPageMap } from "#src/lib/alpha-navigation.js";
import {
  buildCategoryCollectionStats,
  loadCategoryCollectionCounts,
  type CategoryCollectionCounts,
} from "#src/lib/category-collection-stats.js";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import { loadAgencySummaries } from "#src/lib/data/summaries.js";
import { US_STATE_TILES } from "#src/lib/geo/states.js";
import { PAGE_SIZE } from "#src/lib/pagination.js";
import AgencyCard from "#src/components/AgencyCard.astro";
import { buildItemList, getSiteUrl } from "#src/lib/structured-data.js";

export async function getStaticPaths() {
  const agencies = await loadAgencySummaries();
  const countsByCategory = await loadCategoryCollectionCounts();
  const agenciesByCategory = new Map<string, typeof agencies>();

  agencies.forEach((agency) => {
    const category = agency.category?.toLowerCase();
    if (!category) {
      return;
    }
    const list = agenciesByCategory.get(category) || [];
    list.push(agency);
    agenciesByCategory.set(category, list);
  });

  const allCategories = new Set<string>(
    US_STATE_TILES.map((stateEntry) => stateEntry.code.toLowerCase()),
  );
  allCategories.add("federal");

  return Array.from(allCategories).map((category) => {
    const categoryAgencies = agenciesByCategory.get(category) || [];
    return {
      params: { category },
      props: {
        agencies: categoryAgencies,
        totalCount: categoryAgencies.length,
        categoryCounts: countsByCategory.get(category) || {
          agencyCount: 0,
          personnelCount: 0,
          reportCount: 0,
          civilCaseCount: 0,
        },
      },
    };
  });
}

const { category } = Astro.params;
const categoryParam = (category as string) ?? "";
const categoryCode = categoryParam.toUpperCase();
const {
  agencies = [],
  totalCount = 0,
  categoryCounts = {
    agencyCount: 0,
    personnelCount: 0,
    reportCount: 0,
    civilCaseCount: 0,
  },
} = Astro.props as {
  agencies: any[];
  totalCount: number;
  categoryCounts: CategoryCollectionCounts;
};
const pageAgencies = agencies.slice(0, PAGE_SIZE);
const totalPages = Math.max(1, Math.ceil(totalCount / PAGE_SIZE));
const alphaItems = buildAlphaPageMap(
  agencies,
  (agency) => agency.name,
  PAGE_SIZE,
);
const categoryMeta = US_STATE_TILES.find(
  (entry) => entry.code === categoryCode,
);
const categoryLabel =
  categoryParam.toLowerCase() === "federal"
    ? "Federal"
    : categoryMeta?.name || categoryCode;
const title =
  categoryParam.toLowerCase() === "federal"
    ? "Federal Law Enforcement Agencies"
    : categoryMeta
      ? `${categoryMeta.name} Law Enforcement Agencies`
      : `${categoryCode} Law Enforcement Agencies`;
const pagePath = `/law-enforcement-agency/${categoryParam.toLowerCase()}/`;
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(pagePath, siteUrl).toString();
const pageDescription = `Showing agencies with at least two active personnel assignments in ${categoryLabel}.`;
const stats = buildCategoryCollectionStats(
  categoryParam.toLowerCase(),
  categoryLabel,
  categoryCounts,
);
const agencyItems = pageAgencies.map((agency, index) => {
  const addressAvailable =
    agency.address || agency.city || agency.state || agency.zipCode;
  const address = addressAvailable
    ? {
        "@type": "PostalAddress",
        ...(agency.address ? { streetAddress: agency.address } : {}),
        ...(agency.city ? { addressLocality: agency.city } : {}),
        ...(agency.state ? { addressRegion: agency.state } : {}),
        ...(agency.zipCode ? { postalCode: agency.zipCode } : {}),
      }
    : null;
  const categorySlugValue = agency.category || categoryParam.toLowerCase();
  const item = {
    "@type": "GovernmentOrganization",
    name: agency.name,
    url: new URL(
      `/law-enforcement-agency/${categorySlugValue}/${agency.slug}/`,
      siteUrl,
    ).toString(),
    ...(address ? { address } : {}),
    ...(agency.phoneNumber ? { telephone: agency.phoneNumber } : {}),
  };
  return {
    "@type": "ListItem",
    position: index + 1,
    item,
  };
});
const agencyItemList = buildItemList(agencyItems);
const websiteId = new URL("/", siteUrl).toString();
const agencyItemListId = agencyItemList ? `${pageUrl}#itemlist` : null;
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": websiteId,
      url: websiteId,
      name: "PoliceConduct.org",
    },
    {
      "@type": "CollectionPage",
      "@id": pageUrl,
      url: pageUrl,
      name: title,
      description: pageDescription,
      isPartOf: { "@id": websiteId },
      ...(agencyItemListId ? { mainEntity: { "@id": agencyItemListId } } : {}),
    },
    ...(agencyItemList ? [{ ...agencyItemList, "@id": agencyItemListId }] : []),
  ],
};
---

<SiteLayout
  title={title}
  description={`Law enforcement agencies currently listed for ${categoryLabel}.`}
  pagePath={pagePath}
  canonicalUrl={pagePath}
  structuredData={structuredData}
>
  <PrefillBootstrap />
  <main>
    <section class="py-vh-3 bg-gray-100 border-bottom border-dark">
      <div class="container">
        <div class="row g-4 align-items-end">
          <div class="col-12">
            <Breadcrumbs
              items={[
                { label: "Home", href: "/" },
                { label: "Agencies", href: "/law-enforcement-agency/" },
                { label: categoryLabel, href: pagePath, current: true },
              ]}
              className="mb-2"
            />
            <p class="text-uppercase small text-muted mb-2">
              {
                categoryParam.toLowerCase() === "federal"
                  ? "Federal view"
                  : "State view"
              }
            </p>
            <h1 class="display-4 fw-bold">{title}</h1>
            <p class="lead text-muted mb-0">{pageDescription}</p>
            <p class="small text-muted mb-0 mt-3">Page 1 of {totalPages}</p>
          </div>
        </div>
      </div>
    </section>
    <div class="bg-white border-bottom border-dark">
      <CollectionStatsBand items={stats} />
    </div>

    <section class="py-vh-2">
      <div class="container">
        <AlphaNavigation
          items={alphaItems}
          basePath={pagePath}
          currentPage={1}
          label={`${categoryLabel} agencies alphabetical navigation`}
        />
        {
          agencies.length === 0 ? (
            <div
              class="alert alert-secondary rounded-0 border-dark d-flex flex-column gap-2"
              role="status"
            >
              <span>No agencies listed yet for {categoryLabel}.</span>
              <a
                class="btn btn-dark rounded-0 w-auto"
                href="/law-enforcement-agency/suggest-edit/"
                target="_self"
                data-prefill-key="prefill:agencySuggestEdit"
                data-prefill-payload={JSON.stringify({
                  jurisdiction: categoryParam.toLowerCase(),
                })}
              >
                Add one now
              </a>
            </div>
          ) : (
            <div class="row row-cols-1 g-3">
              {pageAgencies.map((agency) => (
                <div class="col">
                  <AgencyCard agency={agency} />
                </div>
              ))}
            </div>
          )
        }
        <Pagination basePath={pagePath} currentPage={1} lastPage={totalPages} />
      </div>
    </section>
  </main>
  <script
    is:inline
    id="dsq-count-scr"
    src="https://policeconduct.disqus.com/count.js"
    async></script>
</SiteLayout>
