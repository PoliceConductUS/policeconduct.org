---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import AlphaNavigation from "#src/components/AlphaNavigation.astro";
import CollectionStatsBand from "#src/components/CollectionStatsBand.astro";
import Pagination from "#src/components/Pagination.astro";
import { buildAlphaPageMap } from "#src/lib/alpha-navigation.js";
import {
  buildCategoryCollectionStats,
  loadCategoryCollectionCounts,
  type CategoryCollectionCounts,
} from "#src/lib/category-collection-stats.js";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import { loadAgencySummaries } from "#src/lib/data/summaries.js";
import { US_STATE_TILES } from "#src/lib/geo/states.js";
import { PAGE_SIZE } from "#src/lib/pagination.js";
import { buildItemList, getSiteUrl } from "#src/lib/structured-data.js";

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const agencies = await loadAgencySummaries();
  const countsByCategory = await loadCategoryCollectionCounts();
  const agenciesByCategory = new Map();

  agencies.forEach((agency) => {
    const category = agency.category?.toLowerCase();
    if (!category) {
      return;
    }
    const list = agenciesByCategory.get(category) || [];
    list.push(agency);
    agenciesByCategory.set(category, list);
  });

  const pages: any[] = [];
  agenciesByCategory.forEach((categoryAgencies, category) => {
    const categoryPages = paginate(categoryAgencies, {
      pageSize: PAGE_SIZE,
      params: { category },
      props: {
        allAgencies: categoryAgencies,
        categoryCounts: countsByCategory.get(category) || {
          agencyCount: 0,
          personnelCount: 0,
          reportCount: 0,
          civilCaseCount: 0,
        },
      },
    });
    categoryPages
      .filter((page: any) => {
        const pageParam = page.params?.page;
        if (Array.isArray(pageParam)) {
          return pageParam.length > 0 && pageParam[0] !== "1";
        }
        return (
          typeof pageParam === "string" &&
          pageParam.length > 0 &&
          pageParam !== "1"
        );
      })
      .forEach((page: any) => pages.push(page));
  });

  return pages;
}

const { page } = Astro.props;
const { category } = Astro.params;
const categoryParam = (category as string) ?? "";
const categoryCode = categoryParam.toUpperCase();
const categoryMeta = US_STATE_TILES.find(
  (entry) => entry.code === categoryCode,
);
const categoryLabel =
  categoryParam.toLowerCase() === "federal"
    ? "Federal"
    : categoryMeta?.name || categoryCode;
const titleBase =
  categoryParam.toLowerCase() === "federal"
    ? "Federal Law Enforcement Agencies"
    : categoryMeta
      ? `${categoryMeta.name} Law Enforcement Agencies`
      : `${categoryCode} Law Enforcement Agencies`;
const title =
  page.currentPage > 1 ? `${titleBase} – Page ${page.currentPage}` : titleBase;
const {
  allAgencies = [],
  categoryCounts = {
    agencyCount: 0,
    personnelCount: 0,
    reportCount: 0,
    civilCaseCount: 0,
  },
} = Astro.props as {
  allAgencies: any[];
  categoryCounts: CategoryCollectionCounts;
};
const alphaItems = buildAlphaPageMap(
  allAgencies,
  (agency) => agency.name,
  PAGE_SIZE,
);
const pagePath =
  page.currentPage > 1
    ? `/law-enforcement-agency/${categoryParam.toLowerCase()}/page/${page.currentPage}/`
    : `/law-enforcement-agency/${categoryParam.toLowerCase()}/`;
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(pagePath, siteUrl).toString();
const pageDescription = `Showing agencies with at least two active personnel assignments in ${categoryLabel}.`;
const stats = buildCategoryCollectionStats(
  categoryParam.toLowerCase(),
  categoryLabel,
  categoryCounts,
);
const agencyItems = page.data.map((agency: any, index: number) => {
  const addressAvailable =
    agency.address || agency.city || agency.state || agency.zipCode;
  const address = addressAvailable
    ? {
        "@type": "PostalAddress",
        ...(agency.address ? { streetAddress: agency.address } : {}),
        ...(agency.city ? { addressLocality: agency.city } : {}),
        ...(agency.state ? { addressRegion: agency.state } : {}),
        ...(agency.zipCode ? { postalCode: agency.zipCode } : {}),
      }
    : null;
  const item = {
    "@type": "GovernmentOrganization",
    name: agency.name,
    url: new URL(agency.canonicalPath, siteUrl).toString(),
    ...(address ? { address } : {}),
    ...(agency.phoneNumber ? { telephone: agency.phoneNumber } : {}),
  };
  return {
    "@type": "ListItem",
    position: index + 1,
    item,
  };
});
const agencyItemList = buildItemList(agencyItems);
const websiteId = new URL("/", siteUrl).toString();
const agencyItemListId = agencyItemList ? `${pageUrl}#itemlist` : null;
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": websiteId,
      url: websiteId,
      name: "PoliceConduct.org",
    },
    {
      "@type": "CollectionPage",
      "@id": pageUrl,
      url: pageUrl,
      name: title,
      description: pageDescription,
      isPartOf: { "@id": websiteId },
      ...(agencyItemListId ? { mainEntity: { "@id": agencyItemListId } } : {}),
    },
    ...(agencyItemList ? [{ ...agencyItemList, "@id": agencyItemListId }] : []),
  ],
};
---

<SiteLayout
  title={title}
  description={pageDescription}
  pagePath={pagePath}
  canonicalUrl={pagePath}
  structuredData={structuredData}
>
  <main>
    <section class="py-vh-3 bg-gray-100 border-bottom border-dark">
      <div class="container">
        <div class="row g-4 align-items-end">
          <div class="col-12">
            <Breadcrumbs
              items={[
                { label: "Home", href: "/" },
                { label: "Agencies", href: "/law-enforcement-agency/" },
                {
                  label: categoryLabel,
                  href: `/law-enforcement-agency/${categoryParam.toLowerCase()}/`,
                },
                {
                  label: `Page ${page.currentPage}`,
                  href: pagePath,
                  current: true,
                },
              ]}
              className="mb-2"
            />
            <h1 class="display-4 fw-bold">{title}</h1>
            <p class="lead text-muted mb-0">
              Showing agencies with at least two active personnel assignments in {
                categoryLabel
              }.
            </p>
            <p class="small text-muted mb-0 mt-3">
              Page {page.currentPage} of {page.lastPage}
            </p>
          </div>
        </div>
      </div>
    </section>
    <section class="py-vh-2">
      <div class="container">
        <AlphaNavigation
          items={alphaItems}
          basePath={`/law-enforcement-agency/${categoryParam.toLowerCase()}/`}
          currentPage={page.currentPage}
          label={`${categoryLabel} agencies alphabetical navigation`}
        />
        {
          page.data.length === 0 ? (
            <div
              class="alert alert-secondary rounded-0 border-dark"
              role="status"
            >
              No agencies listed yet for {categoryLabel}.
            </div>
          ) : (
            <div class="profile-record-list">
              {page.data.map((agency: any) => (
                <article class="profile-record">
                  <div class="profile-record-meta">
                    <span>
                      {[agency.city, agency.state].filter(Boolean).join(", ")}
                    </span>
                    {agency.activePersonnelCount > 0 ? (
                      <span>{agency.activePersonnelCount} personnel</span>
                    ) : null}
                  </div>
                  <div class="profile-record-body">
                    <h2 class="profile-record-title">
                      <a href={agency.canonicalPath}>{agency.name}</a>
                    </h2>
                    <div class="profile-record-detail">
                      {agency.address ? <span>{agency.address}</span> : null}
                      {agency.phoneNumber ? (
                        <>
                          <span aria-hidden="true">/</span>
                          <a
                            href={`tel:${agency.phoneNumber.replace(/[^\d+]/g, "")}`}
                          >
                            {agency.phoneNumber}
                          </a>
                        </>
                      ) : null}
                      {agency.activePersonnelCount > 0 ? (
                        <span>{agency.activePersonnelCount} personnel</span>
                      ) : null}
                      {agency.reportCount > 0 ? (
                        <a
                          href={
                            agency.category === "federal"
                              ? "/report/"
                              : `/report/${agency.category}/`
                          }
                        >
                          {agency.reportCount} reports
                        </a>
                      ) : null}
                      {agency.civilCaseCount > 0 ? (
                        <span>{agency.civilCaseCount} civil cases</span>
                      ) : null}
                    </div>
                  </div>
                </article>
              ))}
            </div>
          )
        }
        <Pagination
          basePath={`/law-enforcement-agency/${categoryParam.toLowerCase()}/`}
          currentPage={page.currentPage}
          lastPage={page.lastPage}
        />
      </div>
    </section>
    <CollectionStatsBand items={stats} variant="compact" />
  </main>
  <script
    is:inline
    id="dsq-count-scr"
    src="https://policeconduct.disqus.com/count.js"
    async></script>
</SiteLayout>
<style>
  .display-4 {
    max-width: 100%;
    overflow-wrap: anywhere;
  }

  .profile-record-list {
    border-top: 0;
    display: grid;
    gap: 0;
  }

  .profile-record {
    align-items: start;
    border-top: 1px solid var(--bs-border-color);
    display: grid;
    gap: 0.75rem 1.25rem;
    grid-template-columns: minmax(0, 1fr) minmax(8rem, 13rem);
    padding: 0.95rem 0;
    transition:
      background-color 140ms ease,
      border-color 140ms ease;
  }

  .profile-record:hover {
    background: color-mix(in srgb, var(--bs-gray-100) 42%, var(--bs-white));
  }

  .profile-record-body {
    grid-column: 1;
    grid-row: 1;
    min-width: 0;
  }

  .profile-record-meta {
    align-items: flex-end;
    color: var(--bs-secondary-color);
    display: flex;
    flex-direction: column;
    font-size: 0.8125rem;
    gap: 0.25rem;
    grid-column: 2;
    grid-row: 1;
    line-height: 1.35;
    min-width: 0;
    text-align: right;
  }

  .profile-record-title {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.35;
    margin: 0;
  }

  .profile-record-title a,
  .profile-record-detail a {
    color: var(--bs-dark);
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .profile-record-detail {
    color: var(--bs-secondary-color);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.875rem;
    gap: 0.35rem 0.85rem;
    line-height: 1.5;
    margin-top: 0.35rem;
    min-width: 0;
  }

  .profile-record-detail > span[aria-hidden="true"] {
    display: none;
  }

  .profile-record-meta span,
  .profile-record-meta a {
    color: var(--bs-secondary-color);
    max-width: 100%;
  }

  .profile-record-title a {
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  .profile-record-detail a {
    font-weight: 600;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.16em;
  }

  .profile-record-title,
  .profile-record-detail,
  .profile-record-meta {
    overflow-wrap: anywhere;
  }

  @media (max-width: 991.98px) {
    .display-4 {
      font-size: clamp(2.25rem, 12vw, 3.5rem);
      line-height: 1.05;
    }

    .profile-record {
      grid-template-columns: minmax(0, 1fr);
    }

    .profile-record-body,
    .profile-record-meta {
      grid-column: 1;
    }

    .profile-record-meta {
      align-items: flex-start;
      flex-direction: row;
      flex-wrap: wrap;
      grid-row: 2;
      text-align: left;
    }
  }

  @media (max-width: 575.98px) {
    .profile-record-list,
    .profile-record {
      max-width: calc(100vw - 1rem);
    }

    .profile-record-detail {
      align-items: flex-start;
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }

    .profile-record-detail > * {
      margin-right: 0;
    }
  }
</style>
