---
import SiteLayout from "#src/layouts/SiteLayout.astro";
import UsaChoroplethMap from "#src/components/UsaChoroplethMap.astro";
import {
  loadAgencySummaries,
  loadPersonnelSummaries,
  loadReportSummaries,
} from "#src/lib/data/summaries.js";
import { withDb } from "#src/lib/db.js";
import { US_STATE_TILES } from "#src/lib/geo/states.js";
import { buildWebPage, getSiteUrl } from "#src/lib/structured-data.js";

const pagePath = "/";
const pageDescription =
  "Independent public record for police interaction reports, commendations, law enforcement agencies, personnel profiles, and civil litigation records across the United States.";
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(pagePath, siteUrl).toString();
const [agencies, personnel, reports, civilCasesData] = await Promise.all([
  loadAgencySummaries(),
  loadPersonnelSummaries(),
  loadReportSummaries(),
  withDb(async (client) => {
    const categoryResult = await client.query(
      `
        select upper(a.category) as category, count(distinct cco.civil_case_id) as case_count
        from public.civil_case_officers cco
        join public.agency_officers ao on ao.id = cco.agency_officer_id
        join public.agency a on ao.agency_id = a.id
        where a.category is not null
        group by upper(a.category)
      `,
    );
    const result = await client.query(
      "select count(*) as count from public.civil_cases",
    );
    return {
      categoryCounts: categoryResult.rows.map(
        (row: { category: string; case_count: string | number }) => ({
          category: String(row.category || "").toLowerCase(),
          count: Number(row.case_count || 0),
        }),
      ),
      totalCount: Number(result.rows[0]?.count ?? 0),
    };
  }),
]);
const civilCasesByCategory = new Map(
  civilCasesData.categoryCounts.map((entry) => [entry.category, entry.count]),
);
const reportCountsByCategory = reports.reduce(
  (acc: Map<string, number>, report) => {
    const key = String(report.category || "").toLowerCase();
    if (!key) {
      return acc;
    }
    acc.set(key, (acc.get(key) ?? 0) + 1);
    return acc;
  },
  new Map<string, number>(),
);
const personnelCountsByCategory = personnel.reduce(
  (acc: Map<string, number>, entry) => {
    const key = String(entry.agencyCategory || "").toLowerCase();
    if (!key) {
      return acc;
    }
    acc.set(key, (acc.get(key) ?? 0) + 1);
    return acc;
  },
  new Map<string, number>(),
);
const agencyCountsByCategory = agencies.reduce(
  (acc: Map<string, number>, agency) => {
    const key = String(agency.category || "").toLowerCase();
    if (!key) {
      return acc;
    }
    acc.set(key, (acc.get(key) ?? 0) + 1);
    return acc;
  },
  new Map<string, number>(),
);
const federalAgencies = agencies.filter(
  (agency) => String(agency.category || "").toLowerCase() === "federal",
);
const categoryCoverageStats = US_STATE_TILES.map((state) => {
  const category = state.code.toLowerCase();
  const reportCount = reportCountsByCategory.get(category) ?? 0;
  const personnelCount = personnelCountsByCategory.get(category) ?? 0;
  const agencyCount = agencyCountsByCategory.get(category) ?? 0;
  const civilCaseCount = civilCasesByCategory.get(category) ?? 0;
  const totalCount =
    reportCount + personnelCount + agencyCount + civilCaseCount;
  return {
    code: state.code,
    count: totalCount,
    href: `/${category}/`,
    hoverLabel:
      totalCount > 0
        ? `${state.name}: ${reportCount} reports, ${personnelCount} personnel, ${agencyCount} agencies, ${civilCaseCount} civil cases`
        : `${state.name}: no entries yet`,
  };
});
const federalCoverageCount =
  (reportCountsByCategory.get("federal") ?? 0) +
  (personnelCountsByCategory.get("federal") ?? 0) +
  (agencyCountsByCategory.get("federal") ?? 0) +
  (civilCasesByCategory.get("federal") ?? 0);
const organization = {
  "@type": "NonprofitOrganization",
  "@id": `${pageUrl}#organization`,
  name: "Institute for Police Conduct, Inc.",
  alternateName: "PoliceConduct.org",
  url: pageUrl,
  description: pageDescription,
  taxID: "99-3296620",
  nonprofitStatus: "https://schema.org/Nonprofit501c3",
  address: {
    "@type": "PostalAddress",
    streetAddress: "8 The Green #11026",
    addressLocality: "Dover",
    addressRegion: "DE",
    postalCode: "19901",
    addressCountry: "US",
  },
  sameAs: [
    "https://facebook.com/PoliceConductUS",
    "https://twitter.com/PoliceConductUS",
    "https://instagram.com/PoliceConductUS",
    "https://www.tiktok.com/@policeconductus",
    "https://linkedin.com/company/PoliceConductUS",
    "https://youtube.com/@PoliceConductUS",
    "https://www.reddit.com/user/PoliceConductUS/",
    "https://github.com/PoliceConductUS",
  ],
};
const structuredData = buildWebPage({
  siteUrl,
  pageUrl,
  name: "Institute for Police Conduct, Inc.",
  description: pageDescription,
});
structuredData.mainEntity = organization;
---

<SiteLayout
  title="Police Interaction Reports, Agency Records, and Personnel Profiles | PoliceConduct.org"
  description={pageDescription}
  pagePath={pagePath}
  socialImage="/img/webp/usa-1778524_1280.webp"
  structuredData={structuredData}
>
  <main>
    <div class="w-100 overflow-hidden bg-gray-100" id="top">
      <div class="container position-relative">
        <div
          class="col-12 col-lg-8 mt-0 h-100 position-absolute top-0 end-0 bg-cover"
          data-aos="fade-left"
        >
          <img
            src="/img/webp/usa-1778524_1280.webp"
            alt=""
            width="1280"
            height="853"
            class="w-100 h-100 object-fit-cover"
            fetchpriority="high"
            loading="eager"
            decoding="async"
          />
        </div>
        <div class="row">
          <div class="col-lg-7 py-vh-2 position-relative" data-aos="fade-right">
            <h1 class="display-1 fw-bold mt-5">
              Report a police interaction. Research the public record.
            </h1>
            <p class="lead">
              PoliceConduct.org helps people document interactions with law
              enforcement and review public records about agencies, personnel,
              reports, and civil litigation.
            </p>
            <a
              href="/report/new/"
              class="btn btn-dark btn-xl shadow me-3 rounded-0 my-5"
              >Submit a report</a
            >
            <a
              href="/report/"
              class="btn btn-outline-dark btn-xl shadow rounded-0 my-5"
              >Research records</a
            >
          </div>
        </div>
      </div>
    </div>
    <section class="py-vh-3 bg-light border-top border-dark" id="overview">
      <div class="container">
        <div class="row justify-content-end mb-4">
          <div class="col-lg-8">
            <h2 class="display-6 mb-2">National overview</h2>
            <p class="lead mb-0">
              Start with your state or federal agencies and follow the record
              from there.
            </p>
          </div>
        </div>
        <div class="row g-4 align-items-stretch">
          <div class="col-12">
            <UsaChoroplethMap
              stats={categoryCoverageStats}
              title="United States"
              subtitle="Combined coverage across reports, personnel, agencies, and civil litigation."
              emptyLabel="No entries yet"
              interactionLabel="Select a state to view its overview."
              federalPanel={{
                eyebrow: "Federal",
                title: "Federal overview",
                value: federalCoverageCount,
                description:
                  "Combined federal entries across reports, personnel, agencies, and civil litigation.",
                items: [
                  {
                    label: "Federal overview",
                    href: "/federal/",
                  },
                  ...federalAgencies.map((agency) => ({
                    label: agency.name,
                    href: `/law-enforcement-agency/${agency.category}/${agency.slug}/`,
                  })),
                ],
                actionHref: "/federal/",
                actionLabel: "Open federal overview",
              }}
            />
          </div>
        </div>
      </div>
    </section>

    <div
      class="small py-vh-3 bg-gray-900 text-light w-100 overflow-hidden"
      id="use-record"
    >
      <div class="container">
        <div class="row mb-4">
          <div class="col-lg-8">
            <h2 class="h3 mb-2">Use the record</h2>
            <p class="mb-0 text-light">
              Use the site to document an interaction, research a local agency,
              or work with others on public-interest reporting and oversight.
            </p>
          </div>
        </div>
        <div class="row">
          <div class="col-md-6 col-lg-4" data-aos="fade-up">
            <span class="h5 fw-lighter">01.</span>
            <h3 class="py-4 border-top border-light">Report an interaction</h3>
            <p>
              Add a documented public account, whether the interaction was
              negative, positive, or mixed.
            </p>
            <a class="link-light fw-semibold" href="/report/new/"
              >Submit a report</a
            >
          </div>
          <div
            class="col-md-6 col-lg-4"
            data-aos="fade-up"
            data-aos-delay="200"
          >
            <span class="h5 fw-lighter">02.</span>
            <h3 class="py-4 border-top border-light">Research local records</h3>
            <p>
              Review reports, agencies, personnel, and civil litigation by
              state, agency, or person.
            </p>
            <a class="link-light fw-semibold" href="/report/"
              >Research records</a
            >
          </div>

          <div
            class="col-md-6 col-lg-4"
            data-aos="fade-up"
            data-aos-delay="400"
          >
            <span class="h5 fw-lighter">03.</span>
            <h3 class="py-4 border-top border-light">
              Partner with the project
            </h3>
            <p>
              Oversight bodies, law firms, newsrooms, nonprofits, and
              researchers can extend the usefulness of the record.
            </p>
            <a class="link-light fw-semibold" href="/partner/"
              >Explore partner paths</a
            >
          </div>
        </div>
      </div>
    </div>

    <div class="py-vh-4 w-100 overflow-hidden" id="broken">
      <div class="container">
        <div class="row d-flex justify-content-between align-items-center">
          <div class="col-lg-4">
            <h2 class="py-4 border-top border-dark" data-aos="fade-right">
              Public records help communities and law enforcement respond to the
              same facts.
            </h2>
            <small>— Institute for Police Conduct</small>
          </div>
          <div class="col-lg-8">
            <div class="row">
              <div class="col-12">
                <h2 class="display-6 mb-4" data-aos="fade-down">
                  What's broken?
                </h2>
                <h3>
                  Public information about police conduct is fragmented,
                  inconsistent, and often difficult for ordinary people to
                  access or interpret.
                </h3>
                <p class="mb-0 text-black-50">
                  Relevant material may exist across court dockets,
                  public-records responses, agency materials, news coverage, and
                  community accounts, but it is rarely organized for fast,
                  meaningful review.
                </p>
              </div>
              <div class="col-md-4" data-aos="fade-up">
                <h4 class="h5 my-3">Patterns are hard to identify</h4>
                <p class="text-black-50 mb-0">
                  Incidents that look isolated in one source may look different
                  alongside prior complaints, litigation, or public reports.
                </p>
              </div>
              <div class="col-md-4" data-aos="fade-up">
                <h4 class="h5 my-3">Access is uneven</h4>
                <p class="text-black-50 mb-0">
                  Journalists, lawyers, and well-resourced organizations may be
                  able to assemble a fuller picture. Most people cannot.
                </p>
              </div>
              <div class="col-md-4" data-aos="fade-up">
                <h4 class="h5 my-3">Context is easy to lose</h4>
                <p class="text-black-50 mb-0">
                  Serious concerns may remain obscure, while isolated
                  allegations may circulate without enough context or
                  corroboration.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div
      class="py-vh-4 bg-gray-900 text-light w-100 overflow-hidden"
      id="mission"
    >
      <div class="container">
        <div class="row justify-content-end mb-4">
          <div class="col-lg-8" data-aos="fade-down">
            <h2 class="display-6 mb-2">Our mission</h2>
            <p class="lead mb-0">
              Make police conduct easier to document, understand, and review.
            </p>
          </div>
        </div>
        <div class="row d-flex justify-content-between align-items-center">
          <div class="col-lg-6">
            <div
              class="shadow ratio ratio-16x9 rounded bg-cover bp-center"
              data-aos="fade-right"
              style="
                  background-image: url(img/webp/people15.webp);
                  --bs-aspect-ratio: 58%;
                "
            >
            </div>
          </div>
          <div class="col-lg-4">
            <h3 class="py-4 border-top border-light" data-aos="fade-left">
              Institute for Police Conduct is a nonprofit, public-interest
              record focused on making police conduct easier to document,
              understand, and review.
            </h3>
            <p class="text-light" data-aos="fade-left" data-aos-delay="200">
              The goal is not to replace courts, internal affairs, or formal
              oversight bodies. The goal is to make already-existing public
              information and structured public reporting more usable for the
              public.
            </p>
            <p class="mb-0" data-aos="fade-left" data-aos-delay="250">
              <a class="link-light fw-semibold" href="/about/"
                >Learn more about the organization</a
              >
            </p>
          </div>
        </div>
      </div>
    </div>

    <div class="py-vh-5 bg-gray-900 text-light w-100 overflow-hidden">
      <div class="container text-center">
        <p class="text-light lead">Need help reaching the team?</p>
        <h2 class="h3 mb-3">Contact the Institute for Police Conduct</h2>
        <p class="text-light mb-4">
          Use the contact form for partnerships, questions, corrections, or
          support.
        </p>
        <div class="d-flex flex-wrap justify-content-center gap-3">
          <a class="btn btn-light btn-xl rounded-0" href="/about/contact/"
            >Contact us</a
          >
          <a class="btn btn-outline-light btn-xl rounded-0" href="/donate/"
            >Donate</a
          >
        </div>
      </div>
    </div>
  </main>
  <script>
    import AOS from "aos";
    import "aos/dist/aos.css";

    if (!document.documentElement.dataset.aosInit) {
      AOS.init({
        duration: 800,
        once: true,
      });
      document.documentElement.dataset.aosInit = "1";
    }
  </script>
</SiteLayout>
