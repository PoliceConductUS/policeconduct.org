  </main>
  <script>
    import {
      flattenFormData,
      initRecaptcha,
      showFormLoadError,
      submitJsonForm,
    } from "#src/lib/client/forms.ts";
    import type { ReportNewPrefill } from "#src/lib/forms/prefill";

    const form = document.getElementById(
      "reportForm",
    ) as HTMLFormElement | null;
    const formShell = document.querySelector(
      '[data-form-shell="reportNew"]',
    ) as HTMLElement | null;

    if (form) {
      const draftEndpoint = "/api/forms/draft";
      const reportDraftCookieName = "pc_report_draft";
      const officerList = form.querySelector("[data-officers]") as HTMLElement;
      const addOfficerButton = form.querySelector(
        "[data-add-officer]",
      ) as HTMLButtonElement;
      const officerTemplateElement = document.getElementById(
        "officerTemplate",
      ) as HTMLTemplateElement | null;
      const witnessList = form.querySelector("[data-witnesses]") as HTMLElement;
      const addWitnessButton = form.querySelector(
        "[data-add-witness]",
      ) as HTMLButtonElement;
      const witnessTemplateElement = document.getElementById(
        "witnessTemplate",
      ) as HTMLTemplateElement | null;
      const evidenceList = form.querySelector(
        "[data-evidence-list]",
      ) as HTMLElement;
      const addEvidenceButton = form.querySelector(
        "[data-add-evidence]",
      ) as HTMLButtonElement;
      const evidenceTemplateElement = document.getElementById(
        "evidenceTemplate",
      ) as HTMLTemplateElement | null;

      type OfficerDraft = {
        name: string;
        badge: string;
        department: string;
        traits: Record<string, string>;
      };
      type WitnessDraft = {
        name: string;
        phone: string;
        email: string;
      };
      type EvidenceDraft = {
        link: string;
        description: string;
      };

      type ReportDraft = {
        officers: OfficerDraft[];
        witnesses: WitnessDraft[];
        evidence: EvidenceDraft[];
        [key: string]: unknown;
      };
      const structuredRoots = ["officers", "witnesses", "evidence"];

      const getReportDraftId = () => {
        const value = `; ${document.cookie}`;
        const parts = value.split(`; ${reportDraftCookieName}=`);
        if (parts.length !== 2) {
          return "";
        }
        const cookieValue = parts.pop();
        return cookieValue ? cookieValue.split(";")[0] : "";
      };

      const setReportDraftId = (draftId: string) => {
        document.cookie = `${reportDraftCookieName}=${draftId}; Max-Age=${60 * 60}; Path=/report/new/; SameSite=Lax`;
      };

      const clearReportDraftCookie = () => {
        document.cookie = `${reportDraftCookieName}=; Max-Age=0; Path=/report/new/; SameSite=Lax`;
      };

      const emptyOfficer = (): OfficerDraft => ({
        name: "",
        badge: "",
        department: "",
        traits: {},
      });
      const emptyWitness = (): WitnessDraft => ({
        name: "",
        phone: "",
        email: "",
      });
      const emptyEvidence = (): EvidenceDraft => ({
        link: "",
        description: "",
      });

      let draft: ReportDraft = {
        officers: [emptyOfficer()],
        witnesses: [],
        evidence: [],
      };

      if (
        !officerTemplateElement ||
        !witnessTemplateElement ||
        !evidenceTemplateElement
      ) {
        showFormLoadError({ formName: "reportNew", shell: formShell });
      } else {
        const officerTemplate = officerTemplateElement.content
          .firstElementChild as HTMLElement | null;
        const witnessTemplate = witnessTemplateElement.content
          .firstElementChild as HTMLElement | null;
        const evidenceTemplate = evidenceTemplateElement.content
          .firstElementChild as HTMLElement | null;

        if (!officerTemplate || !witnessTemplate || !evidenceTemplate) {
          showFormLoadError({ formName: "reportNew", shell: formShell });
        } else {
          const officerFieldName = (index: number, field: string) =>
            `officers[${index}][${field}]`;
          const officerFieldId = (index: number, field: string) =>
            `officers-${index}-${field}`;
          const officerTraitName = (index: number, traitId: string) =>
            `officers[${index}][traits][${traitId}]`;
          const officerTraitId = (
            index: number,
            traitId: string,
            rubricId: string,
          ) => `officer-${index}-trait-${traitId}-${rubricId}`;
          const witnessFieldName = (index: number, field: string) =>
            `witnesses[${index}][${field}]`;
          const witnessFieldId = (index: number, field: string) =>
            `witness-${index}-${field}`;
          const evidenceFieldName = (index: number, field: string) =>
            `evidence[${index}][${field}]`;
          const evidenceFieldId = (index: number, field: string) =>
            `evidence-${field}-${index}`;
          const readReportData = (formData: FormData) => {
            const data = flattenFormData(
              formData,
              ...structuredRoots,
            ) as ReportDraft;
            data.witnesses ??= [];
            data.evidence ??= [];
            return data;
          };

          const validateOfficerAssessments = () => {
            let isValid = true;

            form
              .querySelectorAll<HTMLElement>("[data-officer]")
              .forEach((officerElement) => {
                const assessmentError =
                  officerElement.querySelector<HTMLElement>(
                    "[data-officer-assessment-error]",
                  );
                const traitGroups = new Map<string, HTMLInputElement[]>();
                let hasAssessmentError = false;

                officerElement
                  .querySelectorAll<HTMLInputElement>("[data-officer-trait]")
                  .forEach((field) => {
                    field.setCustomValidity("");
                    if (!field.name) {
                      return;
                    }

                    const group = traitGroups.get(field.name) || [];
                    group.push(field);
                    traitGroups.set(field.name, group);
                  });

                traitGroups.forEach((fields) => {
                  if (fields.some((field) => field.checked)) {
                    return;
                  }

                  isValid = false;
                  hasAssessmentError = true;
                  fields.forEach((field) => {
                    field.setCustomValidity(
                      "Please choose an assessment or Not Observed / Does not apply.",
                    );
                  });
                });

                if (assessmentError) {
                  assessmentError.classList.toggle(
                    "d-none",
                    !hasAssessmentError,
                  );
                }
              });

            return isValid;
          };

          const updateOfficers = (
            getNextOfficers: (officers: OfficerDraft[]) => OfficerDraft[],
          ) => {
            const data = readReportData(new FormData(form));
            data.officers = getNextOfficers(data.officers);
            draft = data;
            renderOfficers();
          };

          const appendOfficer = () => {
            updateOfficers((officers) => [...officers, emptyOfficer()]);
          };

          const deleteOfficer = (index: number) => {
            updateOfficers((officers) => [
              ...officers.slice(0, index),
              ...officers.slice(index + 1),
            ]);
          };

          const addOfficer = () => {
            appendOfficer();
          };

          const removeOfficer = (index: number) => {
            deleteOfficer(index);
          };

          const updateWitnesses = (
            getNextWitnesses: (witnesses: WitnessDraft[]) => WitnessDraft[],
          ) => {
            const data = readReportData(new FormData(form));
            data.witnesses = getNextWitnesses(data.witnesses);
            draft = data;
            renderWitnesses();
          };

          const appendWitness = () => {
            updateWitnesses((witnesses) => [...witnesses, emptyWitness()]);
          };

          const deleteWitness = (index: number) => {
            updateWitnesses((witnesses) => [
              ...witnesses.slice(0, index),
              ...witnesses.slice(index + 1),
            ]);
          };

          const addWitness = () => {
            appendWitness();
          };

          const removeWitness = (index: number) => {
            deleteWitness(index);
          };

          const updateEvidence = (
            getNextEvidence: (evidence: EvidenceDraft[]) => EvidenceDraft[],
          ) => {
            const data = readReportData(new FormData(form));
            data.evidence = getNextEvidence(data.evidence);
            draft = data;
            renderEvidence();
          };

          const appendEvidence = () => {
            updateEvidence((evidence) => [...evidence, emptyEvidence()]);
          };

          const deleteEvidence = (index: number) => {
            updateEvidence((evidence) => [
              ...evidence.slice(0, index),
              ...evidence.slice(index + 1),
            ]);
          };

          const addEvidence = () => {
            appendEvidence();
          };

          const removeEvidence = (index: number) => {
            deleteEvidence(index);
          };

          const applyPrefill = () => {
            const payload = window.__IPC_PREFILL__?.readAndConsume?.(
              "prefill:reportNew",
            ) as ReportNewPrefill | null;
            if (!payload?.officer) {
              return;
            }

            draft.officers = [
              {
                ...draft.officers[0],
                ...payload.officer,
              },
            ];
          };

          const renderOfficers = () => {
            const officers = draft.officers;
            const officerElements = officers.map((officer, index) => {
              const currentOfficer = {
                ...emptyOfficer(),
                ...officer,
                traits: officer.traits || {},
              };
              const officerElement = officerTemplate.cloneNode(
                true,
              ) as HTMLElement;
              const title = officerElement.querySelector(
                "[data-officer-title]",
              );
              const removeButton = officerElement.querySelector(
                "[data-remove-officer]",
              ) as HTMLButtonElement;

              if (title) {
                title.textContent = `Officer ${index + 1}`;
              }

              officerElement.dataset.index = String(index);

              if (officers.length === 1) {
                removeButton.remove();
              } else {
                removeButton.addEventListener("click", () =>
                  removeOfficer(index),
                );
              }

              officerElement
                .querySelectorAll<HTMLElement>("[data-officer-field]")
                .forEach((field) => {
                  const key = field.dataset.officerField as keyof OfficerDraft;
                  if (!key) {
                    throw new Error("Expected officer field key.");
                  }
                  field.setAttribute("name", officerFieldName(index, key));
                  if (field instanceof HTMLInputElement) {
                    field.id = officerFieldId(index, key);
                  }
                  if (field instanceof HTMLTextAreaElement) {
                    field.id = officerFieldId(index, key);
                  }
                });

              officerElement
                .querySelectorAll<HTMLLabelElement>("[data-officer-label]")
                .forEach((label) => {
                  const key = label.dataset.officerLabel as keyof OfficerDraft;
                  if (!key) {
                    throw new Error("Expected officer label key.");
                  }
                  label.htmlFor = officerFieldId(index, key);
                });

              officerElement
                .querySelectorAll<HTMLInputElement>("[data-officer-trait]")
                .forEach((field) => {
                  const traitId = field.dataset.officerTrait;
                  const rubricId = field.dataset.officerRubric;
                  if (!traitId || !rubricId) {
                    throw new Error("Expected officer trait metadata.");
                  }
                  field.name = officerTraitName(index, traitId);
                  field.id = officerTraitId(index, traitId, rubricId);
                });

              const nameInput = officerElement.querySelector<HTMLInputElement>(
                `[data-officer-field="name"]`,
              );
              const badgeInput = officerElement.querySelector<HTMLInputElement>(
                `[data-officer-field="badge"]`,
              );
              const departmentInput =
                officerElement.querySelector<HTMLInputElement>(
                  `[data-officer-field="department"]`,
                );
              if (nameInput) {
                nameInput.value = currentOfficer.name;
              }
              if (badgeInput) {
                badgeInput.value = currentOfficer.badge;
              }
              if (departmentInput) {
                departmentInput.value = currentOfficer.department;
              }

              Object.entries(currentOfficer.traits).forEach(
                ([traitId, value]) => {
                  const traitInput =
                    officerElement.querySelector<HTMLInputElement>(
                      `[data-officer-trait="${CSS.escape(traitId)}"][value="${CSS.escape(value)}"]`,
                    );
                  if (traitInput) {
                    traitInput.checked = true;
                  }
                },
              );

              return officerElement;
            });

            officerList.replaceChildren(...officerElements);
          };

          const renderWitnesses = () => {
            const witnessElements = draft.witnesses.map((witness, index) => {
              const currentWitness = {
                ...emptyWitness(),
                ...witness,
              };
              const witnessElement = witnessTemplate.cloneNode(
                true,
              ) as HTMLElement;

              const title = witnessElement.querySelector(
                "[data-witness-title]",
              );
              const removeButton = witnessElement.querySelector(
                "[data-remove-witness]",
              ) as HTMLButtonElement;

              if (title) {
                title.textContent = `Witness ${index + 1}`;
              }

              removeButton.addEventListener("click", () =>
                removeWitness(index),
              );

              witnessElement
                .querySelectorAll<HTMLInputElement>("[data-witness-field]")
                .forEach((field) => {
                  const key = field.dataset.witnessField as keyof WitnessDraft;
                  if (!key) {
                    throw new Error("Expected witness field key.");
                  }
                  field.name = witnessFieldName(index, key);
                  field.id = witnessFieldId(index, key);
                  field.value = currentWitness[key];
                });

              witnessElement
                .querySelectorAll<HTMLLabelElement>("[data-witness-label]")
                .forEach((label) => {
                  const key = label.dataset.witnessLabel as keyof WitnessDraft;
                  if (!key) {
                    throw new Error("Expected witness label key.");
                  }
                  label.htmlFor = witnessFieldId(index, key);
                });

              return witnessElement;
            });

            witnessList.replaceChildren(...witnessElements);
          };

          const renderEvidence = () => {
            const evidenceElements = draft.evidence.map((item, index) => {
              const currentEvidence = {
                ...emptyEvidence(),
                ...item,
              };
              const evidenceElement = evidenceTemplate.cloneNode(
                true,
              ) as HTMLElement;
              const title = evidenceElement.querySelector(
                "[data-evidence-title]",
              );
              const removeButton = evidenceElement.querySelector(
                "[data-remove-evidence]",
              ) as HTMLButtonElement;

              if (title) {
                title.textContent = `Evidence ${index + 1}`;
              }

              removeButton.addEventListener("click", () =>
                removeEvidence(index),
              );

              evidenceElement
                .querySelectorAll<HTMLInputElement>("[data-evidence-field]")
                .forEach((field) => {
                  const key = field.dataset
                    .evidenceField as keyof EvidenceDraft;
                  if (!key) {
                    throw new Error("Expected evidence field key.");
                  }
                  field.name = evidenceFieldName(index, key);
                  field.id = evidenceFieldId(index, key);
                  field.value = currentEvidence[key];
                });

              evidenceElement
                .querySelectorAll<HTMLLabelElement>("[data-evidence-label]")
                .forEach((label) => {
                  const key = label.dataset
                    .evidenceLabel as keyof EvidenceDraft;
                  if (!key) {
                    throw new Error("Expected evidence label key.");
                  }
                  label.htmlFor = evidenceFieldId(index, key);
                });

              return evidenceElement;
            });

            evidenceList.replaceChildren(...evidenceElements);
          };

          const saveDraft = async () => {
            const data = readReportData(new FormData(form));

            try {
              const response = await fetch(draftEndpoint, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                  draftId: getReportDraftId() || null,
                  data,
                }),
              });

              if (!response.ok) {
                return false;
              }

              const result = await response.json();
              if (result?.draftId) {
                setReportDraftId(result.draftId);
              }
              return true;
            } catch (_error) {
              return false;
            }
          };

          let saveDraftTimer: number | null = null;
          let saveDraftInFlight: Promise<boolean> | null = null;
          let rerunDraftSave = false;
          let lastSavedDraftSnapshot = "";
          let draftDirty = false;

          const getDraftSnapshot = () =>
            JSON.stringify(readReportData(new FormData(form)));

          const runDraftSave = async (): Promise<boolean> => {
            if (!draftDirty) {
              return true;
            }

            const snapshot = getDraftSnapshot();
            if (snapshot === lastSavedDraftSnapshot) {
              draftDirty = false;
              return true;
            }

            while (saveDraftInFlight) {
              rerunDraftSave = true;
              await saveDraftInFlight;
            }

            let result = false;
            do {
              const nextSnapshot = getDraftSnapshot();
              if (nextSnapshot === lastSavedDraftSnapshot) {
                draftDirty = false;
                return true;
              }
              rerunDraftSave = false;
              saveDraftInFlight = saveDraft();
              result = await saveDraftInFlight;
              if (result) {
                lastSavedDraftSnapshot = nextSnapshot;
                draftDirty = false;
              }
              saveDraftInFlight = null;
            } while (rerunDraftSave);

            return result;
          };

          const scheduleDraftSave = (delay = 350) => {
            if (saveDraftTimer !== null) {
              window.clearTimeout(saveDraftTimer);
            }

            saveDraftTimer = window.setTimeout(() => {
              saveDraftTimer = null;
              void runDraftSave();
            }, delay);
          };

          const flushDraftSave = async () => {
            if (saveDraftTimer !== null) {
              window.clearTimeout(saveDraftTimer);
              saveDraftTimer = null;
            }

            return runDraftSave();
          };

          const markDraftDirty = (delay = 350) => {
            draftDirty = true;
            scheduleDraftSave(delay);
          };

          const restoreDraft = (data: ReportDraft) => {
            draft = data;

            renderOfficers();
            renderWitnesses();
            renderEvidence();

            Object.entries(data).forEach(([name, rawValue]) => {
              if (structuredRoots.includes(name)) {
                return;
              }

              const values = Array.isArray(rawValue)
                ? rawValue.map((value) => String(value ?? ""))
                : [String(rawValue ?? "")];

              form
                .querySelectorAll(`[name="${CSS.escape(name)}"]`)
                .forEach((field) => {
                  if (
                    field instanceof HTMLInputElement &&
                    field.type === "checkbox"
                  ) {
                    field.checked = values.includes(field.value);
                    return;
                  }

                  if (
                    field instanceof HTMLInputElement &&
                    field.type === "radio"
                  ) {
                    field.checked = values.includes(field.value);
                    return;
                  }

                  if (
                    field instanceof HTMLInputElement ||
                    field instanceof HTMLTextAreaElement ||
                    field instanceof HTMLSelectElement
                  ) {
                    field.value = values[0] || "";
                  }
                });
            });
          };

          const loadDraft = async () => {
            const draftId = getReportDraftId();

            if (!draftId) {
              return;
            }

            try {
              const response = await fetch(
                `${draftEndpoint}?draftId=${encodeURIComponent(draftId)}`,
                {
                  headers: { Accept: "application/json" },
                },
              );

              if (response.status === 204) {
                clearReportDraftCookie();
                return;
              }

              if (!response.ok) {
                return;
              }

              const payload = await response.json();
              if (payload?.data) {
                restoreDraft(payload.data as ReportDraft);
                lastSavedDraftSnapshot = getDraftSnapshot();
                draftDirty = false;
                return;
              }

              clearReportDraftCookie();
            } catch (_error) {}
          };

          applyPrefill();
          renderOfficers();
          renderWitnesses();
          renderEvidence();
          lastSavedDraftSnapshot = getDraftSnapshot();
          draftDirty = false;

          form.addEventListener("change", (event) => {
            const target = event.target;
            if (
              !(
                target instanceof HTMLInputElement ||
                target instanceof HTMLTextAreaElement ||
                target instanceof HTMLSelectElement
              )
            ) {
              return;
            }
            if (target.matches("[data-officer-trait]") && target.name) {
              const officerElement = target.closest("[data-officer]");
              form
                .querySelectorAll<HTMLInputElement>(
                  `input[type="radio"][name="${CSS.escape(target.name)}"]`,
                )
                .forEach((field) => field.setCustomValidity(""));
              officerElement
                ?.querySelector<HTMLElement>("[data-officer-assessment-error]")
                ?.classList.add("d-none");
            }
            markDraftDirty();
          });
          addOfficerButton.addEventListener("click", addOfficer);
          addWitnessButton.addEventListener("click", addWitness);
          addEvidenceButton.addEventListener("click", addEvidence);

          form.addEventListener("submit", async (event) => {
            await submitJsonForm({
              event,
              form,
              formName: "reportNew",
              async onBeforeSubmit() {
                if (await flushDraftSave()) {
                  return;
                }
                throw new Error(
                  "We could not safely save your progress to the server. Please try again. If you cannot submit this form, print this page and email it to hello@policeconduct.org.",
                );
              },
              validate() {
                return validateOfficerAssessments();
              },
              buildPayload({ formData, formName, recaptchaToken }) {
                return {
                  data: readReportData(formData),
                  draftId: getReportDraftId() || null,
                  formName,
                  recaptchaToken,
                };
              },
              onSuccess: clearReportDraftCookie,
              recaptchaAction: "reportNewSubmit",
            });
          });
          initRecaptcha();

          const scrollToReportSection = (hash: string) => {
            if (!hash.startsWith("#")) {
              return;
            }

            const target = document.querySelector<HTMLElement>(hash);
            if (!target) {
              return;
            }

            target.closest("details")?.setAttribute("open", "");

            window.requestAnimationFrame(() => {
              target.scrollIntoView({
                behavior: "smooth",
                block: "start",
              });
            });
          };

          form
            .querySelectorAll<HTMLAnchorElement>("[data-report-jump]")
            .forEach((link) => {
              link.addEventListener("click", (event) => {
                const hash = link.getAttribute("href") || "";
                if (!hash.startsWith("#")) {
                  return;
                }

                event.preventDefault();
                history.replaceState(null, "", hash);
                scrollToReportSection(hash);
              });
            });

          void loadDraft();
        }
      }
    } else {
      showFormLoadError({ formName: "reportNew", shell: formShell });
    }
  </script>
</SiteLayout>
