---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import CollectionStatsBand from "#src/components/CollectionStatsBand.astro";
import Pagination from "#src/components/Pagination.astro";
import ReportDisclaimer from "#src/components/ReportDisclaimer.astro";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import {
  buildCategoryCollectionStats,
  loadCategoryCollectionCounts,
  type CategoryCollectionCounts,
} from "#src/lib/category-collection-stats.js";
import { US_STATE_TILES } from "#src/lib/geo/states.js";
import type { ReportSummary } from "#src/lib/data/types.js";
import { loadReportSummaries } from "#src/lib/data/summaries.js";
import { PAGE_SIZE } from "#src/lib/pagination.js";
import { buildItemList, getSiteUrl } from "#src/lib/structured-data.js";

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const reports = await loadReportSummaries();
  const countsByCategory = await loadCategoryCollectionCounts();
  const reportsByState = new Map<string, ReportSummary[]>();

  reports.forEach((report) => {
    const list = reportsByState.get(report.state) || [];
    list.push(report);
    reportsByState.set(report.state, list);
  });

  const pages: any[] = [];
  reportsByState.forEach((stateReports, category) => {
    const statePages = paginate(stateReports, {
      pageSize: PAGE_SIZE,
      params: { category },
      props: {
        categoryCounts: countsByCategory.get(category) || {
          agencyCount: 0,
          personnelCount: 0,
          reportCount: 0,
          civilCaseCount: 0,
        },
      },
    });
    statePages
      .filter((page: any) => {
        const pageParam = page.params?.page;
        if (Array.isArray(pageParam)) {
          return pageParam.length > 0 && pageParam[0] !== "1";
        }
        return (
          typeof pageParam === "string" &&
          pageParam.length > 0 &&
          pageParam !== "1"
        );
      })
      .forEach((page: any) => pages.push(page));
  });

  return pages;
}

const { page } = Astro.props;
const { category } = Astro.params;
const categorySlug = (category as string).toLowerCase();
const categoryCode = categorySlug.toUpperCase();
const categoryMeta = US_STATE_TILES.find(
  (entry) => entry.code === categoryCode,
);
const titleBase = categoryMeta
  ? `${categoryMeta.name} Reports`
  : `${categoryCode} Reports`;
const title =
  page.currentPage > 1 ? `${titleBase} – Page ${page.currentPage}` : titleBase;
const {
  categoryCounts = {
    agencyCount: 0,
    personnelCount: 0,
    reportCount: 0,
    civilCaseCount: 0,
  },
} = Astro.props as {
  categoryCounts: CategoryCollectionCounts;
};
const stats = buildCategoryCollectionStats(
  categorySlug,
  categoryMeta?.name || categoryCode,
  categoryCounts,
);
const pagePath = `/report/${categorySlug}/page/${page.currentPage}/`;
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(pagePath, siteUrl).toString();
const reportItems = page.data.map((report: ReportSummary, index: number) => ({
  "@type": "ListItem",
  position: index + 1,
  item: {
    "@type": "Report",
    name: report.title,
    url: new URL(`/report/${categorySlug}/${report.slug}/`, siteUrl).toString(),
    ...(report.agencyName
      ? {
          about: {
            "@type": "GovernmentOrganization",
            name: report.agencyName,
          },
        }
      : {}),
  },
}));
const reportItemList = buildItemList(reportItems);
const websiteId = new URL("/", siteUrl).toString();
const reportItemListId = reportItemList ? `${pageUrl}#itemlist` : null;
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": websiteId,
      url: websiteId,
      name: "PoliceConduct.org",
    },
    {
      "@type": "CollectionPage",
      "@id": pageUrl,
      url: pageUrl,
      name: title,
      description: `Reports recorded within ${categoryMeta?.name || categoryCode}.`,
      isPartOf: { "@id": websiteId },
      ...(reportItemListId ? { mainEntity: { "@id": reportItemListId } } : {}),
    },
    ...(reportItemList ? [{ ...reportItemList, "@id": reportItemListId }] : []),
  ],
};

const formatDisplayDate = (value?: string | null) => {
  if (!value) return "—";
  const parsed = new Date(value);
  if (Number.isNaN(parsed.getTime())) return value;
  return parsed.toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  });
};
---

<SiteLayout
  title={title}
  description={`Reports recorded within ${categoryMeta?.name || categoryCode}.`}
  pagePath={pagePath}
  canonicalUrl={pagePath}
  structuredData={structuredData}
>
  <main>
    <section class="py-vh-3 bg-gray-100 border-bottom border-dark">
      <div class="container">
        <div class="row g-4 align-items-end">
          <div class="col-12">
            <Breadcrumbs
              items={[
                { label: "Home", href: "/" },
                { label: "Reports", href: "/report/" },
                {
                  label: categoryMeta?.name || categoryCode,
                  href: `/report/${categorySlug}/`,
                },
                {
                  label: `Page ${page.currentPage}`,
                  href: pagePath,
                  current: true,
                },
              ]}
              className="mb-2"
            />
            <h1 class="display-4 fw-bold">{title}</h1>
            <p class="lead text-muted mb-0">
              Showing published reports recorded within {
                categoryMeta?.name || categoryCode
              }.
            </p>
            <p class="small text-muted mb-0 mt-3">
              Page {page.currentPage} of {page.lastPage}
            </p>
          </div>
        </div>
      </div>
    </section>
    <section class="py-vh-2">
      <div class="container">
        <div class="row mb-4">
          <div class="col-12 col-lg-10 col-xl-8">
            <ReportDisclaimer />
          </div>
        </div>
        {
          page.data.length === 0 ? (
            <div
              class="alert alert-secondary rounded-0 border-dark"
              role="status"
            >
              No reports listed yet for {categoryMeta?.name || categoryCode}.
            </div>
          ) : (
            <div class="profile-record-list">
              {page.data.map((report: ReportSummary) => (
                <article class="profile-record">
                  <div class="profile-record-meta">
                    <span>{formatDisplayDate(report.incidentDate)}</span>
                    {report.ratingOverall ? (
                      <span>Rating {report.ratingOverall}</span>
                    ) : null}
                  </div>
                  <div class="profile-record-body">
                    <h2 class="profile-record-title">
                      <a href={`/report/${categorySlug}/${report.slug}/`}>
                        {report.title}
                      </a>
                    </h2>
                    <div class="profile-record-detail">
                      <span>{report.address || "Location not listed"}</span>
                      {report.personnel?.length ? (
                        <>
                          <span aria-hidden="true">/</span>
                          <span>
                            Personnel:{" "}
                            {report.personnel.map((person, index) => (
                              <>
                                {index > 0 ? ", " : null}
                                {person.slug ? (
                                  <a href={`/personnel/${person.slug}/`}>
                                    {person.name}
                                  </a>
                                ) : (
                                  <span>{person.name}</span>
                                )}
                                {person.licenseType
                                  ? ` (${person.licenseType})`
                                  : ""}
                              </>
                            ))}
                          </span>
                        </>
                      ) : null}
                    </div>
                  </div>
                </article>
              ))}
            </div>
          )
        }
        <Pagination
          basePath={`/report/${categorySlug}/`}
          currentPage={page.currentPage}
          lastPage={page.lastPage}
        />
      </div>
    </section>
    <CollectionStatsBand items={stats} variant="compact" />
  </main>
  <script
    is:inline
    id="dsq-count-scr"
    src="https://policeconduct.disqus.com/count.js"
    async></script>
</SiteLayout>
<style>
  .display-4 {
    max-width: 100%;
    overflow-wrap: anywhere;
  }

  .profile-record-list {
    border-top: 0;
    display: grid;
    gap: 0;
  }

  .profile-record {
    align-items: start;
    border-top: 1px solid var(--bs-border-color);
    display: grid;
    gap: 0.75rem 1.25rem;
    grid-template-columns: minmax(0, 1fr) minmax(8rem, 13rem);
    padding: 0.95rem 0;
    transition:
      background-color 140ms ease,
      border-color 140ms ease;
  }

  .profile-record:hover {
    background: color-mix(in srgb, var(--bs-gray-100) 42%, var(--bs-white));
  }

  .profile-record-body {
    grid-column: 1;
    grid-row: 1;
    min-width: 0;
  }

  .profile-record-meta {
    align-items: flex-end;
    color: var(--bs-secondary-color);
    display: flex;
    flex-direction: column;
    font-size: 0.8125rem;
    gap: 0.25rem;
    grid-column: 2;
    grid-row: 1;
    line-height: 1.35;
    min-width: 0;
    text-align: right;
  }

  .profile-record-title {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.35;
    margin: 0;
  }

  .profile-record-title a,
  .profile-record-detail a {
    color: var(--bs-dark);
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .profile-record-detail {
    color: var(--bs-secondary-color);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.875rem;
    gap: 0.35rem 0.85rem;
    line-height: 1.5;
    margin-top: 0.35rem;
    min-width: 0;
  }

  .profile-record-detail > span[aria-hidden="true"] {
    display: none;
  }

  .profile-record-meta span,
  .profile-record-meta a {
    color: var(--bs-secondary-color);
    max-width: 100%;
  }

  .profile-record-title a {
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  .profile-record-detail a {
    font-weight: 600;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.16em;
  }

  .profile-record-title,
  .profile-record-detail,
  .profile-record-meta {
    overflow-wrap: anywhere;
  }

  @media (max-width: 991.98px) {
    .display-4 {
      font-size: clamp(2.25rem, 12vw, 3.5rem);
      line-height: 1.05;
    }

    .profile-record {
      grid-template-columns: minmax(0, 1fr);
    }

    .profile-record-body,
    .profile-record-meta {
      grid-column: 1;
    }

    .profile-record-meta {
      align-items: flex-start;
      flex-direction: row;
      flex-wrap: wrap;
      grid-row: 2;
      text-align: left;
    }
  }

  @media (max-width: 575.98px) {
    .profile-record-list,
    .profile-record {
      max-width: calc(100vw - 1rem);
    }

    .profile-record-detail {
      align-items: flex-start;
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }

    .profile-record-detail > * {
      margin-right: 0;
    }
  }
</style>
