---
import { loadReportSummaries } from "#src/lib/data/summaries.js";

export async function getStaticPaths() {
  const states = new Set(
    (await loadReportSummaries()).map((report) => report.state),
  );
  return Array.from(states).map((state) => ({
    params: { category: state },
    props: { canonicalPath: `/${state}/reports/` },
  }));
}

return Astro.redirect(Astro.props.canonicalPath, 301);
---
