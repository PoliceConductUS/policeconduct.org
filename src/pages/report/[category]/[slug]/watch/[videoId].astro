---
import { loadReportSummaries } from "#src/lib/data/summaries.js";
import { loadReportDetail } from "#src/lib/report-detail.js";

export async function getStaticPaths() {
  const reports = await loadReportSummaries();
  const paths = [];

  for (const report of reports) {
    const detail = await loadReportDetail(report.slug);
    if (!detail) {
      continue;
    }

    for (const link of detail.evidenceLinks.filter((item) => item.embed)) {
      paths.push({
        params: {
          category: report.state,
          slug: report.slug,
          videoId: link.id,
        },
      });
    }
  }

  return paths;
}

const { category, slug, videoId } = Astro.params;
const categorySlug = String(category || "").toLowerCase();
const data = await loadReportDetail(String(slug || ""));
if (!data) {
  throw new Error(`Report ${slug} not found.`);
}

const reportStateSlug = String(data.report.category || "")
  .trim()
  .toLowerCase();
if (reportStateSlug && reportStateSlug !== categorySlug) {
  return Astro.redirect(
    `/report/${reportStateSlug}/${slug}/watch/${videoId}/`,
    301,
  );
}

const video = data.evidenceLinks.find((link) => link.id === videoId);
if (!video) {
  throw new Error(`Video ${videoId} not found on report ${slug}.`);
}

return Astro.redirect(
  video.videoPath || `/report/${categorySlug}/${slug}/`,
  video.videoPath ? 301 : 302,
);
---
