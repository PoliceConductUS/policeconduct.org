---
import SiteLayout from "#src/layouts/SiteLayout.astro";
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import ReportDisclaimer from "#src/components/ReportDisclaimer.astro";
import UsaChoroplethMap from "#src/components/UsaChoroplethMap.astro";
import { US_STATE_TILES } from "#src/lib/geo/states.js";
import { loadReportSummaries } from "#src/lib/data/summaries.js";
import { loadFederalAgencySummaries } from "#src/lib/data/federal-agencies.js";
import {
  buildItemList,
  buildWebPage,
  getSiteUrl,
} from "#src/lib/structured-data.js";

const [reports, federalAgencies] = await Promise.all([
  loadReportSummaries(),
  loadFederalAgencySummaries(),
]);
const reportCountsByState = new Map<string, number>();
for (const report of reports) {
  reportCountsByState.set(
    report.state.toUpperCase(),
    (reportCountsByState.get(report.state.toUpperCase()) || 0) + 1,
  );
}
const stateStats = US_STATE_TILES.map((state) => ({
  code: state.code,
  count: reportCountsByState.get(state.code) || 0,
  href: `/report/${state.code.toLowerCase()}/`,
}));
const totalReports = reports.length;
const statesWithReports = stateStats.filter((state) => state.count > 0).length;
const pagePath = "/report/";
const suggestReportHref = "/report/new/";
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(pagePath, siteUrl).toString();
const reportItems = reports.slice(0, 25).map((report, index) => {
  const item = {
    "@type": "Report",
    name: report.title,
    url: new URL(`/report/${report.state}/${report.slug}/`, siteUrl).toString(),
    ...(report.agencyName
      ? {
          about: {
            "@type": "GovernmentOrganization",
            name: report.agencyName,
          },
        }
      : {}),
  };
  return {
    "@type": "ListItem",
    position: index + 1,
    item,
  };
});
const structuredData = buildWebPage({
  siteUrl,
  pageUrl,
  name: "Reports | PoliceConduct.org",
  description: "Reports submitted by users documenting police interactions.",
  type: "CollectionPage",
});
const reportItemList = buildItemList(reportItems);
if (reportItemList) {
  structuredData.mainEntity = reportItemList;
}
---

<SiteLayout
  title="Reports | PoliceConduct.org"
  description="Reports submitted by users documenting police interactions."
  pagePath={pagePath}
  structuredData={structuredData}
>
  <main>
    <section class="py-vh-3 bg-gray-100 border-bottom border-dark">
      <div class="container">
        <div class="row g-4 align-items-end">
          <div class="col-12 col-lg-8">
            <Breadcrumbs
              items={[
                { label: "Home", href: "/" },
                { label: "Reports", href: pagePath, current: true },
              ]}
              className="mb-2"
            />
            <h1 class="display-4 fw-bold">Reports</h1>
            <p class="lead text-muted mb-0">
              Reports submitted by users documenting police interactions.
            </p>
            <div class="ipc-hero-summary ipc-hero-summary-mobile mt-3">
              <span class="badge bg-light text-dark border rounded-0">
                {totalReports} reports
              </span>
              <span class="badge bg-light text-dark border rounded-0">
                {statesWithReports} states covered
              </span>
            </div>
          </div>
          <div class="col-12 col-lg-4 d-none d-lg-flex justify-content-lg-end">
            <div class="ipc-hero-summary" aria-label="Report summary">
              <span class="badge bg-light text-dark border rounded-0">
                {totalReports} reports
              </span>
              <span class="badge bg-light text-dark border rounded-0">
                {statesWithReports} states covered
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>
    <section class="py-vh-2">
      <div class="container">
        <div class="row mb-4">
          <div class="col-12 col-lg-10 col-xl-8">
            <ReportDisclaimer />
          </div>
        </div>
        <UsaChoroplethMap
          stats={stateStats}
          title="States"
          subtitle="Select a state to view published reports for agencies in that jurisdiction."
          emptyLabel="No reports yet"
          interactionLabel="Hover for counts; click a state to browse reports."
          headerAction={{
            href: suggestReportHref,
            label: "Submit a report",
          }}
          federalPanel={{
            title: "Federal agencies",
            value: federalAgencies.length,
            description: "Federal agencies referenced in listed reports.",
            items: federalAgencies.map((agency) => ({
              label: agency.name,
              href: agency.path,
              badgeText: `${agency.branchCount} locations`,
            })),
          }}
        />
      </div>
    </section>
  </main>
  <script
    is:inline
    id="dsq-count-scr"
    src="https://policeconduct.disqus.com/count.js"
    async></script>
</SiteLayout>
