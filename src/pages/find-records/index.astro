---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import { loadAgencyFinderResults } from "#src/lib/data/agencies.js";
import { loadFederalAgencySummaries } from "#src/lib/data/federal-agencies.js";
import { loadLocationBuildPayloads } from "#src/lib/data/build-payloads.js";
import { buildWebPage, getSiteUrl } from "#src/lib/structured-data.js";

const [locations, federalAgencies, agencies] = await Promise.all([
  loadLocationBuildPayloads(),
  loadFederalAgencySummaries(),
  loadAgencyFinderResults(),
]);

const places = locations
  .filter((location) => location.level === "place")
  .map((place) => ({
    href: place.path,
    label: [place.displayName, place.administrativeArea, place.stateLabel]
      .filter(Boolean)
      .join(", "),
    meta: `${place.agencies?.length ?? 0} ${
      (place.agencies?.length ?? 0) === 1 ? "agency" : "agencies"
    } in the record`,
    searchText: [
      place.displayName,
      place.administrativeArea,
      place.administrativeAreaSlug,
      place.state,
      place.stateLabel,
    ]
      .filter(Boolean)
      .join(" "),
  }));

const agencyResults = agencies.map((agency) => ({
  href: agency.canonicalPath,
  label: agency.name,
  meta: [agency.city, agency.administrativeArea, agency.state]
    .filter(Boolean)
    .join(", "),
  searchText: [
    agency.name,
    agency.city,
    agency.administrativeArea,
    agency.state,
    agency.zipCode,
    agency.canonicalPath,
  ]
    .filter(Boolean)
    .join(" "),
}));

const federalAgencyResults = federalAgencies.map((agency) => ({
  href: agency.path,
  label: agency.name,
  meta: `${agency.branchCount} ${
    agency.branchCount === 1 ? "location" : "locations"
  } in the record`,
  searchText: agency.name,
}));

const pagePath = "/find-records/";
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(pagePath, siteUrl).toString();
const description =
  "Find PoliceConduct.org records by place or law enforcement agency.";
const structuredData = buildWebPage({
  siteUrl,
  pageUrl,
  name: "Find records by place or agency | PoliceConduct.org",
  description,
  type: "SearchResultsPage",
});
const finderGroups = [
  {
    type: "place",
    label: "Places",
    results: places,
  },
  {
    type: "agency",
    label: "Agencies",
    results: agencyResults,
  },
  {
    type: "federal-agency",
    label: "Federal agencies",
    results: federalAgencyResults,
  },
];
const finderDataJson = JSON.stringify(finderGroups).replace(/</g, "\\u003c");
---

<SiteLayout
  title="Find Records | PoliceConduct.org"
  description={description}
  pagePath={pagePath}
  structuredData={structuredData}
>
  <main>
    <section class="py-vh-3 bg-gray-100 border-bottom border-dark">
      <div class="container">
        <Breadcrumbs
          items={[
            { label: "Home", href: "/" },
            { label: "Find Records", href: pagePath, current: true },
          ]}
          className="mb-2"
        />
        <h1 class="ipc-page-title mb-3">Find records by place or agency</h1>
        <p class="lead text-muted mb-0">
          Enter a place or law enforcement agency to see what PoliceConduct.org
          has in the record.
        </p>
      </div>
    </section>

    <section class="py-vh-2">
      <div class="container">
        <div class="finder-shell" data-record-finder>
          <div class="finder-search-panel">
            <label class="form-label fw-semibold" for="recordFinder">
              Place or agency
            </label>
            <input
              class="form-control form-control-lg rounded-0"
              id="recordFinder"
              type="search"
              placeholder="Irving, Dallas County, Texas, or Irving Police Department"
              data-record-finder-input
              autocomplete="off"
              aria-describedby="recordFinderStatus"
            />
            <p
              class="finder-status text-muted small mb-0"
              id="recordFinderStatus"
              data-finder-status
              role="status"
              aria-live="polite"
            >
              Type a place or agency name to show matching records.
            </p>
          </div>

          <div class="finder-empty-state" data-finder-start>
            <h2 class="ipc-section-title">Start with a place or agency.</h2>
            <p class="text-muted mb-0">
              Search results will focus on places, law enforcement agencies, and
              federal agencies. Open a result to see connected personnel,
              reports, civil cases, and other records.
            </p>
          </div>

          <div class="finder-empty-state d-none" data-finder-no-results>
            <h2 class="ipc-section-title">
              We do not have records for that search yet.
            </h2>
            <p class="text-muted mb-0">
              We use searches with no results to understand which places and
              agencies people are looking for.
            </p>
          </div>

          <div class="finder-result-groups d-none" data-finder-results>
            {
              finderGroups.map((group) => (
                <section
                  class="finder-result-group"
                  data-result-group={group.type}
                  hidden
                >
                  <h2 class="ipc-section-title">{group.label}</h2>
                  <div
                    class="finder-result-list"
                    data-result-list={group.type}
                  />
                </section>
              ))
            }
          </div>
        </div>
      </div>
    </section>
  </main>

  <script
    id="recordFinderData"
    type="application/json"
    set:html={finderDataJson}
    is:inline
  />

  <script is:inline>
    const input = document.querySelector("[data-record-finder-input]");
    const startState = document.querySelector("[data-finder-start]");
    const noResultsState = document.querySelector("[data-finder-no-results]");
    const resultsRoot = document.querySelector("[data-finder-results]");
    const status = document.querySelector("[data-finder-status]");
    const groupElements = new Map(
      [...document.querySelectorAll("[data-result-group]")].map((group) => [
        group.getAttribute("data-result-group"),
        group,
      ]),
    );
    const resultLists = new Map(
      [...document.querySelectorAll("[data-result-list]")].map((list) => [
        list.getAttribute("data-result-list"),
        list,
      ]),
    );
    const finderDataElement = document.getElementById("recordFinderData");
    const finderGroups = finderDataElement?.textContent
      ? JSON.parse(finderDataElement.textContent)
      : [];
    const maxVisiblePerGroup = 12;
    const reportedNoResultQueries = new Set();
    let noResultTimer = 0;

    const normalize = (value) =>
      String(value || "")
        .trim()
        .toLowerCase()
        .replace(/\s+/g, " ");

    const reportNoResults = (query) => {
      if (!query || reportedNoResultQueries.has(query)) {
        return;
      }
      reportedNoResultQueries.add(query);
      window.__IPC_ANALYTICS__?.track?.("coverage_search_no_results", {
        page_path: window.location.pathname,
        query,
        query_length: query.length,
        result_count: 0,
      });
    };

    const setHidden = (element, hidden) => {
      element?.classList.toggle("d-none", hidden);
    };

    const setStatus = (message) => {
      if (status) {
        status.textContent = message;
      }
    };

    const clearResults = () => {
      resultLists.forEach((list) => {
        list.replaceChildren();
      });
      groupElements.forEach((group) => {
        group.hidden = true;
      });
    };

    const renderResult = (result) => {
      const link = document.createElement("a");
      link.className = "finder-result";
      link.href = result.href;

      const label = document.createElement("span");
      label.textContent = result.label;
      link.append(label);

      if (result.meta) {
        const meta = document.createElement("small");
        meta.textContent = result.meta;
        link.append(meta);
      }

      return link;
    };

    const updateResults = () => {
      const query = normalize(input?.value);
      window.clearTimeout(noResultTimer);
      clearResults();

      if (!query) {
        setHidden(startState, false);
        setHidden(noResultsState, true);
        setHidden(resultsRoot, true);
        setStatus("Type a place or agency name to show matching records.");
        return;
      }

      let visibleTotal = 0;
      let matchTotal = 0;

      finderGroups.forEach((group) => {
        const matches = group.results.filter((result) =>
          normalize(result.searchText).includes(query),
        );
        matchTotal += matches.length;

        const list = resultLists.get(group.type);
        const groupElement = groupElements.get(group.type);
        const visibleResults = matches.slice(0, maxVisiblePerGroup);

        if (!list || !groupElement || visibleResults.length === 0) {
          return;
        }

        list.replaceChildren(...visibleResults.map(renderResult));
        groupElement.hidden = false;
        visibleTotal += visibleResults.length;
      });

      setHidden(startState, true);
      setHidden(noResultsState, visibleTotal !== 0);
      setHidden(resultsRoot, visibleTotal === 0);
      setStatus(
        visibleTotal === 0
          ? `No matching records for "${input?.value.trim() || query}".`
          : `Showing ${visibleTotal} of ${matchTotal} matching records.`,
      );

      if (visibleTotal === 0) {
        noResultTimer = window.setTimeout(() => reportNoResults(query), 750);
      }
    };

    input?.addEventListener("input", updateResults);
    updateResults();
  </script>
</SiteLayout>

<style>
  .finder-shell {
    display: grid;
    gap: 1.5rem;
  }

  .finder-search-panel {
    background: var(--bs-white);
    border: 1px solid var(--bs-border-color);
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .finder-status {
    margin-top: 0.75rem;
  }

  .finder-empty-state {
    border: 1px solid var(--bs-border-color);
    padding: clamp(1.25rem, 3vw, 2rem);
    background: var(--bs-white);
  }

  .finder-result-groups {
    display: grid;
    gap: 2rem;
  }

  .finder-result-group {
    border-top: 1px solid var(--bs-border-color);
    padding-top: 1rem;
  }

  .finder-result-list {
    display: grid;
  }

  .finder-result {
    align-items: baseline;
    border-bottom: 1px solid var(--bs-border-color);
    color: var(--bs-dark);
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    padding: 0.75rem 0;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  .finder-result small {
    color: var(--bs-secondary-color);
    text-align: right;
  }

  @media (max-width: 767.98px) {
    .finder-result {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.15rem;
    }

    .finder-result small {
      text-align: left;
    }
  }
</style>
