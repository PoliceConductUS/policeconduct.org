---
import Breadcrumbs from "#src/components/Breadcrumbs.astro";
import SiteLayout from "#src/layouts/SiteLayout.astro";
import { loadFederalAgencySummaries } from "#src/lib/data/federal-agencies.js";
import { loadLocationBuildPayloads } from "#src/lib/data/build-payloads.js";
import { loadAgencySummaries } from "#src/lib/data/summaries.js";
import { buildWebPage, getSiteUrl } from "#src/lib/structured-data.js";

const [locations, federalAgencies, agencies] = await Promise.all([
  loadLocationBuildPayloads(),
  loadFederalAgencySummaries(),
  loadAgencySummaries(),
]);

const places = locations
  .filter((location) => location.level === "place")
  .map((place) => ({
    href: place.path,
    label: [place.displayName, place.administrativeArea, place.stateLabel]
      .filter(Boolean)
      .join(", "),
    meta: `${place.agencies?.length ?? 0} ${
      (place.agencies?.length ?? 0) === 1 ? "agency" : "agencies"
    } in the record`,
    searchText: [
      place.displayName,
      place.administrativeArea,
      place.administrativeAreaSlug,
      place.state,
      place.stateLabel,
    ]
      .filter(Boolean)
      .join(" "),
  }));

const agencyResults = agencies.map((agency) => ({
  href: agency.canonicalPath,
  label: agency.name,
  meta: [agency.city, agency.administrativeArea, agency.state]
    .filter(Boolean)
    .join(", "),
  searchText: [
    agency.name,
    agency.city,
    agency.administrativeArea,
    agency.administrativeAreaSlug,
    agency.state,
    agency.zipCode,
  ]
    .filter(Boolean)
    .join(" "),
}));

const federalAgencyResults = federalAgencies.map((agency) => ({
  href: agency.path,
  label: agency.name,
  meta: `${agency.branchCount} ${
    agency.branchCount === 1 ? "location" : "locations"
  } in the record`,
  searchText: agency.name,
}));

const pagePath = "/find-records/";
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(pagePath, siteUrl).toString();
const description =
  "Find PoliceConduct.org records by place or law enforcement agency.";
const structuredData = buildWebPage({
  siteUrl,
  pageUrl,
  name: "Find records by place or agency | PoliceConduct.org",
  description,
  type: "SearchResultsPage",
});
---

<SiteLayout
  title="Find Records | PoliceConduct.org"
  description={description}
  pagePath={pagePath}
  structuredData={structuredData}
>
  <main>
    <section class="py-vh-3 bg-gray-100 border-bottom border-dark">
      <div class="container">
        <Breadcrumbs
          items={[
            { label: "Home", href: "/" },
            { label: "Find Records", href: pagePath, current: true },
          ]}
          className="mb-2"
        />
        <h1 class="display-4 fw-bold mb-3">Find records by place or agency</h1>
        <p class="lead text-muted mb-0">
          Enter a place or law enforcement agency to see what PoliceConduct.org
          has in the record.
        </p>
      </div>
    </section>

    <section class="py-vh-2">
      <div class="container">
        <div class="finder-shell" data-record-finder>
          <div class="finder-search-panel">
            <label class="form-label fw-semibold" for="recordFinder">
              Place or agency
            </label>
            <input
              class="form-control form-control-lg rounded-0"
              id="recordFinder"
              type="search"
              placeholder="Irving, Dallas County, Texas, or Irving Police Department"
              data-record-finder-input
              autocomplete="off"
            />
          </div>

          <div class="finder-empty-state" data-finder-start>
            <h2 class="h4">Start with a place or agency.</h2>
            <p class="text-muted mb-0">
              Search results will focus on places, law enforcement agencies, and
              federal agencies. Open a result to see connected personnel,
              reports, civil cases, and other records.
            </p>
          </div>

          <div class="finder-empty-state d-none" data-finder-no-results>
            <h2 class="h4">We do not have records for that search yet.</h2>
            <p class="text-muted mb-0">
              We use searches with no results to understand which places and
              agencies people are looking for.
            </p>
          </div>

          <div class="finder-result-groups d-none" data-finder-results>
            <section class="finder-result-group" data-result-group>
              <h2 class="h4">Places</h2>
              <div class="finder-result-list">
                {
                  places.map((place) => (
                    <a
                      class="finder-result"
                      href={place.href}
                      data-finder-result
                      data-result-type="place"
                      data-search-item={place.searchText}
                    >
                      <span>{place.label}</span>
                      <small>{place.meta}</small>
                    </a>
                  ))
                }
              </div>
            </section>

            <section class="finder-result-group" data-result-group>
              <h2 class="h4">Agencies</h2>
              <div class="finder-result-list">
                {
                  agencyResults.map((agency) => (
                    <a
                      class="finder-result"
                      href={agency.href}
                      data-finder-result
                      data-result-type="agency"
                      data-search-item={agency.searchText}
                    >
                      <span>{agency.label}</span>
                      <small>{agency.meta}</small>
                    </a>
                  ))
                }
              </div>
            </section>

            <section class="finder-result-group" data-result-group>
              <h2 class="h4">Federal agencies</h2>
              <div class="finder-result-list">
                {
                  federalAgencyResults.map((agency) => (
                    <a
                      class="finder-result"
                      href={agency.href}
                      data-finder-result
                      data-result-type="federal-agency"
                      data-search-item={agency.searchText}
                    >
                      <span>{agency.label}</span>
                      <small>{agency.meta}</small>
                    </a>
                  ))
                }
              </div>
            </section>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script is:inline>
    const input = document.querySelector("[data-record-finder-input]");
    const startState = document.querySelector("[data-finder-start]");
    const noResultsState = document.querySelector("[data-finder-no-results]");
    const resultsRoot = document.querySelector("[data-finder-results]");
    const groups = [...document.querySelectorAll("[data-result-group]")];
    const results = [...document.querySelectorAll("[data-finder-result]")];
    const maxVisiblePerGroup = 12;
    const reportedNoResultQueries = new Set();
    let noResultTimer = 0;

    const normalize = (value) =>
      String(value || "")
        .trim()
        .toLowerCase()
        .replace(/\s+/g, " ");

    const reportNoResults = (query) => {
      if (!query || reportedNoResultQueries.has(query)) {
        return;
      }
      reportedNoResultQueries.add(query);
      window.__IPC_ANALYTICS__?.track?.("coverage_search_no_results", {
        page_path: window.location.pathname,
        query,
        query_length: query.length,
        result_count: 0,
      });
    };

    const setHidden = (element, hidden) => {
      element?.classList.toggle("d-none", hidden);
    };

    const updateResults = () => {
      const query = normalize(input?.value);
      window.clearTimeout(noResultTimer);

      if (!query) {
        setHidden(startState, false);
        setHidden(noResultsState, true);
        setHidden(resultsRoot, true);
        results.forEach((result) => {
          result.hidden = true;
        });
        return;
      }

      let visibleTotal = 0;
      const visibleByType = new Map();

      results.forEach((result) => {
        const text = normalize(result.getAttribute("data-search-item"));
        const type = result.getAttribute("data-result-type") || "result";
        const currentVisibleForType = visibleByType.get(type) || 0;
        const matches = text.includes(query);
        const shouldShow =
          matches && currentVisibleForType < maxVisiblePerGroup;
        result.hidden = !shouldShow;
        if (matches) {
          visibleByType.set(type, currentVisibleForType + 1);
        }
        if (shouldShow) {
          visibleTotal += 1;
        }
      });

      groups.forEach((group) => {
        const hasVisibleResult = Boolean(
          group.querySelector("[data-finder-result]:not([hidden])"),
        );
        group.hidden = !hasVisibleResult;
      });

      setHidden(startState, true);
      setHidden(noResultsState, visibleTotal !== 0);
      setHidden(resultsRoot, visibleTotal === 0);

      if (visibleTotal === 0) {
        noResultTimer = window.setTimeout(() => reportNoResults(query), 750);
      }
    };

    input?.addEventListener("input", updateResults);
    updateResults();
  </script>
</SiteLayout>

<style>
  .finder-shell {
    display: grid;
    gap: 1.5rem;
  }

  .finder-search-panel {
    background: var(--bs-white);
    border: 1px solid var(--bs-border-color);
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .finder-empty-state {
    border: 1px solid var(--bs-border-color);
    padding: clamp(1.25rem, 3vw, 2rem);
    background: var(--bs-white);
  }

  .finder-result-groups {
    display: grid;
    gap: 2rem;
  }

  .finder-result-group {
    border-top: 1px solid var(--bs-border-color);
    padding-top: 1rem;
  }

  .finder-result-list {
    display: grid;
  }

  .finder-result {
    align-items: baseline;
    border-bottom: 1px solid var(--bs-border-color);
    color: var(--bs-dark);
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    padding: 0.75rem 0;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  .finder-result small {
    color: var(--bs-secondary-color);
    text-align: right;
  }

  @media (max-width: 767.98px) {
    .finder-result {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.15rem;
    }

    .finder-result small {
      text-align: left;
    }
  }
</style>
